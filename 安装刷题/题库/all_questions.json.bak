 "source": "安装教材精读笔记"}, {"id": "ch07-061", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "给排水、采暖、燃气工程专业在2018广东安装定额中应套用（ ）。", "options": {"A": "第4册", "B": "第7册", "C": "第10册", "D": "第12册"}, "answer": ["C"], "analysis": "给排水、采暖、燃气工程对应第10册。", "tags": ["2018定额", "专业对应册"], "source": "安装教材精读笔记"}, {"id": "ch07-062", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "通风空调工程专业在2018广东安装定额中应套用（ ）。", "options": {"A": "第7册", "B": "第8册", "C": "第9册", "D": "第10册"}, "answer": ["A"], "analysis": "通风空调工程对应第7册。", "tags": ["2018定额", "专业对应册"], "source": "安装教材精读笔记"}, {"id": "ch07-063", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "消防工程专业在2018广东安装定额中应套用（ ）。", "options": {"A": "第7册", "B": "第8册", "C": "第9册", "D": "第11册"}, "answer": ["C"], "analysis": "消防工程对应第9册。", "tags": ["2018定额", "专业对应册"], "source": "安装教材精读笔记"}, {"id": "ch07-064", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "建筑智能化工程专业在2018广东安装定额中应套用（ ）。", "options": {"A": "第4册", "B": "第5册", "C": "第6册", "D": "第7册"}, "answer": ["B"], "analysis": "建筑智能化工程对应第5册。", "tags": ["2018定额", "专业对应册"], "source": "安装教材精读笔记"}, {"id": "ch07-065", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "工业管道工程专业在2018广东安装定额中应套用（ ）。", "options": {"A": "第7册", "B": "第8册", "C": "第9册", "D": "第10册"}, "answer": ["B"], "analysis": "工业管道工程对应第8册。", "tags": ["2018定额", "专业对应册"], "source": "安装教材精读笔记"}, {"id": "ch07-066", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2018广东安装定额中分上下册出版的册有（ ）。", "options": {"A": "第4册、第8册", "B": "第7册、第10册", "C": "第1册、第2册", "D": "第9册、第11册"}, "answer": ["A"], "analysis": "第4册电气设备安装工程（上下册）、第8册工业管道工程（上下册）为分上下册出版。", "tags": ["2018定额", "上下册"], "source": "安装教材精读笔记"}, {"id": "ch07-067", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "下列属于2018广东安装定额中分上下册出版的是（ ）。", "options": {"A": "第7册通风空调工程", "B": "第8册工业管道工程", "C": "第10册给排水采暖燃气", "D": "第12册刷油防腐蚀绝热"}, "answer": ["B"], "analysis": "第8册工业管道工程分上下册；第4册电气设备也分上下册。", "tags": ["2018定额", "上下册"], "source": "安装教材精读笔记"}, {"id": "ch07-068", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "刷油、防腐蚀、绝热工程在2018广东安装定额中属于（ ）。", "options": {"A": "第11册", "B": "第12册", "C": "第10册", "D": "第3册"}, "answer": ["B"], "analysis": "刷油、防腐蚀、绝热工程属第12册。", "tags": ["2018定额", "册号"], "source": "安装教材精读笔记"}, {"id": "ch07-069", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单与2018定额衔接中，清单主要解决（ ）。", "options": {"A": "需要多少工料机", "B": "工程量怎么算（计量规则）", "C": "人工单价", "D": "材料单价"}, "answer": ["B"], "analysis": "清单管\"量怎么算\"——规定计量规则；定额管\"要多少工料机\"——规定消耗量。", "tags": ["清单定额", "分工"], "source": "安装教材精读笔记"}, {"id": "ch07-070", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单与2018定额衔接中，定额主要解决（ ）。", "options": {"A": "工程量怎么算", "B": "需要多少工料机（消耗量）", "C": "项目特征描述", "D": "计量单位"}, "answer": ["B"], "analysis": "定额规定\"消耗多少\"——人工、材料、施工机具的消耗量，用于计价。", "tags": ["清单定额", "分工"], "source": "安装教材精读笔记"}, {"id": "ch07-071", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单规定计量规则、2018定额规定消耗量，二者结合主要用于（ ）。", "options": {"A": "仅计算工程量", "B": "计价（算出综合单价）", "C": "仅编制施工组织设计", "D": "仅用于审计"}, "answer": ["B"], "analysis": "清单计量+定额消耗量，二者结合用于计价，计算综合单价与工程造价。", "tags": ["清单定额", "衔接计价"], "source": "安装教材精读笔记"}, {"id": "ch07-072", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "下列对\"清单\"与\"定额\"定位表述正确的是（ ）。", "options": {"A": "清单是计价依据，定额是计量标准", "B": "清单是工程量计算标准（计量），定额是消耗量定额（计价）", "C": "二者都是推荐性标准", "D": "二者都是强制性标准"}, "answer": ["B"], "analysis": "清单=工程量计算标准（管计量），定额=消耗量定额（管计价）。", "tags": ["清单定额", "定位"], "source": "2018定额详细解读"}, {"id": "ch07-073", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "在广东省内，2024版清单与2018版定额的执行效力组合是（ ）。", "options": {"A": "清单强制、定额推荐", "B": "清单推荐、定额强制", "C": "二者均推荐", "D": "二者均强制"}, "answer": ["B"], "analysis": "清单为推荐性标准（合同约定后具约束力），定额在广东为强制性执行。", "tags": ["清单定额", "效力"], "source": "2018定额详细解读"}, {"id": "ch07-074", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "柔性软风管在2024清单与2018定额（第7册）中的计量单位一致性表现为（ ）。", "options": {"A": "清单m、定额㎡", "B": "清单㎡、定额m", "C": "清单m、定额m", "D": "清单个、定额m"}, "answer": ["C"], "analysis": "柔性软风管清单按中心线长度\"m\"，定额（第7册）也按\"m\"，单位一致。", "tags": ["清单定额", "计量单位一致", "柔性软风管"], "source": "历年真题精华版"}, {"id": "ch07-075", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单描述工作内容、2018定额包含工作内容，二者关系应当是（ ）。", "options": {"A": "互不相干", "B": "定额工作内容需与清单一致，不一致时调整或补充", "C": "以投标人习惯为准", "D": "以清单为准不需考虑定额"}, "answer": ["B"], "analysis": "清单描述工作内容，定额包含的工作内容需与清单一致，不一致时应调整或补充。", "tags": ["清单定额", "工作内容对应"], "source": "历年真题精华版"}, {"id": "ch07-076", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "在套用2018定额时，项目特征描述的主要作用是（ ）。", "options": {"A": "仅作备案", "B": "根据特征选择相应的定额子目", "C": "决定工程量", "D": "与定额无关"}, "answer": ["B"], "analysis": "项目特征（如管道材质、连接方式、压力等级）用于选择对应的定额子目。", "tags": ["清单定额", "项目特征选子目"], "source": "历年真题精华版"}, {"id": "ch07-077", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "根据广东省2018安装定额总说明，管理费的计算基数是（ ）。", "options": {"A": "分部分项的人工费", "B": "分部分项的人工费与施工机具费之和", "C": "分部分项的人工费与材料费之和", "D": "分部分项的人工费、材料费与施工机具费之和"}, "answer": ["B"], "analysis": "第10册总说明明确规定：管理费以分部分项的人工费与施工机具费之和为计算基数。", "tags": ["广东专属", "管理费基数"], "source": "第10册总说明"}, {"id": "ch07-078", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "广东省2018安装定额中，利润的计算基数通常（ ）。", "options": {"A": "仅以人工费", "B": "以人工费与施工机具费之和（与管理费基数相同）", "C": "以人工费与材料费之和", "D": "以直接工程费"}, "answer": ["B"], "analysis": "广东安装定额管理费、利润均以分部分项的人工费与施工机具费之和为计算基数。", "tags": ["广东专属", "利润基数"], "source": "第10册总说明"}, {"id": "ch07-079", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "关于管理费/利润计费基数，广东省与北京市的主要区别是（ ）。", "options": {"A": "两者都以人工费+施工机具费", "B": "广东以人工费+施工机具费，北京多以人工费为基数", "C": "两者都以纯人工费", "D": "广东以纯人工费，北京以人工费+机具费"}, "answer": ["B"], "analysis": "广东二造安装定额管理费/利润基数为人工费+施工机具费，与北京等地\"纯人工费\"基数相反，属广东专属考点。", "tags": ["广东专属", "管理费基数对比"], "source": "WebSearch补充"}, {"id": "ch07-080", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2018广东安装定额中，人工费是指（ ）。", "options": {"A": "管理人员的工资", "B": "直接从事施工作业的生产工人的薪酬", "C": "企业全部职工工资", "D": "仅基本工资"}, "answer": ["B"], "analysis": "人工费是直接从事施工作业的生产工人的薪酬，含工资、社保、公积金、福利等，不包括管理人员。", "tags": ["2018定额", "人工费"], "source": "2018定额详细解读"}, {"id": "ch07-081", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2018广东安装定额中，施工机具费包括（ ）。", "options": {"A": "仅施工机械使用费", "B": "施工机械使用费与施工仪器仪表使用费", "C": "人工费与材料费", "D": "仅仪器仪表使用费"}, "answer": ["B"], "analysis": "施工机具费=施工机械使用费+施工仪器仪表使用费。", "tags": ["2018定额", "施工机具费"], "source": "2018定额详细解读"}, {"id": "ch07-082", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2018广东安装定额中，表示\"未计价材料\"的符号是（ ）。", "options": {"A": "（ ）", "B": "[ ]", "C": "＜ ＞", "D": "｛ ｝"}, "answer": ["B"], "analysis": "定额中带\"[ ]\"符号者表示未计价材料，其价格未计入基价，应按\"[]\"内所列用量计算。", "tags": ["2018定额", "未计价材料"], "source": "2018定额详细解读"}, {"id": "ch07-083", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2018广东安装定额规定，单位价值在2000元以内、使用年限在一年以内的工具用具（ ）。", "options": {"A": "计入施工机具费", "B": "未计入施工机具费", "C": "计入人工费", "D": "计入材料费"}, "answer": ["B"], "analysis": "单位价值2000元以内、使用年限一年以内的工具用具未计入施工机具费。", "tags": ["2018定额", "施工机具费"], "source": "2018定额详细解读"}, {"id": "ch07-084", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2018广东安装定额中，生产工人的社会保险费和住房公积金应计入（ ）。", "options": {"A": "管理费", "B": "人工费", "C": "规费", "D": "材料费"}, "answer": ["B"], "analysis": "属于生产工人的社会保险费和住房公积金计入人工费；管理人员的社会保险费和住房公积金计入管理费。", "tags": ["2018定额", "人工费", "管理费"], "source": "2018定额详细解读"}, {"id": "ch07-085", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "相较2013版，下列属于GB/T 50856-2024修订内容的有（ ）。", "options": {"A": "标准性质由强制性调整为推荐性", "B": "新增附录M、附录N", "C": "不再设立强制性条文", "D": "适用范围新增设计施工总承包"}, "answer": ["A", "B", "C"], "analysis": "2024版：性质改推荐性、新增M/N附录、不再设强制性条文；适用范围是\"不再适用\"设计施工总承包，故D错。", "tags": ["2024清单", "修订内容"], "source": "2024清单详细解读"}, {"id": "ch07-086", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "下列专业附录中，属于GB/T 50856-2024通用安装工程14个附录的有（ ）。", "options": {"A": "附录D 电气设备安装工程", "B": "附录G 通风空调工程", "C": "附录I 机械设备安装工程", "D": "附录K 给排水、采暖、燃气工程"}, "answer": ["A", "B", "D"], "analysis": "附录无\"I\"，机械设备为附录A；D、G、K均为有效附录。", "tags": ["2024清单", "附录"], "source": "2024清单详细解读"}, {"id": "ch07-087", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "下列通用安装工程清单附录中，确实存在的包括（ ）。", "options": {"A": "附录A 机械设备安装工程", "B": "附录C 静置设备与工艺金属结构制作安装工程", "C": "附录J 消防工程", "D": "附录P 措施项目"}, "answer": ["A", "B", "C", "D"], "analysis": "A、C、J、P均为2024版有效附录。", "tags": ["2024清单", "附录"], "source": "2024清单详细解读"}, {"id": "ch07-088", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "2024版清单每个专业附录一般包含的内容有（ ）。", "options": {"A": "工程量清单项目设置", "B": "项目特征描述", "C": "计量单位", "D": "工程量计算规则"}, "answer": ["A", "B", "C", "D"], "analysis": "每个附录均包含项目设置、项目特征、计量单位、计算规则四部分。", "tags": ["2024清单", "附录内容"], "source": "安装教材精读笔记"}, {"id": "ch07-089", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "根据2024版清单计量规则，下列说法正确的有（ ）。", "options": {"A": "工程量按设计图示尺寸计算", "B": "计量单位应严格按规范执行", "C": "项目特征描述会影响综合单价", "D": "可由投标人自行调整计量单位"}, "answer": ["A", "B", "C"], "analysis": "工程量按图示尺寸、单位按规范、特征影响单价均正确；计量单位不得自行调整，D错。", "tags": ["2024清单", "计量规则"], "source": "安装教材精读笔记"}, {"id": "ch07-090", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "分部分项工程综合单价通常包含的费用要素有（ ）。", "options": {"A": "人工费", "B": "材料费", "C": "施工机具使用费", "D": "管理费及利润"}, "answer": ["A", "B", "C", "D"], "analysis": "综合单价=人工费+材料费+施工机具使用费+管理费+利润。", "tags": ["综合单价", "费用组成"], "source": "历年真题精华版"}, {"id": "ch07-091", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "下列费用中，通常不计入分部分项工程综合单价、需单独列项的有（ ）。", "options": {"A": "规费", "B": "税金", "C": "利润", "D": "材料费"}, "answer": ["A", "B"], "analysis": "综合单价不含规费和税金，规费税金在汇总时单独列项；利润、材料费计入综合单价。", "tags": ["综合单价", "规费税金"], "source": "历年真题精华版"}, {"id": "ch07-092", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "分部分项工程费包含的组成内容有（ ）。", "options": {"A": "人工费", "B": "材料费", "C": "施工机具使用费", "D": "企业管理费、利润"}, "answer": ["A", "B", "C", "D"], "analysis": "分部分项工程费=人工费+材料费+施工机具使用费+企业管理费+利润。", "tags": ["分部分项工程费", "费用组成"], "source": "历年真题精华版"}, {"id": "ch07-094", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "一份完整的工程量清单一般包含（ ）。", "options": {"A": "封面、扉页、总说明", "B": "分部分项工程量清单表", "C": "措施项目清单表", "D": "其他项目、规费税金清单"}, "answer": ["A", "B", "C", "D"], "analysis": "清单由封面、扉页、总说明、分部分项、措施项目、其他项目、规费税金清单等组成。", "tags": ["工程量清单", "组成"], "source": "历年真题精华版"}, {"id": "ch07-095", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "工程量清单编制的依据包括（ ）。", "options": {"A": "计价标准（规范）", "B": "建设工程设计文件", "C": "招标文件", "D": "施工现场情况"}, "answer": ["A", "B", "C", "D"], "analysis": "清单编制依据含计价标准、设计文件、招标文件、施工现场情况、工程特点等。", "tags": ["清单编制", "依据"], "source": "历年真题精华版"}, {"id": "ch07-096", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "项目特征描述在清单计价中的作用包括（ ）。", "options": {"A": "影响综合单价", "B": "用于选择相应的定额子目", "C": "作为合同价款调整的因素之一", "D": "仅作形式参考无实质影响"}, "answer": ["A", "B", "C"], "analysis": "项目特征影响综合单价、决定定额子目选择、特征不符可调价，并非无实质影响。", "tags": ["2024清单", "项目特征"], "source": "安装教材精读笔记"}, {"id": "ch07-097", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "2024版清单修订为满足新发展需求，覆盖了（ ）。", "options": {"A": "装配式建筑", "B": "绿色建筑", "C": "地下综合管廊", "D": "海绵城市"}, "answer": ["A", "B", "C", "D"], "analysis": "2024版满足装配式、绿色建筑、地下综合管廊、海绵城市等计量计价需求。", "tags": ["2024清单", "新发展需求"], "source": "2024清单详细解读"}, {"id": "ch07-098", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "关于2018版广东省通用安装工程综合定额，下列说法正确的有（ ）。", "options": {"A": "属于消耗量定额（反映社会平均成本）", "B": "在广东省内强制性执行", "C": "自2019-03-01起实施", "D": "属于推荐性国家标准"}, "answer": ["A", "B", "C"], "analysis": "2018定额为消耗量定额、广东强制、2019-03-01实施；它是地方定额非推荐性国标，D错。", "tags": ["2018定额", "性质"], "source": "2018定额详细解读"}, {"id": "ch07-100", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "下列册号与名称对应正确的有（ ）。", "options": {"A": "第1册 机械设备安装工程", "B": "第4册 电气设备安装工程", "C": "第7册 通风空调工程", "D": "第12册 刷油、防腐蚀、绝热工程"}, "answer": ["A", "B", "C", "D"], "analysis": "上述册号与名称全部对应正确。", "tags": ["2018定额", "册号"], "source": "安装教材精读笔记"}, {"id": "ch07-101", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "下列专业与其对应的2018广东安装定额册号正确的有（ ）。", "options": {"A": "给排水、采暖、燃气 — 第10册", "B": "消防工程 — 第9册", "C": "建筑智能化 — 第5册", "D": "通风空调 — 第7册"}, "answer": ["A", "B", "C", "D"], "analysis": "给排水10、消防9、智能化5、通风7，对应关系均正确。", "tags": ["2018定额", "专业对应册"], "source": "安装教材精读笔记"}, {"id": "ch07-102", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "2018广东安装定额第12册（刷油、防腐蚀、绝热工程）包含的内容有（ ）。", "options": {"A": "刷油工程", "B": "防腐蚀工程", "C": "绝热工程", "D": "工业管道安装"}, "answer": ["A", "B", "C"], "analysis": "第12册含刷油、防腐蚀、绝热（含管道/设备/通风管道绝热）；工业管道安装属第8册。", "tags": ["2018定额", "第12册"], "source": "2018定额详细解读"}, {"id": "ch07-103", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "关于清单与定额的分工，下列说法正确的有（ ）。", "options": {"A": "清单规定计量规则", "B": "定额规定消耗量", "C": "清单管\"量怎么算\"", "D": "定额管\"要多少工料机\""}, "answer": ["A", "B", "C", "D"], "analysis": "清单管计量规则（量怎么算），定额管消耗量（要多少工料机），二者分工明确。", "tags": ["清单定额", "分工"], "source": "安装教材精读笔记"}, {"id": "ch07-104", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "关于2024清单与2018定额的关系，下列说法正确的有（ ）。", "options": {"A": "二者配套使用", "B": "清单用于计算工程量（计量）", "C": "定额用于计价（消耗）", "D": "二者互不相关"}, "answer": ["A", "B", "C"], "analysis": "清单与定额配套使用，清单管计量、定额管计价，并非互不相关。", "tags": ["清单定额", "关系"], "source": "2018定额详细解读"}, {"id": "ch07-105", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "将2024版清单与2018版定额结合，主要用于（ ）。", "options": {"A": "按清单规则计算工程量", "B": "按定额确定工料机消耗量", "C": "计算综合单价与工程造价", "D": "仅用于工程审计"}, "answer": ["A", "B", "C"], "analysis": "两者结合：清单算量、定额定消耗、最终计价算综合单价，并非仅用于审计。", "tags": ["清单定额", "衔接计价"], "source": "安装教材精读笔记"}, {"id": "ch07-106", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "根据广东省2018安装定额，管理费的计算基数组成包括（ ）。", "options": {"A": "分部分项的人工费", "B": "分部分项的施工机具费", "C": "材料费", "D": "规费"}, "answer": ["A", "B"], "analysis": "管理费以分部分项的人工费与施工机具费之和为计算基数，不含材料费和规费。", "tags": ["广东专属", "管理费基数"], "source": "第10册总说明"}, {"id": "ch07-107", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "2018广东安装定额中，施工机具费的组成包括（ ）。", "options": {"A": "施工机械使用费", "B": "施工仪器仪表使用费", "C": "材料费", "D": "人工费"}, "answer": ["A", "B"], "analysis": "施工机具费=施工机械使用费+施工仪器仪表使用费，不含材料费、人工费。", "tags": ["2018定额", "施工机具费"], "source": "2018定额详细解读"}, {"id": "ch07-108", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "2018广东安装定额中，人工费包含的内容有（ ）。", "options": {"A": "生产工人工资性收入", "B": "生产工人社会保险费", "C": "生产工人住房公积金", "D": "管理人员工资"}, "answer": ["A", "B", "C"], "analysis": "人工费为生产工人薪酬，含工资、社保、公积金、福利等；管理人员工资计入管理费。", "tags": ["2018定额", "人工费"], "source": "2018定额详细解读"}, {"id": "ch07-109", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "关于定额中的\"未计价材料\"（带[ ]符号），下列说法正确的有（ ）。", "options": {"A": "用[ ]符号标注", "B": "其价格未计入定额基价", "C": "应按[ ]内所列用量计算价格", "D": "已包含在定额基价中"}, "answer": ["A", "B", "C"], "analysis": "未计价材料带[ ]，基价不含其价格，需按[]内用量计算，D错。", "tags": ["2018定额", "未计价材料"], "source": "2018定额详细解读"}, {"id": "ch07-110", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "2018广东安装定额中，管理费包括的内容有（ ）。", "options": {"A": "管理人员薪酬", "B": "办公费", "C": "差旅交通费", "D": "生产工人工资"}, "answer": ["A", "B", "C"], "analysis": "管理费含管理人员薪酬、办公费、差旅交通费等；生产工人工资属人工费，不计入管理费。", "tags": ["2018定额", "管理费"], "source": "2018定额详细解读"}, {"id": "ch07-111", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "关于柔性软风管与帆布软接口的计量，下列说法正确的有（ ）。", "options": {"A": "柔性软风管清单计量单位为m", "B": "帆布软接口（定额）计量单位为㎡", "C": "柔性软风管定额计量单位也为m", "D": "帆布软接口清单计量单位为m"}, "answer": ["A", "B", "C"], "analysis": "柔性软风管清单、定额均按m；帆布软接口按㎡（第7册）。帆布软接口是定额项目，D表述不准确。", "tags": ["清单定额", "计量单位", "柔性软风管"], "source": "历年真题精华版"}, {"id": "ch07-112", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "风管展开面积的计算规则正确的有（ ）。", "options": {"A": "矩形风管 S=2×(宽+高)×长度", "B": "圆形风管 S=π×直径×长度", "C": "矩形风管 S=(宽+高)×长度", "D": "圆形风管 S=2×π×半径×长度（即π×直径×长度）"}, "answer": ["A", "B", "D"], "analysis": "矩形S=2(宽+高)长，圆形S=π×直径×长=2πr×长；C少乘2，错误。", "tags": ["工程量计算", "风管展开面积"], "source": "安装教材精读笔记"}, {"id": "ch07-113", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "给排水管道工程量计算的一般规则包括（ ）。", "options": {"A": "管道按中心线长度以m计算", "B": "管件（弯头、三通等）分别计算", "C": "阀门按类型和规格以个计算", "D": "卫生器具按套计算"}, "answer": ["A", "B", "C", "D"], "analysis": "管道按中心线长度m；管件分别算；阀门按个；卫生器具按套。", "tags": ["工程量计算", "给排水"], "source": "安装教材精读笔记"}, {"id": "ch07-114", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "电气照明工程配管配线工程量计算要点包括（ ）。", "options": {"A": "配管长度=水平段+垂直段（m）", "B": "配线长度=配管长度+预留长度（m）", "C": "灯具按套计算", "D": "阀门按m计算"}, "answer": ["A", "B", "C"], "analysis": "配管=水平+垂直（m），配线=配管+预留（m），灯具按套；阀门按个非m，D错。", "tags": ["工程量计算", "电气配管配线"], "source": "安装教材精读笔记"}, {"id": "ch07-115", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "下列清单附录与2018定额册号的对应关系中，正确的有（ ）。", "options": {"A": "附录D电气设备 ↔ 第4册", "B": "附录G通风空调 ↔ 第7册", "C": "附录K给排水采暖燃气 ↔ 第10册", "D": "附录J消防 ↔ 第9册"}, "answer": ["A", "B", "C", "D"], "analysis": "清单附录D/G/K/J分别对应定额第4/7/10/9册，全部正确。", "tags": ["清单定额", "附录对应册"], "source": "安装教材精读笔记"}, {"id": "ch07-116", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "关于广东二造安装专业管理费/利润计费基数（与北京对比），下列说法正确的有（ ）。", "options": {"A": "广东以人工费+施工机具费之和为基数", "B": "利润基数与管理费基数相同", "C": "北京多以纯人工费为基数", "D": "广东以纯人工费为基数"}, "answer": ["A", "B", "C"], "analysis": "广东管理费/利润基数=人工费+施工机具费，与北京纯人工费相反；D错。", "tags": ["广东专属", "管理费基数对比"], "source": "WebSearch补充"}, {"id": "ch07-117", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "安装工程预算编制的依据包括（ ）。", "options": {"A": "施工图纸", "B": "施工组织设计", "C": "预算定额（2018广东定额）", "D": "市场价格信息"}, "answer": ["A", "B", "C", "D"], "analysis": "预算编制依据含施工图纸、施工组织设计、预算定额、市场价格信息、费用定额等。", "tags": ["预算编制", "依据"], "source": "历年真题精华版"}, {"id": "ch07-118", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "2018广东安装定额的动态调整包括（ ）。", "options": {"A": "人工费可按各市动态人工调整系数调整", "B": "材料费可按各市信息价格调整", "C": "施工机具费可按各市规定执行", "D": "均不可调整"}, "answer": ["A", "B", "C"], "analysis": "人工、材料、机具均可按各市规定动态调整，D错。", "tags": ["2018定额", "动态调整"], "source": "2018定额详细解读"}, {"id": "ch07-119", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "关于施工机具费的工具用具处理，下列说法正确的有（ ）。", "options": {"A": "单位价值2000元以内的未计入施工机具费", "B": "使用年限1年以内的未计入施工机具费", "C": "均计入施工机具费", "D": "均不计入施工机具费"}, "answer": ["A", "B"], "analysis": "单位价值2000元以内、使用年限1年以内的工具用具未计入施工机具费；并非全部计入或全不计入。", "tags": ["2018定额", "施工机具费"], "source": "2018定额详细解读"}, {"id": "ch07-120", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "2018广东安装定额关于借工、时工、停工窝工的管理费规定有（ ）。", "options": {"A": "借工管理费20.00元/工日", "B": "时工管理费20.00元/工日", "C": "停工、窝工管理费10.00元/工日", "D": "借工管理费10.00元/工日"}, "answer": ["A", "B", "C"], "analysis": "借工、时工管理费统一20元/工日，停工窝工10元/工日。", "tags": ["2018定额", "管理费"], "source": "第10册总说明"}, {"id": "ch07-121", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "下列通用安装工程清单附录中，属于\"设备类\"专业附录的有（ ）。", "options": {"A": "附录A 机械设备安装工程", "B": "附录B 热力设备安装工程", "C": "附录C 静置设备与工艺金属结构", "D": "附录E 建筑智能化工程"}, "answer": ["A", "B", "C"], "analysis": "A机械设备、B热力设备、C静置设备均属设备类；E建筑智能化属弱电类。", "tags": ["2024清单", "附录"], "source": "2024清单详细解读"}, {"id": "ch07-122", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "下列通用安装工程清单附录中，属于电气与自控类相关专业的有（ ）。", "options": {"A": "附录D 电气设备安装工程", "B": "附录E 建筑智能化工程", "C": "附录F 自动化控制仪表安装工程", "D": "附录G 通风空调工程"}, "answer": ["A", "B", "C"], "analysis": "D电气、E智能化、F自动化仪表属电气自控类；G通风空调属暖通类。", "tags": ["2024清单", "附录"], "source": "2024清单详细解读"}, {"id": "ch07-123", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "清单项目特征描述通常应明确的内容有（ ）。", "options": {"A": "材质", "B": "规格", "C": "连接方式", "D": "施工人员姓名"}, "answer": ["A", "B", "C"], "analysis": "项目特征应描述材质、规格、连接方式等影响单价的内容，不含施工人员姓名。", "tags": ["2024清单", "项目特征"], "source": "安装教材精读笔记"}, {"id": "ch07-124", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "下列计量单位与项目对应正确的有（ ）。", "options": {"A": "柔性软风管 — m", "B": "帆布软接口 — ㎡", "C": "卫生器具 — 套", "D": "阀门 — 个"}, "answer": ["A", "B", "C", "D"], "analysis": "柔性软风管m、帆布软接口㎡、卫生器具套、阀门个，均正确。", "tags": ["计量单位", "工程量计算"], "source": "历年真题精华版"}, {"id": "ch07-125", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "2018广东安装定额中，施工机械使用费包括（ ）。", "options": {"A": "折旧费、检修费、维护费", "B": "安拆费", "C": "机上人工费", "D": "燃料动力费"}, "answer": ["A", "B", "C", "D"], "analysis": "施工机械使用费含折旧、检修、维护、安拆、机上人工、燃料动力等费用。", "tags": ["2018定额", "施工机具费"], "source": "2018定额详细解读"}, {"id": "ch07-126", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "2018广东安装定额中，施工仪器仪表使用费包括（ ）。", "options": {"A": "折旧费", "B": "维护费", "C": "校验费", "D": "动力费"}, "answer": ["A", "B", "C", "D"], "analysis": "施工仪器仪表使用费含折旧、维护、校验、动力费等。", "tags": ["2018定额", "施工机具费"], "source": "2018定额详细解读"}, {"id": "ch07-127", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "关于2024清单与2018定额的实施时间，下列说法正确的有（ ）。", "options": {"A": "2024清单自2025-09-01实施", "B": "2018定额自2019-03-01实施", "C": "两者在广东省内均为强制性", "D": "2024清单为推荐性标准"}, "answer": ["A", "B", "D"], "analysis": "清单2025-09-01实施、定额2019-03-01实施；清单为推荐性、定额在广东强制，故C错。", "tags": ["清单定额", "实施时间"], "source": "2018定额详细解读"}, {"id": "ch07-128", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "2018广东安装定额总说明规定的费用要素包括（ ）。", "options": {"A": "人工费", "B": "材料费", "C": "施工机具费", "D": "管理费、利润"}, "answer": ["A", "B", "C", "D"], "analysis": "定额费用要素含人工费、材料费、施工机具费、管理费、利润。", "tags": ["2018定额", "费用要素"], "source": "2018定额详细解读"}, {"id": "ch07-129", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "工程量清单中的\"其他项目\"通常可包含（ ）。", "options": {"A": "暂列金额", "B": "暂估价", "C": "计日工", "D": "总承包服务费"}, "answer": ["A", "B", "C", "D"], "analysis": "其他项目含暂列金额、暂估价、计日工、总承包服务费等。", "tags": ["工程量清单", "其他项目"], "source": "历年真题精华版"}, {"id": "ch07-130", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "关于GB/T 50856-2024与GB 50856-2013的区别，下列说法正确的有（ ）。", "options": {"A": "标准性质由强制性改为推荐性", "B": "编号由GB改为GB/T", "C": "附录数量由12个增至14个", "D": "适用范围扩大至设计施工总承包"}, "answer": ["A", "B", "C"], "analysis": "2024版性质改推荐性、编号GB/T、附录12→14；适用范围是\"不再适用\"EPC，D错。", "tags": ["2024清单", "与2013区别"], "source": "2024清单详细解读"}, {"id": "ch07-131", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "关于广东省2018安装定额管理费的计算，下列说法正确的有（ ）。", "options": {"A": "基数包含分部分项人工费", "B": "基数包含分部分项施工机具费", "C": "基数包含材料费", "D": "实际执行时随人工、机具价格变动而调整"}, "answer": ["A", "B", "D"], "analysis": "管理费以分部分项人工费+施工机具费为基数，不含材料费，并随价格变动调整。", "tags": ["广东专属", "管理费基数"], "source": "第10册总说明"}, {"id": "ch07-132", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "关于2018广东安装定额项目的工作内容，下列说法正确的有（ ）。", "options": {"A": "工作内容简要说明主要施工工序", "B": "次要工序虽未说明但已综合计入", "C": "主要、次要工序均已综合考虑", "D": "次要工序需另行单独计价"}, "answer": ["A", "B", "C"], "analysis": "定额工作内容说明主要工序，次要工序已综合计入，不另计，D错。", "tags": ["2018定额", "工作内容"], "source": "2018定额详细解读"}, {"id": "ch07-135", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "项目特征描述会影响综合单价，原因在于（ ）。", "options": {"A": "不同材质单价不同", "B": "不同连接方式施工工艺不同", "C": "影响定额子目的选择", "D": "与综合单价无关"}, "answer": ["A", "B", "C"], "analysis": "材质、连接方式不同导致单价与定额子目不同，故影响综合单价，D错。", "tags": ["2024清单", "项目特征", "综合单价"], "source": "安装教材精读笔记"}, {"id": "ch07-136", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "关于清单计量单位的使用，下列说法正确的有（ ）。", "options": {"A": "严格按规范要求的单位", "B": "不得自行更改", "C": "可按投标人习惯调整", "D": "与设计图示计量一致"}, "answer": ["A", "B", "D"], "analysis": "计量单位应严格按规范、与设计图示一致，不得自行按习惯调整，C错。", "tags": ["2024清单", "计量单位"], "source": "安装教材精读笔记"}, {"id": "ch07-137", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "关于广东省2018安装定额管理费的取定，下列说法正确的有（ ）。", "options": {"A": "按不同费率计算", "B": "费率已列入各章相应项目中", "C": "实际执行时随人工、机具价格变动调整", "D": "费率固定不可调整"}, "answer": ["A", "B", "C"], "analysis": "管理费按不同费率计算并列入各章项目，实际随价格变动调整，并非固定不可调。", "tags": ["广东专属", "管理费"], "source": "第10册总说明"}, {"id": "ch07-138", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "GB/T 50856-2024相较2013版新增的附录有（ ）。", "options": {"A": "附录M 刷油、防腐蚀、绝热工程", "B": "附录N 其他及附属工程", "C": "附录I 设备安装工程", "D": "附录P 措施项目"}, "answer": ["A", "B"], "analysis": "新增附录为M、N；附录I不存在，附录P（措施项目）2013版已有。", "tags": ["2024清单", "新增附录"], "source": "2024清单详细解读"}, {"id": "ch07-139", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "\"工程量按设计图示尺寸计算\"原则适用于（ ）。", "options": {"A": "清单工程量计算", "B": "依据清单规则计算工程量", "C": "定额人工消耗量确定", "D": "仅用于设计概算"}, "answer": ["A", "B"], "analysis": "按设计图示尺寸计算是清单计量规则的核心原则，用于清单工程量计算；不直接决定定额消耗量，D错。", "tags": ["2024清单", "计量原则"], "source": "安装教材精读笔记"}, {"id": "ch07-140", "date": "2026-07-06", "chapter": "ch07", "type": "multiple", "stem": "关于综合单价与分部分项工程费，下列说法正确的有（ ）。", "options": {"A": "综合单价=人工费+材料费+施工机具使用费+管理费+利润", "B": "综合单价不含规费和税金", "C": "分部分项工程费=Σ（综合单价×工程量）", "D": "规费、税金在汇总时单独列项"}, "answer": ["A", "B", "C", "D"], "analysis": "综合单价含人材机管利、不含规费税金；分部分项费=Σ综合单价×量；规费税金单独列项。全部正确。", "tags": ["综合单价", "分部分项工程费"], "source": "历年真题精华版"}, {"id": "ch08-001", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM的中文全称是（ ）。", "options": {"A": "建筑信息模型", "B": "建筑信息模拟", "C": "建筑信息管理", "D": "建筑信息建模"}, "answer": ["A"], "analysis": "BIM（Building Information Modeling）的中文全称为建筑信息模型，是以三维数字技术为基础、集成建设工程项目各种相关信息的工程数据模型。", "tags": ["BIM基本概念"], "source": "安装教材精读笔记.md"}, {"id": "ch08-002", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM本质上是一种（ ）。", "options": {"A": "三维几何空壳", "B": "集成工程项目各种相关信息的工程数据模型", "C": "二维图纸集合", "D": "施工进度计划表"}, "answer": ["B"], "analysis": "BIM（建筑信息模型）不是一个单纯的几何模型，而是集成了几何尺寸、材料、成本、进度等多维信息的工程数据模型。", "tags": ["BIM基本概念"], "source": "安装教材精读笔记.md"}, {"id": "ch08-003", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "下列各项中，不属于BIM技术支持下工程量计算特点的是（ ）。", "options": {"A": "模型自动提取工程量", "B": "三维可视化碰撞检查", "C": "手工逐张图纸计算", "D": "5D集成（3D+时间+成本）"}, "answer": ["C"], "analysis": "计算机辅助工程量计算（BIM）以模型自动提取、三维可视化碰撞检查、5D集成等为特征，手工逐张图纸计算属于传统方式，不属于BIM特点。", "tags": ["BIM与算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-004", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM模型能够自动提取工程量，主要依靠的是（ ）。", "options": {"A": "构件几何与参数属性", "B": "人工现场测量", "C": "图纸比例尺目测", "D": "普通计算器"}, "answer": ["A"], "analysis": "BIM模型中的构件既包含几何信息（尺寸、形状）也包含参数属性（材质、规格等），软件可据此自动统计工程量。", "tags": ["BIM自动算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-005", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM技术的“可视化”特征是指（ ）。", "options": {"A": "以三维模型直观展示工程对象", "B": "只能查看二维平面图", "C": "仅以文字报表表达", "D": "仅以颜色区分构件"}, "answer": ["A"], "analysis": "可视化是BIM的核心特征之一，指将工程信息以三维直观模型方式呈现，便于理解和协同。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-006", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "三维可视化检查碰撞属于BIM的（ ）应用。", "options": {"A": "碰撞检查（管线综合）", "B": "手工算量", "C": "定额套用", "D": "材料采购"}, "answer": ["A"], "analysis": "利用BIM三维模型进行碰撞检查（管线综合），可发现不同专业间的空间冲突，是第8章明确列出的BIM应用。", "tags": ["BIM碰撞检查"], "source": "安装教材精读笔记.md"}, {"id": "ch08-007", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM碰撞检查主要用于解决（ ）。", "options": {"A": "不同专业管线、构件之间的空间冲突", "B": "钢筋下料长度", "C": "混凝土配合比", "D": "土方开挖顺序"}, "answer": ["A"], "analysis": "碰撞检查基于三维模型检查建筑、结构、机电等专业之间的空间干涉与冲突，避免施工阶段返工。", "tags": ["BIM碰撞检查"], "source": "安装教材精读笔记.md"}, {"id": "ch08-008", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM中的“硬碰撞”是指（ ）。", "options": {"A": "实体构件相互穿透或相交", "B": "构件间间距不满足净距要求", "C": "模型颜色冲突", "D": "时间计划冲突"}, "answer": ["A"], "analysis": "硬碰撞指不同构件在空间中实体相交、穿透；软碰撞则指间距不满足规范净距要求。", "tags": ["BIM碰撞检查"], "source": "安装教材精读笔记.md"}, {"id": "ch08-009", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM中的“软碰撞”通常指（ ）。", "options": {"A": "构件间间距不满足规范要求或净距不足", "B": "实体构件相互穿透", "C": "模型缺失", "D": "材质标注错误"}, "answer": ["A"], "analysis": "软碰撞指构件之间虽未实体相交，但间距（如安装操作空间、检修空间）不满足规范或功能要求。", "tags": ["BIM碰撞检查"], "source": "安装教材精读笔记.md"}, {"id": "ch08-010", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "5D BIM中的“5D”是在3D基础上增加了（ ）。", "options": {"A": "时间+成本", "B": "仅成本", "C": "仅时间", "D": "人员+材料"}, "answer": ["A"], "analysis": "第8章明确：5D BIM=3D+时间+成本，即在三维几何模型基础上增加进度（时间）和造价（成本）两个维度。", "tags": ["5D BIM"], "source": "安装教材精读笔记.md"}, {"id": "ch08-011", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "5D BIM=3D+（ ）+成本。", "options": {"A": "时间（进度）", "B": "质量", "C": "安全", "D": "运维"}, "answer": ["A"], "analysis": "5D BIM由三维几何模型、时间（进度）维度和成本（造价）维度共同构成。", "tags": ["5D BIM"], "source": "安装教材精读笔记.md"}, {"id": "ch08-012", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "4D BIM是在3D基础上增加（ ）维度。", "options": {"A": "时间/进度", "B": "成本", "C": "运维", "D": "能耗"}, "answer": ["A"], "analysis": "4D BIM=3D+时间（进度），用于施工进度模拟与管理；再加成本即为5D。", "tags": ["BIM维度"], "source": "安装教材精读笔记.md"}, {"id": "ch08-013", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "在BIM维度体系中，主要用于施工进度模拟的是（ ）。", "options": {"A": "4D", "B": "3D", "C": "5D", "D": "2D"}, "answer": ["A"], "analysis": "4D BIM加入时间维度，可将模型与施工进度计划关联，进行施工过程模拟。", "tags": ["BIM维度"], "source": "安装教材精读笔记.md"}, {"id": "ch08-014", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "在BIM维度体系中，主要用于造价与成本管理的是（ ）。", "options": {"A": "5D", "B": "3D", "C": "4D", "D": "2D"}, "answer": ["A"], "analysis": "5D BIM=3D+时间+成本，将工程量与造价关联，用于造价与成本动态管理。", "tags": ["5D BIM"], "source": "安装教材精读笔记.md"}, {"id": "ch08-015", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "5D BIM中“成本”维度的主要作用是（ ）。", "options": {"A": "实现工程量与造价的动态关联", "B": "仅查看三维外观", "C": "仅排施工进度", "D": "仅出图存档"}, "answer": ["A"], "analysis": "成本维度使模型构件与工程量、单价关联，支持随进度动态统计造价。", "tags": ["5D BIM"], "source": "安装教材精读笔记.md"}, {"id": "ch08-016", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "关于5D BIM，下列说法错误的一项是（ ）。", "options": {"A": "5D BIM=3D+成本（无需时间维度）", "B": "5D BIM=3D+时间+成本", "C": "可用于进度款管理", "D": "可用于成本动态控制"}, "answer": ["A"], "analysis": "5D BIM必须包含3D+时间+成本三要素，A项遗漏了时间维度，表述错误。", "tags": ["5D BIM"], "source": "安装教材精读笔记.md"}, {"id": "ch08-017", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM模型自动提取的工程量可直接用于（ ）。", "options": {"A": "生成工程量清单并计价", "B": "替代工程设计", "C": "替代施工组织", "D": "替代工程验收"}, "answer": ["A"], "analysis": "BIM自动提取的工程量可输出为工程量清单，进而用于计价，是计算机辅助算量的直接成果。", "tags": ["BIM自动算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-018", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "相比手工算量，基于BIM的算量主要优势是（ ）。", "options": {"A": "提高算量效率与准确性", "B": "速度更慢", "C": "成本更高", "D": "需要大量纸质图纸"}, "answer": ["A"], "analysis": "计算机辅助（BIM）算量可减少人工计算误差、提高效率和成果质量，是第8章强调的优势。", "tags": ["BIM与算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-019", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "计算机辅助工程量计算技术最先替代的是（ ）。", "options": {"A": "手工计算工程量", "B": "工程设计绘图", "C": "施工组织设计", "D": "招标代理"}, "answer": ["A"], "analysis": "计算机辅助工程量计算的发展目的即替代传统的手工算量，提高算量速度与质量。", "tags": ["计算机辅助算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-020", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "20世纪90年代初，随着计算机技术发展，较早出现的算量工具是（ ）。", "options": {"A": "表格法算量软件", "B": "BIM算量软件", "C": "人工智能算量", "D": "云算量平台"}, "answer": ["A"], "analysis": "计算机辅助算量发展早期，先出现利用软件表格法算量的工具，替代手工计算，之后逐步发展为图形算量、BIM算量。", "tags": ["计算机辅助算量"], "source": "安装教材精读笔记.md（含WebSearch补充）"}, {"id": "ch08-021", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "我国算量软件的一般发展顺序是（ ）。", "options": {"A": "手工算量→表格法算量→图形算量→BIM算量", "B": "BIM算量→图形算量→表格法算量→手工算量", "C": "图形算量→手工算量→BIM算量→表格法算量", "D": "表格法算量→手工算量→BIM算量→图形算量"}, "answer": ["A"], "analysis": "算量技术演进路径为：手工算量→表格法算量→图形算量→BIM（模型）算量。", "tags": ["计算机辅助算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-022", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "在我国安装算量软件中，市场占有率最高的是（ ）。", "options": {"A": "广联达", "B": "鲁班", "C": "斯维尔", "D": "品茗"}, "answer": ["A"], "analysis": "第8章明确指出：广联达市场占有率最高，是全国主流算量软件。", "tags": ["算量软件"], "source": "安装教材精读笔记.md"}, {"id": "ch08-023", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "在广东地区常用的安装算量软件是（ ）。", "options": {"A": "斯维尔", "B": "广联达", "C": "鲁班", "D": "新点"}, "answer": ["A"], "analysis": "第8章明确指出：斯维尔在广东地区常用，契合广东计价与定额习惯。", "tags": ["算量软件"], "source": "安装教材精读笔记.md"}, {"id": "ch08-024", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "下列算量软件中被称作“传统老牌”的是（ ）。", "options": {"A": "鲁班", "B": "广联达", "C": "斯维尔", "D": "Revit"}, "answer": ["A"], "analysis": "第8章指出：鲁班属于传统老牌算量软件，在行业内有较长应用历史。", "tags": ["算量软件"], "source": "安装教材精读笔记.md"}, {"id": "ch08-025", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "广联达算量软件在全国市场的主要特点是（ ）。", "options": {"A": "市场占有率最高", "B": "仅在广东使用", "C": "已淘汰", "D": "只做土建不算安装"}, "answer": ["A"], "analysis": "广联达是全国市场占有率最高的算量软件，涵盖土建、安装等多个专业。", "tags": ["算量软件"], "source": "安装教材精读笔记.md"}, {"id": "ch08-026", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "斯维尔算量软件的主要地域特点是（ ）。", "options": {"A": "广东地区常用", "B": "全国市占率最高", "C": "仅北方使用", "D": "已停用"}, "answer": ["A"], "analysis": "斯维尔是广东地区常用的算量软件，适配广东本地定额与计价规则。", "tags": ["算量软件"], "source": "安装教材精读笔记.md"}, {"id": "ch08-027", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "鲁班软件在行业中的定位是（ ）。", "options": {"A": "传统老牌算量软件", "B": "新兴BIM独角兽", "C": "仅做建筑设计", "D": "仅做监理"}, "answer": ["A"], "analysis": "鲁班属于传统老牌算量软件，应用历史较长。", "tags": ["算量软件"], "source": "安装教材精读笔记.md"}, {"id": "ch08-028", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "下列属于基于BIM的安装工程量计算产品的是（ ）。", "options": {"A": "新点BIM 5D算量（安装）", "B": "Excel表格", "C": "纯手工算量", "D": "扫描仪"}, "answer": ["A"], "analysis": "新点BIM 5D算量（安装）是基于BIM技术的安装工程量计算软件，可依托智能建模实现自动出量。", "tags": ["算量软件"], "source": "安装教材精读笔记.md（含WebSearch补充）"}, {"id": "ch08-029", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "广联达BIM安装计量软件主要用于（ ）。", "options": {"A": "安装工程量的计算", "B": "土建结构受力计算", "C": "财务核算", "D": "合同管理"}, "answer": ["A"], "analysis": "广联达BIM安装计量属于安装专业工程量计算软件，用于电气、给排水、消防、暖通等安装工程量提取。", "tags": ["算量软件"], "source": "安装教材精读笔记.md（含WebSearch补充）"}, {"id": "ch08-030", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "算量软件输出的工程量结果通常直接用于（ ）。", "options": {"A": "工程量清单编制与计价", "B": "建筑方案设计", "C": "工程地质勘察", "D": "环境影响评价"}, "answer": ["A"], "analysis": "算量软件输出工程量是编制工程量清单和计价的基础数据。", "tags": ["算量软件"], "source": "安装教材精读笔记.md"}, {"id": "ch08-031", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM技术在造价管理中的核心应用不包括（ ）。", "options": {"A": "手工现场丈量", "B": "自动算量", "C": "碰撞检查", "D": "5D成本管控"}, "answer": ["A"], "analysis": "手工现场丈量不属于BIM应用；BIM核心应用包括模型自动算量、碰撞检查、5D成本动态管控等。", "tags": ["BIM与造价"], "source": "安装教材精读笔记.md"}, {"id": "ch08-032", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM模型包含的信息维度一般不包括（ ）。", "options": {"A": "仅颜色信息", "B": "几何尺寸", "C": "材料属性", "D": "成本信息（5D）"}, "answer": ["A"], "analysis": "BIM模型集成几何、材料、进度、成本等多维信息，而非仅有颜色。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-033", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "利用BIM进行管线综合优化，主要应用了（ ）。", "options": {"A": "三维协调与碰撞检查", "B": "手工逐项统计", "C": "二维描图", "D": "现场拍照"}, "answer": ["A"], "analysis": "管线综合优化依托BIM的三维协调与碰撞检查功能，提前发现并解决冲突。", "tags": ["BIM碰撞检查"], "source": "安装教材精读笔记.md"}, {"id": "ch08-034", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "5D BIM可用于进行（ ）。", "options": {"A": "基于进度的工程量与造价动态管理", "B": "仅三维外观展示", "C": "仅打印图纸", "D": "仅档案存档"}, "answer": ["A"], "analysis": "5D BIM将模型、进度与成本关联，可按进度动态统计工程量与造价。", "tags": ["5D BIM"], "source": "安装教材精读笔记.md"}, {"id": "ch08-035", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM模型的“协调性”体现在（ ）。", "options": {"A": "各专业在同一模型上协同、减少冲突", "B": "只能单专业独立建模", "C": "仅用于出图", "D": "各模型互不关联"}, "answer": ["A"], "analysis": "协调性指不同专业基于同一信息模型协同工作，提前协调空间关系、减少冲突。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-036", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM模型的“模拟性”可支持（ ）。", "options": {"A": "施工过程、进度、成本模拟", "B": "仅静态展示", "C": "仅文字说明", "D": "仅打印输出"}, "answer": ["A"], "analysis": "模拟性指利用BIM模型进行施工过程、进度（4D）、成本（5D）等多方面模拟。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-037", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM模型的“优化性”是指（ ）。", "options": {"A": "基于模型信息对设计方案进行优化", "B": "仅记录信息", "C": "仅展示外观", "D": "仅存档备查"}, "answer": ["A"], "analysis": "优化性指借助BIM模拟与协调结果，对设计、施工方案进行比选与优化。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-038", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM模型的“可出图性”是指（ ）。", "options": {"A": "可自动生成各专业图纸与报表", "B": "只能手绘", "C": "不能输出图纸", "D": "仅三维展示"}, "answer": ["A"], "analysis": "可出图性指BIM可基于模型自动生成平面图、剖面图及各类工程量报表。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-039", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM自动提取工程量所依据的核心数据是（ ）。", "options": {"A": "模型的几何与参数信息", "B": "随机猜测", "C": "主要依赖人工估算", "D": "照片比对"}, "answer": ["A"], "analysis": "BIM算量以模型承载的几何与参数信息为数据基础，由软件自动统计。", "tags": ["BIM自动算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-040", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM与清单计价的结合，可实现（ ）。", "options": {"A": "模型到清单、造价的自动关联", "B": "脱离模型纯手算", "C": "仅用于设计", "D": "仅用于施工"}, "answer": ["A"], "analysis": "BIM模型可依据构件信息自动映射清单项目并提取工程量，实现模型到清单计价的关联。", "tags": ["BIM与造价"], "source": "安装教材精读笔记.md"}, {"id": "ch08-041", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "下列算量方式属于“计算机辅助工程量计算”的是（ ）。", "options": {"A": "软件自动算量", "B": "纯手工算量", "C": "经验估算", "D": "目测估算"}, "answer": ["A"], "analysis": "计算机辅助工程量计算即借助算量软件自动计算工程量，区别于手工与估算。", "tags": ["计算机辅助算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-042", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "算量软件对工程造价成果文件的作用是（ ）。", "options": {"A": "提高计价成果质量与速度", "B": "降低成果质量", "C": "与造价无关", "D": "仅用于存档"}, "answer": ["A"], "analysis": "计算机辅助算量可加快算量速度、提高成果质量，是造价信息化的重要方向。", "tags": ["计算机辅助算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-043", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM应用于工程量计算，最早依托的是（ ）。", "options": {"A": "三维信息模型", "B": "纯二维图纸", "C": "口头描述", "D": "现场照片"}, "answer": ["A"], "analysis": "BIM算量以三维信息模型为数据基础，区别于传统二维图纸手算。", "tags": ["BIM自动算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-044", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "关于BIM与算量软件的关系，正确的是（ ）。", "options": {"A": "BIM为算量软件提供模型数据基础", "B": "两者毫无关系", "C": "算量软件完全替代BIM", "D": "BIM完全替代算量软件"}, "answer": ["A"], "analysis": "BIM提供包含几何与参数的信息模型，算量软件读取模型自动提取工程量，二者是数据与工具的关系。", "tags": ["BIM与算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-045", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "下列属于BIM在全过程造价管理中应用的是（ ）。", "options": {"A": "决策、设计、施工、运维各阶段成本管控", "B": "仅施工阶段", "C": "仅设计阶段", "D": "仅竣工阶段"}, "answer": ["A"], "analysis": "BIM支持的5D成本管控可贯穿项目决策、设计、施工到运维各阶段。", "tags": ["BIM与造价"], "source": "安装教材精读笔记.md"}, {"id": "ch08-046", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "碰撞检查在工程（ ）进行最为有效。", "options": {"A": "设计阶段/施工前", "B": "竣工后", "C": "拆除阶段", "D": "仅运营阶段"}, "answer": ["A"], "analysis": "在设计阶段、施工前开展碰撞检查，可提前发现冲突、减少施工返工。", "tags": ["BIM碰撞检查"], "source": "安装教材精读笔记.md"}, {"id": "ch08-047", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM 5D中的成本信息主要来源于（ ）。", "options": {"A": "模型构件工程量×综合单价", "B": "仅人工费", "C": "仅材料费", "D": "仅机械费"}, "answer": ["A"], "analysis": "5D成本由模型提取的工程量乘以相应单价得出，实现量价关联。", "tags": ["5D BIM"], "source": "安装教材精读笔记.md"}, {"id": "ch08-048", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "基于BIM的进度款管理属于（ ）。", "options": {"A": "5D应用", "B": "3D应用", "C": "2D应用", "D": "纯财务应用"}, "answer": ["A"], "analysis": "进度款管理需将工程量（3D）、进度（时间）与造价（成本）结合，属于5D BIM应用。", "tags": ["5D BIM"], "source": "安装教材精读笔记.md"}, {"id": "ch08-049", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "相比传统算量，BIM算量的“信息完备性”是指（ ）。", "options": {"A": "模型集成了几何与非几何（成本、时间）信息", "B": "仅有线条", "C": "仅有文字", "D": "仅有图片"}, "answer": ["A"], "analysis": "信息完备性指BIM模型不仅含几何信息，还集成材料、进度、成本等非几何信息。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-050", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "算量软件广联达的适用专业范围（ ）。", "options": {"A": "涵盖土建、安装等多个专业", "B": "仅安装", "C": "仅市政", "D": "仅园林"}, "answer": ["A"], "analysis": "广联达产品体系覆盖土建、安装、市政等多个专业方向。", "tags": ["算量软件"], "source": "安装教材精读笔记.md"}, {"id": "ch08-051", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "斯维尔软件在广东常用，主要面向（ ）。", "options": {"A": "安装工程等工程量计算", "B": "仅建筑设计", "C": "仅工程勘察", "D": "仅审计"}, "answer": ["A"], "analysis": "斯维尔是面向安装工程等专业的算量软件，在广东地区常用。", "tags": ["算量软件"], "source": "安装教材精读笔记.md"}, {"id": "ch08-052", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM技术支持的“协同”工作主要依靠（ ）。", "options": {"A": "统一的信息模型平台", "B": "各自独立的纸质图纸", "C": "电话沟通", "D": "纸质文件传递"}, "answer": ["A"], "analysis": "协同依托统一BIM信息模型平台实现多专业信息共享与联动。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-053", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM技术能够减少设计变更和返工，主要因为（ ）。", "options": {"A": "碰撞检查提前发现冲突", "B": "手算更快", "C": "图纸更多", "D": "各专业互不影响"}, "answer": ["A"], "analysis": "通过碰撞检查在设计阶段提前发现并解决空间冲突，从而减少施工阶段变更与返工。", "tags": ["BIM碰撞检查"], "source": "安装教材精读笔记.md"}, {"id": "ch08-054", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "下列关于5D BIM说法，错误的一项是（ ）。", "options": {"A": "仅三维+时间即可，无需成本", "B": "三维+时间+成本", "C": "用于造价管理", "D": "用于进度款管理"}, "answer": ["A"], "analysis": "5D BIM必须包含成本维度，A项认为无需成本，表述错误。", "tags": ["5D BIM"], "source": "安装教材精读笔记.md"}, {"id": "ch08-055", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM模型的“关联性”是指（ ）。", "options": {"A": "构件修改后相关信息自动更新", "B": "各构件互不影响", "C": "需手动逐项修改", "D": "无数据关联"}, "answer": ["A"], "analysis": "关联性指模型构件间存在逻辑联系，修改一处相关信息自动联动更新。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-056", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "算量软件发展的主要驱动力是（ ）。", "options": {"A": "提高算量效率与准确性", "B": "减少市场竞争", "C": "增加人工投入", "D": "延长工期"}, "answer": ["A"], "analysis": "算量软件的发展以解决手工算量效率低、易出错为驱动，旨在提升效率与准确性。", "tags": ["计算机辅助算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-057", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "在BIM 5D中，时间维度通常关联（ ）。", "options": {"A": "施工进度计划", "B": "材料品牌", "C": "人员工资标准", "D": "天气情况"}, "answer": ["A"], "analysis": "5D中的时间（4D）维度与施工进度计划关联，实现进度与量价联动。", "tags": ["5D BIM"], "source": "安装教材精读笔记.md"}, {"id": "ch08-058", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "BIM用于施工模拟可帮助（ ）。", "options": {"A": "优化施工组织与进度", "B": "仅绘图", "C": "仅存档", "D": "仅打印"}, "answer": ["A"], "analysis": "借助4D/5D模拟可优化施工组织、进度安排与资源配置。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-059", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "计算机辅助工程量计算对造价人员的意义是（ ）。", "options": {"A": "将人员从繁琐手工计算中解放，专注分析与决策", "B": "增加手工工作量", "C": "与造价无关", "D": "完全替代造价人员"}, "answer": ["A"], "analysis": "算量软件提升效率，使造价人员从重复算量中解放，转向数据分析与决策。", "tags": ["计算机辅助算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-060", "date": "2026-07-06", "chapter": "ch08", "type": "single", "stem": "下列关于主流算量软件的说法，正确的是（ ）。", "options": {"A": "广联达市占率最高、斯维尔广东常用、鲁班为传统老牌", "B": "三者功能完全相同", "C": "仅有一家可用", "D": "均不常用"}, "answer": ["A"], "analysis": "第8章明确：广联达市占率最高、斯维尔广东常用、鲁班为传统老牌。", "tags": ["算量软件"], "source": "安装教材精读笔记.md"}, {"id": "ch08-061", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "BIM技术的核心特征包括（ ）。", "options": {"A": "可视化", "B": "协调性", "C": "模拟性", "D": "优化性"}, "answer": ["A", "B", "C", "D"], "analysis": "BIM核心特征通常包括可视化、协调性、模拟性、优化性、可出图性，本题四项均属其核心特征。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-062", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "BIM模型可承载的信息包括（ ）。", "options": {"A": "几何尺寸", "B": "材料规格", "C": "成本信息", "D": "施工进度"}, "answer": ["A", "B", "C", "D"], "analysis": "BIM模型集成几何尺寸、材料规格、进度（4D）、成本（5D）等多维信息。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-063", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "BIM在工程造价中的主要应用包括（ ）。", "options": {"A": "自动提取工程量", "B": "三维碰撞检查", "C": "5D成本动态管理", "D": "手工现场丈量"}, "answer": ["A", "B", "C"], "analysis": "BIM造价应用包括模型自动算量、碰撞检查、5D成本管控；手工现场丈量不属于BIM应用。", "tags": ["BIM与造价"], "source": "安装教材精读笔记.md"}, {"id": "ch08-064", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "关于5D BIM，下列说法正确的有（ ）。", "options": {"A": "由3D几何模型发展而来", "B": "在3D基础上增加时间维度", "C": "在4D基础上增加成本维度", "D": "仅用于三维外观展示"}, "answer": ["A", "B", "C"], "analysis": "5D BIM由3D发展，3D+时间=4D，4D+成本=5D，用于造价管理而非仅展示。", "tags": ["5D BIM"], "source": "安装教材精读笔记.md"}, {"id": "ch08-065", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "5D BIM包含的三个核心维度是（ ）。", "options": {"A": "三维几何", "B": "时间/进度", "C": "成本/造价", "D": "运维管理"}, "answer": ["A", "B", "C"], "analysis": "5D BIM=3D几何+时间进度+成本造价；运维管理属于更高维度（6D）。", "tags": ["5D BIM"], "source": "安装教材精读笔记.md"}, {"id": "ch08-066", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "属于BIM维度扩展的有（ ）。", "options": {"A": "3D几何", "B": "4D时间", "C": "5D成本", "D": "6D运维"}, "answer": ["A", "B", "C", "D"], "analysis": "BIM维度从3D几何、4D时间、5D成本到6D运维逐级扩展，构成nD体系。", "tags": ["BIM维度"], "source": "安装教材精读笔记.md"}, {"id": "ch08-067", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "BIM碰撞检查可发现的冲突类型包括（ ）。", "options": {"A": "硬碰撞（实体相交）", "B": "软碰撞（净距不足）", "C": "材质标注错误", "D": "颜色冲突"}, "answer": ["A", "B"], "analysis": "碰撞检查主要识别硬碰撞（实体相交）与软碰撞（间距/净距不满足要求）；材质、颜色不属于空间碰撞。", "tags": ["BIM碰撞检查"], "source": "安装教材精读笔记.md"}, {"id": "ch08-068", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "碰撞检查的主要作用包括（ ）。", "options": {"A": "提前发现管线冲突", "B": "减少施工返工", "C": "优化管线综合", "D": "增加设计变更"}, "answer": ["A", "B", "C"], "analysis": "碰撞检查可提前发现冲突、优化管线综合、减少现场返工；其目的不是增加变更。", "tags": ["BIM碰撞检查"], "source": "安装教材精读笔记.md"}, {"id": "ch08-069", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "BIM三维可视化在工程中的价值包括（ ）。", "options": {"A": "直观展示空间关系", "B": "辅助方案比选", "C": "发现错漏碰缺", "D": "替代结构受力计算"}, "answer": ["A", "B", "C"], "analysis": "三维可视化利于展示空间、辅助比选、发现错漏碰缺；BIM不替代结构专业受力计算。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-070", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "计算机辅助工程量计算的发展阶段包括（ ）。", "options": {"A": "手工算量", "B": "表格法算量", "C": "图形算量", "D": "BIM算量"}, "answer": ["A", "B", "C", "D"], "analysis": "算量技术演进为手工算量→表格法算量→图形算量→BIM（模型）算量。", "tags": ["计算机辅助算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-071", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "我国常见的安装算量软件包括（ ）。", "options": {"A": "广联达", "B": "鲁班", "C": "斯维尔", "D": "新点"}, "answer": ["A", "B", "C", "D"], "analysis": "国内常见安装算量软件有广联达、鲁班、斯维尔、新点等，其中广联达市占率最高、斯维尔广东常用、鲁班为传统老牌。", "tags": ["算量软件"], "source": "安装教材精读笔记.md（含WebSearch补充）"}, {"id": "ch08-072", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "下列关于主流算量软件地域/市场特点，正确的有（ ）。", "options": {"A": "广联达市场占有率最高", "B": "斯维尔在广东地区常用", "C": "鲁班为传统老牌软件", "D": "广联达仅在广东使用"}, "answer": ["A", "B", "C"], "analysis": "广联达全国市占率最高而并非仅在广东；斯维尔广东常用、鲁班为传统老牌。", "tags": ["算量软件"], "source": "安装教材精读笔记.md"}, {"id": "ch08-073", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "关于广联达算量软件，说法正确的有（ ）。", "options": {"A": "市场占有率最高", "B": "涵盖土建、安装等多专业", "C": "仅做财务核算", "D": "已淘汰"}, "answer": ["A", "B"], "analysis": "广联达全国市占率最高、覆盖多专业；并非仅做财务，也未被淘汰。", "tags": ["算量软件"], "source": "安装教材精读笔记.md"}, {"id": "ch08-074", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "关于斯维尔算量软件，说法正确的有（ ）。", "options": {"A": "广东地区常用", "B": "可用于安装工程量计算", "C": "全国市占率最高", "D": "仅做工程勘察"}, "answer": ["A", "B"], "analysis": "斯维尔广东常用、面向安装等专业算量；全国市占率最高的是广联达，斯维尔并非仅做勘察。", "tags": ["算量软件"], "source": "安装教材精读笔记.md"}, {"id": "ch08-075", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "关于鲁班软件，说法正确的有（ ）。", "options": {"A": "传统老牌算量软件", "B": "在行业内有较长应用历史", "C": "仅做建筑设计", "D": "仅做工程监理"}, "answer": ["A", "B"], "analysis": "鲁班为传统老牌算量软件，应用历史较长；并非仅做设计或监理。", "tags": ["算量软件"], "source": "安装教材精读笔记.md"}, {"id": "ch08-076", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "BIM自动提取工程量的优点包括（ ）。", "options": {"A": "效率高", "B": "准确性好", "C": "减少人为误差", "D": "必须手工计算"}, "answer": ["A", "B", "C"], "analysis": "BIM自动算量具有效率高、准确性好、减少人为误差的优点；并非必须手工计算。", "tags": ["BIM自动算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-077", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "BIM模型可用于生成（ ）。", "options": {"A": "工程量清单", "B": "材料表", "C": "设备明细表", "D": "施工合同文本"}, "answer": ["A", "B", "C"], "analysis": "BIM模型可输出工程量清单、材料表、设备明细等；施工合同文本不属模型直接生成。", "tags": ["BIM自动算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-078", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "5D BIM在项目管理中可支持（ ）。", "options": {"A": "进度款申请", "B": "成本动态控制", "C": "资源计划编制", "D": "仅输出三维图"}, "answer": ["A", "B", "C"], "analysis": "5D BIM可支持进度款、成本动态控制、资源计划等；并非仅输出三维图。", "tags": ["5D BIM"], "source": "安装教材精读笔记.md"}, {"id": "ch08-079", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "BIM在全过程造价管理中的应用阶段包括（ ）。", "options": {"A": "决策阶段", "B": "设计阶段", "C": "施工阶段", "D": "运维阶段"}, "answer": ["A", "B", "C", "D"], "analysis": "BIM支持的5D成本管控可贯穿决策、设计、施工、运维全过程。", "tags": ["BIM与造价"], "source": "安装教材精读笔记.md"}, {"id": "ch08-080", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "基于BIM的管线综合优化可（ ）。", "options": {"A": "协调各专业空间关系", "B": "避免碰撞冲突", "C": "减少施工返工", "D": "增加专业冲突"}, "answer": ["A", "B", "C"], "analysis": "管线综合优化通过协调空间、避免碰撞、减少返工，而非增加冲突。", "tags": ["BIM碰撞检查"], "source": "安装教材精读笔记.md"}, {"id": "ch08-081", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "算量软件对工程造价的作用包括（ ）。", "options": {"A": "提高算量速度", "B": "提高成果质量", "C": "减轻劳动强度", "D": "降低准确性"}, "answer": ["A", "B", "C"], "analysis": "算量软件可提高速度、质量并减轻人工劳动强度，而非降低准确性。", "tags": ["计算机辅助算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-082", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "BIM模型“关联性”带来的好处有（ ）。", "options": {"A": "构件修改自动更新相关量", "B": "保持数据一致性", "C": "减少漏算", "D": "需逐项手工修改"}, "answer": ["A", "B", "C"], "analysis": "关联性使修改联动、数据一致、减少漏算；并非需逐项手工修改。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-083", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "BIM的“模拟性”可支持（ ）。", "options": {"A": "施工进度模拟", "B": "成本模拟", "C": "节能模拟", "D": "仅静态展示"}, "answer": ["A", "B", "C"], "analysis": "模拟性支持进度（4D）、成本（5D）、节能等多种模拟，而非仅静态展示。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-084", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "下列属于BIM与清单计价衔接优势的有（ ）。", "options": {"A": "模型到清单自动关联", "B": "依据模型提取工程量", "C": "减少重复录入", "D": "必须完全手算"}, "answer": ["A", "B", "C"], "analysis": "BIM与清单计价衔接可实现模型到清单关联、自动提量、减少重复录入；并非必须手算。", "tags": ["BIM与造价"], "source": "安装教材精读笔记.md"}, {"id": "ch08-085", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "关于BIM与算量软件关系，正确的有（ ）。", "options": {"A": "BIM为算量提供模型基础", "B": "算量软件读取模型提取工程量", "C": "二者毫无关系", "D": "算量软件弃用BIM"}, "answer": ["A", "B"], "analysis": "BIM提供信息模型，算量软件读取模型自动提量，二者是数据与工具关系，并非无关或弃用。", "tags": ["BIM与算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-086", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "采用BIM进行工程量计算，其数据来源包括（ ）。", "options": {"A": "模型几何信息", "B": "构件参数属性", "C": "项目特征信息", "D": "以人工估算为主"}, "answer": ["A", "B", "C"], "analysis": "BIM算量以模型几何、参数属性、项目特征等模型信息为数据来源，而非以人工估算为主。", "tags": ["BIM自动算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-087", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "BIM 5D成本管控可实现（ ）。", "options": {"A": "实时统计已完成工程量造价", "B": "对比预算成本", "C": "动态预警超支", "D": "仅在竣工后核算"}, "answer": ["A", "B", "C"], "analysis": "5D成本管控可动态统计、对比预算、预警超支；并非仅竣工后核算。", "tags": ["5D BIM"], "source": "安装教材精读笔记.md"}, {"id": "ch08-088", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "下列属于BIM技术支持下的协同工作表现的有（ ）。", "options": {"A": "多专业基于同一模型", "B": "信息共享", "C": "冲突前置发现", "D": "各自独立互不通气"}, "answer": ["A", "B", "C"], "analysis": "BIM协同表现为多专业同模型、信息共享、冲突前置发现；各自独立互不通气违背协同。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-089", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "关于碰撞检查实施时机，正确的有（ ）。", "options": {"A": "在设计阶段进行", "B": "在施工前优化", "C": "可减少现场返工", "D": "竣工后才检查"}, "answer": ["A", "B", "C"], "analysis": "碰撞检查应在设计阶段、施工前开展以减少返工；竣工后才检查则失去意义。", "tags": ["BIM碰撞检查"], "source": "安装教材精读笔记.md"}, {"id": "ch08-090", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "BIM技术在造价文件编制中的优势包括（ ）。", "options": {"A": "快速出量", "B": "数据可追溯", "C": "便于调整修改", "D": "完全无需人员参与"}, "answer": ["A", "B", "C"], "analysis": "BIM可快速出量、数据可追溯、便于调整；但仍需造价人员专业判断，并非完全无需人员。", "tags": ["BIM与造价"], "source": "安装教材精读笔记.md"}, {"id": "ch08-091", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "下列属于广联达产品体系的有（ ）。", "options": {"A": "广联达BIM安装计量", "B": "广联达计价软件", "C": "斯维尔算量", "D": "鲁班算量"}, "answer": ["A", "B"], "analysis": "广联达BIM安装计量、广联达计价软件属广联达体系；斯维尔、鲁班为其他厂商产品。", "tags": ["算量软件"], "source": "安装教材精读笔记.md（含WebSearch补充）"}, {"id": "ch08-092", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "关于斯维尔在广东常用，合理的原因有（ ）。", "options": {"A": "适应广东定额与计价习惯", "B": "本地化服务支持", "C": "符合广东计量计价要求", "D": "全国唯一算量软件"}, "answer": ["A", "B", "C"], "analysis": "斯维尔因适配广东定额、计价习惯与本地化服务而在广东常用；并非全国唯一软件。", "tags": ["算量软件"], "source": "安装教材精读笔记.md"}, {"id": "ch08-093", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "算量软件输出成果可应用于（ ）。", "options": {"A": "施工图预算", "B": "招标控制价", "C": "投标报价", "D": "仅装饰设计"}, "answer": ["A", "B", "C"], "analysis": "算量成果可用于施工图预算、招标控制价、投标报价等造价文件编制；并非仅装饰设计。", "tags": ["算量软件"], "source": "安装教材精读笔记.md"}, {"id": "ch08-094", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "BIM的“可出图性”可输出（ ）。", "options": {"A": "平面图", "B": "剖面图", "C": "工程量清单报表", "D": "结构计算书"}, "answer": ["A", "B", "C"], "analysis": "可出图性可输出平立剖图纸及各类报表；结构计算书由结构专业软件完成，不属BIM直接输出。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-095", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "下列属于BIM区别于传统二维CAD的特点有（ ）。", "options": {"A": "包含构件参数信息", "B": "支持多维度信息集成", "C": "可视化三维表达", "D": "仅线条绘图"}, "answer": ["A", "B", "C"], "analysis": "BIM包含参数信息、多维集成、三维可视化；仅线条绘图是传统CAD特征。", "tags": ["BIM特征"], "source": "安装教材精读笔记.md"}, {"id": "ch08-096", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "5D BIM中成本维度的数据通常包含（ ）。", "options": {"A": "工程量", "B": "综合单价", "C": "合价", "D": "施工进度"}, "answer": ["A", "B", "C"], "analysis": "成本维度数据由工程量、综合单价、合价等组成；施工进度属时间维度。", "tags": ["5D BIM"], "source": "安装教材精读笔记.md"}, {"id": "ch08-097", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "BIM用于施工阶段造价管理的有（ ）。", "options": {"A": "进度款计算", "B": "变更计量", "C": "材料用量控制", "D": "仅设计建模"}, "answer": ["A", "B", "C"], "analysis": "施工阶段BIM可用于进度款、变更计量、材料用量控制等；不仅限设计建模。", "tags": ["BIM与造价"], "source": "安装教材精读笔记.md"}, {"id": "ch08-098", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "关于计算机辅助算量，下列说法正确的有（ ）。", "options": {"A": "提升效率", "B": "提高准确性", "C": "是造价信息化方向", "D": "将被完全废弃"}, "answer": ["A", "B", "C"], "analysis": "计算机辅助算量是造价信息化方向，可提升效率与准确性，不会被完全废弃。", "tags": ["计算机辅助算量"], "source": "安装教材精读笔记.md"}, {"id": "ch08-099", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "下列软件中属于BIM相关算量/造价软件的有（ ）。", "options": {"A": "广联达BIM安装计量", "B": "新点BIM 5D算量", "C": "斯维尔", "D": "鲁班"}, "answer": ["A", "B", "C", "D"], "analysis": "广联达BIM安装计量、新点BIM 5D算量、斯维尔、鲁班均为国内常见BIM/算量类软件。", "tags": ["算量软件"], "source": "安装教材精读笔记.md（含WebSearch补充）"}, {"id": "ch08-100", "date": "2026-07-06", "chapter": "ch08", "type": "multiple", "stem": "BIM技术在安装工程中可应用的方面有（ ）。", "options": {"A": "管线综合碰撞检查", "B": "安装工程量自动提取", "C": "施工工序模拟", "D": "仅土建结构"}, "answer": ["A", "B", "C"], "analysis": "BIM在安装工程可用于管线碰撞检查、工程量自动提取、施工工序模拟等；不仅限土建结构。", "tags": ["BIM与算量"], "source": "安装教材精读笔记.md"}, {"id": "ch09-001", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "根据《建设工程计量与计价实务（安装工程）》教材，施工图预算（安装专业）的编制依据不包括以下哪项？", "options": {"A": "施工图纸", "B": "预算定额", "C": "工程监理合同", "D": "市场价格信息"}, "answer": ["C"], "analysis": "教材明确安装工程预算编制依据共5项：施工图纸、预算定额（2018版广东定额）、费用定额、市场价格信息、施工组织设计。工程监理合同不属于预算编制依据。", "tags": ["编制依据"], "source": "安装教材精读笔记"}, {"id": "ch09-002", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "广东省安装工程预算编制中，所依据的'预算定额'是指（ ）。", "options": {"A": "2013版国家清单计价规范", "B": "2018版广东省通用安装工程综合定额", "C": "GB/T 50856-2024清单", "D": "GB 50500-2013"}, "answer": ["B"], "analysis": "教材9.1编制依据明确预算定额指2018版广东定额（即《广东省通用安装工程综合定额》2018版），用于确定人工、材料、机具的消耗量。", "tags": ["编制依据", "预算定额"], "source": "安装教材精读笔记"}, {"id": "ch09-003", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "在施工图预算编制依据中，'费用定额'的主要作用是（ ）。", "options": {"A": "规定工程量清单的计量规则", "B": "规定各项费用的取费标准（费率、计费基数）", "C": "提供材料市场单价", "D": "确定施工组织方案"}, "answer": ["B"], "analysis": "费用定额规定建筑安装工程费的各项取费标准，如企业管理费、利润、规费、税金等的费率及计费基数，是计算除人材机以外的费用的法定依据。", "tags": ["编制依据", "费用定额"], "source": "安装教材精读笔记"}, {"id": "ch09-004", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "编制安装工程施工图预算时，市场价格信息主要用于确定（ ）。", "options": {"A": "工程量计算规则", "B": "人工、材料、施工机具的单价", "C": "施工组织设计", "D": "费用定额的费率"}, "answer": ["B"], "analysis": "市场价格信息用于确定人工、材料、施工机具使用费的实际单价，是定额基价中人工、材料、机具价差调整及未计价材料计价的重要依据。", "tags": ["编制依据", "市场价格信息"], "source": "安装教材精读笔记"}, {"id": "ch09-005", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "在施工图预算编制依据中，施工组织设计的作用主要是为（ ）提供依据。", "options": {"A": "分部分项工程量计算", "B": "措施项目费的计取和施工方法选择", "C": "规费的计算", "D": "税金的计算"}, "answer": ["B"], "analysis": "施工组织设计明确施工方案、施工方法、进度安排、平面布置等，是确定措施项目（如脚手架、垂直运输、夜间施工等）及相应措施项目费的依据。", "tags": ["编制依据", "施工组织设计"], "source": "安装教材精读笔记"}, {"id": "ch09-006", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "安装工程预算编制依据中，'施工图纸'是计算（ ）的基础。", "options": {"A": "措施项目费", "B": "规费", "C": "分部分项工程量", "D": "税金"}, "answer": ["C"], "analysis": "施工图纸反映工程设计内容、规格、数量，是计算分部分项工程量的根本依据，工程量按设计图示尺寸计算。", "tags": ["编制依据", "施工图纸"], "source": "安装教材精读笔记"}, {"id": "ch09-007", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "下列属于安装工程预算编制依据的是（ ）。", "options": {"A": "建设单位内部财务制度", "B": "施工组织设计", "C": "监理单位工作手册", "D": "施工单位宣传册"}, "answer": ["B"], "analysis": "教材9.1列出的5项编制依据含施工组织设计，其余三项均非编制依据。", "tags": ["编制依据"], "source": "安装教材精读笔记"}, {"id": "ch09-008", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "下列哪一项不属于教材所列施工图预算编制的五项依据？", "options": {"A": "施工图纸", "B": "费用定额", "C": "工程地质勘察报告", "D": "市场价格信息"}, "answer": ["C"], "analysis": "教材9.1明确五项依据为：施工图纸、预算定额、费用定额、市场价格信息、施工组织设计。工程地质勘察报告未列入。", "tags": ["编制依据"], "source": "安装教材精读笔记"}, {"id": "ch09-009", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "安装工程预算编制中，预算定额（2018版广东定额）主要解决（ ）问题。", "options": {"A": "工程量计算规则（怎么算量）", "B": "人工、材料、施工机具的消耗量（要多少）", "C": "税金税率", "D": "规费费率"}, "answer": ["B"], "analysis": "教材7.3及9.1说明：2018定额规定'消耗量'，即完成单位工程需要消耗多少人工、材料、机具；清单规定'计量规则'（怎么算量）。", "tags": ["编制依据", "预算定额", "清单与定额衔接"], "source": "安装教材精读笔记"}, {"id": "ch09-010", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "关于预算编制依据的下列表述，正确的是（ ）。", "options": {"A": "只需施工图纸和定额即可编制预算", "B": "市场价格信息是可有可无的参考", "C": "费用定额、市场价格信息、施工组织设计均是必要依据", "D": "施工组织设计对预算没有影响"}, "answer": ["C"], "analysis": "教材9.1列出5项依据缺一不可：施工图纸、预算定额、费用定额、市场价格信息、施工组织设计均对预算有重要影响。", "tags": ["编制依据"], "source": "安装教材精读笔记"}, {"id": "ch09-011", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "广东省2018安装定额中，材料价格按（ ）综合水平确定。", "options": {"A": "2015年全省", "B": "2017年全省", "C": "2020年全省", "D": "2024年全省"}, "answer": ["B"], "analysis": "据2018定额详细解读，定额中的人工费、材料费、施工机具台班单价均按照2017年广东省建筑市场综合水平取定。", "tags": ["预算定额", "材料价格"], "source": "2018定额详细解读"}, {"id": "ch09-012", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "根据2018定额，人工费按（ ）工作制计算。", "options": {"A": "6小时", "B": "8小时", "C": "10小时", "D": "12小时"}, "answer": ["B"], "analysis": "2018定额规定人工费按8小时工作制计算；借工、时工4小时以内按半个工日，4小时以上8小时以内按一个工日。", "tags": ["预算定额", "人工费"], "source": "2018定额详细解读"}, {"id": "ch09-013", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "根据2024年广东二级造价师（安装）考试真题，安装工程预算编制依据包括（ ）。", "options": {"A": "施工图纸", "B": "施工组织设计", "C": "预算定额", "D": "市场价格信息", "E": "工程承包合同"}, "answer": ["A", "B", "C", "D"], "analysis": "2024真题明确安装工程预算编制依据包括：施工图纸、施工组织设计、预算定额、市场价格信息（全选ABCD）。工程承包合同虽与造价有关，但在该题标准答案中未列入核心编制依据五项。", "tags": ["编制依据", "历年真题"], "source": "历年真题精华版"}, {"id": "ch09-014", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "教材所列施工图预算编制的依据包括（ ）。", "options": {"A": "施工图纸", "B": "预算定额", "C": "费用定额", "D": "市场价格信息", "E": "工程承包合同"}, "answer": ["A", "B", "C", "D"], "analysis": "教材9.1明确编制依据含施工图纸、预算定额（2018版广东定额）、费用定额、市场价格信息、施工组织设计，共五项；工程承包合同不属于核心编制依据。本题前四项均为依据。", "tags": ["编制依据"], "source": "安装教材精读笔记"}, {"id": "ch09-015", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "下列属于施工图预算编制依据中'施工图纸'所应包含内容的是（ ）。", "options": {"A": "平面图", "B": "系统图", "C": "设计说明", "D": "设备材料表", "E": "竣工结算书"}, "answer": ["A", "B", "C", "D"], "analysis": "施工图纸包括平面图、系统图、设计说明、设备材料表等设计文件，是计算工程量的基础。竣工结算书是施工完成后的文件，非预算编制依据。", "tags": ["编制依据", "施工图纸"], "source": "安装教材精读笔记"}, {"id": "ch09-016", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "施工组织设计作为预算编制依据，能为以下哪些费用的确定提供依据？（ ）", "options": {"A": "措施项目费", "B": "施工方法的选择", "C": "某些材料消耗量", "D": "分部分项工程的项目划分", "E": "税金税率"}, "answer": ["A", "B", "C", "D"], "analysis": "施工组织设计明确施工部署、方案、方法、平面布置、资源计划等，是措施项目费计取、施工方法选择、材料消耗及分部分项项目划分的依据；税金税率由费用定额规定。", "tags": ["编制依据", "施工组织设计", "措施项目费"], "source": "安装教材精读笔记"}, {"id": "ch09-017", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "市场价格信息在施工图预算编制中的作用包括（ ）。", "options": {"A": "确定人工单价", "B": "确定材料单价", "C": "确定施工机具台班单价", "D": "计算规费", "E": "确定工程量"}, "answer": ["A", "B", "C"], "analysis": "市场价格信息用于确定人工、材料、施工机具使用费的实际单价；规费按费用定额计取，工程量按设计图示尺寸计算，与市场价格信息无关。", "tags": ["编制依据", "市场价格信息"], "source": "安装教材精读笔记"}, {"id": "ch09-018", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "关于预算定额与费用定额的关系，下列说法正确的有（ ）。", "options": {"A": "预算定额规定人材机消耗量", "B": "费用定额规定各项取费标准", "C": "两者都是预算编制依据", "D": "预算定额规定税金税率", "E": "费用定额规定计量规则"}, "answer": ["A", "B", "C"], "analysis": "预算定额（2018广东定额）规定人工、材料、机具消耗量；费用定额规定企业管理费、利润、规费、税金等取费标准；二者均为编制依据。计量规则由清单规定，税金由费用定额规定而非预算定额。", "tags": ["编制依据", "预算定额", "费用定额"], "source": "安装教材精读笔记"}, {"id": "ch09-019", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "下列文件中，属于广东省安装工程施工图预算编制应当依据的有（ ）。", "options": {"A": "2018版广东省通用安装工程综合定额", "B": "GB/T 50856-2024", "C": "广东省建设工程计价依据（费用定额）", "D": "施工图纸及施工组织设计", "E": "施工单位内部成本管理制度"}, "answer": ["A", "B", "C", "D"], "analysis": "预算编制应依据2018广东定额、2024清单（计量规则）、费用定额、施工图纸及施工组织设计。施工单位内部成本管理制度属企业管理范畴，非法定编制依据。", "tags": ["编制依据"], "source": "安装教材精读笔记"}, {"id": "ch09-020", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "施工图预算编制中，需要用到'费用定额'来计算的费用包括（ ）。", "options": {"A": "企业管理费", "B": "利润", "C": "规费", "D": "税金", "E": "人工费消耗量"}, "answer": ["A", "B", "C", "D"], "analysis": "费用定额规定企业管理费、利润、规费、税金等取费标准。人工费消耗量由预算定额规定，非费用定额。", "tags": ["编制依据", "费用定额"], "source": "安装教材精读笔记"}, {"id": "ch09-021", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "根据教材，安装工程施工图预算编制的第一步是（ ）。", "options": {"A": "计算工程量", "B": "套用定额", "C": "收集资料", "D": "汇总总造价"}, "answer": ["C"], "analysis": "教材9.2编制步骤：第1步收集资料，之后依次计算工程量、套用定额、计算直接费、计算间接费利润税金、汇总总造价。", "tags": ["编制步骤"], "source": "安装教材精读笔记"}, {"id": "ch09-022", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "施工图预算编制中，计算工程量应依据（ ）。", "options": {"A": "2018版广东定额", "B": "GB/T 50856-2024清单计量规则", "C": "施工企业定额", "D": "监理签证"}, "answer": ["B"], "analysis": "教材9.2明确'计算工程量（依据GB/T 50856-2024）'，即按2024版清单的计量规则计算设计图示尺寸工程量。", "tags": ["编制步骤", "工程量计算"], "source": "安装教材精读笔记"}, {"id": "ch09-023", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "施工图预算编制中，套用定额（确定人材机消耗量）应依据（ ）。", "options": {"A": "GB/T 50856-2024清单", "B": "2018版广东省通用安装工程综合定额", "C": "建设单位预算", "D": "设计概算指标"}, "answer": ["B"], "analysis": "教材9.2明确'套用定额（依据2018版广东定额）'，即按2018广东定额确定完成单位工程所需人工、材料、机具消耗量。", "tags": ["编制步骤", "套定额"], "source": "安装教材精读笔记"}, {"id": "ch09-024", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "施工图预算编制步骤中，'计算直接费'是在（ ）之后进行的。", "options": {"A": "编制施工组织设计", "B": "计算工程量并套用定额", "C": "汇总总造价", "D": "计算税金"}, "answer": ["B"], "analysis": "步骤顺序：收集资料→计算工程量→套用定额→计算直接费→计算间接费、利润、税金→汇总总造价。计算直接费在套定额之后。", "tags": ["编制步骤"], "source": "安装教材精读笔记"}, {"id": "ch09-025", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "下列施工图预算编制步骤中，排在最后一步的是（ ）。", "options": {"A": "计算间接费、利润、税金", "B": "汇总总造价", "C": "套用定额", "D": "计算工程量"}, "answer": ["B"], "analysis": "教材9.2第六步为'汇总总造价'，是最后一步，即将分部分项、措施、其他、规费、税金汇总形成工程总造价。", "tags": ["编制步骤"], "source": "安装教材精读笔记"}, {"id": "ch09-026", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "在施工图预算编制六步骤中，'计算间接费、利润、税金'应在（ ）之后。", "options": {"A": "收集资料", "B": "计算直接费", "C": "计算工程量", "D": "套用定额"}, "answer": ["B"], "analysis": "步骤：收集资料→计算工程量→套用定额→计算直接费→计算间接费、利润、税金→汇总总造价。间接费等费用计算在直接费之后。", "tags": ["编制步骤"], "source": "安装教材精读笔记"}, {"id": "ch09-027", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "清单与定额在预算编制中的衔接关系是（ ）。", "options": {"A": "清单规定消耗量，定额规定计量规则", "B": "清单规定计量规则，定额规定消耗量", "C": "两者都规定计量规则", "D": "两者都规定消耗量"}, "answer": ["B"], "analysis": "教材7.3及9.2说明：2024清单规定'怎么算量'（计量规则），2018定额规定'消耗多少'（人材机消耗量），两者结合用于计价。", "tags": ["编制步骤", "清单与定额衔接"], "source": "安装教材精读笔记"}, {"id": "ch09-028", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "施工图预算编制中，'计算直接费'是指计算（ ）之和。", "options": {"A": "人工费+材料费+施工机具费", "B": "分部分项+措施+其他", "C": "规费+税金", "D": "管理费+利润"}, "answer": ["A"], "analysis": "直接费由人工费、材料费、施工机具使用费（人材机）组成，是套用定额并乘以单价后求得的分部分项直接工程费用。", "tags": ["编制步骤", "直接费"], "source": "安装教材精读笔记"}, {"id": "ch09-029", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "下列关于施工图预算编制步骤的说法，正确的是（ ）。", "options": {"A": "先套定额再算工程量", "B": "先汇总造价再算费用", "C": "按'收集资料→算量→套定额→直接费→间接费利润税金→汇总'顺序进行", "D": "计算税金在计算直接费之前"}, "answer": ["C"], "analysis": "教材9.2给出的六步标准顺序为：收集资料、计算工程量、套用定额、计算直接费、计算间接费利润税金、汇总总造价。", "tags": ["编制步骤"], "source": "安装教材精读笔记"}, {"id": "ch09-030", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "施工图预算编制中，将分部分项工程费、措施项目费、其他项目费、规费、税金汇总形成总造价的步骤称为（ ）。", "options": {"A": "计算直接费", "B": "套用定额", "C": "汇总总造价", "D": "计算工程量"}, "answer": ["C"], "analysis": "第六步'汇总总造价'即将上述各项费用汇总得到建筑安装工程总造价。", "tags": ["编制步骤", "汇总总造价"], "source": "安装教材精读笔记"}, {"id": "ch09-031", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "教材所列施工图预算编制的步骤包括（ ）。", "options": {"A": "收集资料", "B": "计算工程量", "C": "套用定额", "D": "计算直接费", "E": "编制竣工决算"}, "answer": ["A", "B", "C", "D"], "analysis": "教材9.2列出六步：收集资料、计算工程量、套用定额、计算直接费、计算间接费利润税金、汇总总造价；编制竣工决算是项目竣工后的工作，不属施工图预算编制步骤。", "tags": ["编制步骤"], "source": "安装教材精读笔记"}, {"id": "ch09-032", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "关于施工图预算编制步骤，下列说法正确的有（ ）。", "options": {"A": "计算工程量依据GB/T 50856-2024", "B": "套用定额依据2018版广东定额", "C": "先算直接费再算工程量", "D": "最后一步是汇总总造价", "E": "收集资料是第一步"}, "answer": ["A", "B", "D", "E"], "analysis": "教材9.2：算量依据2024清单，套定额依据2018广东定额，第一步收集资料，最后一步汇总总造价。计算直接费在算量、套定额之后，故C错误。", "tags": ["编制步骤"], "source": "安装教材精读笔记"}, {"id": "ch09-033", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "在施工图预算编制中，下列先后顺序正确的有（ ）。", "options": {"A": "先收集资料，后计算工程量", "B": "先计算工程量，后套用定额", "C": "先套用定额，后计算直接费", "D": "先计算直接费，后计算间接费利润税金", "E": "先汇总总造价，后计算税金"}, "answer": ["A", "B", "C", "D"], "analysis": "标准顺序：收集资料→算量→套定额→直接费→间接费利润税金→汇总总造价。税金在汇总前已计算，故E错误。", "tags": ["编制步骤"], "source": "安装教材精读笔记"}, {"id": "ch09-034", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "施工图预算编制时，'套用定额'环节需要完成的工作包括（ ）。", "options": {"A": "根据项目特征选择定额子目", "B": "确定人材机消耗量", "C": "计算清单工程量", "D": "进行必要的定额换算", "E": "确定材料市场单价"}, "answer": ["A", "B", "D"], "analysis": "套定额是根据项目特征选择2018广东定额子目、确定消耗量，必要时进行材料/人工/机具换算。清单工程量计算是上一步工作，材料市场单价属价格信息并非套定额本身工作。", "tags": ["编制步骤", "套定额"], "source": "安装教材精读笔记"}, {"id": "ch09-035", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "下列关于清单与定额在预算编制中衔接的说法，正确的有（ ）。", "options": {"A": "2024清单规定计量规则", "B": "2018定额规定消耗量", "C": "两者配套使用", "D": "清单规定材料单价", "E": "定额规定税金税率"}, "answer": ["A", "B", "C"], "analysis": "教材明确清单规定'怎么算量'（计量规则）、定额规定'消耗多少'（人材机消耗量），二者配套使用。材料单价由市场价格信息确定，税金由费用定额规定。", "tags": ["编制步骤", "清单与定额衔接"], "source": "安装教材精读笔记"}, {"id": "ch09-036", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "按造价形成划分，建筑安装工程费由（ ）组成。", "options": {"A": "人工费、材料费、施工机具费、企业管理费、利润", "B": "分部分项工程费、措施项目费、其他项目费、规费、税金", "C": "直接费、间接费、利润、税金", "D": "设备费、安装费、其他费"}, "answer": ["B"], "analysis": "教材9.3费用构成树：建筑安装工程费=分部分项工程费+措施项目费+其他项目费+规费+税金（按造价形成划分）。", "tags": ["费用构成"], "source": "安装教材精读笔记"}, {"id": "ch09-037", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "建筑安装工程费按造价形成划分时，下列（ ）不属于其组成部分。", "options": {"A": "分部分项工程费", "B": "措施项目费", "C": "设备购置费", "D": "税金"}, "answer": ["C"], "analysis": "按造价形成划分，建筑安装工程费由分部分项、措施、其他、规费、税金组成；设备购置费属于工程造价的其他构成（设备及工器具购置费），不属建筑安装工程费。", "tags": ["费用构成"], "source": "安装教材精读笔记"}, {"id": "ch09-038", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "建筑安装工程费按费用构成要素划分，不包括下列（ ）。", "options": {"A": "人工费", "B": "材料费", "C": "施工机具使用费", "D": "措施项目费"}, "answer": ["D"], "analysis": "按费用构成要素划分：人工费、材料费、施工机具使用费、企业管理费、利润、规费、税金。措施项目费是按造价形成划分的项目，不属于要素划分项。", "tags": ["费用构成", "费用要素"], "source": "安装教材精读笔记"}, {"id": "ch09-039", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "建筑安装工程费按费用构成要素划分，其组成不包括（ ）。", "options": {"A": "企业管理费", "B": "利润", "C": "规费", "D": "其他项目费"}, "answer": ["D"], "analysis": "要素划分为人、材、机、企业管理费、利润、规费、税金七项；其他项目费是按造价形成划分的内容。", "tags": ["费用构成", "费用要素"], "source": "安装教材精读笔记"}, {"id": "ch09-040", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "下列关于建筑安装工程费两种划分方式关系的说法，正确的是（ ）。", "options": {"A": "两种划分完全相同", "B": "按造价形成划分含分部分项等五项，按要素划分含人材机等七项，两者是从不同角度的分类", "C": "措施项目费只出现在要素划分中", "D": "规费只出现在造价形成划分中"}, "answer": ["B"], "analysis": "建筑安装工程费可按两种角度划分：造价形成（分部分项、措施、其他、规费、税金）与费用要素（人、材、机、企管费、利润、规费、税金），是同一费用的不同归类。", "tags": ["费用构成"], "source": "安装教材精读笔记"}, {"id": "ch09-041", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "按造价形成划分，建筑安装工程费的组成部分包括（ ）。", "options": {"A": "分部分项工程费", "B": "措施项目费", "C": "其他项目费", "D": "规费", "E": "设备购置费"}, "answer": ["A", "B", "C", "D"], "analysis": "教材9.3费用构成树明确：建筑安装工程费=分部分项工程费+措施项目费+其他项目费+规费+税金。设备购置费属于工程造价中设备工器具购置费，不属建筑安装工程费。", "tags": ["费用构成"], "source": "安装教材精读笔记"}, {"id": "ch09-042", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "按费用构成要素划分，建筑安装工程费包括（ ）。", "options": {"A": "人工费、材料费", "B": "施工机具使用费", "C": "企业管理费、利润", "D": "规费", "E": "措施项目费"}, "answer": ["A", "B", "C", "D"], "analysis": "按费用构成要素划分，建筑安装工程费由人工费、材料费、施工机具使用费、企业管理费、利润、规费、税金七项组成；措施项目费是按造价形成划分的内容，不属要素划分项。", "tags": ["费用构成", "费用要素"], "source": "安装教材精读笔记"}, {"id": "ch09-043", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "下列费用项目中，既属于建筑安装工程费按造价形成划分、也属于按费用要素划分组成部分的有（ ）。", "options": {"A": "规费", "B": "税金", "C": "分部分项工程费", "D": "措施项目费", "E": "利润"}, "answer": ["A", "B"], "analysis": "规费和税金在两种划分中均单列存在；分部分项、措施项目是按造价形成划分的，利润是按要素划分的，二者不重合为同一表述。", "tags": ["费用构成"], "source": "安装教材精读笔记"}, {"id": "ch09-044", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "关于建筑安装工程费用构成，下列说法正确的有（ ）。", "options": {"A": "分部分项工程费是主体费用", "B": "措施项目费为完成工程施工发生的非工程实体费用", "C": "其他项目费包括暂列金额等", "D": "规费由企业自主决定", "E": "税金为增值税"}, "answer": ["A", "B", "C", "E"], "analysis": "分部分项工程费为主体；措施项目费为非工程实体项目费用；其他项目费含暂列金额、暂估价、计日工、总承包服务费；规费属规费（法定，非企业自主）；税金为增值税。故D错误。", "tags": ["费用构成"], "source": "安装教材精读笔记"}, {"id": "ch09-045", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "分部分项工程费的组成不包括（ ）。", "options": {"A": "人工费", "B": "材料费", "C": "规费", "D": "利润"}, "answer": ["C"], "analysis": "教材9.3：分部分项工程费=人工费+材料费+施工机具使用费+企业管理费（管理费）+利润。规费单独列项，不计入分部分项工程费。", "tags": ["分部分项工程费"], "source": "安装教材精读笔记"}, {"id": "ch09-046", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "分部分项工程费的组成中，'管理费'对应的是费用要素划分中的（ ）。", "options": {"A": "规费", "B": "企业管理费", "C": "利润", "D": "税金"}, "answer": ["B"], "analysis": "教材9.3费用树将分部分项工程费中的'管理费'即企业管理费，与人工、材料、机械、利润共同构成分部分项工程费。", "tags": ["分部分项工程费", "管理费"], "source": "安装教材精读笔记"}, {"id": "ch09-047", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "根据2018广东定额，人工费是指（ ）的薪酬。", "options": {"A": "工程项目管理人员", "B": "直接从事施工作业的生产工人", "C": "企业行政人员", "D": "设计单位人员"}, "answer": ["B"], "analysis": "2018定额详细解读：人工费是直接从事施工作业的生产工人的薪酬，包括基本用工、辅助用工、人工幅度差、现场运输及清理现场等用工费用。", "tags": ["分部分项工程费", "人工费"], "source": "2018定额详细解读"}, {"id": "ch09-048", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "下列费用中属于材料费的是（ ）。", "options": {"A": "管理人员工资", "B": "材料原价", "C": "施工机械折旧费", "D": "工程排污费"}, "answer": ["B"], "analysis": "材料费包括材料原价、运杂费、运输损耗费、采购及保管费。管理人员工资属企业管理费，机械折旧属施工机具费，排污属规费。", "tags": ["分部分项工程费", "材料费"], "source": "2018定额详细解读"}, {"id": "ch09-049", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "施工机具使用费不包括（ ）。", "options": {"A": "施工机械使用费", "B": "施工仪器仪表使用费", "C": "机上人工费", "D": "生产工人基本工资"}, "answer": ["D"], "analysis": "施工机具费含施工机械使用费（折旧、检修、维护、安拆、机上人工、燃料动力等）和施工仪器仪表使用费（折旧、维护、校验、动力）。生产工人基本工资属人工费。", "tags": ["分部分项工程费", "施工机具费"], "source": "2018定额详细解读"}, {"id": "ch09-050", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "企业管理费（管理费）是指施工企业为（ ）而发生的费用。", "options": {"A": "直接从事施工作业", "B": "完成承包工程而组织施工生产和经营管理", "C": "购买施工机械", "D": "缴纳社会保险费"}, "answer": ["B"], "analysis": "2018定额：管理费是施工企业为完成承包工程而组织施工生产和经营管理所发生的费用，含管理人员薪酬、办公费、差旅交通费、工具用具使用费等。", "tags": ["分部分项工程费", "管理费"], "source": "2018定额详细解读"}, {"id": "ch09-051", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "下列内容中属于企业管理费（管理费）的是（ ）。", "options": {"A": "生产工人工资", "B": "材料原价", "C": "管理人员薪酬", "D": "施工机械燃料动力费"}, "answer": ["C"], "analysis": "企业管理费含管理人员薪酬、办公费、差旅交通费、工具用具使用费等。生产工人工资属人工费，材料原价属材料费，机械燃料动力属施工机具费。", "tags": ["分部分项工程费", "管理费"], "source": "2018定额详细解读"}, {"id": "ch09-052", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "2018定额中，材料消耗量已综合考虑了（ ）。", "options": {"A": "仅材料净用量", "B": "净用量加合理的施工及场内运输损耗", "C": "材料市场涨价", "D": "材料采购回扣"}, "answer": ["B"], "analysis": "2018定额解读：材料消耗量已含成品、半成品、材料配料等施工及场内运输过程中合理的损耗消耗量。", "tags": ["分部分项工程费", "材料费"], "source": "2018定额详细解读"}, {"id": "ch09-053", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "2018定额中带'[ ]'符号的材料表示（ ）。", "options": {"A": "已计价材料", "B": "未计价材料（基价不含其价格）", "C": "损耗材料", "D": "周转材料"}, "answer": ["B"], "analysis": "2018定额规定：带'[ ]'符号者为未计价材料，其基价中不包括价格，应根据'[]'内所列用量另行计算材料费。", "tags": ["分部分项工程费", "材料费", "未计价材料"], "source": "2018定额详细解读"}, {"id": "ch09-054", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "单位价值在2000元以内、使用年限在一年以内的工具用具（ ）施工机具费内。", "options": {"A": "计入", "B": "不计入", "C": "部分计入", "D": "由企业自定"}, "answer": ["B"], "analysis": "2018定额：单位价值在2000元以内、使用年限在一年以内的工具用具未计入施工机具费内（属企业管理费中的工具用具使用费）。", "tags": ["分部分项工程费", "施工机具费"], "source": "2018定额详细解读"}, {"id": "ch09-055", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "施工仪器仪表使用费不包括（ ）。", "options": {"A": "折旧费", "B": "维护费", "C": "校验费", "D": "机上人工费"}, "answer": ["D"], "analysis": "施工仪器仪表使用费含折旧费、维护费、校验费、动力费；机上人工费属施工机械使用费的内容。", "tags": ["分部分项工程费", "施工机具费"], "source": "2018定额详细解读"}, {"id": "ch09-056", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "分部分项工程费中，利润是施工企业（ ）的组成部分。", "options": {"A": "按国家统一规定强制收取", "B": "完成承包工程后形成的盈利", "C": "计入规费", "D": "计入税金"}, "answer": ["B"], "analysis": "利润是施工企业完成所承包工程获得的盈利，是分部分项工程费的组成之一（与人工、材料、机械、管理费并列）。", "tags": ["分部分项工程费", "利润"], "source": "安装教材精读笔记"}, {"id": "ch09-058", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "下列费用中，应计入分部分项工程费的有（ ）。", "options": {"A": "人工费", "B": "材料费", "C": "施工机具使用费", "D": "企业管理费", "E": "税金"}, "answer": ["A", "B", "C", "D"], "analysis": "分部分项工程费由人工费、材料费、施工机具使用费、企业管理费（管理费）、利润组成；税金单独列项，不计入分部分项工程费。", "tags": ["分部分项工程费"], "source": "安装教材精读笔记"}, {"id": "ch09-059", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "下列属于人工费组成内容的有（ ）。", "options": {"A": "工资性收入", "B": "社会保险费", "C": "住房公积金", "D": "职工福利费", "E": "材料运杂费"}, "answer": ["A", "B", "C", "D"], "analysis": "2018定额：人工费含工资性收入、社会保险费（养老医疗工伤失业生育）、住房公积金、工会经费、职工教育经费、职工福利费、特殊情况下支付的工资。材料运杂费属材料费。", "tags": ["分部分项工程费", "人工费"], "source": "2018定额详细解读"}, {"id": "ch09-060", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "材料费的组成包括（ ）。", "options": {"A": "材料原价", "B": "运杂费", "C": "运输损耗费", "D": "采购及保管费", "E": "施工机械折旧费"}, "answer": ["A", "B", "C", "D"], "analysis": "材料费含材料原价、运杂费、运输损耗费、采购及保管费。施工机械折旧费属施工机具使用费。", "tags": ["分部分项工程费", "材料费"], "source": "2018定额详细解读"}, {"id": "ch09-061", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "施工机械使用费包括（ ）。", "options": {"A": "折旧费", "B": "检修费", "C": "维护费", "D": "燃料动力费", "E": "材料运杂费"}, "answer": ["A", "B", "C", "D"], "analysis": "施工机械使用费含折旧费、检修费、维护费、安拆费、机上人工费、燃料动力费、其他费用；材料运杂费属材料费，不属施工机械使用费。", "tags": ["分部分项工程费", "施工机具费"], "source": "2018定额详细解读"}, {"id": "ch09-062", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "施工仪器仪表使用费包括（ ）。", "options": {"A": "折旧费", "B": "维护费", "C": "校验费", "D": "动力费", "E": "机上人工费"}, "answer": ["A", "B", "C", "D"], "analysis": "施工仪器仪表使用费含折旧费、维护费、校验费、动力费。机上人工费属施工机械使用费，不在此列。", "tags": ["分部分项工程费", "施工机具费"], "source": "2018定额详细解读"}, {"id": "ch09-063", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "企业管理费（管理费）包括（ ）。", "options": {"A": "管理人员薪酬", "B": "办公费", "C": "差旅交通费", "D": "检验试验费", "E": "生产工人工资"}, "answer": ["A", "B", "C", "D"], "analysis": "企业管理费含管理人员薪酬、办公费、差旅交通费、施工单位进退场费、工具用具使用费、检验试验费等。生产工人工资属人工费。", "tags": ["分部分项工程费", "管理费"], "source": "2018定额详细解读"}, {"id": "ch09-064", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "关于分部分项工程费，下列说法正确的有（ ）。", "options": {"A": "由人材机管利五部分构成", "B": "是工程造价的主体部分", "C": "规费包含在其中", "D": "利润为施工企业盈利", "E": "管理费即企业管理费"}, "answer": ["A", "B", "D", "E"], "analysis": "分部分项工程费=人工+材料+施工机具+企业管理费（管理费）+利润，为主体费用；规费单列，不计入分部分项工程费，故C错误。", "tags": ["分部分项工程费"], "source": "安装教材精读笔记"}, {"id": "ch09-065", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "下列费用中，属于措施项目费的是（ ）。", "options": {"A": "人工费", "B": "安全文明施工费", "C": "工程排污费", "D": "增值税"}, "answer": ["B"], "analysis": "措施项目费包括专业措施项目、安全文明施工费、临时设施、夜间施工增加费、二次搬运费、已完工程及设备保护费等。工程排污费属规费，增值税属税金。", "tags": ["措施项目费"], "source": "2024清单详细解读"}, {"id": "ch09-066", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "根据GB/T 50856-2024附录P措施项目，下列（ ）属于措施项目。", "options": {"A": "分部分项中的电缆敷设", "B": "夜间施工增加费", "C": "设备购置费", "D": "企业管理费"}, "answer": ["B"], "analysis": "2024清单附录P措施项目含专业措施项目、安全文明施工、临时设施、夜间施工增加费、二次搬运费、已完工程及设备保护费等。", "tags": ["措施项目费"], "source": "2024清单详细解读"}, {"id": "ch09-067", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "下列措施项目中，属于为完成工程施工而发生、但一般不形成工程实体的费用是（ ）。", "options": {"A": "分部分项工程费", "B": "措施项目费", "C": "其他项目费", "D": "规费"}, "answer": ["B"], "analysis": "措施项目费是指为完成建设工程施工，发生于施工准备和施工过程中的技术、生活、安全、环境保护等方面的非工程实体费用。", "tags": ["措施项目费"], "source": "2024清单详细解读"}, {"id": "ch09-068", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "下列费用中不属于措施项目费的是（ ）。", "options": {"A": "临时设施费", "B": "二次搬运费", "C": "已完工程及设备保护费", "D": "利润"}, "answer": ["D"], "analysis": "临时设施、二次搬运、已完工程及设备保护均属措施项目费；利润是分部分项工程费及企业盈利的组成，非措施项目。", "tags": ["措施项目费"], "source": "2024清单详细解读"}, {"id": "ch09-069", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "安全文明施工费在措施项目中属于（ ）。", "options": {"A": "可竞争费用，可自主下调", "B": "不可竞争费用，应按规定计取", "C": "列入规费", "D": "列入税金"}, "answer": ["B"], "analysis": "安全文明施工费属措施项目中的不可竞争费用，应按规定标准计取，不得作为竞争性费用下调。", "tags": ["措施项目费", "安全文明施工费"], "source": "2024清单详细解读"}, {"id": "ch09-070", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "根据2024清单附录P，下列（ ）不属于措施项目。", "options": {"A": "临时设施", "B": "夜间施工增加费", "C": "二次搬运费", "D": "分部分项工程费"}, "answer": ["D"], "analysis": "措施项目含临时设施、夜间施工增加费、二次搬运费等；分部分项工程费是与措施项目并列的工程造价款项，本身不是措施项目。", "tags": ["措施项目费"], "source": "2024清单详细解读"}, {"id": "ch09-071", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "已完工程及设备保护费属于（ ）。", "options": {"A": "分部分项工程费", "B": "措施项目费", "C": "其他项目费", "D": "规费"}, "answer": ["B"], "analysis": "已完工程及设备保护费是措施项目费的内容之一（为保护已完工程及设备所发生的费用）。", "tags": ["措施项目费"], "source": "2024清单详细解读"}, {"id": "ch09-072", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "下列费用中，属于措施项目费的有（ ）。", "options": {"A": "安全文明施工费", "B": "临时设施费", "C": "夜间施工增加费", "D": "二次搬运费", "E": "企业管理费"}, "answer": ["A", "B", "C", "D"], "analysis": "依据2024清单附录P及费用构成，安全文明施工、临时设施、夜间施工增加、二次搬运等均属措施项目费；企业管理费属分部分项工程费组成，非措施项目费。", "tags": ["措施项目费"], "source": "2024清单详细解读"}, {"id": "ch09-073", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "关于措施项目费，下列说法正确的有（ ）。", "options": {"A": "发生于施工准备和施工过程中", "B": "一般为非工程实体费用", "C": "含安全文明施工费", "D": "含临时设施费", "E": "均属可竞争费用"}, "answer": ["A", "B", "C", "D"], "analysis": "措施项目费为完成施工发生的非工程实体费用，含安全文明施工、临时设施等；其中安全文明施工费属不可竞争费用，故E错误。", "tags": ["措施项目费"], "source": "2024清单详细解读"}, {"id": "ch09-074", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "下列属于专业措施项目相关范畴的有（ ）。", "options": {"A": "脚手架搭拆", "B": "垂直运输", "C": "超高施工增加", "D": "安全文明施工", "E": "已完工程保护"}, "answer": ["A", "B", "C"], "analysis": "脚手架、垂直运输、超高施工增加等属于与专业施工相关的专业措施项目；安全文明施工、已完工程保护为通用措施项目。", "tags": ["措施项目费", "专业措施"], "source": "2024清单详细解读"}, {"id": "ch09-075", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "其他项目费的内容包括（ ）。", "options": {"A": "人工费、材料费", "B": "暂列金额、暂估价、计日工、总承包服务费", "C": "规费、税金", "D": "企业管理费、利润"}, "answer": ["B"], "analysis": "教材及清单规定，其他项目费包括暂列金额、暂估价、计日工、总承包服务费。", "tags": ["其他项目费"], "source": "安装教材精读笔记"}, {"id": "ch09-077", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "暂列金额属于（ ）。", "options": {"A": "分部分项工程费", "B": "措施项目费", "C": "其他项目费", "D": "规费"}, "answer": ["C"], "analysis": "暂列金额是招标人暂定并列入其他项目费的款项，用于施工合同签订时尚未确定或不可预见的所需费用。", "tags": ["其他项目费", "暂列金额"], "source": "安装教材精读笔记"}, {"id": "ch09-078", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "计日工属于（ ）。", "options": {"A": "措施项目费", "B": "其他项目费", "C": "规费", "D": "税金"}, "answer": ["B"], "analysis": "计日工是其他项目费的组成部分，用于完成发包人提出的工程合同范围以外的零星项目或工作。", "tags": ["其他项目费", "计日工"], "source": "安装教材精读笔记"}, {"id": "ch09-079", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "其他项目费通常包括（ ）。", "options": {"A": "暂列金额", "B": "暂估价", "C": "计日工", "D": "总承包服务费", "E": "安全文明施工费"}, "answer": ["A", "B", "C", "D"], "analysis": "其他项目费包括暂列金额、暂估价、计日工、总承包服务费；安全文明施工费属措施项目费。", "tags": ["其他项目费"], "source": "安装教材精读笔记"}, {"id": "ch09-080", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "关于其他项目费，下列说法正确的有（ ）。", "options": {"A": "暂列金额由招标人暂定", "B": "暂估价包括材料和设备暂估价", "C": "计日工用于零星工作", "D": "总承包服务费由总承包人计取", "E": "其他项目费计入规费"}, "answer": ["A", "B", "C", "D"], "analysis": "其他项目费含暂列金额（招标人暂定）、暂估价（材料/设备/专业工程）、计日工（零星工作）、总承包服务费（总承包人计取）。其他项目费与规费并列，不计入规费。", "tags": ["其他项目费"], "source": "安装教材精读笔记"}, {"id": "ch09-081", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "下列费用项目中，属于建筑安装工程费按造价形成划分的'其他项目费'的有（ ）。", "options": {"A": "暂列金额", "B": "暂估价", "C": "计日工", "D": "总承包服务费", "E": "二次搬运费"}, "answer": ["A", "B", "C", "D"], "analysis": "其他项目费由暂列金额、暂估价、计日工、总承包服务费组成；二次搬运费属措施项目费。", "tags": ["其他项目费"], "source": "安装教材精读笔记"}, {"id": "ch09-082", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "规费是指按国家法律、法规规定，由（ ）缴纳并计入建筑安装工程造价的费用。", "options": {"A": "企业自愿", "B": "省级政府规定必须", "C": "定额站建议", "D": "施工单位协商"}, "answer": ["B"], "analysis": "规费是按国家法律、法规规定，由省级政府和有关权力部门规定必须缴纳或计取的费用，计入建筑安装工程费。", "tags": ["规费"], "source": "安装教材精读笔记"}, {"id": "ch09-083", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "下列费用中属于规费的是（ ）。", "options": {"A": "企业管理费", "B": "社会保险费", "C": "利润", "D": "材料费"}, "answer": ["B"], "analysis": "规费包括社会保险费（养老、医疗、工伤、失业、生育）和住房公积金等，由政府部门规定计取。", "tags": ["规费"], "source": "安装教材精读笔记"}, {"id": "ch09-084", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "住房公积金属于（ ）。", "options": {"A": "分部分项工程费", "B": "措施项目费", "C": "规费", "D": "企业管理费"}, "answer": ["C"], "analysis": "住房公积金与社会保险费同属规费，按规费规定计取，不属分部分项、措施或企业管理费。", "tags": ["规费", "住房公积金"], "source": "安装教材精读笔记"}, {"id": "ch09-085", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "规费的组成包括（ ）。", "options": {"A": "社会保险费", "B": "住房公积金", "C": "工程排污费", "D": "环境保护税", "E": "企业管理费"}, "answer": ["A", "B", "C", "D"], "analysis": "规费包括社会保险费、住房公积金，以及工程排污费、环境保护税等由政府规定计取的费用；企业管理费属分部分项工程费组成，非规费。", "tags": ["规费"], "source": "安装教材精读笔记"}, {"id": "ch09-086", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "社会保险费包括（ ）。", "options": {"A": "基本养老保险费", "B": "基本医疗保险费", "C": "工伤保险费", "D": "失业保险费", "E": "商业保险费"}, "answer": ["A", "B", "C", "D"], "analysis": "社会保险费含养老、医疗、工伤、失业、生育五项保险费用，属规费组成部分；商业保险费由企业自愿投保，不属法定社会保险费。", "tags": ["规费", "社会保险费"], "source": "安装教材精读笔记"}, {"id": "ch09-087", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "建筑安装工程费中的税金是指（ ）。", "options": {"A": "营业税", "B": "增值税", "C": "企业所得税", "D": "印花税"}, "answer": ["B"], "analysis": "按现行规定，建筑安装工程费的税金为增值税（一般计税或简易计税），不再为营业税。", "tags": ["税金"], "source": "安装教材精读笔记"}, {"id": "ch09-088", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "建筑安装工程费按造价形成划分时，税金位于费用构成的（ ）。", "options": {"A": "第一项", "B": "与分部分项并列的末项", "C": "措施项目内", "D": "规费内"}, "answer": ["B"], "analysis": "造价形成划分：分部分项+措施+其他+规费+税金，税金为单独列项的最后一项费用。", "tags": ["税金"], "source": "安装教材精读笔记"}, {"id": "ch09-089", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "下列费用中，属于建筑安装工程费按造价形成划分单独列项的是（ ）。", "options": {"A": "企业管理费", "B": "利润", "C": "税金", "D": "人工费"}, "answer": ["C"], "analysis": "按造价形成划分，税金与分部分项、措施、其他、规费并列单独列项；企业管理费、利润、人工费属要素划分/分部分项内部组成。", "tags": ["税金"], "source": "安装教材精读笔记"}, {"id": "ch09-090", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "关于建筑安装工程费中的税金，下列说法正确的有（ ）。", "options": {"A": "指增值税", "B": "按造价形成单独列项", "C": "属于规费", "D": "计税基数含人材机等", "E": "为不可竞争费用"}, "answer": ["A", "B", "D", "E"], "analysis": "税金为增值税，按造价形成与分部分项等并列单独列项，计税基数包含税前造价（人材机管利规费等），属不可竞争费用；税金不属规费，故C错误。", "tags": ["税金"], "source": "安装教材精读笔记"}, {"id": "ch09-091", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "建筑安装工程费中，分部分项工程费、措施项目费、其他项目费、规费、税金五者之间的关系是（ ）。", "options": {"A": "相互包含", "B": "并列汇总构成建筑安装工程费", "C": "税金包含规费", "D": "措施费包含分部分项"}, "answer": ["B"], "analysis": "五者为并列关系，汇总相加得到建筑安装工程费总造价。", "tags": ["费用构成"], "source": "安装教材精读笔记"}, {"id": "ch09-092", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "在建筑安装工程费用构成中，'企业管理费'一词与分部分项工程费中的'管理费'的关系是（ ）。", "options": {"A": "两者无关", "B": "管理费即企业管理费", "C": "管理费大于企业管理费", "D": "管理费包含税金"}, "answer": ["B"], "analysis": "分部分项工程费中的'管理费'即企业管理费，是同一概念在两种表述中的对应。", "tags": ["分部分项工程费", "管理费"], "source": "安装教材精读笔记"}, {"id": "ch09-093", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "施工机具使用费在费用构成中属于（ ）。", "options": {"A": "只属措施项目费", "B": "分部分项工程费中的施工机具使用费（要素）", "C": "只属规费", "D": "只属税金"}, "answer": ["B"], "analysis": "施工机具使用费（施工机械+仪器仪表）是分部分项工程费的组成要素之一，也是按要素划分的组成部分。", "tags": ["分部分项工程费", "施工机具费"], "source": "2018定额详细解读"}, {"id": "ch09-094", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "分部分项工程费中的材料费，未计价材料（带'[]'）的价格应（ ）。", "options": {"A": "忽略不计", "B": "按定额基价计", "C": "按'[]'内用量乘市场单价另计", "D": "计入措施费"}, "answer": ["C"], "analysis": "2018定额：带'[]'的未计价材料，基价不含其价格，应按'[]'内列明用量乘以市场价格另行计算材料费。", "tags": ["分部分项工程费", "材料费", "未计价材料"], "source": "2018定额详细解读"}, {"id": "ch09-095", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "根据2018定额，材料价格按（ ）确定。", "options": {"A": "编制人随意定价", "B": "2017年全省综合水平", "C": "施工单位报价", "D": "国际市场价格"}, "answer": ["B"], "analysis": "2018定额的材料、人工、机具单价均按2017年广东省建筑市场综合水平取定，实际可调差。", "tags": ["预算定额", "材料价格"], "source": "2018定额详细解读"}, {"id": "ch09-096", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "施工图预算编制中，'计算间接费'通常指计算（ ）。", "options": {"A": "人工费", "B": "材料费", "C": "企业管理费和规费等", "D": "分部分项工程量"}, "answer": ["C"], "analysis": "编制步骤中'计算间接费、利润、税金'的间接费主要指企业管理费（管理费）、规费等非直接生产性费用。", "tags": ["编制步骤", "间接费"], "source": "安装教材精读笔记"}, {"id": "ch09-097", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "下列（ ）不是建筑安装工程费按造价形成划分的组成部分。", "options": {"A": "分部分项工程费", "B": "措施项目费", "C": "其他项目费", "D": "企业管理费"}, "answer": ["D"], "analysis": "按造价形成划分：分部分项、措施、其他、规费、税金；企业管理费属费用要素划分，且包含在分部分项工程费内，不作为造价形成划分的顶层项。", "tags": ["费用构成"], "source": "安装教材精读笔记"}, {"id": "ch09-098", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "安装工程施工图预算编制的主要成果是（ ）。", "options": {"A": "施工组织设计", "B": "工程总造价文件", "C": "材料采购单", "D": "竣工图"}, "answer": ["B"], "analysis": "施工图预算编制的最终成果是确定建筑安装工程总造价（含分部分项、措施、其他、规费、税金汇总），作为投标报价或造价控制的参考。", "tags": ["编制步骤", "汇总总造价"], "source": "安装教材精读笔记"}, {"id": "ch09-099", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "下列费用项目中，属于建筑安装工程费按造价形成划分顶层列项的有（ ）。", "options": {"A": "分部分项工程费", "B": "措施项目费", "C": "其他项目费", "D": "规费", "E": "企业管理费"}, "answer": ["A", "B", "C", "D"], "analysis": "造价形成划分顶层为分部分项、措施、其他、规费、税金五项；企业管理费属要素划分，且内含于分部分项工程费，非顶层列项。", "tags": ["费用构成"], "source": "安装教材精读笔记"}, {"id": "ch09-100", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "关于分部分项工程费与措施项目费的区别，下列说法正确的有（ ）。", "options": {"A": "分部分项形成工程实体", "B": "措施项目一般是非工程实体费用", "C": "两者均计入建筑安装工程费", "D": "措施项目费含安全文明施工费", "E": "分部分项工程费含规费"}, "answer": ["A", "B", "C", "D"], "analysis": "分部分项形成工程实体、措施为非实体费用，二者均计入建筑安装费；安全文明施工费属措施项目。规费单列，不计入分部分项工程费，故E错误。", "tags": ["费用构成", "分部分项工程费", "措施项目费"], "source": "安装教材精读笔记"}, {"id": "ch09-101", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "施工图预算编制所需的'资料'在第一步收集时，应包括（ ）。", "options": {"A": "施工图纸", "B": "施工组织设计", "C": "预算定额与费用定额", "D": "市场价格信息", "E": "竣工决算报告"}, "answer": ["A", "B", "C", "D"], "analysis": "第一步'收集资料'需收集施工图纸、施工组织设计、预算定额、费用定额、市场价格信息等编制依据；竣工决算报告是竣工后文件，预算阶段尚不存在。", "tags": ["编制步骤", "收集资料"], "source": "安装教材精读笔记"}, {"id": "ch09-102", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "建筑安装工程费按费用构成要素划分时，下列（ ）属于其组成。", "options": {"A": "人工费", "B": "材料费", "C": "施工机具使用费", "D": "企业管理费", "E": "措施项目费"}, "answer": ["A", "B", "C", "D"], "analysis": "要素划分为人、材、机、企业管理费、利润、规费、税金七项；措施项目费是按造价形成划分的内容，不属要素划分项。", "tags": ["费用构成", "费用要素"], "source": "安装教材精读笔记"}, {"id": "ch09-103", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "下列表述中，符合教材费用构成树的有（ ）。", "options": {"A": "建筑安装工程费含分部分项工程费", "B": "分部分项工程费含人工费", "C": "分部分项工程费含管理费", "D": "分部分项工程费含利润", "E": "分部分项工程费含规费"}, "answer": ["A", "B", "C", "D"], "analysis": "教材费用树：建筑安装工程费→分部分项(人工+材料+机械+管理费+利润)/措施/其他/规费/税金。规费与分部分项为并列顶层项，不计入分部分项，故E错误。", "tags": ["费用构成", "分部分项工程费"], "source": "安装教材精读笔记"}, {"id": "ch09-104", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "施工图预算编制中，市场价格信息可用于（ ）。", "options": {"A": "调整人工单价", "B": "确定未计价材料价格", "C": "调整材料价差", "D": "确定施工机具台班单价", "E": "规定工程量计算规则"}, "answer": ["A", "B", "C", "D"], "analysis": "市场价格信息用于人、材、机单价的确定与调整（含未计价材料计价）；工程量计算规则由清单规定，与市场价格信息无关。", "tags": ["编制依据", "市场价格信息"], "source": "安装教材精读笔记"}, {"id": "ch09-105", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "下列关于预算编制依据与步骤的说法，正确的有（ ）。", "options": {"A": "依据含施工图纸、预算定额、费用定额、市场价格信息、施工组织设计", "B": "算量依据2024清单", "C": "套定额依据2018广东定额", "D": "最后汇总总造价", "E": "费用定额规定人工消耗量"}, "answer": ["A", "B", "C", "D"], "analysis": "五项依据、算量依清单、套定额依2018广东定额、末步汇总总造价均正确；人工消耗量由预算定额规定，非费用定额，故E错误。", "tags": ["编制依据", "编制步骤"], "source": "安装教材精读笔记"}, {"id": "ch09-106", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "按造价形成划分，建筑安装工程费的五大部分中，排在第一位的是（ ）。", "options": {"A": "措施项目费", "B": "分部分项工程费", "C": "其他项目费", "D": "规费"}, "answer": ["B"], "analysis": "造价形成划分顺序：分部分项工程费、措施项目费、其他项目费、规费、税金，分部分项工程费排第一位且为主体。", "tags": ["费用构成"], "source": "安装教材精读笔记"}, {"id": "ch09-107", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "在分部分项工程费五要素（人工+材料+机械+管理费+利润）中，'施工机具使用费'对应2018定额中的（ ）。", "options": {"A": "仅施工机械使用费", "B": "施工机械使用费+施工仪器仪表使用费", "C": "仅仪器仪表使用费", "D": "机上人工费"}, "answer": ["B"], "analysis": "分部分项工程费中的施工机具使用费=施工机械使用费+施工仪器仪表使用费，与2018定额一致。", "tags": ["分部分项工程费", "施工机具费"], "source": "2018定额详细解读"}, {"id": "ch09-108", "date": "2026-07-06", "chapter": "ch09", "type": "single", "stem": "安装工程预算编制中，费用定额规定的取费基数和费率主要用于计算（ ）。", "options": {"A": "工程量", "B": "人工消耗量", "C": "企业管理费、利润、规费、税金等", "D": "材料净用量"}, "answer": ["C"], "analysis": "费用定额规定企业管理费、利润、规费、税金等的计费基数和费率，用以计算这些费用；工程量与人工、材料消耗量由图纸/定额确定。", "tags": ["编制依据", "费用定额"], "source": "安装教材精读笔记"}, {"id": "ch09-109", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "下列费用中，属于建筑安装工程费按造价形成划分、且不属于按费用要素划分单列项的有（ ）。", "options": {"A": "分部分项工程费", "B": "措施项目费", "C": "其他项目费", "D": "规费", "E": "税金"}, "answer": ["A", "B", "C"], "analysis": "分部分项、措施、其他项目费是按造价形成划分的顶层项，在要素划分中不存在这些顶层名称（要素划分为人材机等），故它们属于仅造价形成划分特有的列项；规费、税金两种划分均有。", "tags": ["费用构成"], "source": "安装教材精读笔记"}, {"id": "ch09-110", "date": "2026-07-06", "chapter": "ch09", "type": "multiple", "stem": "关于2024清单（GB/T 50856-2024）与预算编制的关系，下列说法正确的有（ ）。", "options": {"A": "标准性质为推荐性标准（GB/T）", "B": "规定工程量计量规则", "C": "2025年9月1日实施", "D": "与2018广东定额配套使用", "E": "规定材料市场单价"}, "answer": ["A", "B", "C", "D"], "analysis": "2024清单为推荐性标准、规定计量规则、2025-09-01实施、与2018定额配套用于计价；材料市场单价由市场价格信息确定，非清单规定，故E错误。", "tags": ["清单与定额衔接", "2024清单"], "source": "2024清单详细解读"}, {"id": "ch10-001", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "根据教材，最高投标限价的编制原则中，关于限价水平的表述是（ ）。", "options": {"A": "可适当上浮", "B": "可适当下调", "C": "不得上浮或下调", "D": "可由招标人自主浮动"}, "answer": ["C"], "analysis": "教材第10章明确列出最高投标限价编制原则共4条，其中第4条为'不得上浮或下调'，即最高投标限价应客观编制，不得人为抬高或压低。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-002", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "下列哪项不属于最高投标限价的编制原则？（ ）", "options": {"A": "依据国家或省级建设主管部门颁发的计价定额", "B": "依据设计文件", "C": "采用市场价格信息", "D": "可根据企业实力自主调整"}, "answer": ["D"], "analysis": "教材列示的最高投标限价编制原则为：依据计价定额、依据设计文件、采用市场价格信息、不得上浮或下调。'根据企业实力自主调整'属于投标报价层面的行为，不属于限价编制原则。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-003", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价编制所依据的'计价定额'，应由（ ）颁发。", "options": {"A": "施工企业", "B": "国家或省级建设主管部门", "C": "监理单位", "D": "设计单位"}, "answer": ["B"], "analysis": "教材第10章编制原则第1条明确：最高投标限价应'依据国家或省级建设主管部门颁发的计价定额'编制。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-004", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "编制最高投标限价时，材料和机械等价格应采用（ ）。", "options": {"A": "定额固定基价", "B": "市场价格信息", "C": "概算价格", "D": "投标报价"}, "answer": ["B"], "analysis": "教材第10章编制原则第3条：最高投标限价应'采用市场价格信息'，使限价反映当前市场行情。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-005", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价编制原则中'依据设计文件'的作用是（ ）。", "options": {"A": "确定施工组织", "B": "作为计量与计价的基础", "C": "确定投标人资格", "D": "确定工期"}, "answer": ["B"], "analysis": "设计文件（施工图）是确定项目特征、工程数量和计价的基础依据，最高投标限价必须依据设计文件编制。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-007", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "施工图预算的编制主体是（ ）。", "options": {"A": "施工单位", "B": "招标人", "C": "造价咨询人", "D": "政府造价管理机构"}, "answer": ["A"], "analysis": "教材第10章区别表：施工图预算由施工单位编制，用作投标报价的参考；最高投标限价由招标人编制。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-008", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "招标人编制最高投标限价的主要目的是（ ）。", "options": {"A": "作为投标报价参考", "B": "控制工程造价", "C": "作为竣工结算依据", "D": "作为竣工决算依据"}, "answer": ["B"], "analysis": "教材第10章区别表：最高投标限价的目的是'控制工程造价'；施工图预算的目的是'投标报价参考'。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-009", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "施工单位编制施工图预算的主要目的是（ ）。", "options": {"A": "控制工程造价", "B": "作为投标报价的参考", "C": "招标控制", "D": "审计决算"}, "answer": ["B"], "analysis": "教材第10章区别表：施工图预算的目的是'投标报价参考'，供施工单位测算成本、确定投标报价。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-010", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价应在（ ）编制。", "options": {"A": "施工图完成后", "B": "招标前", "C": "竣工验收后", "D": "开工后"}, "answer": ["B"], "analysis": "教材第10章区别表：最高投标限价的编制时间为'招标前'；施工图预算的编制时间为'施工图完成后'。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-011", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "施工图预算应在（ ）编制。", "options": {"A": "招标前", "B": "施工图完成后", "C": "合同签订后", "D": "竣工验收后"}, "answer": ["B"], "analysis": "教材第10章区别表：施工图预算的编制时间为'施工图完成后'，施工单位据此测算并用于投标报价。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-012", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "关于最高投标限价与施工图预算的编制主体，正确的是（ ）。", "options": {"A": "二者都由施工单位编制", "B": "最高投标限价由招标人编制", "C": "施工图预算由招标人编制", "D": "二者都由招标人编制"}, "answer": ["B"], "analysis": "教材区别表：最高投标限价由招标人编制，施工图预算由施工单位编制。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-013", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "下列关于最高投标限价编制时间的说法，正确的是（ ）。", "options": {"A": "施工图完成后", "B": "招标前", "C": "竣工结算时", "D": "施工完成后"}, "answer": ["B"], "analysis": "教材区别表明确：最高投标限价在招标前编制，随招标文件一并公布。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-014", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价（建筑安装工程费）的组成部分不包括（ ）。", "options": {"A": "分部分项工程费", "B": "措施项目费", "C": "其他项目费", "D": "设备购置费"}, "answer": ["D"], "analysis": "建筑安装工程费由分部分项工程费、措施项目费、其他项目费、规费、税金组成（见教材第9章费用构成）。设备购置费属于工程造价的其他构成，不属建筑安装工程费。", "tags": ["建筑安装工程费组成"], "source": "安装教材精读笔记.md"}, {"id": "ch10-015", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "分部分项工程费中通常不包括（ ）。", "options": {"A": "人工费", "B": "材料费", "C": "施工机具使用费", "D": "规费"}, "answer": ["D"], "analysis": "分部分项工程费=人工费+材料费+施工机具使用费+企业管理费+利润；规费单独列项计取，不包含在分部分项工程费内。", "tags": ["建筑安装工程费组成"], "source": "安装教材精读笔记.md"}, {"id": "ch10-017", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "规费和税金在建筑安装工程费构成中的特点是（ ）。", "options": {"A": "可作为竞争性费用由投标人自主确定", "B": "应按规定计取，不得作为竞争性费用", "C": "由招标人自行决定", "D": "由合同双方协商"}, "answer": ["B"], "analysis": "规费和税金属于法定规费性质，应按照国家及省级规定计取，不得作为竞争性费用参与投标浮动。", "tags": ["建筑安装工程费组成"], "source": "历年真题精华版.md"}, {"id": "ch10-018", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "其他项目费不包括（ ）。", "options": {"A": "暂列金额", "B": "暂估价", "C": "计日工", "D": "人工费"}, "answer": ["D"], "analysis": "其他项目费由暂列金额、暂估价、计日工、总承包服务费组成（见教材第11章）。人工费属分部分项工程费。", "tags": ["其他项目费"], "source": "安装教材精读笔记.md"}, {"id": "ch10-019", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "总承包服务费属于（ ）。", "options": {"A": "分部分项工程费", "B": "措施项目费", "C": "其他项目费", "D": "规费"}, "answer": ["C"], "analysis": "总承包服务费是招标人自行采购材料设备或分包专业工程时，向总承包人支付的服务费用，列入其他项目费。", "tags": ["其他项目费"], "source": "安装教材精读笔记.md"}, {"id": "ch10-021", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价（招标控制价）应在（ ）公布。", "options": {"A": "开标后", "B": "招标时（随招标文件公布）", "C": "评标时", "D": "签约后"}, "answer": ["B"], "analysis": "招标控制价（即最高投标限价）应在招标时公布，并作为招标文件的组成部分，不得上浮或下调。", "tags": ["招标控制价公布"], "source": "WebSearch-广东二造真题"}, {"id": "ch10-022", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "投标人的投标报价高于最高投标限价的，其投标应（ ）。", "options": {"A": "降价后接受", "B": "予以拒绝", "C": "正常评审", "D": "作废但可澄清"}, "answer": ["B"], "analysis": "投标人的投标报价高于招标控制价（最高投标限价）的，其投标应予以拒绝。", "tags": ["招标控制价公布"], "source": "WebSearch-广东二造真题"}, {"id": "ch10-023", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价可由（ ）编制。", "options": {"A": "仅招标人", "B": "仅造价咨询人", "C": "招标人或其委托的工程造价咨询人", "D": "仅施工单位"}, "answer": ["C"], "analysis": "最高投标限价（招标控制价）可以由招标人自行编制，也可以委托具有相应资质的工程造价咨询人编制。", "tags": ["招标控制价公布"], "source": "WebSearch-广东二造真题"}, {"id": "ch10-024", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "投标人编制投标报价时，暂列金额和专业工程暂估价应（ ）。", "options": {"A": "自主确定", "B": "按招标工程量清单中列出的金额填写且不得变动", "C": "按企业成本确定", "D": "可据情下调"}, "answer": ["B"], "analysis": "工程量清单计价模式下，暂列金额和专业工程暂估价应按招标工程量清单中列出的金额填写，投标人不得变动。", "tags": ["其他项目费"], "source": "WebSearch-广东二造真题"}, {"id": "ch10-025", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "'招标控制价'与'最高投标限价'的关系是（ ）。", "options": {"A": "完全不同的两个概念", "B": "同一概念的不同称谓", "C": "前者大于后者", "D": "后者包含前者"}, "answer": ["B"], "analysis": "招标控制价即最高投标限价，是同一概念在不同阶段/文件中的称谓，均指招标人设定的投标报价上限。", "tags": ["招标控制价公布"], "source": "WebSearch-广东二造真题"}, {"id": "ch10-026", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价编制不需要依据（ ）。", "options": {"A": "计价定额", "B": "设计文件", "C": "市场价格信息", "D": "投标人企业定额"}, "answer": ["D"], "analysis": "最高投标限价依据计价定额、设计文件、市场价格信息等编制；企业定额是施工单位编制投标报价的依据，不用于限价编制。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-027", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "与施工图预算相比，最高投标限价编制所采用的价格依据是（ ）。", "options": {"A": "定额基价", "B": "市场价格信息", "C": "概算指标", "D": "企业成本"}, "answer": ["B"], "analysis": "教材编制原则第3条明确最高投标限价应'采用市场价格信息'，以反映市场实际价格水平。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-028", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "在最高投标限价编制中，2024版清单（GB/T 50856-2024）规定的是（ ）。", "options": {"A": "人工材料消耗量", "B": "计量规则", "C": "综合单价", "D": "利润"}, "answer": ["B"], "analysis": "教材第7章：2024清单规定'计量规则'（怎么算量），2018定额规定'消耗量'（需要多少工料机），二者结合用于计价。", "tags": ["清单与定额衔接"], "source": "安装教材精读笔记.md"}, {"id": "ch10-029", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "在最高投标限价编制中，2018版广东安装定额规定的是（ ）。", "options": {"A": "计量规则", "B": "消耗量", "C": "清单项目", "D": "项目特征"}, "answer": ["B"], "analysis": "2018广东安装定额是消耗量定额，规定完成单位工程所需的人工、材料、施工机具消耗量。", "tags": ["清单与定额衔接"], "source": "2018定额详细解读.md"}, {"id": "ch10-030", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价中分部分项综合单价的编制应依据（ ）。", "options": {"A": "仅清单", "B": "清单计量规则与定额消耗量相结合", "C": "仅定额", "D": "投标报价"}, "answer": ["B"], "analysis": "综合单价以清单项目划分为基础，按清单计量规则算量，套用定额确定工料机消耗量并计价，二者结合形成。", "tags": ["清单与定额衔接"], "source": "安装教材精读笔记.md"}, {"id": "ch10-031", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "与最高投标限价相比，施工图预算的编制时间通常（ ）。", "options": {"A": "更早（招标前）", "B": "更晚（施工图完成后）", "C": "与限价同时", "D": "无法确定"}, "answer": ["B"], "analysis": "教材区别表：最高投标限价在招标前编制，施工图预算在施工图完成后编制，故施工图预算编制时间相对更晚。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-032", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "从性质上看，最高投标限价是（ ）。", "options": {"A": "投标人的报价", "B": "招标人设置的工程造价上限", "C": "合同价", "D": "竣工结算价"}, "answer": ["B"], "analysis": "最高投标限价是招标人为控制工程造价而设定的投标报价最高上限，超过该上限的投标将被拒绝。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-033", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "下列关于最高投标限价，说法错误的是（ ）。", "options": {"A": "由招标人编制", "B": "在招标前编制", "C": "目的是控制工程造价", "D": "由施工单位编制"}, "answer": ["D"], "analysis": "最高投标限价由招标人（或其委托的咨询人）编制，而非施工单位；施工单位编制的是施工图预算。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-034", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "下列关于施工图预算，说法正确的是（ ）。", "options": {"A": "由招标人编制", "B": "在招标前编制", "C": "由施工单位编制、作为投标报价参考", "D": "目的是控制工程造价"}, "answer": ["C"], "analysis": "教材区别表：施工图预算由施工单位编制，目的是作为投标报价参考；最高投标限价由招标人编制用于控制造价。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-035", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价与施工图预算编制都应依据（ ）。", "options": {"A": "设计文件", "B": "投标人企业定额", "C": "投标报价", "D": "中标合同"}, "answer": ["A"], "analysis": "二者均以设计文件（施工图）为计量计价基础：限价依据设计文件，施工图预算同样依据施工图纸。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-036", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "在工程量清单计价模式下，最高投标限价是根据（ ）编制的。", "options": {"A": "投标报价", "B": "招标工程量清单", "C": "合同价", "D": "竣工结算价"}, "answer": ["B"], "analysis": "最高投标限价应依据招标工程量清单、计价定额、设计文件及市场价格信息等编制，招标工程量清单是其编制基础。", "tags": ["最高投标限价编制原则"], "source": "历年真题精华版.md"}, {"id": "ch10-037", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价中的'限价'二字强调的是（ ）。", "options": {"A": "低价中标", "B": "价格上限", "C": "最低成本", "D": "企业自主价"}, "answer": ["B"], "analysis": "'限价'指投标报价的上限，超过该上限的投标将被拒绝，体现的是对工程造价的控制。", "tags": ["招标控制价公布"], "source": "WebSearch-广东二造真题"}, {"id": "ch10-038", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "下列哪项不是最高投标限价编制原则的内容？（ ）", "options": {"A": "依据国家或省级计价定额", "B": "依据设计文件", "C": "采用市场价格信息", "D": "由投标人确定"}, "answer": ["D"], "analysis": "编制原则为：依据计价定额、依据设计文件、采用市场价格信息、不得上浮或下调；'由投标人确定'不属于限价编制原则。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-039", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "编制最高投标限价时，材料、机械等价格宜采用（ ）。", "options": {"A": "定额固定价", "B": "市场价格信息", "C": "概算价", "D": "计划价格"}, "answer": ["B"], "analysis": "教材原则第3条：最高投标限价应'采用市场价格信息'，材料、机械台班等价格应反映市场水平。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-040", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "在广东省，最高投标限价编制所依据的计价定额是指（ ）。", "options": {"A": "GB 50500-2013", "B": "2018版广东安装定额", "C": "2024版清单", "D": "企业定额"}, "answer": ["B"], "analysis": "广东省最高投标限价编制采用《广东省通用安装工程综合定额（2018版）》等计价定额作为消耗量计价依据。", "tags": ["清单与定额衔接"], "source": "2018定额详细解读.md"}, {"id": "ch10-041", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价编制时，工程量应依据（ ）计算。", "options": {"A": "企业定额", "B": "招标工程量清单（按2024清单计量规则）", "C": "概算指标", "D": "经验估算"}, "answer": ["B"], "analysis": "工程量应按设计图示尺寸、依2024清单（GB/T 50856-2024）的计量规则计算，形成招标工程量清单。", "tags": ["清单与定额衔接"], "source": "GB/T 50856-2024 详细解读.md"}, {"id": "ch10-043", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "2018版广东安装定额的实施日期是（ ）。", "options": {"A": "2013年", "B": "2019年3月1日", "C": "2025年9月1日", "D": "2024年"}, "answer": ["B"], "analysis": "2018版广东安装定额自2019年3月1日起在广东省内施行，是最高投标限价的计价依据。", "tags": ["清单与定额衔接"], "source": "2018定额详细解读.md"}, {"id": "ch10-045", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "2024版清单（GB/T 50856-2024）共包含（ ）个附录。", "options": {"A": "12个", "B": "14个", "C": "13个", "D": "11个"}, "answer": ["B"], "analysis": "2024清单设附录A～N，共14个附录（较2013版新增附录M刷油防腐蚀绝热、附录N其他及附属工程）。", "tags": ["清单与定额衔接"], "source": "GB/T 50856-2024 详细解读.md"}, {"id": "ch10-046", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "2018版广东通用安装工程综合定额共分为（ ）册。", "options": {"A": "10册", "B": "12册", "C": "14册", "D": "11册"}, "answer": ["B"], "analysis": "2018广东安装定额共12册，涵盖机械设备、电气、智能化、通风空调、消防、给排水等专业。", "tags": ["清单与定额衔接"], "source": "2018定额详细解读.md"}, {"id": "ch10-047", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价中，措施项目费的计算应依据（ ）。", "options": {"A": "企业自主确定", "B": "计价定额及有关规定", "C": "投标报价", "D": "合同价"}, "answer": ["B"], "analysis": "措施项目费应按计价定额及费用定额、有关规定计算，其中安全文明施工费等不可竞争费用应按规定计取。", "tags": ["建筑安装工程费组成"], "source": "安装教材精读笔记.md"}, {"id": "ch10-048", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "下列关于最高投标限价，说法正确的是（ ）。", "options": {"A": "可以上浮", "B": "可以下调", "C": "不得上浮或下调", "D": "由市场自由决定"}, "answer": ["C"], "analysis": "教材编制原则第4条及清单计价规定均明确：最高投标限价应客观编制，不得上浮或下调。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-049", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "施工图预算作为投标报价参考，其编制主体是（ ）。", "options": {"A": "招标人", "B": "施工单位", "C": "造价管理机构", "D": "审计机关"}, "answer": ["B"], "analysis": "教材区别表：施工图预算由施工单位编制，用于投标报价参考。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-050", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价控制的是（ ）。", "options": {"A": "投标人的利润水平", "B": "工程造价的上限", "C": "施工企业成本", "D": "设计标准"}, "answer": ["B"], "analysis": "最高投标限价的目的是控制工程造价，设定投标报价的价格上限。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-051", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价公布后，投标人投标报价（ ）该限价。", "options": {"A": "可以超过", "B": "不得超过", "C": "必须低于10%", "D": "可随意"}, "answer": ["B"], "analysis": "投标报价高于最高投标限价的，其投标应予以拒绝，故投标报价不得超过最高投标限价。", "tags": ["招标控制价公布"], "source": "WebSearch-广东二造真题"}, {"id": "ch10-052", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "教材列示的最高投标限价编制原则共有（ ）。", "options": {"A": "3条", "B": "4条", "C": "5条", "D": "6条"}, "answer": ["B"], "analysis": "教材第10章列示4条原则：依据计价定额、依据设计文件、采用市场价格信息、不得上浮或下调。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-053", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "教材列示的最高投标限价编制原则中，第4条是（ ）。", "options": {"A": "依据计价定额", "B": "依据设计文件", "C": "采用市场价格信息", "D": "不得上浮或下调"}, "answer": ["D"], "analysis": "4条原则顺序为：①依据计价定额；②依据设计文件；③采用市场价格信息；④不得上浮或下调。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-054", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价编制原则第1条是（ ）。", "options": {"A": "采用市场价格信息", "B": "依据国家或省级建设主管部门颁发的计价定额", "C": "不得上浮或下调", "D": "依据设计文件"}, "answer": ["B"], "analysis": "第1条原则：依据国家或省级建设主管部门颁发的计价定额。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-055", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价编制原则第2条是（ ）。", "options": {"A": "依据设计文件", "B": "依据计价定额", "C": "采用市场价格信息", "D": "不得浮动"}, "answer": ["A"], "analysis": "第2条原则：依据设计文件。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-056", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价编制原则第3条是（ ）。", "options": {"A": "采用市场价格信息", "B": "依据设计文件", "C": "依据计价定额", "D": "不得浮动"}, "answer": ["A"], "analysis": "第3条原则：采用市场价格信息。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-057", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "与最高投标限价不同，施工图预算的编制时间在（ ）。", "options": {"A": "招标前", "B": "施工图完成后", "C": "签约时", "D": "竣工时"}, "answer": ["B"], "analysis": "教材区别表：施工图预算在施工图完成后编制；最高投标限价在招标前编制。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-058", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价编制时间'招标前'意味着其编制的主要依据是（ ）。", "options": {"A": "竣工图", "B": "施工图及招标文件", "C": "结算资料", "D": "合同文本"}, "answer": ["B"], "analysis": "最高投标限价在招标前编制，依据施工图（设计文件）和招标文件、招标工程量清单等。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-059", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "最高投标限价用于招标阶段控制（ ）。", "options": {"A": "施工企业资质", "B": "工程造价", "C": "设计质量", "D": "工期"}, "answer": ["B"], "analysis": "最高投标限价在招标阶段用于设定造价上限，控制工程造价。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-060", "date": "2026-07-06", "chapter": "ch10", "type": "single", "stem": "下列属于其他项目费组成部分的是（ ）。", "options": {"A": "规费", "B": "暂列金额", "C": "税金", "D": "安全文明施工费"}, "answer": ["B"], "analysis": "其他项目费包括暂列金额、暂估价、计日工、总承包服务费；规费、税金单独列项，安全文明施工费属措施项目费。", "tags": ["其他项目费"], "source": "安装教材精读笔记.md"}, {"id": "ch10-062", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "关于最高投标限价，下列说法正确的有（ ）。", "options": {"A": "编制主体为招标人", "B": "目的为控制工程造价", "C": "编制时间为招标前", "D": "编制主体为施工单位"}, "answer": ["A", "B", "C"], "analysis": "教材区别表：最高投标限价由招标人编制、目的是控制工程造价、在招标前编制；施工单位编制的是施工图预算。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-063", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "关于施工图预算（与最高投标限价对比），下列说法正确的有（ ）。", "options": {"A": "编制主体为施工单位", "B": "目的为投标报价参考", "C": "编制时间为施工图完成后", "D": "编制主体为招标人"}, "answer": ["A", "B", "C"], "analysis": "教材区别表：施工图预算由施工单位编制、目的为投标报价参考、在施工图完成后编制。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-064", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "最高投标限价（建筑安装工程费）由下列哪些费用组成？（ ）", "options": {"A": "分部分项工程费", "B": "措施项目费", "C": "其他项目费", "D": "规费和税金"}, "answer": ["A", "B", "C", "D"], "analysis": "建筑安装工程费=分部分项工程费+措施项目费+其他项目费+规费+税金，上述各项均属于其组成。", "tags": ["建筑安装工程费组成"], "source": "安装教材精读笔记.md"}, {"id": "ch10-065", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "其他项目费包括（ ）。", "options": {"A": "暂列金额", "B": "暂估价", "C": "计日工", "D": "总承包服务费"}, "answer": ["A", "B", "C", "D"], "analysis": "其他项目费由暂列金额、暂估价、计日工、总承包服务费四项组成。", "tags": ["其他项目费"], "source": "安装教材精读笔记.md"}, {"id": "ch10-066", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "关于最高投标限价的公布，下列说法正确的有（ ）。", "options": {"A": "应在招标时公布", "B": "不得上浮或下调", "C": "投标报价高于限价的应予拒绝", "D": "可由投标人编制"}, "answer": ["A", "B", "C"], "analysis": "最高投标限价应随招标文件公布、不得上浮或下调，高于限价的投标应予拒绝；限价由招标人（或其委托咨询人）编制，不由投标人编制。", "tags": ["招标控制价公布"], "source": "WebSearch-广东二造真题"}, {"id": "ch10-068", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "投标人编制投标报价时，应按招标工程量清单中列出的金额填写且不得变动的有（ ）。", "options": {"A": "暂列金额", "B": "专业工程暂估价", "C": "计日工", "D": "总承包服务费"}, "answer": ["A", "B"], "analysis": "暂列金额和专业工程暂估价应按招标清单列出的金额填写、不得变动；计日工和总承包服务费由投标人自主报价。", "tags": ["其他项目费"], "source": "WebSearch-广东二造真题"}, {"id": "ch10-069", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "最高投标限价的编制依据包括（ ）。", "options": {"A": "国家或省级计价定额", "B": "设计文件", "C": "市场价格信息", "D": "招标工程量清单"}, "answer": ["A", "B", "C", "D"], "analysis": "最高投标限价依据计价定额、设计文件、市场价格信息及招标工程量清单等编制。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-070", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "与最高投标限价编制相关的标准/定额有（ ）。", "options": {"A": "2024版清单（计量规则）", "B": "2018版广东安装定额（消耗量）", "C": "GB/T 50500 计价标准", "D": "投标人企业定额"}, "answer": ["A", "B", "C"], "analysis": "限价编制以2024清单计量规则、2018广东定额消耗量、GB/T 50500计价标准等为配套依据；企业定额用于投标报价而非限价。", "tags": ["清单与定额衔接"], "source": "GB/T 50856-2024 详细解读.md"}, {"id": "ch10-071", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "关于2024版清单（GB/T 50856-2024），下列说法正确的有（ ）。", "options": {"A": "属推荐性标准", "B": "共14个附录", "C": "自2025年9月1日起实施", "D": "规定人工材料消耗量"}, "answer": ["A", "B", "C"], "analysis": "2024清单为推荐性标准（GB/T）、14个附录、2025年9月1日实施；它规定计量规则而非消耗量（消耗量由定额规定）。", "tags": ["清单与定额衔接"], "source": "GB/T 50856-2024 详细解读.md"}, {"id": "ch10-072", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "关于2018版广东安装定额，下列说法正确的有（ ）。", "options": {"A": "共12册", "B": "规定消耗量", "C": "自2019年3月1日起实施", "D": "规定计量规则"}, "answer": ["A", "B", "C"], "analysis": "2018广东安装定额共12册、规定工料机消耗量、2019年3月1日实施；计量规则由2024清单规定。", "tags": ["清单与定额衔接"], "source": "2018定额详细解读.md"}, {"id": "ch10-075", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "最高投标限价与施工图预算的区别主要体现在（ ）。", "options": {"A": "编制主体不同", "B": "编制目的不同", "C": "编制时间不同", "D": "计价定额不同"}, "answer": ["A", "B", "C"], "analysis": "教材区别表从编制主体（招标人/施工单位）、目的（控制造价/投标参考）、时间（招标前/施工图后）三方面区分；二者计价依据（定额、设计文件）基本相同。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-076", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "下列关于最高投标限价编制原则，正确的有（ ）。", "options": {"A": "依据国家或省级计价定额", "B": "依据设计文件", "C": "采用市场价格信息", "D": "可根据行情随意下调"}, "answer": ["A", "B", "C"], "analysis": "前三项为教材列示原则；'随意下调'违背'不得上浮或下调'原则，错误。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-077", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "编制最高投标限价时，市场价格信息可用于确定（ ）。", "options": {"A": "材料价格", "B": "施工机具台班价格", "C": "人工单价", "D": "企业管理费费率"}, "answer": ["A", "B", "C"], "analysis": "材料、机械台班、人工等价格可采市场价格信息；企业管理费按费用定额费率计取。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-078", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "最高投标限价的作用包括（ ）。", "options": {"A": "控制工程造价", "B": "作为评标时判断报价有效性的上限", "C": "防止投标人哄抬标价", "D": "直接确定为合同价"}, "answer": ["A", "B", "C"], "analysis": "最高投标限价用于设定造价上限、作为评标有效性判断依据、防止哄抬标价；合同价由中标人的有效报价确定，并非直接等于限价。", "tags": ["最高投标限价与施工图预算区别"], "source": "WebSearch-广东二造真题"}, {"id": "ch10-079", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "下列关于最高投标限价，说法错误的有（ ）。", "options": {"A": "由招标人编制", "B": "可以适当上浮", "C": "可以适当下调", "D": "目的是控制工程造价"}, "answer": ["B", "C"], "analysis": "最高投标限价不得上浮或下调（BC错误）；由招标人编制、目的是控制造价（AD正确）。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-080", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "关于招标控制价（最高投标限价）的规定，正确的有（ ）。", "options": {"A": "应在招标文件中公布", "B": "不得上浮或下调", "C": "投标报价高于限价的应予拒绝", "D": "必须统一下浮5%"}, "answer": ["A", "B", "C"], "analysis": "限价应公布、不得浮动、超价拒标；并无'必须下浮5%'的规定。", "tags": ["招标控制价公布"], "source": "WebSearch-广东二造真题"}, {"id": "ch10-081", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "安装工程预算（施工图预算）的编制依据包括（ ）。", "options": {"A": "施工图纸", "B": "施工组织设计", "C": "预算定额", "D": "市场价格信息"}, "answer": ["A", "B", "C", "D"], "analysis": "真题归纳：施工图预算编制依据包括施工图纸、施工组织设计、预算定额、市场价格信息及费用定额等。", "tags": ["最高投标限价与施工图预算区别"], "source": "历年真题精华版.md"}, {"id": "ch10-082", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "工程量清单的编制依据包括（ ）。", "options": {"A": "工程量清单计价规范", "B": "建设工程设计文件", "C": "招标文件", "D": "施工现场情况"}, "answer": ["A", "B", "C", "D"], "analysis": "真题归纳：清单编制依据包括计价规范、设计文件、招标文件、施工现场情况及工程特点等，最高投标限价亦据此编制。", "tags": ["最高投标限价编制原则"], "source": "历年真题精华版.md"}, {"id": "ch10-083", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "最高投标限价编制中，2024清单与2018定额的关系是（ ）。", "options": {"A": "清单规定计量规则", "B": "定额规定消耗量", "C": "二者配套使用", "D": "二者互相替代"}, "answer": ["A", "B", "C"], "analysis": "清单管'怎么算量'（计量规则），定额管'消耗多少'（工料机消耗量），二者配套用于计价，不可互相替代。", "tags": ["清单与定额衔接"], "source": "安装教材精读笔记.md"}, {"id": "ch10-084", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "建筑安装工程费按费用构成要素包括（ ）。", "options": {"A": "人工费、材料费", "B": "施工机具使用费", "C": "企业管理费、利润", "D": "规费、税金"}, "answer": ["A", "B", "C", "D"], "analysis": "按费用构成要素，建筑安装工程费包括人工费、材料费、施工机具使用费、企业管理费、利润、规费和税金。", "tags": ["建筑安装工程费组成"], "source": "历年真题精华版.md"}, {"id": "ch10-085", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "下列费用中应按规定计取、不得作为竞争性费用的有（ ）。", "options": {"A": "规费", "B": "税金", "C": "安全文明施工费", "D": "企业管理费"}, "answer": ["A", "B", "C"], "analysis": "规费、税金及安全文明施工费等属不可竞争性费用，应按规定计取；企业管理费可竞争。", "tags": ["建筑安装工程费组成"], "source": "历年真题精华版.md"}, {"id": "ch10-086", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "最高投标限价编制应避免的行为有（ ）。", "options": {"A": "人为上浮", "B": "人为下调", "C": "依据计价定额", "D": "依据设计文件"}, "answer": ["A", "B"], "analysis": "编制原则要求'不得上浮或下调'，故人为上浮或下调均应避免；依据定额和设计文件则是正确做法。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-087", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "对最高投标限价中'限'字的理解，正确的有（ ）。", "options": {"A": "是招标人设置的价格上限", "B": "投标报价不得超过该上限", "C": "用以控制工程造价", "D": "由投标人决定其数值"}, "answer": ["A", "B", "C"], "analysis": "'限'指价格上限，由招标人设定并据以控制造价，投标报价不得超过；并非由投标人决定。", "tags": ["招标控制价公布"], "source": "WebSearch-广东二造真题"}, {"id": "ch10-088", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "最高投标限价与投标报价的关系为（ ）。", "options": {"A": "限价是投标报价的上限", "B": "投标报价不得高于限价", "C": "投标报价可高于限价", "D": "限价由投标人编制"}, "answer": ["A", "B"], "analysis": "限价是上限，投标报价不得高于限价（高于则拒标）；限价由招标人编制而非投标人。", "tags": ["招标控制价公布"], "source": "WebSearch-广东二造真题"}, {"id": "ch10-089", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "最高投标限价编制中'采用市场价格信息'体现了（ ）。", "options": {"A": "反映当前市场行情", "B": "使限价更贴近实际价格", "C": "可随意定价", "D": "不再需要计价定额"}, "answer": ["A", "B"], "analysis": "采用市场价格信息是为了反映市场行情、使限价贴近实际；但仍须以计价定额为消耗量依据，并非随意定价。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-090", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "最高投标限价的编制主体可以是（ ）。", "options": {"A": "招标人", "B": "招标人委托的造价咨询人", "C": "施工单位", "D": "设计单位"}, "answer": ["A", "B"], "analysis": "限价由招标人自行或委托造价咨询人编制；施工单位编制的是施工图预算，设计单位一般不编制限价。", "tags": ["最高投标限价与施工图预算区别"], "source": "WebSearch-广东二造真题"}, {"id": "ch10-091", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "最高投标限价由下列哪些部分汇总而成？（ ）", "options": {"A": "分部分项工程费", "B": "措施项目费", "C": "其他项目费", "D": "规费和税金"}, "answer": ["A", "B", "C", "D"], "analysis": "最高投标限价=分部分项+措施+其他+规费+税金，逐项汇总而成。", "tags": ["建筑安装工程费组成"], "source": "安装教材精读笔记.md"}, {"id": "ch10-092", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "关于最高投标限价编制时间'招标前'，下列说法正确的有（ ）。", "options": {"A": "在发布招标公告前完成", "B": "作为招标文件组成部分一并公布", "C": "依据设计文件编制", "D": "在竣工后编制"}, "answer": ["A", "B", "C"], "analysis": "限价在招标前完成、随招标文件公布、依据设计文件编制；并非竣工后编制。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-093", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "与施工图预算相比，最高投标限价（ ）。", "options": {"A": "由招标人编制", "B": "用于控制工程造价", "C": "在招标前编制", "D": "由施工单位编制"}, "answer": ["A", "B", "C"], "analysis": "限价由招标人编、控制造价、招标前编；施工图预算由施工单位编。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-094", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "最高投标限价编制原则中'依据设计文件'意味着（ ）。", "options": {"A": "按设计图示尺寸计算工程量", "B": "按设计项目特征选择定额、确定单价", "C": "依据施工经验估算", "D": "依据企业定额"}, "answer": ["A", "B"], "analysis": "依据设计文件即按图示尺寸算量、按项目特征计价；施工经验估算和企业定额不属于限价编制依据。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-095", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "投标人编制报价时，可在其他项目费中自主确定的有（ ）。", "options": {"A": "计日工", "B": "总承包服务费", "C": "暂列金额", "D": "专业工程暂估价"}, "answer": ["A", "B"], "analysis": "计日工、总承包服务费由投标人自主报价；暂列金额和专业工程暂估价须按招标清单金额填写不得变动。", "tags": ["其他项目费"], "source": "WebSearch-广东二造真题"}, {"id": "ch10-096", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "最高投标限价编制所依据的'计价定额'相关文件包括（ ）。", "options": {"A": "2018版广东安装定额", "B": "配套的费用定额", "C": "投标人企业定额", "D": "投标报价"}, "answer": ["A", "B"], "analysis": "限价以2018广东定额及配套费用定额为计价依据；企业定额和投标报价用于投标报价而非限价。", "tags": ["清单与定额衔接"], "source": "2018定额详细解读.md"}, {"id": "ch10-097", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "最高投标限价与施工图预算的共同点有（ ）。", "options": {"A": "都依据设计文件", "B": "都计算建筑安装工程费", "C": "都使用计价定额", "D": "都由招标人编制"}, "answer": ["A", "B", "C"], "analysis": "二者都依据设计文件、都计算建筑安装工程费、都使用计价定额；但编制主体不同（限价由招标人、预算由施工单位）。", "tags": ["最高投标限价与施工图预算区别"], "source": "安装教材精读笔记.md"}, {"id": "ch10-098", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "下列关于最高投标限价，说法正确的有（ ）。", "options": {"A": "不得上浮或下调", "B": "应随招标文件公布", "C": "投标报价高于限价应予拒绝", "D": "由施工单位编制"}, "answer": ["A", "B", "C"], "analysis": "限价不得浮动、应公布、超价拒标；由招标人（或委托咨询人）编制，不由施工单位编制。", "tags": ["招标控制价公布"], "source": "WebSearch-广东二造真题"}, {"id": "ch10-099", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "最高投标限价编制应采用的依据包括（ ）。", "options": {"A": "国家或省级建设主管部门颁发的计价定额", "B": "设计文件", "C": "市场价格信息", "D": "投标人企业成本"}, "answer": ["A", "B", "C"], "analysis": "限价依据计价定额、设计文件、市场价格信息编制；企业成本属投标报价范畴，不用于限价。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch10-100", "date": "2026-07-06", "chapter": "ch10", "type": "multiple", "stem": "最高投标限价编制应遵循的原则中，体现其客观性与公正性的有（ ）。", "options": {"A": "依据计价定额", "B": "依据设计文件", "C": "采用市场价格信息", "D": "不得上浮或下调"}, "answer": ["A", "B", "C", "D"], "analysis": "四条原则共同保证了限价编制的客观公正：以定额为尺度、以设计为依据、以市场为价格、且不得人为浮动。", "tags": ["最高投标限价编制原则"], "source": "安装教材精读笔记.md"}, {"id": "ch11-001", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "在投标报价编制中，'不平衡报价法'最核心的特点是？", "options": {"A": "在总报价基本不变的前提下，有意识地调整各清单子项单价", "B": "大幅提高总报价以获取更高利润", "C": "降低总报价以牺牲利润换取中标", "D": "只对措施项目费进行调整"}, "answer": ["A"], "analysis": "不平衡报价法是指在总报价基本不变（保持总价竞争力）的前提下，投标人有意识地调整工程量清单中各个子项单价，以实现早收钱、多收钱或规避风险的目的。这是教材第11章明确列出的三种报价策略之一。", "tags": ["投标报价策略", "不平衡报价法"], "source": "安装教材精读笔记"}, {"id": "ch11-002", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "投标报价策略中，在总价基本不变的前提下有意识地调整工程量清单中各子项单价的方法是？", "options": {"A": "多方案报价法", "B": "不平衡报价法", "C": "增加建议法", "D": "突然降价法"}, "answer": ["B"], "analysis": "教材第11.1节明确：不平衡报价法是在总价基本不变的前提下，有意识调整各子项单价。多方案报价法提供多种技术方案，增加建议法在报价中增加优化建议，突然降价法不属于教材所列三种策略。", "tags": ["投标报价策略", "不平衡报价法"], "source": "安装教材精读笔记"}, {"id": "ch11-003", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "采用不平衡报价法时，对于能够在早期结算并收取工程款的项目（如土方、基础工程），投标报价一般应？", "options": {"A": "适当降低单价", "B": "适当提高单价", "C": "保持单价不变", "D": "报零单价"}, "answer": ["B"], "analysis": "不平衡报价法典型做法之一：对前期工程（早期能结算收款的项目）适当提高单价，以加速资金周转、早收钱。来源为不平衡报价真题总结。", "tags": ["投标报价策略", "不平衡报价法", "早期项目"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-004", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "采用不平衡报价法时，对于预计将来实际工程量可能增加的项目，投标报价应？", "options": {"A": "适当降低单价", "B": "适当提高单价", "C": "保持原价不变", "D": "不参与报价"}, "answer": ["B"], "analysis": "预计工程量增加的项目提高单价，可在实际工程量变大后获得更多结算价款，是不平衡报价法的常用策略。", "tags": ["投标报价策略", "不平衡报价法", "工程量变化"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-005", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "采用不平衡报价法时，对于预计将来实际工程量可能减少的项目，投标报价应？", "options": {"A": "适当提高单价", "B": "适当降低单价", "C": "保持原价不变", "D": "报零单价"}, "answer": ["B"], "analysis": "预计工程量减少的项目降低单价，可减少实际工程量变小后的价款损失，与'增量提价'相对应。", "tags": ["投标报价策略", "不平衡报价法", "工程量变化"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-006", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "采用不平衡报价法时，对图纸或工程内容说明不清楚、日后很可能增加工程量的分项工程，其单价应？", "options": {"A": "适当降低", "B": "适当调高", "C": "维持不变", "D": "不报价"}, "answer": ["B"], "analysis": "对工程内容说明不清楚、预计工程量会增加的分项工程，适当提高单价，待后期工程量明确增加后可多结算。", "tags": ["投标报价策略", "不平衡报价法", "说明不清"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-007", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "采用不平衡报价法时，对于肯定要实施但暂定工程量可能偏大的早期项目，单价应？", "options": {"A": "降低单价", "B": "提高单价", "C": "报价为零", "D": "维持平衡价"}, "answer": ["B"], "analysis": "肯定实施且预期工程量可能增加、又属早期结算的项目，应提高单价，既早收钱又多收钱。", "tags": ["投标报价策略", "不平衡报价法", "早期项目"], "source": "安装教材精读笔记"}, {"id": "ch11-008", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "采用不平衡报价法时，对于后期施工的项目（如装饰、安装收尾工程），一般应？", "options": {"A": "适当提高单价", "B": "适当降低单价", "C": "维持不变", "D": "不报价"}, "answer": ["B"], "analysis": "后期工程结算收款较晚，适当降低单价可压低总价、提高中标竞争力，资金时间价值上也更划算。", "tags": ["投标报价策略", "不平衡报价法", "后期项目"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-009", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "采用不平衡报价法时，对于计日工单价，一般宜？", "options": {"A": "报低", "B": "报高", "C": "不报", "D": "与清单完全一致"}, "answer": ["B"], "analysis": "计日工数量不确定但发生时按实结算，适当报高可在实际发生时多结算；且计日工一般不直接决定中标与否。", "tags": ["投标报价策略", "不平衡报价法", "计日工"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-010", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "不平衡报价法调整单价时，调整幅度一般不宜超过？", "options": {"A": "±5%", "B": "±10%", "C": "±15%", "D": "±20%"}, "answer": ["B"], "analysis": "单价调整幅度不宜畸高畸低，一般不宜超过±10%；只有对承包商具有特别优势的分项工程，才可适当增大调整幅度。", "tags": ["投标报价策略", "不平衡报价法", "调整幅度"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-011", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "不平衡报价法得以实施的前提条件是？", "options": {"A": "总报价可以大幅提高", "B": "总报价基本不变", "C": "所有单价必须一律提高", "D": "措施费单独报高"}, "answer": ["B"], "analysis": "不平衡报价是在'总价基本不变'前提下调整各子项单价，若总价大幅提高就失去了'不影响中标'的意义。", "tags": ["投标报价策略", "不平衡报价法", "前提"], "source": "安装教材精读笔记"}, {"id": "ch11-012", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "投标报价中采用'不平衡报价法'的主要目的通常是？", "options": {"A": "抬高总价确保中标", "B": "在不影响总价竞争力的前提下实现早收钱、多收钱", "C": "完全按定额水平报价", "D": "降低工程质量以省钱"}, "answer": ["B"], "analysis": "不平衡报价法的目的是在保持总价竞争力（不影响中标）的同时，通过单价结构调整实现资金早回笼、利润最大化或风险规避。", "tags": ["投标报价策略", "不平衡报价法", "目的"], "source": "安装教材精读笔记"}, {"id": "ch11-013", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "采用不平衡报价法时，对于暂定但很可能由投标人自行施工的项目，其单价应？", "options": {"A": "报低", "B": "报高", "C": "不报", "D": "维持平衡价"}, "answer": ["B"], "analysis": "暂定项目中估计今后会由自己施工（必然发生）的，可报高价，以便实际施工时多结算。", "tags": ["投标报价策略", "不平衡报价法", "暂定项目"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-014", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "采用不平衡报价法时，对于暂定但可能分包出去或可能被取消的项目，其单价应？", "options": {"A": "报高", "B": "报低", "C": "不报", "D": "维持不变"}, "answer": ["B"], "analysis": "暂定项目中估计可能分包或不发生的，应报低价，即使中标也不会因低价而吃亏，并可压低总价提高竞争力。", "tags": ["投标报价策略", "不平衡报价法", "暂定项目"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-015", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "不平衡报价法在下列哪种合同类型下最能发挥作用？", "options": {"A": "总价合同", "B": "单价合同", "C": "成本加酬金合同", "D": "固定总价包干合同"}, "answer": ["B"], "analysis": "单价合同中工程量按实际发生结算、单价保持不变，调整单价可在工程量变化后影响结算总价，因此不平衡报价在单价合同中最有效。", "tags": ["投标报价策略", "不平衡报价法", "合同类型"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-016", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "下列哪一种做法不属于不平衡报价法的典型应用？", "options": {"A": "对早期结算项目提高单价", "B": "对预计工程量增加的项目提高单价", "C": "大幅提高总报价以取得中标", "D": "对计日工适当报高"}, "answer": ["C"], "analysis": "不平衡报价强调'总价基本不变'，大幅提高总报价会丧失中标竞争力，不属于不平衡报价法。A、B、D均为其典型应用。", "tags": ["投标报价策略", "不平衡报价法", "辨析"], "source": "安装教材精读笔记"}, {"id": "ch11-017", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "投标报价策略中，当招标文件允许时，投标人提供两种或两种以上技术方案并分别报价的方法是？", "options": {"A": "不平衡报价法", "B": "多方案报价法", "C": "增加建议法", "D": "突然降价法"}, "answer": ["B"], "analysis": "教材第11.1节：多方案报价法是提供多种技术方案，并分别报价。不平衡报价法调单价，增加建议法提优化建议。", "tags": ["投标报价策略", "多方案报价法"], "source": "安装教材精读笔记"}, {"id": "ch11-018", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "多方案报价法通常最适合用于下列哪种情形？", "options": {"A": "招标文件条款明确、无修改空间", "B": "招标文件中工程范围不很明确、条款不够清楚", "C": "总价合同且工程量完全固定", "D": "只需报一个总价"}, "answer": ["B"], "analysis": "当招标文件条款不很清楚、工程范围界定不清时，投标人可报备选方案并分别报价，以争取更有利条件或提高中标机会。", "tags": ["投标报价策略", "多方案报价法", "适用情形"], "source": "安装教材精读笔记"}, {"id": "ch11-019", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "多方案报价法与不平衡报价法的主要区别在于？", "options": {"A": "多方案报价提供多种技术方案及相应报价，不平衡报价只调整单价", "B": "两者完全相同", "C": "多方案报价一定提高总价", "D": "不平衡报价不调整单价"}, "answer": ["A"], "analysis": "多方案报价法的核心是提供多个技术方案并分别报价；不平衡报价法是在单一方案下调整各子项单价。二者策略维度不同。", "tags": ["投标报价策略", "多方案报价法", "辨析"], "source": "安装教材精读笔记"}, {"id": "ch11-020", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "采用多方案报价法时，投标人一般应？", "options": {"A": "只报一个方案", "B": "同时提出可选方案并分别报价", "C": "只报总价", "D": "不报技术方案"}, "answer": ["B"], "analysis": "多方案报价法要求投标人在允许的前提下，提出备选技术方案并分别列出报价，供评标比较。", "tags": ["投标报价策略", "多方案报价法"], "source": "安装教材精读笔记"}, {"id": "ch11-021", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "当招标文件允许提交备选方案时，投标人采用多方案报价法的主要目的是？", "options": {"A": "提高中标机会并争取更有利的价格条件", "B": "降低工程质量", "C": "回避报价", "D": "仅展示技术实力"}, "answer": ["A"], "analysis": "多方案报价通过提供可比较的备选方案及报价，既展示技术能力，又争取更优价格和中标机会。", "tags": ["投标报价策略", "多方案报价法", "目的"], "source": "安装教材精读笔记"}, {"id": "ch11-022", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "投标报价策略中，投标人在报价中增加优化原设计的建议并附相应报价的方法是？", "options": {"A": "不平衡报价法", "B": "多方案报价法", "C": "增加建议法", "D": "突然降价法"}, "answer": ["C"], "analysis": "教材第11.1节：增加建议法是在报价中增加优化建议（修改原设计）并附相应报价。", "tags": ["投标报价策略", "增加建议法"], "source": "安装教材精读笔记"}, {"id": "ch11-023", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "增加建议法（又称建议方案法）的核心做法是？", "options": {"A": "修改原设计提出更合理的方案并报价", "B": "提高总报价", "C": "仅报单价", "D": "不提任何建议"}, "answer": ["A"], "analysis": "增加建议法核心是对原设计提出更合理、更有利的优化方案，并附报价供招标人参考，以争取中标或有利条件。", "tags": ["投标报价策略", "增加建议法"], "source": "安装教材精读笔记"}, {"id": "ch11-024", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "采用增加建议法时，投标人提出的建议方案应当？", "options": {"A": "比原方案工期更长", "B": "比原方案更合理、更有利（如降低成本或缩短工期）", "C": "成本更高", "D": "完全不可行"}, "answer": ["B"], "analysis": "增加建议法的建议方案应技术上可行且比原方案更有利（降低成本、缩短工期、提高质量等），才有采纳价值。", "tags": ["投标报价策略", "增加建议法"], "source": "安装教材精读笔记"}, {"id": "ch11-025", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "关于增加建议法，下列说法正确的是？", "options": {"A": "投标人可直接修改招标文件中的设计", "B": "投标人可提出修改原设计的建议并附报价，供招标人参考", "C": "建议方案无需报价", "D": "增加建议法仅适用于总价合同"}, "answer": ["B"], "analysis": "增加建议法是投标人提出优化建议（非强制修改招标文件），并附相应报价供招标人选择参考；建议方案应当报价。", "tags": ["投标报价策略", "增加建议法", "辨析"], "source": "安装教材精读笔记"}, {"id": "ch11-026", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "采用增加建议法提出备选方案时，通常应？", "options": {"A": "同时报出原方案与建议方案的报价", "B": "只报建议方案", "C": "不报原方案", "D": "仅报一个总价"}, "answer": ["A"], "analysis": "增加建议法一般应同时报出原方案报价与建议方案报价，便于招标人对比择优。", "tags": ["投标报价策略", "增加建议法"], "source": "安装教材精读笔记"}, {"id": "ch11-027", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "其他项目费中，招标人在工程量清单中暂定并包括在合同价款中的一笔款项是？", "options": {"A": "暂估价", "B": "暂列金额", "C": "计日工", "D": "总承包服务费"}, "answer": ["B"], "analysis": "暂列金额是招标人在工程量清单中暂定并包括在合同价款中的一笔款项，用于签约时尚未确定或不可预见的费用。", "tags": ["其他项目费", "暂列金额"], "source": "GB/T 50856-2024"}, {"id": "ch11-028", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "暂列金额一般用于？", "options": {"A": "必然发生的专业工程分包", "B": "施工合同签订时尚未确定或不可预见的所需材料、工程变更等费用", "C": "已确定供应商的材料采购", "D": "总承包人对分包的管理"}, "answer": ["B"], "analysis": "暂列金额用于施工合同签订时尚未确定或不可预见的所需材料、设备、服务的采购，以及工程变更、价款调整等费用。", "tags": ["其他项目费", "暂列金额", "用途"], "source": "GB/T 50856-2024"}, {"id": "ch11-029", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "关于暂列金额，下列说法正确的是？", "options": {"A": "属于投标人自有费用", "B": "由招标人暂定并列入合同价款", "C": "必须全部使用", "D": "属于暂估价的一种"}, "answer": ["B"], "analysis": "暂列金额由招标人暂定并列入合同价款，未必全部使用；它不同于暂估价，也非投标人自有费用。", "tags": ["其他项目费", "暂列金额", "辨析"], "source": "GB/T 50856-2024"}, {"id": "ch11-030", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "在合同履约中，暂列金额的使用决定权一般属于？", "options": {"A": "投标人", "B": "招标人（发包人）", "C": "监理单位单方面", "D": "材料供应商"}, "answer": ["B"], "analysis": "暂列金额由招标人（发包人）掌握使用，用于签约时尚未确定或不可预见的费用，是否动用及动用多少由发包人决定。", "tags": ["其他项目费", "暂列金额", "使用权"], "source": "GB/T 50856-2024"}, {"id": "ch11-031", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "在投标报价中，暂列金额一般应？", "options": {"A": "由投标人自主确定金额", "B": "按招标工程量清单中列出的金额填报", "C": "不填报", "D": "由投标人下调后填报"}, "answer": ["B"], "analysis": "投标人应按招标工程量清单中招标人列出的暂列金额金额计入投标总价，不得自行更改。", "tags": ["其他项目费", "暂列金额", "填报"], "source": "GB/T 50856-2024"}, {"id": "ch11-032", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "暂列金额与暂估价的主要区别在于？", "options": {"A": "暂列金额是未必发生的费用，暂估价是必然发生但价格暂定的费用", "B": "两者完全相同", "C": "暂列金额由投标人确定", "D": "暂估价不可能发生"}, "answer": ["A"], "analysis": "暂列金额对应不一定发生的费用（如变更），暂估价对应必然发生但签约时价格暂不能确定的项目（材料、设备、专业工程）。", "tags": ["其他项目费", "暂列金额", "暂估价", "辨析"], "source": "GB/T 50856-2024"}, {"id": "ch11-033", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "其他项目费中，招标阶段不能合理确定价格、由招标人暂定并在招标文件中写明金额的是？", "options": {"A": "暂列金额", "B": "暂估价", "C": "计日工", "D": "总承包服务费"}, "answer": ["B"], "analysis": "暂估价是招标人在招标文件中暂定的、签约时价格不能确定的材料、工程设备或专业工程的金额。", "tags": ["其他项目费", "暂估价"], "source": "GB/T 50856-2024"}, {"id": "ch11-034", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "暂估价通常包括？", "options": {"A": "仅人工费", "B": "材料、工程设备、专业工程暂估价", "C": "仅措施费", "D": "仅规费"}, "answer": ["B"], "analysis": "暂估价按内容分为材料暂估价、工程设备暂估价和专业工程暂估价三类。", "tags": ["其他项目费", "暂估价", "分类"], "source": "GB/T 50856-2024"}, {"id": "ch11-035", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "关于专业工程暂估价，下列说法正确的是？", "options": {"A": "由投标人自行定价", "B": "由招标人暂定，按相关规定另行发包或计价", "C": "不计入合同价款", "D": "属于计日工"}, "answer": ["B"], "analysis": "专业工程暂估价由招标人暂定金额，通常对应招标人另行发包的专业工程，按合同约定方式计价，计入其他项目费。", "tags": ["其他项目费", "暂估价", "专业工程暂估价"], "source": "GB/T 50856-2024"}, {"id": "ch11-036", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "材料、工程设备暂估价的单价一般应按？", "options": {"A": "投标人自定", "B": "招标工程量清单中列出的暂估单价", "C": "市场最低价", "D": "不填报"}, "answer": ["B"], "analysis": "材料、工程设备暂估价应按招标工程量清单列出的暂估单价填报，结算时按实际价格调整。", "tags": ["其他项目费", "暂估价", "填报"], "source": "GB/T 50856-2024"}, {"id": "ch11-037", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "暂估价与计日工的主要区别是？", "options": {"A": "暂估价是必然发生但价格暂定，计日工是完成零星工作计价", "B": "两者完全相同", "C": "计日工是必然发生的主体工程", "D": "暂估价不可能发生"}, "answer": ["A"], "analysis": "暂估价针对必然发生但价格暂定的项目；计日工针对工程量清单之外、施工中可能发生的零星工作按工日（或台班）计价。", "tags": ["其他项目费", "暂估价", "计日工", "辨析"], "source": "GB/T 50856-2024"}, {"id": "ch11-038", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "专业工程暂估价在投标报价中一般应计入？", "options": {"A": "分部分项工程费", "B": "其他项目费", "C": "规费", "D": "税金"}, "answer": ["B"], "analysis": "专业工程暂估价属于其他项目费的组成部分，应计入其他项目费，而非分部分项、规费或税金。", "tags": ["其他项目费", "暂估价", "组成"], "source": "GB/T 50856-2024"}, {"id": "ch11-039", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "其他项目费中，为完成招标人提出的零星工作（如零星项目、甩项工程）而设立的计价项目是？", "options": {"A": "暂列金额", "B": "暂估价", "C": "计日工", "D": "总承包服务费"}, "answer": ["C"], "analysis": "计日工是为完成招标人提出的、工程量清单之外的零星工作或变更零星工作而设立的计价项目。", "tags": ["其他项目费", "计日工"], "source": "GB/T 50856-2024"}, {"id": "ch11-040", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "计日工通常适用于？", "options": {"A": "大宗主体工程", "B": "工程量清单之外、施工中可能发生的零星工作或变更工作", "C": "固定总价包干项目", "D": "专业工程分包"}, "answer": ["B"], "analysis": "计日工用于工程量清单之外、施工过程中可能发生的零星项目、甩项工程或变更零星工作，按实际发生计工计价。", "tags": ["其他项目费", "计日工", "适用"], "source": "GB/T 50856-2024"}, {"id": "ch11-041", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "投标报价中，计日工项目应按照招标工程量清单列出的项目和数量，填写？", "options": {"A": "不填写", "B": "计日工单价和合价", "C": "仅填总价", "D": "仅填数量"}, "answer": ["B"], "analysis": "投标人应按清单列出的计日工项目、数量填报单价并计算合价，合价计入其他项目费。", "tags": ["其他项目费", "计日工", "填报"], "source": "GB/T 50856-2024"}, {"id": "ch11-042", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "关于计日工，下列说法错误的是？", "options": {"A": "用于零星工作计价", "B": "投标人应填写单价", "C": "计日工数量由投标人自行确定", "D": "属于其他项目费"}, "answer": ["C"], "analysis": "计日工的数量由招标人在工程量清单中列出，投标人只需填报单价并计算合价，不能自行确定数量。A、B、D均正确。", "tags": ["其他项目费", "计日工", "辨析"], "source": "GB/T 50856-2024"}, {"id": "ch11-043", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "其他项目费中，总承包人为配合协调发包人进行的专业工程发包、自行采购设备材料等进行管理和服务所发生的费用是？", "options": {"A": "暂列金额", "B": "暂估价", "C": "计日工", "D": "总承包服务费"}, "answer": ["D"], "analysis": "总承包服务费是总承包人为配合协调发包人发包的专业工程、供应的材料设备以及施工现场统一管理而发生的服务费用。", "tags": ["其他项目费", "总承包服务费"], "source": "GB/T 50856-2024"}, {"id": "ch11-044", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "总承包服务费一般由谁计取？", "options": {"A": "分包人", "B": "总承包人", "C": "材料供应商", "D": "监理人"}, "answer": ["B"], "analysis": "总承包服务费由总承包人计取，是对其提供配合、协调、管理服务所应得的费用。", "tags": ["其他项目费", "总承包服务费", "计取"], "source": "GB/T 50856-2024"}, {"id": "ch11-045", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "总承包服务费通常针对？", "options": {"A": "招标人自行发包的专业工程、采购的材料设备等", "B": "投标人自有工程", "C": "规费", "D": "税金"}, "answer": ["A"], "analysis": "总承包服务费针对发包人自行发包的专业工程和自行采购供应的材料、设备，以及施工现场统一管理服务。", "tags": ["其他项目费", "总承包服务费", "针对对象"], "source": "GB/T 50856-2024"}, {"id": "ch11-046", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "关于总承包服务费，下列说法正确的是？", "options": {"A": "由分包人支付给总承包人", "B": "由发包人支付给总承包人，体现在其他项目费中", "C": "计入规费", "D": "计入税金"}, "answer": ["B"], "analysis": "总承包服务费是发包人就总承包人提供的配合协调服务应支付的费用，列入其他项目费，不计入规费或税金。", "tags": ["其他项目费", "总承包服务费", "辨析"], "source": "GB/T 50856-2024"}, {"id": "ch11-047", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "根据教材，其他项目费的组成一般不包括下列哪项？", "options": {"A": "暂列金额", "B": "暂估价", "C": "计日工", "D": "安全文明施工费"}, "answer": ["D"], "analysis": "教材第11.2节明确其他项目费由暂列金额、暂估价、计日工、总承包服务费组成；安全文明施工费属于措施项目费。", "tags": ["其他项目费", "组成", "辨析"], "source": "安装教材精读笔记"}, {"id": "ch11-048", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "安装工程的投标报价组成中，不属于'其他项目费'组成的是？", "options": {"A": "暂列金额", "B": "暂估价", "C": "计日工", "D": "规费"}, "answer": ["D"], "analysis": "其他项目费=暂列金额+暂估价+计日工+总承包服务费；规费是独立于其他项目费的建筑安装工程费组成项。", "tags": ["其他项目费", "规费", "辨析"], "source": "安装教材精读笔记"}, {"id": "ch11-049", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "招标工程量清单中的'其他项目清单'通常不包含？", "options": {"A": "暂列金额", "B": "暂估价", "C": "计日工", "D": "企业管理费"}, "answer": ["D"], "analysis": "其他项目清单列暂列金额、暂估价、计日工、总承包服务费；企业管理费包含在分部分项综合单价中，不单列于其他项目清单。", "tags": ["其他项目费", "其他项目清单", "辨析"], "source": "GB/T 50856-2024"}, {"id": "ch11-050", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "投标报价中的其他项目费，按教材规定由暂列金额、暂估价、计日工和下列哪一项共同组成？", "options": {"A": "措施项目费", "B": "总承包服务费", "C": "规费", "D": "利润"}, "answer": ["B"], "analysis": "教材第11.2节：其他项目费包括暂列金额、暂估价、计日工、总承包服务费四项。", "tags": ["其他项目费", "组成"], "source": "安装教材精读笔记"}, {"id": "ch11-051", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "安装工程投标报价的费用组成中，下列不作为独立组成项的一项是？", "options": {"A": "分部分项工程费", "B": "措施项目费", "C": "其他项目费", "D": "企业管理费"}, "answer": ["D"], "analysis": "投标报价按五大项组成：分部分项工程费、措施项目费、其他项目费、规费、税金。企业管理费已包含在分部分项综合单价中，不是独立组成项。", "tags": ["报价组成", "费用构成", "辨析"], "source": "安装教材精读笔记"}, {"id": "ch11-052", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "分部分项工程费的综合单价中通常不包括？", "options": {"A": "人工费", "B": "材料费", "C": "规费", "D": "利润"}, "answer": ["C"], "analysis": "分部分项工程费综合单价=人工费+材料费+施工机具使用费+企业管理费+利润，规费和税金单独列项，不包含在综合单价内。", "tags": ["报价组成", "分部分项工程费", "综合单价"], "source": "广东二级造价师安装专业历年真题精华版"}, {"id": "ch11-053", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "根据历年真题，建筑安装工程费按费用构成要素包括人工费、材料费、施工机具使用费、企业管理费、利润、规费和税金，其中属于'分部分项工程费'综合单价组成的是？", "options": {"A": "规费、税金", "B": "人工费、材料费、施工机具使用费、企业管理费、利润", "C": "规费、利润", "D": "税金、规费"}, "answer": ["B"], "analysis": "分部分项工程费综合单价由人工费、材料费、施工机具使用费、企业管理费、利润组成；规费与税金单独列项。", "tags": ["报价组成", "分部分项工程费", "综合单价"], "source": "广东二级造价师安装专业历年真题精华版"}, {"id": "ch11-054", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "规费在投标报价中属于？", "options": {"A": "分部分项工程费", "B": "措施项目费", "C": "其他项目费", "D": "单独列项的建筑安装工程费组成之一"}, "answer": ["D"], "analysis": "规费与分部分项工程费、措施项目费、其他项目费、税金并列，是建筑安装工程费的独立组成项，不得计入综合单价。", "tags": ["报价组成", "规费"], "source": "安装教材精读笔记"}, {"id": "ch11-055", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "税金（增值税）在投标报价中？", "options": {"A": "计入分部分项工程费", "B": "计入措施项目费", "C": "作为单独一项计入建筑安装工程费", "D": "不计入报价"}, "answer": ["C"], "analysis": "税金是建筑安装工程费的独立组成项，按税前造价乘以增值税税率计算，单独列项，不计入分部分项或措施项目。", "tags": ["报价组成", "税金"], "source": "安装教材精读笔记"}, {"id": "ch11-056", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "投标报价中，下列不属于措施项目费的是？", "options": {"A": "安全文明施工费", "B": "夜间施工增加费", "C": "暂列金额", "D": "二次搬运费"}, "answer": ["C"], "analysis": "安全文明施工费、夜间施工增加费、二次搬运费均属措施项目费；暂列金额属于其他项目费。", "tags": ["报价组成", "措施项目费", "辨析"], "source": "安装教材精读笔记"}, {"id": "ch11-057", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "安装工程费用组成中，分部分项工程费的综合单价由人工费、材料费、施工机具使用费以及哪两项构成？", "options": {"A": "规费、税金", "B": "企业管理费、利润", "C": "暂列金额、暂估价", "D": "总承包服务费、计日工"}, "answer": ["B"], "analysis": "综合单价=人工费+材料费+施工机具使用费+企业管理费+利润，企业管理费与利润是其中两项。", "tags": ["报价组成", "分部分项工程费", "综合单价"], "source": "广东二级造价师安装专业历年真题精华版"}, {"id": "ch11-058", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "投标报价编制时，投标人应按招标工程量清单中的暂列金额、暂估价等？", "options": {"A": "可由投标人修改后计入", "B": "按招标人列出的金额计入投标总价", "C": "由投标人自主确定", "D": "不计入"}, "answer": ["B"], "analysis": "暂列金额、暂估价等由招标人列出，投标人应按其金额计入投标总价，不得自行更改或遗漏。", "tags": ["其他项目费", "填报", "投标报价"], "source": "GB/T 50856-2024"}, {"id": "ch11-059", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "工程量清单是招标文件的组成部分，可作为下列哪项工作的依据？", "options": {"A": "仅编制招标控制价", "B": "编制招标控制价、投标报价、计算工程量、支付工程款、调整合同价款、办理竣工结算等", "C": "仅办理竣工结算", "D": "仅支付工程款"}, "answer": ["B"], "analysis": "GB/T 50856-2024第4.1.2条：工程量清单是招标文件组成部分，应作为编制招标控制价、投标报价、计算工程量、支付工程款、调整合同价款、办理竣工结算等的依据。", "tags": ["工程量清单", "投标报价", "依据"], "source": "GB/T 50856-2024"}, {"id": "ch11-060", "date": "2026-07-06", "chapter": "ch11", "type": "single", "stem": "投标报价应由谁编制？", "options": {"A": "招标人", "B": "投标人", "C": "监理人", "D": "造价管理机构"}, "answer": ["B"], "analysis": "投标报价由投标人自主编制并承担相应责任；招标控制价（最高投标限价）才由招标人编制。", "tags": ["投标报价", "编制主体"], "source": "安装教材精读笔记"}, {"id": "ch11-061", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "下列属于不平衡报价法适用情形的有？", "options": {"A": "对早期能够结算收款的项目适当提高单价", "B": "对预计将来工程量可能增加的项目适当提高单价", "C": "对预计将来工程量可能减少的项目适当降低单价", "D": "对图纸或说明不清楚、可能增加工程量的项目适当提高单价"}, "answer": ["A", "B", "C", "D"], "analysis": "上述均为不平衡报价法的典型适用情形：早结算项目提价、增量项目提价、减量项目降价、说明不清可能增量项目提价。", "tags": ["投标报价策略", "不平衡报价法", "适用情形"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-062", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "关于不平衡报价法，下列说法正确的有？", "options": {"A": "在总报价基本不变的前提下进行", "B": "有意识调整各清单子项单价", "C": "适用于单价合同", "D": "可以大幅提高总价以获取利润"}, "answer": ["A", "B", "C"], "analysis": "不平衡报价法前提是总价基本不变、调整子项单价、在单价合同下有效；大幅提高总价会丧失中标竞争力，不属于不平衡报价。", "tags": ["投标报价策略", "不平衡报价法", "辨析"], "source": "安装教材精读笔记"}, {"id": "ch11-063", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "采用不平衡报价法时，下列做法正确的有？", "options": {"A": "对前期工程项目适当提高单价", "B": "对后期工程项目适当降低单价", "C": "对预计工程量增加的项目提高单价", "D": "对计日工单价可适当报高"}, "answer": ["A", "B", "C", "D"], "analysis": "前期提价、后期降价、增量提价、计日工报高均属不平衡报价法常见做法，可早收钱、多收钱。", "tags": ["投标报价策略", "不平衡报价法", "做法"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-064", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "不平衡报价法中，关于暂定项目（招标人列出的暂定项目）的报价，下列说法正确的有？", "options": {"A": "估计今后一定会施工的，可报高价", "B": "估计今后可能不分包出去的，可报低价", "C": "估计可能由自己施工的可报高价", "D": "估计可能分包或取消的可报低价"}, "answer": ["A", "C", "D"], "analysis": "暂定项目中必然实施或自己施工的报高价，可能分包或不发生的报低价；B表述相反（'可能不分包'意味着可能自己施工，应报高而非报低），故不选。", "tags": ["投标报价策略", "不平衡报价法", "暂定项目"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-065", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "不平衡报价法的调整应注意的事项包括？", "options": {"A": "调整幅度不宜畸高畸低", "B": "单价调整幅度一般不宜超过±10%", "C": "总报价应基本保持不变", "D": "可以随意大幅提高某些单价"}, "answer": ["A", "B", "C"], "analysis": "不平衡报价应保持总价基本不变，单价调整幅度一般不宜超过±10%、避免畸高畸低；随意大幅提高单价会引起招标人或评标质疑。", "tags": ["投标报价策略", "不平衡报价法", "调整幅度"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-066", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "下列情形中，投标时适合采用不平衡报价法提高单价的有？", "options": {"A": "早期施工的基础工程", "B": "图纸不明确、预计工程量会增加的项目", "C": "计日工", "D": "必然减少的工程量项目"}, "answer": ["A", "B", "C"], "analysis": "早期项目、预计增量项目、计日工均可适当提高单价；必然减少的工程量变降价更合适。", "tags": ["投标报价策略", "不平衡报价法", "提价"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-067", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "下列情形中，投标时适合采用不平衡报价法降低单价的有？", "options": {"A": "后期施工的项目", "B": "预计工程量会减少的项目", "C": "可能分包或取消的暂定项目", "D": "早期能结算收款的项目"}, "answer": ["A", "B", "C"], "analysis": "后期项目、预计减量项目、可能分包或取消的暂定项目适合降低单价；早期结算项目应提高单价。", "tags": ["投标报价策略", "不平衡报价法", "降价"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-068", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "不平衡报价法与正常（平衡）报价的区别在于？", "options": {"A": "保持总价基本不变", "B": "调整各分部分项工程的相对单价水平", "C": "在单价合同中可实现早收钱、多收钱", "D": "必须提高总报价"}, "answer": ["A", "B", "C"], "analysis": "不平衡报价在总价基本不变前提下调整子项相对单价，使早期/增量项目单价偏高，从而实现早收钱、多收钱；并非提高总报价。", "tags": ["投标报价策略", "不平衡报价法", "辨析"], "source": "安装教材精读笔记"}, {"id": "ch11-069", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "关于不平衡报价法的风险，下列说法正确的有？", "options": {"A": "单价畸高畸低易引起招标人质疑", "B": "单价偏离招标控制价一定比例时需提供合理解释", "C": "可能被评标时要求澄清", "D": "没有任何风险"}, "answer": ["A", "B", "C"], "analysis": "不平衡报价并非无风险：单价畸高畸低会被质疑，分部分项单价偏离控制价一定比例需解释，评标时可能被要求澄清。", "tags": ["投标报价策略", "不平衡报价法", "风险"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-070", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "采用不平衡报价法时，投标人应重点关注招标文件的哪些内容？", "options": {"A": "各清单项目的付款（结算）时间先后", "B": "工程量的预计变化情况", "C": "暂定项目的实施可能性", "D": "仅关注总价即可"}, "answer": ["A", "B", "C"], "analysis": "不平衡报价需分析项目结算先后（早/晚）、工程量变化趋势、暂定项目实施可能性，据此调整单价，而非只看总价。", "tags": ["投标报价策略", "不平衡报价法", "关注点"], "source": "WebSearch-不平衡报价真题"}, {"id": "ch11-071", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "关于多方案报价法，下列说法正确的有？", "options": {"A": "提供两种或两种以上技术方案", "B": "各方案分别报价", "C": "适用于招标文件条款不够明确、工程范围不很清晰的情况", "D": "只需报一个总价"}, "answer": ["A", "B", "C"], "analysis": "多方案报价法提供多种技术方案并分别报价，常用于招标文件不够明确、范围不清时；只报一个总价不符合其定义。", "tags": ["投标报价策略", "多方案报价法"], "source": "安装教材精读笔记"}, {"id": "ch11-072", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "采用多方案报价法时，投标人应注意的事项包括？", "options": {"A": "备选方案应技术上可行", "B": "备选方案应与原方案分别报价", "C": "备选方案通常应更经济或更有利", "D": "无需报价只提方案即可"}, "answer": ["A", "B", "C"], "analysis": "多方案报价要求备选方案技术可行、与原方案分别报价，且一般应比原方案更经济或更有利；仅提方案不报价不符合要求。", "tags": ["投标报价策略", "多方案报价法", "注意"], "source": "安装教材精读笔记"}, {"id": "ch11-073", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "下列哪些情形适合采用多方案报价法？", "options": {"A": "招标文件中某些条款规定不够明确", "B": "工程范围界定不很清楚", "C": "招标人允许提交备选方案", "D": "招标文件要求只能报一个方案且条款清晰"}, "answer": ["A", "B", "C"], "analysis": "多方案报价适用于条款不明、范围不清且招标人允许备选方案的情形；若明确要求只报一个方案且条款清晰，则不适合。", "tags": ["投标报价策略", "多方案报价法", "适用"], "source": "安装教材精读笔记"}, {"id": "ch11-074", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "关于增加建议法（建议方案法），下列说法正确的有？", "options": {"A": "投标人在报价中可增加优化原设计的建议", "B": "建议方案应附相应报价", "C": "建议方案应比原方案更合理、更有利", "D": "可直接替代招标文件设计无须说明"}, "answer": ["A", "B", "C"], "analysis": "增加建议法是投标人提出优化原设计的建议并附报价，方案应更合理有利；但建议仅供招标人参考，不能直接替代招标文件设计。", "tags": ["投标报价策略", "增加建议法"], "source": "安装教材精读笔记"}, {"id": "ch11-075", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "采用增加建议法时，投标人的建议方案一般应满足？", "options": {"A": "工期可缩短", "B": "成本可降低", "C": "技术上可行", "D": "质量不可靠"}, "answer": ["A", "B", "C"], "analysis": "增加建议法的建议方案应技术上可行，并力求缩短工期、降低成本或提高质量；质量不可靠的方案无采纳价值。", "tags": ["投标报价策略", "增加建议法", "要求"], "source": "安装教材精读笔记"}, {"id": "ch11-076", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "增加建议法的作用包括？", "options": {"A": "展示投标人技术实力", "B": "为招标人提供优化方案以争取中标", "C": "可能降低工程成本或缩短工期", "D": "必然提高总报价"}, "answer": ["A", "B", "C"], "analysis": "增加建议法通过优化建议展示实力、争取中标并可能降本增效；并非必然提高总报价。", "tags": ["投标报价策略", "增加建议法", "作用"], "source": "安装教材精读笔记"}, {"id": "ch11-077", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "关于暂列金额，下列说法正确的有？", "options": {"A": "由招标人在工程量清单中暂定", "B": "包括在合同价款中", "C": "用于尚未确定或不可预见的费用", "D": "由投标人自主确定金额"}, "answer": ["A", "B", "C"], "analysis": "暂列金额由招标人暂定并列入合同价款，用于签约时尚未确定或不可预见的费用；金额由招标人确定，投标人不得自行更改。", "tags": ["其他项目费", "暂列金额"], "source": "GB/T 50856-2024"}, {"id": "ch11-078", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "暂列金额可能用于以下哪些方面？", "options": {"A": "施工合同签订时尚未确定的材料采购", "B": "工程变更引起的费用", "C": "合同约定调整因素出现时的价款调整", "D": "投标人必得的管理费"}, "answer": ["A", "B", "C"], "analysis": "暂列金额用于签约时未确定或不可预见的费用，如材料采购、工程变更、价款调整等；不属于投标人必得的管理费。", "tags": ["其他项目费", "暂列金额", "用途"], "source": "GB/T 50856-2024"}, {"id": "ch11-079", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "投标报价时，关于暂列金额下列说法正确的有？", "options": {"A": "应按招标工程量清单列出的金额填报", "B": "投标人不得自行更改金额", "C": "计入其他项目费", "D": "计入分部分项工程费"}, "answer": ["A", "B", "C"], "analysis": "投标人应按招标人列出的暂列金额金额填报、不得更改，并计入其他项目费；不计入分部分项工程费。", "tags": ["其他项目费", "暂列金额", "填报"], "source": "GB/T 50856-2024"}, {"id": "ch11-080", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "暂列金额与暂估价的共同点包括？", "options": {"A": "都由招标人列出", "B": "都计入其他项目费", "C": "金额都可能在履约中调整", "D": "都由投标人确定"}, "answer": ["A", "B", "C"], "analysis": "暂列金额与暂估价均由招标人列出、计入其他项目费，且履约中金额都可能调整；二者均非由投标人确定。", "tags": ["其他项目费", "暂列金额", "暂估价", "共同点"], "source": "GB/T 50856-2024"}, {"id": "ch11-081", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "关于暂估价，下列说法正确的有？", "options": {"A": "招标阶段不能合理确定价格", "B": "由招标人在招标文件中暂定金额", "C": "包括材料、工程设备、专业工程暂估价", "D": "由投标人自行确定价格"}, "answer": ["A", "B", "C"], "analysis": "暂估价是签约时价格不能确定的项目，由招标人暂定金额，分为材料、工程设备、专业工程暂估价；价格由招标人暂定而非投标人自定。", "tags": ["其他项目费", "暂估价"], "source": "GB/T 50856-2024"}, {"id": "ch11-082", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "暂估价按内容可分为？", "options": {"A": "材料暂估价", "B": "工程设备暂估价", "C": "专业工程暂估价", "D": "计日工暂估价"}, "answer": ["A", "B", "C"], "analysis": "暂估价分为材料暂估价、工程设备暂估价、专业工程暂估价三类；不存在'计日工暂估价'这一类别，计日工是独立的其他项目费项。", "tags": ["其他项目费", "暂估价", "分类"], "source": "GB/T 50856-2024"}, {"id": "ch11-083", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "关于专业工程暂估价，下列说法正确的有？", "options": {"A": "由招标人暂定金额", "B": "通常对应招标人另行发包的专业工程", "C": "计入其他项目费", "D": "由投标人自主定价"}, "answer": ["A", "B", "C"], "analysis": "专业工程暂估价由招标人暂定金额、通常对应另行发包的专业工程、计入其他项目费；价格由招标人暂定而非投标人自定。", "tags": ["其他项目费", "暂估价", "专业工程暂估价"], "source": "GB/T 50856-2024"}, {"id": "ch11-084", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "投标报价中，关于暂估价的填报下列说法正确的有？", "options": {"A": "材料、工程设备暂估单价按清单列出填写", "B": "专业工程暂估金额按清单列出填写", "C": "计入其他项目费", "D": "由投标人自行定价"}, "answer": ["A", "B", "C"], "analysis": "暂估价应按招标清单列出的暂估单价/金额填报并计入其他项目费；投标人不得自行定价。", "tags": ["其他项目费", "暂估价", "填报"], "source": "GB/T 50856-2024"}, {"id": "ch11-085", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "关于计日工，下列说法正确的有？", "options": {"A": "用于完成招标人提出的零星工作", "B": "属于其他项目费", "C": "投标人应填报单价", "D": "数量由投标人自行确定"}, "answer": ["A", "B", "C"], "analysis": "计日工用于零星工作、属其他项目费、投标人应填报单价；但数量由招标人列出，投标人不得自行确定。", "tags": ["其他项目费", "计日工"], "source": "GB/T 50856-2024"}, {"id": "ch11-087", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "投标报价时，计日工项目应？", "options": {"A": "按清单列出的项目填报", "B": "填写计日工单价", "C": "计算合价计入其他项目费", "D": "不填报价"}, "answer": ["A", "B", "C"], "analysis": "计日工按清单项目填报单价、计算合价并计入其他项目费；不填报价则无法结算零星工作。", "tags": ["其他项目费", "计日工", "填报"], "source": "GB/T 50856-2024"}, {"id": "ch11-088", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "关于总承包服务费，下列说法正确的有？", "options": {"A": "由总承包人计取", "B": "用于配合协调发包人发包的专业工程", "C": "用于管理发包人采购的设备材料", "D": "计入其他项目费"}, "answer": ["A", "B", "C", "D"], "analysis": "总承包服务费由总承包人计取，用于配合协调发包人发包的专业工程、管理发包人采购的材料设备、施工现场统一管理等，计入其他项目费。", "tags": ["其他项目费", "总承包服务费"], "source": "GB/T 50856-2024"}, {"id": "ch11-089", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "总承包服务费通常针对以下哪些情况？", "options": {"A": "招标人自行发包的专业工程", "B": "招标人采购供应的材料、设备", "C": "施工现场统一管理", "D": "投标人自身施工的分部分项工程"}, "answer": ["A", "B", "C"], "analysis": "总承包服务费针对发包人发包的专业工程、发包人采购的材料设备以及现场统一管理；投标人自身施工的分部分项工程已含在分部分项报价中。", "tags": ["其他项目费", "总承包服务费", "针对"], "source": "GB/T 50856-2024"}, {"id": "ch11-091", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "根据教材，其他项目费一般包括哪些？", "options": {"A": "暂列金额", "B": "暂估价", "C": "计日工", "D": "总承包服务费"}, "answer": ["A", "B", "C", "D"], "analysis": "教材第11.2节明确：其他项目费包括暂列金额、暂估价、计日工、总承包服务费四项。", "tags": ["其他项目费", "组成"], "source": "安装教材精读笔记"}, {"id": "ch11-092", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "下列费用中，属于其他项目费组成的有？", "options": {"A": "暂列金额", "B": "总承包服务费", "C": "计日工", "D": "安全文明施工费"}, "answer": ["A", "B", "C"], "analysis": "暂列金额、总承包服务费、计日工均属其他项目费；安全文明施工费属于措施项目费。", "tags": ["其他项目费", "组成", "辨析"], "source": "安装教材精读笔记"}, {"id": "ch11-093", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "招标工程量清单中的'其他项目清单'通常包含？", "options": {"A": "暂列金额", "B": "暂估价", "C": "计日工", "D": "总承包服务费"}, "answer": ["A", "B", "C", "D"], "analysis": "其他项目清单由暂列金额、暂估价、计日工、总承包服务费四部分组成。", "tags": ["其他项目费", "其他项目清单", "组成"], "source": "GB/T 50856-2024"}, {"id": "ch11-094", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "下列属于其他项目费、不属于措施项目费的有？", "options": {"A": "暂估价", "B": "计日工", "C": "总承包服务费", "D": "夜间施工增加费"}, "answer": ["A", "B", "C"], "analysis": "暂估价、计日工、总承包服务费属其他项目费；夜间施工增加费属措施项目费。", "tags": ["其他项目费", "措施项目费", "辨析"], "source": "安装教材精读笔记"}, {"id": "ch11-095", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "根据教材，安装工程投标报价的组成一般包括？", "options": {"A": "分部分项工程费", "B": "措施项目费", "C": "其他项目费", "D": "规费和税金"}, "answer": ["A", "B", "C", "D"], "analysis": "教材第11.2节：投标报价组成包括分部分项工程费、措施项目费、其他项目费、规费、税金五项。", "tags": ["报价组成", "费用构成"], "source": "安装教材精读笔记"}, {"id": "ch11-096", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "根据历年真题，建筑安装工程费按费用构成要素包括？", "options": {"A": "人工费、材料费、施工机具使用费", "B": "企业管理费、利润", "C": "规费", "D": "税金"}, "answer": ["A", "B", "C", "D"], "analysis": "按费用构成要素，建筑安装工程费=人工费+材料费+施工机具使用费+企业管理费+利润+规费+税金。", "tags": ["报价组成", "费用构成要素"], "source": "广东二级造价师安装专业历年真题精华版"}, {"id": "ch11-097", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "分部分项工程费的综合单价组成包括？", "options": {"A": "人工费、材料费", "B": "施工机具使用费", "C": "企业管理费、利润", "D": "规费、税金"}, "answer": ["A", "B", "C"], "analysis": "综合单价=人工费+材料费+施工机具使用费+企业管理费+利润；规费与税金单独列项，不计入综合单价。", "tags": ["报价组成", "分部分项工程费", "综合单价"], "source": "广东二级造价师安装专业历年真题精华版"}, {"id": "ch11-098", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "投标报价中，下列不应计入分部分项工程费综合单价的有？", "options": {"A": "规费", "B": "税金", "C": "企业管理费", "D": "利润"}, "answer": ["A", "B"], "analysis": "规费与税金是独立列项的费用，不计入分部分项综合单价；企业管理费与利润则包含在综合单价内。", "tags": ["报价组成", "分部分项工程费", "综合单价", "辨析"], "source": "广东二级造价师安装专业历年真题精华版"}, {"id": "ch11-100", "date": "2026-07-06", "chapter": "ch11", "type": "multiple", "stem": "安装工程投标报价的五大组成部分中，属于按招标清单单独列项、不并入综合单价的有？", "options": {"A": "规费", "B": "税金", "C": "其他项目费", "D": "企业管理费"}, "answer": ["A", "B", "C"], "analysis": "规费、税金、其他项目费均在投标报价中单独列项，不并入分部分项综合单价；企业管理费已包含在综合单价内。", "tags": ["报价组成", "费用构成", "辨析"], "source": "安装教材精读笔记"}, {"id": "ch12-001", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "根据安装工程价款结算相关规定，下列属于工程价款结算方式的是（ ）。", "options": {"A": "按年结算", "B": "按月结算", "C": "按周结算", "D": "按旬结算"}, "answer": ["B"], "analysis": "工程价款结算方式主要有三种：按月结算、分段结算、竣工后一次结算。按年/周/旬结算不属于规定方式。", "tags": ["结算方式"], "source": "安装教材精读笔记"}, {"id": "ch12-002", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "按月结算是指（ ）。", "options": {"A": "每月按实际完成的工程量结算工程进度款", "B": "按工程形象进度分段结算", "C": "竣工后一次性结清", "D": "按季度固定付款"}, "answer": ["A"], "analysis": "按月结算是每月按实际完成的工程量结算进度款，是最常用的进度款结算方式。", "tags": ["结算方式", "按月结算"], "source": "安装教材精读笔记"}, {"id": "ch12-003", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "分段结算是按照（ ）进行结算的。", "options": {"A": "日历月份", "B": "工程形象进度划分的段落", "C": "竣工后一次性", "D": "承包人报送额"}, "answer": ["B"], "analysis": "分段结算按工程形象进度（如基础、主体、装修等阶段）划分段落进行结算。", "tags": ["结算方式", "分段结算"], "source": "安装教材精读笔记"}, {"id": "ch12-004", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "竣工后一次结算通常适用于（ ）。", "options": {"A": "工期长、规模大的工程", "B": "建设规模小、工期短的工程", "C": "所有政府投资项目", "D": "分期开发的住宅小区"}, "answer": ["B"], "analysis": "竣工后一次结算适用于建设规模较小、工期较短（如合同工期在短期内）的工程，竣工后一次性结清价款。", "tags": ["结算方式", "竣工后一次结算"], "source": "安装教材精读笔记"}, {"id": "ch12-005", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于工程价款的三种结算方式，下列说法正确的有（ ）。", "options": {"A": "按月结算是每月按实际完成的工程量结算进度款", "B": "分段结算是按工程形象进度划分段落进行结算", "C": "竣工后一次结算适用于建设规模小、工期短的工程", "D": "结算方式只能由发包人单方决定，承包人无权参与"}, "answer": ["A", "B", "C"], "analysis": "三种结算方式：按月结算、分段结算、竣工后一次结算，应在合同中由发承包双方约定，并非发包人单方决定。", "tags": ["结算方式"], "source": "安装教材精读笔记"}, {"id": "ch12-006", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "根据规定，工程价款的结算方式主要包括（ ）。", "options": {"A": "按月结算", "B": "分段结算", "C": "竣工后一次结算", "D": "按周结算", "E": "按旬结算"}, "answer": ["A", "B", "C"], "analysis": "工程价款结算的三种法定方式：按月结算、分段结算、竣工后一次结算。", "tags": ["结算方式"], "source": "安装教材精读笔记"}, {"id": "ch12-007", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于竣工后一次结算，下列说法正确的有（ ）。", "options": {"A": "适用于建设规模较小的工程", "B": "适用于工期较短的工程", "C": "竣工后一次性结清价款", "D": "必须按月支付进度款", "E": "不适用于安装工程"}, "answer": ["A", "B", "C"], "analysis": "竣工后一次结算用于规模小、工期短的工程，竣工后一次性结清；并非必须按月付进度款，且同样适用于安装工程。", "tags": ["结算方式", "竣工后一次结算"], "source": "安装教材精读笔记"}, {"id": "ch12-008", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "分段结算中，划分结算节点（段落）的依据包括（ ）。", "options": {"A": "工程形象进度", "B": "合同约定", "C": "发包人单方面随意决定", "D": "材料采购进度"}, "answer": ["A", "B"], "analysis": "分段结算以工程形象进度划分段落，具体节点由合同约定，不能由发包人单方面随意决定。", "tags": ["结算方式", "分段结算"], "source": "安装教材精读笔记"}, {"id": "ch12-009", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "下列工程中，最适合采用竣工后一次结算的是（ ）。", "options": {"A": "大型综合体机电安装", "B": "合同工期仅6个月的小型安装工程", "C": "跨年度市政工程", "D": "分期开发的小区"}, "answer": ["B"], "analysis": "工期短、规模小的小型安装工程最适合竣工后一次结算。", "tags": ["结算方式", "竣工后一次结算"], "source": "安装教材精读笔记"}, {"id": "ch12-010", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于按月结算，下列说法正确的有（ ）。", "options": {"A": "每月按实际完成工程量结算", "B": "是最常见的进度款结算方式", "C": "需定期进行工程量计量", "D": "竣工后不再结算", "E": "不需承包人申请"}, "answer": ["A", "B", "C"], "analysis": "按月结算需定期计量、承包人申请、发包人支付进度款；竣工后仍需办理竣工结算。", "tags": ["结算方式", "按月结算"], "source": "安装教材精读笔记"}, {"id": "ch12-011", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于合同约定结算方式的特点，下列说法正确的有（ ）。", "options": {"A": "应在合同中明确约定", "B": "按月结算需定期计量", "C": "分段结算按形象进度", "D": "竣工后一次结算用于短工期工程", "E": "结算方式不得变更"}, "answer": ["A", "B", "C", "D"], "analysis": "结算方式由发承包双方在合同中约定，三种方式各有适用情形；并非绝对不得变更（依法可协商）。", "tags": ["结算方式"], "source": "安装教材精读笔记"}, {"id": "ch12-012", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "在三种结算方式中，需要发包人定期对已完工程量进行计量的通常是（ ）。", "options": {"A": "仅竣工后一次结算", "B": "按月结算和分段结算", "C": "仅竣工结算", "D": "均无需计量"}, "answer": ["B"], "analysis": "按月结算和分段结算均需定期对已完工程量计量；竣工后一次结算一般竣工后计量。", "tags": ["结算方式", "工程计量"], "source": "安装教材精读笔记"}, {"id": "ch12-013", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "按照工程量清单计价规范，工程进度款的支付比例按照合同约定，按期中结算价款总额计，一般（ ）。（2022年真题）", "options": {"A": "不低于50%，不高于80%", "B": "不低于50%，不高于85%", "C": "不低于60%，不高于85%", "D": "不低于60%，不高于90%"}, "answer": ["D"], "analysis": "依据GB 50500-2013，进度款支付比例按期中结算价款总额计，不低于60%、不高于90%。", "tags": ["进度款支付", "必背数字"], "source": "广东二级造价师安装专业历年真题精华版"}, {"id": "ch12-014", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "工程进度款支付比例的下限是（ ）。", "options": {"A": "50%", "B": "60%", "C": "70%", "D": "80%"}, "answer": ["B"], "analysis": "进度款支付比例不低于60%。", "tags": ["进度款支付", "必背数字"], "source": "安装教材精读笔记"}, {"id": "ch12-015", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "工程进度款支付比例的上限是（ ）。", "options": {"A": "85%", "B": "90%", "C": "95%", "D": "100%"}, "answer": ["B"], "analysis": "进度款支付比例不高于90%。", "tags": ["进度款支付", "必背数字"], "source": "安装教材精读笔记"}, {"id": "ch12-016", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于'工程进度款支付比例按期中结算价款总额计'的理解，下列说法正确的有（ ）。", "options": {"A": "以本期已完工程的期中结算价款总额为基数", "B": "不是按合同总价计取", "C": "按发包人指定金额计取", "D": "按竣工结算总价为基数"}, "answer": ["A", "B"], "analysis": "进度款支付比例以期中结算价款总额为基数，而非合同总价或竣工总价，也不是发包人单方指定。", "tags": ["进度款支付"], "source": "安装教材精读笔记"}, {"id": "ch12-017", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "某安装工程期中结算价款总额为200万元，按不低于60%、不高于90%的规定，本期可支付进度款的合理区间是（ ）。", "options": {"A": "100万~180万", "B": "120万~180万", "C": "120万~200万", "D": "60万~90万"}, "answer": ["B"], "analysis": "200×60%=120万元，200×90%=180万元，合理区间为120万~180万。", "tags": ["进度款支付", "必背数字"], "source": "安装教材精读笔记"}, {"id": "ch12-018", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于工程进度款支付比例，下列说法正确的有（ ）。", "options": {"A": "不低于60%", "B": "不高于90%", "C": "按期中结算价款总额计", "D": "由发包人单方决定", "E": "下限为50%"}, "answer": ["A", "B", "C"], "analysis": "进度款支付比例不低于60%、不高于90%，按期中结算价款总额计，由合同约定而非发包人单方决定。", "tags": ["进度款支付", "必背数字"], "source": "安装教材精读笔记"}, {"id": "ch12-019", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "若合同约定进度款支付比例为期中结算价款的60%，期中价款100万元，则本期应付进度款为（ ）。", "options": {"A": "50万", "B": "60万", "C": "90万", "D": "100万"}, "answer": ["B"], "analysis": "100×60%=60万元。", "tags": ["进度款支付"], "source": "安装教材精读笔记"}, {"id": "ch12-020", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "若合同约定进度款支付比例为90%，期中价款100万元，本期应付进度款为（ ）。", "options": {"A": "60万", "B": "85万", "C": "90万", "D": "100万"}, "answer": ["C"], "analysis": "100×90%=90万元，达到支付比例上限。", "tags": ["进度款支付"], "source": "安装教材精读笔记"}, {"id": "ch12-021", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "关于进度款支付比例超过90%的规定，正确的是（ ）。", "options": {"A": "只要双方同意就可以超过", "B": "不得超过90%", "C": "上限为95%", "D": "没有限制"}, "answer": ["B"], "analysis": "进度款支付比例一般规定不高于90%，超过部分通常留待竣工结算时支付。", "tags": ["进度款支付", "必背数字"], "source": "安装教材精读笔记"}, {"id": "ch12-022", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "下列进度款支付比例中，符合'不低于60%、不高于90%'规定的有（ ）。", "options": {"A": "60%", "B": "75%", "C": "90%", "D": "55%", "E": "95%"}, "answer": ["A", "B", "C"], "analysis": "60%、75%、90%均在60%~90%区间内；55%低于下限，95%高于上限。", "tags": ["进度款支付", "必背数字"], "source": "安装教材精读笔记"}, {"id": "ch12-023", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "工程进度款支付比例'不低于60%、不高于90%'的规定，其依据主要是（ ）。", "options": {"A": "GB 50500-2013", "B": "GB/T 50856-2024", "C": "2018广东安装定额", "D": "施工合同示范文本"}, "answer": ["A"], "analysis": "该比例规定出自《建设工程工程量清单计价规范》GB 50500-2013。", "tags": ["进度款支付", "依据"], "source": "安装教材精读笔记"}, {"id": "ch12-024", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于工程进度款支付，下列说法正确的有（ ）。", "options": {"A": "支付比例不低于60%", "B": "支付比例不高于90%", "C": "发包人应在约定时间核实", "D": "承包人无需提交支付申请", "E": "按期中结算价款总额计"}, "answer": ["A", "B", "C", "E"], "analysis": "进度款支付需承包人提交申请、发包人按约定时间核实并签发支付证书，比例60%~90%，按期中结算价款总额计。", "tags": ["进度款支付"], "source": "安装教材精读笔记"}, {"id": "ch12-025", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "进度款支付比例超过90%上限的部分，通常应当（ ）。", "options": {"A": "照常支付", "B": "不予本期支付，留待竣工结算", "C": "由承包人承担", "D": "计入预付款"}, "answer": ["B"], "analysis": "超过90%的部分一般作为保留，待竣工结算时处理，以控制发包人支付风险。", "tags": ["进度款支付"], "source": "安装教材精读笔记"}, {"id": "ch12-026", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "采用按月结算时，关于进度款下列说法正确的有（ ）。", "options": {"A": "每月结算", "B": "支付比例60%~90%", "C": "需计量已完工程", "D": "必须竣工后付款", "E": "比例可超过95%"}, "answer": ["A", "B", "C"], "analysis": "按月结算每月计量并支付进度款，比例60%~90%，并非竣工后付款，也不得超过95%。", "tags": ["进度款支付", "按月结算"], "source": "安装教材精读笔记"}, {"id": "ch12-027", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "工程进度款支付申请中，承包人向发包人提交的是（ ）。", "options": {"A": "竣工结算书", "B": "进度款支付申请", "C": "招标文件", "D": "设计图纸"}, "answer": ["B"], "analysis": "承包人应在每个计量周期到期后向发包人提交进度款支付申请。", "tags": ["进度款支付"], "source": "安装教材精读笔记"}, {"id": "ch12-028", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "进度款支付涉及的主要环节包括（ ）。", "options": {"A": "承包人提交支付申请", "B": "发包人核实计量", "C": "签发支付证书", "D": "支付款项", "E": "竣工审计"}, "answer": ["A", "B", "C", "D"], "analysis": "进度款支付环节：申请→核实计量→签发支付证书→支付；竣工审计非进度款环节。", "tags": ["进度款支付"], "source": "安装教材精读笔记"}, {"id": "ch12-029", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "规定工程进度款支付比例'不低于60%、不高于90%'的主要意义包括（ ）。", "options": {"A": "保障承包人合理资金周转", "B": "控制发包人资金支付风险", "C": "取消工程结算", "D": "提高工程预付款比例"}, "answer": ["A", "B"], "analysis": "该区间既保障承包人资金周转，又控制发包人超付风险；不取消结算，也不直接提高预付款。", "tags": ["进度款支付", "必背数字"], "source": "安装教材精读笔记"}, {"id": "ch12-030", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于进度款支付比例的边界，下列说法正确的有（ ）。", "options": {"A": "下限为60%", "B": "上限为90%", "C": "不得低于下限", "D": "可以突破上限由双方任意约定", "E": "按期中结算价款总额计"}, "answer": ["A", "B", "C", "E"], "analysis": "进度款比例不低于60%、不高于90%，按期中结算价款总额计；一般规定下不应突破上限。", "tags": ["进度款支付", "必背数字"], "source": "安装教材精读笔记"}, {"id": "ch12-031", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "发包人认为需要进行现场计量核价的，应提前（ ）小时通知承包人。（2022年真题）", "options": {"A": "7", "B": "12", "C": "24", "D": "48"}, "answer": ["C"], "analysis": "发包人需现场计量核价时，应在计量前24小时通知承包人。", "tags": ["现场计量", "必背数字"], "source": "广东二级造价师安装专业历年真题精华版"}, {"id": "ch12-032", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "发包人进行现场计量核价时，应提前通知承包人的时间是（ ）。", "options": {"A": "12小时", "B": "24小时", "C": "48小时", "D": "3天"}, "answer": ["B"], "analysis": "现场计量核价应提前24小时通知承包人。", "tags": ["现场计量", "必背数字"], "source": "安装教材精读笔记"}, {"id": "ch12-033", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "发包人进行现场计量核价时，承包人应当（ ）。", "options": {"A": "拒绝参加", "B": "为计量提供便利条件并派人参加", "C": "仅提供图纸", "D": "无需到场"}, "answer": ["B"], "analysis": "承包人应为计量提供便利条件并派人参加。", "tags": ["现场计量"], "source": "安装教材精读笔记"}, {"id": "ch12-034", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "若承包人未按通知时间派人参加现场计量，则（ ）。", "options": {"A": "计量结果无效", "B": "发包人的计量结果有效", "C": "需重新计量", "D": "延期计量"}, "answer": ["B"], "analysis": "承包人未按时参加，发包人的单方计量结果仍有效。", "tags": ["现场计量"], "source": "安装教材精读笔记"}, {"id": "ch12-035", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "发包人需对工程进行计量核价时，应提前通知的对象是（ ）。", "options": {"A": "监理人", "B": "承包人", "C": "设计单位", "D": "造价管理机构"}, "answer": ["B"], "analysis": "计量核价通知的对象是承包人。", "tags": ["现场计量"], "source": "安装教材精读笔记"}, {"id": "ch12-036", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于现场计量核价，下列说法正确的有（ ）。", "options": {"A": "发包人应提前24小时通知承包人", "B": "承包人应提供便利并派人参加", "C": "承包人未参加计量结果仍有效", "D": "发包人可自行计量无需通知", "E": "通知时间由承包人确定"}, "answer": ["A", "B", "C"], "analysis": "计量前24小时通知承包人，承包人参加；未参加结果仍有效；不能无需通知或承包人定时间。", "tags": ["现场计量", "必背数字"], "source": "安装教材精读笔记"}, {"id": "ch12-037", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "工程计量应遵循的原则包括（ ）。", "options": {"A": "按合同约定计量", "B": "计量前通知承包人", "C": "以设计图示尺寸为准", "D": "发包人单方决定", "E": "无需复核"}, "answer": ["A", "B", "C"], "analysis": "工程计量按合同、提前通知、以设计图示为准；非发包人单方决定，也需复核。", "tags": ["现场计量", "工程计量"], "source": "安装教材精读笔记"}, {"id": "ch12-038", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "现场计量核价通知提前24小时的时间要求，其依据主要来自（ ）。", "options": {"A": "2018广东安装定额", "B": "建设工程造价管理/清单计价规范", "C": "施工图纸", "D": "招标文件"}, "answer": ["B"], "analysis": "计量通知24小时规定出自建设工程造价管理相关规范。", "tags": ["现场计量", "依据"], "source": "安装教材精读笔记"}, {"id": "ch12-039", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "发包人进行现场计量核价前提前24小时通知承包人，其目的包括（ ）。", "options": {"A": "让承包人做好计量准备", "B": "双方共同到场确认工程量", "C": "故意拖延工程付款", "D": "替代竣工结算"}, "answer": ["A", "B"], "analysis": "提前通知旨在让承包人准备并共同确认工程量，而非拖延付款或替代结算。", "tags": ["现场计量", "必背数字"], "source": "安装教材精读笔记"}, {"id": "ch12-040", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "下列属于现场计量核价程序环节的有（ ）。", "options": {"A": "发包人提前24小时通知", "B": "承包人派人参加", "C": "共同确认工程量", "D": "发包人单方闭门计量", "E": "形成计量结果"}, "answer": ["A", "B", "C", "E"], "analysis": "程序：通知→承包人参加→共同确认→形成结果；非发包人单方闭门计量。", "tags": ["现场计量"], "source": "安装教材精读笔记"}, {"id": "ch12-041", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "若发包人不按约定提前通知承包人即进行计量，则该计量结果承包人（ ）。", "options": {"A": "必须认可", "B": "可不予认可", "C": "自动有效", "D": "视同结算"}, "answer": ["B"], "analysis": "未提前通知的计量，承包人可不予认可。", "tags": ["现场计量"], "source": "安装教材精读笔记"}, {"id": "ch12-042", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于工程量计量与进度款的关系，下列说法正确的有（ ）。", "options": {"A": "计量是支付进度款的基础", "B": "计量需通知承包人", "C": "计量结果作为期中结算依据", "D": "进度款按计量结果支付", "E": "计量无需依据合同"}, "answer": ["A", "B", "C", "D"], "analysis": "计量是进度款支付基础，需通知承包人、依合同进行，其结果作为期中结算与支付依据。", "tags": ["现场计量", "进度款支付"], "source": "安装教材精读笔记"}, {"id": "ch12-043", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "现场计量核价中，承包人应为计量提供（ ）。", "options": {"A": "资金担保", "B": "便利条件", "C": "垫资", "D": "设计变更"}, "answer": ["B"], "analysis": "承包人有义务为发包人的现场计量核价提供便利条件。", "tags": ["现场计量"], "source": "安装教材精读笔记"}, {"id": "ch12-044", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "根据合同价款调整规定，工程量偏差超过（ ）时，应对综合单价进行调整。", "options": {"A": "5%", "B": "10%", "C": "15%", "D": "20%"}, "answer": ["C"], "analysis": "工程量偏差超过15%时，调整综合单价。", "tags": ["工程量偏差", "必背数字"], "source": "安装教材精读笔记"}, {"id": "ch12-045", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "当实际完成的工程量比招标清单工程量增加超过15%时，对超出部分的综合单价应（ ）。", "options": {"A": "调高", "B": "调低", "C": "不变", "D": "由发包人定"}, "answer": ["B"], "analysis": "增加超过15%时，超出部分的综合单价应予调低。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-046", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "当实际完成的工程量比招标清单工程量减少超过15%时，对剩余部分的综合单价应（ ）。", "options": {"A": "调高", "B": "调低", "C": "不变", "D": "取消"}, "answer": ["A"], "analysis": "减少超过15%时，减少后剩余部分的综合单价应予调高。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-047", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "工程量偏差调整中，判断'增加超过15%'的比较基准是（ ）。", "options": {"A": "合同总价", "B": "清单工程量×(1+15%)", "C": "设计工程量", "D": "定额工程量"}, "answer": ["B"], "analysis": "以清单工程量×(1+15%)为调价分界点。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-048", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "工程量偏差调整中，减少超过15%时，综合单价调高适用于（ ）。", "options": {"A": "全部清单工程量", "B": "实际完成（减少后剩余）部分的工程量", "C": "超出15%的部分", "D": "合同工程量"}, "answer": ["B"], "analysis": "减少超过15%时，对减少后剩余部分的工程量综合单价调高。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-049", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "某清单项目工程量100个、综合单价100元，实际完成130个（增加30%）。超出15%的部分为（ ）。", "options": {"A": "15个", "B": "30个", "C": "130个", "D": "100个"}, "answer": ["A"], "analysis": "100×1.15=115个，超出部分=130-115=15个。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-050", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "接上题，超出15%部分的综合单价应（ ）。", "options": {"A": "按原单价100元", "B": "调低，低于100元", "C": "调高，高于100元", "D": "不计价"}, "answer": ["B"], "analysis": "增加超15%的超出部分综合单价应予调低。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-051", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "某清单项目工程量100个、综合单价100元，实际完成80个（减少20%）。则应（ ）。", "options": {"A": "全部按100元", "B": "剩余80个综合单价调高", "C": "综合单价调低", "D": "不结算"}, "answer": ["B"], "analysis": "减少20%>15%，剩余80个的综合单价应予调高。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-052", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "工程量偏差超过15%时，调整的对象是（ ）。", "options": {"A": "工程量", "B": "综合单价", "C": "规费", "D": "税金"}, "answer": ["B"], "analysis": "工程量偏差调整的是综合单价，而非工程量本身或规费税金。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-053", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于工程量偏差调整，下列说法正确的有（ ）。", "options": {"A": "偏差超过15%时调整", "B": "增加超15%的超出部分单价调低", "C": "减少超15%的剩余部分单价调高", "D": "所有偏差都调整", "E": "不调整单价"}, "answer": ["A", "B", "C"], "analysis": "仅当偏差超过15%才调整单价：增加超出部分调低、减少剩余部分调高。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-054", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "工程量偏差超过15%的情形可能由（ ）引起。", "options": {"A": "设计变更", "B": "工程量清单漏算", "C": "施工图纸变化", "D": "物价上涨", "E": "法规变化"}, "answer": ["A", "B", "C"], "analysis": "工程量偏差多因设计/图纸变更或清单漏算；物价上涨、法规变化属其他调整因素。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-055", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "工程量偏差调整中，若实际工程量等于清单工程量，则（ ）。", "options": {"A": "必须调整", "B": "不调整，按原单价", "C": "调低", "D": "调高"}, "answer": ["B"], "analysis": "无偏差则不调整综合单价。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-056", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "工程量偏差超过15%调整综合单价的规则，适用于（ ）。", "options": {"A": "仅单价合同", "B": "实行工程量清单计价的工程", "C": "仅总价合同", "D": "仅政府工程"}, "answer": ["B"], "analysis": "该规则适用于实行工程量清单计价的工程。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-057", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "当工程量增加但未超过15%时，综合单价（ ）。", "options": {"A": "调低", "B": "调高", "C": "不作调整", "D": "重新组价"}, "answer": ["C"], "analysis": "未超过15%阈值不调整综合单价。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-058", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "当工程量减少但未超过15%时，综合单价（ ）。", "options": {"A": "调低", "B": "调高", "C": "不作调整", "D": "取消"}, "answer": ["C"], "analysis": "未超过15%阈值不调整综合单价。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-059", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "工程量偏差调整时，综合单价调整的原则包括（ ）。", "options": {"A": "增加超15%部分调低", "B": "减少超15%剩余部分调高", "C": "未超15%不调整", "D": "全部调高", "E": "全部调低"}, "answer": ["A", "B", "C"], "analysis": "调整原则：超出部分调低、剩余部分调高、未超阈值不调。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-060", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "工程量偏差超过15%而调整合同价款，属于（ ）调整因素。", "options": {"A": "项目特征不符", "B": "工程量偏差", "C": "物价变化", "D": "法规变化"}, "answer": ["B"], "analysis": "工程量偏差超15%是合同价款调整四大因素之一。", "tags": ["工程量偏差", "合同价款调整"], "source": "安装教材精读笔记"}, {"id": "ch12-061", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "下列属于工程量偏差调整计算要点的有（ ）。", "options": {"A": "确定清单工程量Q0", "B": "确定实际工程量Q1", "C": "比较是否超15%", "D": "调整超出/剩余部分单价", "E": "重算规费"}, "answer": ["A", "B", "C", "D"], "analysis": "计算要点：Q0、Q1、与15%比较、调整相应部分单价；规费一般不因此重算。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-062", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "工程量偏差调整中，当工程量增加超过15%时对超出部分综合单价予以调低，这体现了（ ）。", "options": {"A": "平衡因量增加带来的总价上涨", "B": "发承包双方风险合理分担", "C": "惩罚承包人", "D": "固定单价的绝对不变"}, "answer": ["A", "B"], "analysis": "调低超出部分单价可平衡总价、合理分担风险，并非惩罚或否定单价机制。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-063", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "下列关于工程量偏差的说法，错误的是（ ）。", "options": {"A": "阈值15%", "B": "超阈值调整综合单价", "C": "增加超15%超出部分调低", "D": "减少超15%全部工程调低"}, "answer": ["D"], "analysis": "减少超15%时，是对剩余部分调高，而非全部工程调低。", "tags": ["工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-064", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "合同履行期间，出现招标工程量清单项目特征描述与（ ）不符时，应按实际施工的项目特征重新确定综合单价。", "options": {"A": "招标文件", "B": "设计图纸", "C": "施工组织设计", "D": "定额"}, "answer": ["B"], "analysis": "项目特征以设计图纸（实际施工）为准。", "tags": ["项目特征不符"], "source": "安装教材精读笔记"}, {"id": "ch12-065", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "'工程量清单项目特征描述不符'属于合同价款调整四大因素之一，下列同样属于四大调整因素的有（ ）。", "options": {"A": "工程量偏差超过15%", "B": "物价变化超过合同约定幅度", "C": "法规变化", "D": "承包人自身管理水平不足"}, "answer": ["A", "B", "C"], "analysis": "四大因素：项目特征不符、工程量偏差超15%、物价变化超约定幅度、法规变化。", "tags": ["项目特征不符", "合同价款调整"], "source": "安装教材精读笔记"}, {"id": "ch12-066", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "项目特征描述不符导致合同价款调整，属于（ ）调整因素。", "options": {"A": "工程量偏差", "B": "项目特征不符", "C": "物价变化", "D": "法规变化"}, "answer": ["B"], "analysis": "项目特征不符是四大调整因素之一。", "tags": ["项目特征不符", "合同价款调整"], "source": "安装教材精读笔记"}, {"id": "ch12-067", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "招标工程量清单中项目特征描述与设计图纸不符，应以（ ）为准确定综合单价。", "options": {"A": "清单描述", "B": "设计图纸（实际施工）", "C": "定额", "D": "投标人理解"}, "answer": ["B"], "analysis": "应以设计要求（实际施工特征）为准重新确定单价。", "tags": ["项目特征不符"], "source": "安装教材精读笔记"}, {"id": "ch12-068", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "施工过程中，施工图纸与招标工程量清单项目特征描述不符，综合单价应（ ）。", "options": {"A": "不变", "B": "按实际施工的项目特征重新确定", "C": "由发包人定", "D": "按清单价"}, "answer": ["B"], "analysis": "应按实际施工的项目特征重新确定综合单价。", "tags": ["项目特征不符"], "source": "安装教材精读笔记"}, {"id": "ch12-069", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于项目特征不符调整，下列说法正确的有（ ）。", "options": {"A": "以设计要求为准", "B": "按实际施工特征重新确定单价", "C": "属合同价款调整因素", "D": "由承包人承担差价", "E": "不需调整"}, "answer": ["A", "B", "C"], "analysis": "项目特征不符以设计为准重新组价，属调整因素；差价并非一概由承包人承担。", "tags": ["项目特征不符"], "source": "安装教材精读笔记"}, {"id": "ch12-070", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "下列情形中，可能引起综合单价按'项目特征不符'调整的有（ ）。", "options": {"A": "清单描述材质与图纸不符", "B": "清单规格与图纸不符", "C": "清单工艺与图纸不符", "D": "工程量偏差", "E": "物价上涨"}, "answer": ["A", "B", "C"], "analysis": "材质、规格、工艺等特征与图纸不符属于项目特征不符；工程量偏差、物价上涨属其他因素。", "tags": ["项目特征不符"], "source": "安装教材精读笔记"}, {"id": "ch12-071", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "项目特征不符调整价款，本质上是因（ ）变化引起的计价调整。", "options": {"A": "工程量", "B": "工程内容/特征", "C": "物价", "D": "法规"}, "answer": ["B"], "analysis": "项目特征不符是因工程特征变化引起的单价调整。", "tags": ["项目特征不符"], "source": "安装教材精读笔记"}, {"id": "ch12-072", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "项目特征描述通常应包括的内容有（ ）。", "options": {"A": "材料材质", "B": "规格型号", "C": "连接方式", "D": "施工工艺", "E": "工程量大小"}, "answer": ["A", "B", "C", "D"], "analysis": "项目特征描述材质、规格、连接方式、施工工艺等；工程量大小不属于项目特征。", "tags": ["项目特征不符"], "source": "安装教材精读笔记"}, {"id": "ch12-073", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "项目特征不符引起价款调整的前提是（ ）。", "options": {"A": "工程量增加", "B": "清单特征与图纸/实际施工不符", "C": "物价上涨", "D": "法规变化"}, "answer": ["B"], "analysis": "前提是清单特征描述与实际施工/图纸不符。", "tags": ["项目特征不符"], "source": "安装教材精读笔记"}, {"id": "ch12-074", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "下列关于项目特征不符的说法，正确的是（ ）。", "options": {"A": "不影响综合单价", "B": "应以清单描述为准", "C": "应按实际施工特征重新确定单价", "D": "由承包人承担"}, "answer": ["C"], "analysis": "应按实际施工的项目特征重新确定综合单价。", "tags": ["项目特征不符"], "source": "安装教材精读笔记"}, {"id": "ch12-075", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "判定'项目特征不符'调整因素的依据包括（ ）。", "options": {"A": "招标工程量清单", "B": "设计图纸", "C": "实际施工情况", "D": "物价指数", "E": "法规文件"}, "answer": ["A", "B", "C"], "analysis": "依据招标清单、设计图纸与实际施工对比；物价指数、法规文件属其他因素。", "tags": ["项目特征不符"], "source": "安装教材精读笔记"}, {"id": "ch12-076", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "合同履行期间，因物价变化引起价款调整，当材料、工程设备单价变化超过（ ）时调整。", "options": {"A": "合同约定幅度", "B": "5%", "C": "10%", "D": "15%"}, "answer": ["A"], "analysis": "物价变化调整以合同约定幅度为阈值，而非固定百分比。", "tags": ["物价变化"], "source": "安装教材精读笔记"}, {"id": "ch12-077", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "'物价变化超过合同约定幅度'属于合同价款调整四大因素之一，下列同样属于四大调整因素的有（ ）。", "options": {"A": "工程量清单项目特征描述不符", "B": "工程量偏差超过15%", "C": "法规变化", "D": "承包人施工工艺改进"}, "answer": ["A", "B", "C"], "analysis": "四大因素：项目特征不符、工程量偏差超15%、物价变化超约定幅度、法规变化。", "tags": ["物价变化", "合同价款调整"], "source": "安装教材精读笔记"}, {"id": "ch12-078", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "物价变化导致合同价款调整，属于（ ）调整因素。", "options": {"A": "项目特征不符", "B": "工程量偏差", "C": "物价变化", "D": "法规变化"}, "answer": ["C"], "analysis": "物价变化是四大调整因素之一。", "tags": ["物价变化", "合同价款调整"], "source": "安装教材精读笔记"}, {"id": "ch12-079", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "采用价格指数调整合同价款的方法称为（ ）。", "options": {"A": "造价信息差额调整法", "B": "价格指数调整法", "C": "实际价格法", "D": "平均法"}, "answer": ["B"], "analysis": "采用价格调整公式（价格指数）的方法为价格指数调整法。", "tags": ["物价变化"], "source": "安装教材精读笔记"}, {"id": "ch12-080", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "采用造价信息差额调整法时，主要依据（ ）调整价差。", "options": {"A": "价格指数公式", "B": "工程造价管理机构发布的信息价格", "C": "承包人报价", "D": "定额价"}, "answer": ["B"], "analysis": "造价信息差额调整法以造价管理机构发布的信息价为依据。", "tags": ["物价变化"], "source": "安装教材精读笔记"}, {"id": "ch12-081", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "物价变化调整中，承包人采购的材料单价变化超过约定幅度时，超过部分（ ）。", "options": {"A": "不予调整", "B": "按合同约定调整", "C": "由承包人承担", "D": "由发包人全部承担"}, "answer": ["B"], "analysis": "超约定幅度的部分按合同约定调整。", "tags": ["物价变化"], "source": "安装教材精读笔记"}, {"id": "ch12-082", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于物价变化调整，下列说法正确的有（ ）。", "options": {"A": "超过合同约定幅度才调整", "B": "方法有价格指数调整法", "C": "方法有造价信息差额调整法", "D": "由发包人单方承担", "E": "与合同约定无关"}, "answer": ["A", "B", "C"], "analysis": "物价变化超约定幅度才调，方法为价格指数法和造价信息差额法，依合同执行。", "tags": ["物价变化"], "source": "安装教材精读笔记"}, {"id": "ch12-083", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "物价变化调整合同价款的两种主要方法是（ ）。", "options": {"A": "价格指数调整法", "B": "造价信息差额调整法", "C": "总费用法", "D": "实际费用法", "E": "法规调整法"}, "answer": ["A", "B"], "analysis": "物价变化调整两大方法：价格指数调整法、造价信息差额调整法。", "tags": ["物价变化"], "source": "安装教材精读笔记"}, {"id": "ch12-084", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "价格指数调整法通常使用（ ）计算价差。", "options": {"A": "价格调整公式（调值公式）", "B": "信息价差额", "C": "定额价", "D": "投标价"}, "answer": ["A"], "analysis": "价格指数法用调值公式计算价差。", "tags": ["物价变化"], "source": "安装教材精读笔记"}, {"id": "ch12-085", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "物价变化调整的风险幅度一般由（ ）约定。", "options": {"A": "政府强制固定为5%", "B": "合同双方", "C": "定额", "D": "造价站统一规定"}, "answer": ["B"], "analysis": "风险幅度由合同双方约定。", "tags": ["物价变化"], "source": "安装教材精读笔记"}, {"id": "ch12-086", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "下列情形中，属于物价变化调整范围的是（ ）。", "options": {"A": "人工、材料、机械价格变化超约定幅度", "B": "工程量偏差", "C": "项目特征不符", "D": "法规变化"}, "answer": ["A"], "analysis": "人工、材料、机械价格超约定幅度属物价变化调整。", "tags": ["物价变化"], "source": "安装教材精读笔记"}, {"id": "ch12-087", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于造价信息差额调整法，下列说法正确的有（ ）。", "options": {"A": "依据造价信息价", "B": "计算承包人与基准价的差额", "C": "超约定幅度部分调整", "D": "适用于材料设备价格波动", "E": "与价格指数法完全相同"}, "answer": ["A", "B", "C", "D"], "analysis": "该法以信息价为据计算差额、超幅度调整，适用于材料设备价波动；与价格指数法不同。", "tags": ["物价变化"], "source": "安装教材精读笔记"}, {"id": "ch12-088", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "物价变化调整中，基准价格一般指（ ）。", "options": {"A": "施工期市场价", "B": "投标报价中的价格或合同约定基准", "C": "竣工结算价", "D": "定额价"}, "answer": ["B"], "analysis": "基准价为投标报价或合同约定的基准价格。", "tags": ["物价变化"], "source": "安装教材精读笔记"}, {"id": "ch12-089", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "因物价变化调整的合同价款，通常计入（ ）。", "options": {"A": "规费", "B": "合同价款调整额", "C": "税金", "D": "暂列金额余额"}, "answer": ["B"], "analysis": "物价变化调整额计入合同价款调整。", "tags": ["物价变化"], "source": "安装教材精读笔记"}, {"id": "ch12-090", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "下列属于物价变化引起的合同价款调整因素的有（ ）。", "options": {"A": "材料价格上涨超约定幅度", "B": "机械台班单价上涨超约定幅度", "C": "人工费上涨超约定幅度", "D": "项目特征不符", "E": "法规变化"}, "answer": ["A", "B", "C"], "analysis": "人工、材料、机械价格超约定幅度属物价变化；项目特征不符、法规变化属其他因素。", "tags": ["物价变化"], "source": "安装教材精读笔记"}, {"id": "ch12-091", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "物价变化调整与法规变化调整的主要区别在于（ ）。", "options": {"A": "前者因市场价格波动、后者因法律政策变化", "B": "二者完全相同", "C": "前者不调整", "D": "后者不调整"}, "answer": ["A"], "analysis": "物价变化因市场价格波动，法规变化因法律政策变化。", "tags": ["物价变化", "法规变化"], "source": "安装教材精读笔记"}, {"id": "ch12-093", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "因国家法律、法规、规章和政策变化影响工程造价需调整合同价款，其基准日对招标工程为（ ）。", "options": {"A": "合同签订前28天", "B": "投标截止日前28天", "C": "开工前28天", "D": "竣工前28天"}, "answer": ["B"], "analysis": "招标工程基准日为投标截止日前28天。", "tags": ["法规变化"], "source": "安装教材精读笔记"}, {"id": "ch12-094", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "非招标工程的合同价款调整基准日为（ ）。", "options": {"A": "投标截止日前28天", "B": "合同签订前28天", "C": "开工前28天", "D": "图纸会审前28天"}, "answer": ["B"], "analysis": "非招标工程基准日为合同签订前28天。", "tags": ["法规变化"], "source": "安装教材精读笔记"}, {"id": "ch12-095", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "'法规变化'属于合同价款调整四大因素之一，下列同样属于四大调整因素的有（ ）。", "options": {"A": "工程量清单项目特征描述不符", "B": "工程量偏差超过15%", "C": "物价变化超过合同约定幅度", "D": "工期压缩超过20%"}, "answer": ["A", "B", "C"], "analysis": "四大因素：项目特征不符、工程量偏差超15%、物价变化超约定幅度、法规变化。", "tags": ["法规变化", "合同价款调整"], "source": "安装教材精读笔记"}, {"id": "ch12-096", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "法规变化引起合同价款调整，属于（ ）调整因素。", "options": {"A": "项目特征不符", "B": "工程量偏差", "C": "物价变化", "D": "法规变化"}, "answer": ["D"], "analysis": "法规变化是四大调整因素之一。", "tags": ["法规变化", "合同价款调整"], "source": "安装教材精读笔记"}, {"id": "ch12-097", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "招标工程合同价款调整的基准日是（ ）。", "options": {"A": "投标截止日前28天", "B": "中标通知书发出日", "C": "开工日", "D": "合同签订日"}, "answer": ["A"], "analysis": "招标工程基准日为投标截止日前28天。", "tags": ["法规变化"], "source": "安装教材精读笔记"}, {"id": "ch12-098", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于法规变化调整，下列说法正确的有（ ）。", "options": {"A": "基准日之后变化才调整", "B": "招标工程基准日为投标截止日前28天", "C": "非招标工程为合同签订前28天", "D": "按省级部门规定调整", "E": "由承包人承担"}, "answer": ["A", "B", "C", "D"], "analysis": "基准日之后变化才调，基准日分招标/非招标，按省级或行业主管部门规定调整。", "tags": ["法规变化"], "source": "安装教材精读笔记"}, {"id": "ch12-099", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "下列属于法规变化调整适用情形的有（ ）。", "options": {"A": "国家税法变化", "B": "工程造价规费标准变化", "C": "环保政策导致费用增加", "D": "材料涨价", "E": "工程量偏差"}, "answer": ["A", "B", "C"], "analysis": "法律、规费标准、政策变化属法规变化；材料涨价、工程量偏差属其他因素。", "tags": ["法规变化"], "source": "安装教材精读笔记"}, {"id": "ch12-100", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "基准日之前已发布的法规变化，合同价款（ ）。", "options": {"A": "必须调整", "B": "不予调整（已含在报价中）", "C": "全部调增", "D": "全部调减"}, "answer": ["B"], "analysis": "基准日前的法规变化承包人投标时已考虑，不予调整。", "tags": ["法规变化"], "source": "安装教材精读笔记"}, {"id": "ch12-101", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "法规变化调整所依据的文件通常由（ ）发布。", "options": {"A": "企业", "B": "省级或行业建设主管部门/授权造价管理机构", "C": "项目部", "D": "监理单位"}, "answer": ["B"], "analysis": "依据省级或行业建设主管部门或其授权造价管理机构发布的规定。", "tags": ["法规变化"], "source": "安装教材精读笔记"}, {"id": "ch12-102", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "合同价款调整四大因素中，属于'法规变化'范畴的有（ ）。", "options": {"A": "国家法律变化", "B": "行政法规变化", "C": "部门规章变化", "D": "政策性变化", "E": "物价波动"}, "answer": ["A", "B", "C", "D"], "analysis": "国家法律、法规、规章及政策性变化均属法规变化；物价波动属物价变化。", "tags": ["法规变化"], "source": "安装教材精读笔记"}, {"id": "ch12-103", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "法规变化与物价变化调整的共同点是（ ）。", "options": {"A": "都不调整", "B": "均属合同价款调整因素", "C": "均由承包人承担", "D": "均不计利息"}, "answer": ["B"], "analysis": "二者均为合同价款调整因素。", "tags": ["法规变化", "物价变化"], "source": "安装教材精读笔记"}, {"id": "ch12-104", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "基准日的主要作用是（ ）。", "options": {"A": "确定开工时间", "B": "划分风险，判断法规变化是否调整价款", "C": "确定工期", "D": "确定质量等级"}, "answer": ["B"], "analysis": "基准日用于划分风险，判断后续法规变化是否调整价款。", "tags": ["法规变化"], "source": "安装教材精读笔记"}, {"id": "ch12-105", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "工程发包时，招标人压缩的工期不得超过定额工期的（ ）。", "options": {"A": "10%", "B": "20%", "C": "30%", "D": "50%"}, "answer": ["B"], "analysis": "压缩工期不得超过定额工期的20%。", "tags": ["工期压缩", "必背数字"], "source": "安装教材精读笔记"}, {"id": "ch12-106", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "招标人压缩工期超过定额工期20%的，应在招标文件中（ ）。", "options": {"A": "不予处理", "B": "明示增加赶工费用", "C": "降低质量标准", "D": "取消工期要求"}, "answer": ["B"], "analysis": "超过20%应在招标文件中明示增加赶工费用。", "tags": ["工期压缩"], "source": "安装教材精读笔记"}, {"id": "ch12-107", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "工期压缩超过规定上限时，增加的费用称为（ ）。", "options": {"A": "违约金", "B": "赶工费用（赶工补偿）", "C": "预付款", "D": "质量保证金"}, "answer": ["B"], "analysis": "超限额压缩工期增加的费用为赶工费用（赶工补偿）。", "tags": ["工期压缩"], "source": "安装教材精读笔记"}, {"id": "ch12-108", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于工期压缩上限'不超过定额工期20%'的规定，下列说法正确的有（ ）。", "options": {"A": "招标人压缩工期不得超过定额工期的20%", "B": "超过20%应在招标文件中明示增加赶工费用", "C": "可以无限制压缩工期", "D": "超过20%无需补偿"}, "answer": ["A", "B"], "analysis": "压缩不得超过定额工期20%，超20%须明示增加赶工费。", "tags": ["工期压缩", "必背数字"], "source": "安装教材精读笔记"}, {"id": "ch12-109", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于工期压缩与赶工补偿，下列说法正确的有（ ）。", "options": {"A": "压缩不得超过定额工期20%", "B": "超20%应增加赶工费用", "C": "赶工费用计入合同价款", "D": "可无限制压缩", "E": "与价款无关"}, "answer": ["A", "B", "C"], "analysis": "压缩≤20%，超20%增加赶工费并计入合同价款；不可无限制压缩。", "tags": ["工期压缩"], "source": "安装教材精读笔记"}, {"id": "ch12-110", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "招标人要求缩短工期时，正确的做法是（ ）。", "options": {"A": "压缩不超过定额工期20%", "B": "超20%在招标文件明示赶工费", "C": "保障工程质量安全", "D": "任意压缩", "E": "不补偿"}, "answer": ["A", "B", "C"], "analysis": "缩短工期应≤20%、超20%明示赶工费、保障质量安全。", "tags": ["工期压缩"], "source": "安装教材精读笔记"}, {"id": "ch12-111", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "赶工费用本质上属于（ ）引起的费用增加。", "options": {"A": "物价变化", "B": "工期压缩（提前竣工）", "C": "法规变化", "D": "工程量偏差"}, "answer": ["B"], "analysis": "赶工费因工期压缩/提前竣工引起。", "tags": ["工期压缩"], "source": "安装教材精读笔记"}, {"id": "ch12-112", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于'定额工期'的理解，下列说法正确的有（ ）。", "options": {"A": "是按国家/行业定额标准计算的工期", "B": "是判断工期压缩是否超20%的基准", "C": "等同于合同约定工期", "D": "等同于工程实际工期"}, "answer": ["A", "B"], "analysis": "定额工期按定额标准计算，是压缩上限的基准；不等同合同工期或实际工期。", "tags": ["工期压缩"], "source": "安装教材精读笔记"}, {"id": "ch12-113", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "下列关于工期压缩的说法，正确的有（ ）。", "options": {"A": "不得超过定额工期20%", "B": "超过需增加赶工费", "C": "应保证工程质量安全", "D": "可由发包人任意决定", "E": "与合同价款无关"}, "answer": ["A", "B", "C"], "analysis": "压缩≤20%、超20%增加赶工费、保证质量安全；非发包人任意决定。", "tags": ["工期压缩"], "source": "安装教材精读笔记"}, {"id": "ch12-114", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "工期压缩上限'≤20%'的规定，主要目的是（ ）。", "options": {"A": "加快进度", "B": "防止盲目赶工影响质量安全和合理造价", "C": "节省投资", "D": "简化招标"}, "answer": ["B"], "analysis": "规定上限是为防止盲目赶工影响质量安全与合理造价。", "tags": ["工期压缩"], "source": "安装教材精读笔记"}, {"id": "ch12-115", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "根据规定，合同价款调整的主要因素包括（ ）。", "options": {"A": "工程量清单项目特征描述不符", "B": "工程量偏差超过15%", "C": "物价变化超过合同约定幅度", "D": "法规变化", "E": "承包人管理水平"}, "answer": ["A", "B", "C", "D"], "analysis": "四大因素：项目特征不符、工程量偏差超15%、物价变化超约定幅度、法规变化。", "tags": ["合同价款调整"], "source": "安装教材精读笔记"}, {"id": "ch12-116", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "下列情形中，不属于合同价款调整四大因素的是（ ）。", "options": {"A": "项目特征不符", "B": "工程量偏差超15%", "C": "物价变化超约定幅度", "D": "承包人自身管理不善"}, "answer": ["D"], "analysis": "承包人自身管理不善不属于法定调整因素。", "tags": ["合同价款调整"], "source": "安装教材精读笔记"}, {"id": "ch12-117", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "下列属于工程价款结算内容的有（ ）。", "options": {"A": "按月结算", "B": "分段结算", "C": "竣工后一次结算", "D": "进度款支付", "E": "合同价款调整"}, "answer": ["A", "B", "C", "D"], "analysis": "结算方式（按月/分段/竣工一次）与进度款支付属工程价款结算；合同价款调整单列。", "tags": ["结算方式", "进度款支付"], "source": "安装教材精读笔记"}, {"id": "ch12-118", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "合同价款调整四大因素中，与'量'直接相关的是（ ）。", "options": {"A": "项目特征不符", "B": "工程量偏差", "C": "物价变化", "D": "法规变化"}, "answer": ["B"], "analysis": "工程量偏差与工程量（量）直接相关。", "tags": ["合同价款调整", "工程量偏差"], "source": "安装教材精读笔记"}, {"id": "ch12-119", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "合同价款调整四大因素中，与'市场价格'直接相关的是（ ）。", "options": {"A": "项目特征不符", "B": "工程量偏差", "C": "物价变化", "D": "法规变化"}, "answer": ["C"], "analysis": "物价变化与市场价格波动直接相关。", "tags": ["合同价款调整", "物价变化"], "source": "安装教材精读笔记"}, {"id": "ch12-120", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "关于合同价款调整，下列说法正确的有（ ）。", "options": {"A": "发生调整因素应调整合同价款", "B": "调整需有依据", "C": "调整按合同约定或规定执行", "D": "承包人原因一概不调", "E": "仅物价可调"}, "answer": ["A", "B", "C"], "analysis": "发生调整因素应依合同/规定调整；并非仅物价可调，也非承包人原因一概不调（需具体分析）。", "tags": ["合同价款调整"], "source": "安装教材精读笔记"}, {"id": "ch12-121", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "工程价款结算与合同价款调整的关系是（ ）。", "options": {"A": "结算只付进度款，调整另算", "B": "价款调整结果纳入工程结算", "C": "互不影响", "D": "调整不计入结算"}, "answer": ["B"], "analysis": "合同价款调整的结果应纳入工程结算。", "tags": ["结算方式", "合同价款调整"], "source": "安装教材精读笔记"}, {"id": "ch12-122", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "属于进度款支付与结算管理要求的有（ ）。", "options": {"A": "支付比例60%~90%", "B": "计量提前24小时通知", "C": "按月/分段/竣工一次结算", "D": "偏差超15%调单价", "E": "工期压缩≤20%"}, "answer": ["A", "B", "C"], "analysis": "进度款支付比例、计量通知、结算方式属结算管理；偏差调单价、工期压缩属调整/赶工范畴。", "tags": ["进度款支付", "结算方式", "现场计量"], "source": "安装教材精读笔记"}, {"id": "ch12-123", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "在合同价款调整四大因素中，因'招标清单与图纸特征不一致'对应的是（ ）。", "options": {"A": "项目特征不符", "B": "工程量偏差", "C": "物价变化", "D": "法规变化"}, "answer": ["A"], "analysis": "清单与图纸特征不一致属项目特征不符。", "tags": ["项目特征不符", "合同价款调整"], "source": "安装教材精读笔记"}, {"id": "ch12-124", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "下列属于合同履行中需发承包双方确认的事项有（ ）。", "options": {"A": "现场计量核价", "B": "项目特征不符重新组价", "C": "工程量偏差调整", "D": "法规变化调价", "E": "承包人内部排班"}, "answer": ["A", "B", "C", "D"], "analysis": "计量、特征不符组价、偏差调整、法规调价均需双方确认；内部排班不需。", "tags": ["合同价款调整", "现场计量"], "source": "安装教材精读笔记"}, {"id": "ch12-125", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "合同价款调整一般应在（ ）中进行。", "options": {"A": "招标阶段", "B": "合同履行阶段", "C": "设计阶段", "D": "竣工后不可调"}, "answer": ["B"], "analysis": "合同价款调整发生在合同履行阶段。", "tags": ["合同价款调整"], "source": "安装教材精读笔记"}, {"id": "ch12-126", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "工程竣工结算时，应纳入结算的价款包括（ ）。", "options": {"A": "已付进度款对应的工程价款", "B": "合同价款调整增加额", "C": "合同价款调整减少额", "D": "质量保证金扣留", "E": "承包人利润分红"}, "answer": ["A", "B", "C", "D"], "analysis": "竣工结算汇总已完工程价款、调整增减额并扣留质保金；利润分红不纳入。", "tags": ["结算方式"], "source": "安装教材精读笔记"}, {"id": "ch12-127", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "根据教材，第12章'工程价款结算与合同价款调整'不包括以下哪项核心内容？（ ）", "options": {"A": "结算方式", "B": "进度款支付", "C": "合同价款调整因素", "D": "竣工决算编制"}, "answer": ["D"], "analysis": "竣工决算编制是第13章内容，不在第12章。", "tags": ["章节范围"], "source": "安装教材精读笔记"}, {"id": "ch12-128", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "进度款支付比例与工程量偏差阈值这两个必背数字分别是（ ）。", "options": {"A": "60%~90%", "B": "15%", "C": "24小时", "D": "20%", "E": "28天"}, "answer": ["A", "B"], "analysis": "进度款支付比例60%~90%，工程量偏差阈值15%。", "tags": ["必背数字"], "source": "安装教材精读笔记"}, {"id": "ch12-129", "date": "2026-07-06", "chapter": "ch12", "type": "single", "stem": "现场计量通知时间24小时与工期压缩上限20%，二者分别属于（ ）的管理要求。", "options": {"A": "进度款计量 / 工期与赶工", "B": "物价 / 法规", "C": "结算方式 / 特征", "D": "质保 / 预付款"}, "answer": ["A"], "analysis": "24小时属现场计量通知，20%属工期压缩/赶工管理。", "tags": ["必背数字", "现场计量", "工期压缩"], "source": "安装教材精读笔记"}, {"id": "ch12-130", "date": "2026-07-06", "chapter": "ch12", "type": "multiple", "stem": "总结：第12章应掌握的必背数字包括（ ）。", "options": {"A": "进度款支付比例60%~90%", "B": "现场计量通知24小时", "C": "工程量偏差阈值15%", "D": "工期压缩上限≤20%", "E": "预付款比例10%~30%"}, "answer": ["A", "B", "C", "D"], "analysis": "第12章必背数字：进度款60%~90%、计量通知24h、偏差阈值15%、工期压缩≤20%。", "tags": ["必背数字"], "source": "安装教材精读笔记"}, {"id": "ch13-001", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "根据《安装工程》教材，建设项目竣工决算的内容由四项组成，下列选项不属于竣工决算内容的是（ ）。", "options": {"A": "竣工财务决算报表", "B": "竣工财务决算说明书", "C": "竣工工程平面示意图", "D": "投标报价书"}, "answer": ["D"], "analysis": "竣工决算的内容包括：竣工财务决算报表、竣工财务决算说明书、竣工工程平面示意图、工程造价对比分析四项。投标报价书是招标阶段文件，不属于竣工决算内容。", "tags": ["竣工决算内容"], "source": "安装教材精读笔记"}, {"id": "ch13-002", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "竣工决算四项内容中，被称为竣工决算核心内容（即竣工财务决算）的是（ ）。", "options": {"A": "竣工财务决算报表和竣工财务决算说明书", "B": "竣工工程平面示意图和工程造价对比分析", "C": "竣工财务决算报表和工程造价对比分析", "D": "竣工财务决算说明书和竣工工程平面示意图"}, "answer": ["A"], "analysis": "竣工财务决算说明书和竣工财务决算报表合称竣工财务决算，是竣工决算的核心内容，其余两部分为配套内容。", "tags": ["竣工决算内容", "核心内容"], "source": "WebSearch-竣工决算补充"}, {"id": "ch13-003", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "竣工财务决算说明书的主要作用是（ ）。", "options": {"A": "直接列示各项工程实物量", "B": "对竣工财务决算报表进行分析和补充说明，反映建设成果和经验", "C": "替代竣工财务决算报表", "D": "仅记录施工单位人员名单"}, "answer": ["B"], "analysis": "竣工财务决算说明书主要反映竣工工程建设成果和经验，是对竣工财务决算报表进行分析和补充说明的文件。", "tags": ["竣工财务决算说明书"], "source": "WebSearch-竣工决算补充"}, {"id": "ch13-004", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "竣工工程平面示意图属于竣工决算的（ ）。", "options": {"A": "第一项内容", "B": "第二项内容", "C": "四项内容之一", "D": "与竣工决算无关"}, "answer": ["C"], "analysis": "竣工工程平面示意图是竣工决算四项内容（报表、说明书、平面示意图、造价对比分析）之一，反映工程竣工后的平面布置。", "tags": ["竣工工程平面示意图"], "source": "安装教材精读笔记"}, {"id": "ch13-005", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "工程造价对比分析属于（ ）。", "options": {"A": "施工图预算的组成", "B": "竣工决算的四项内容之一", "C": "投标报价的组成", "D": "最高投标限价的组成"}, "answer": ["B"], "analysis": "工程造价对比分析是竣工决算四项内容之一，用于考核概算、预算执行情况。", "tags": ["工程造价对比分析"], "source": "安装教材精读笔记"}, {"id": "ch13-006", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "竣工决算是（ ）的总结性文件，是竣工验收报告的重要组成部分。", "options": {"A": "施工单位向建设单位报告施工成果", "B": "综合反映竣工项目从筹建到竣工投产全部建设费用、建设成果和财务状况", "C": "仅反映工程质量", "D": "仅反映施工进度"}, "answer": ["B"], "analysis": "竣工决算是以实物数量和货币指标为计量单位，综合反映竣工项目从筹建开始到竣工投产为止全部建设费用、建设成果和财务状况的总结性文件，是竣工验收报告的重要组成部分。", "tags": ["竣工决算概念"], "source": "WebSearch-竣工决算补充"}, {"id": "ch13-007", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "新增资产按资产性质分类，可分为（ ）。", "options": {"A": "固定资产、流动资产、无形资产", "B": "固定资产、递延资产、无形资产", "C": "固定资产、流动资产、递延资产", "D": "有形资产、无形资产、流动资产"}, "answer": ["A"], "analysis": "根据教材，新增资产按性质分为三类：固定资产、流动资产、无形资产。", "tags": ["新增资产分类"], "source": "安装教材精读笔记"}, {"id": "ch13-008", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "新增固定资产价值由（ ）组成。", "options": {"A": "建筑安装工程投资、设备投资、待摊投资", "B": "建筑安装工程投资、设备投资、流动资产", "C": "设备投资、无形资产、待摊投资", "D": "建筑安装工程投资、土地使用权、待摊投资"}, "answer": ["A"], "analysis": "固定资产价值 = 建筑安装工程投资 + 设备投资 + 待摊投资。", "tags": ["固定资产构成"], "source": "安装教材精读笔记"}, {"id": "ch13-009", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "下列投资中，应计入新增固定资产价值的是（ ）。", "options": {"A": "不够固定资产标准的工器具", "B": "土地使用权", "C": "建筑安装工程投资", "D": "专利"}, "answer": ["C"], "analysis": "建筑安装工程投资是固定资产的组成部分；A属于流动资产，B、D属于无形资产。", "tags": ["固定资产构成"], "source": "安装教材精读笔记"}, {"id": "ch13-012", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "流动资产是指（ ）。", "options": {"A": "建筑安装工程投资", "B": "不够固定资产标准的工具、器具", "C": "土地使用权", "D": "设备投资"}, "answer": ["B"], "analysis": "流动资产指不够固定资产标准的工具、器具等。", "tags": ["流动资产"], "source": "安装教材精读笔记"}, {"id": "ch13-013", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "下列资产中，应列入新增流动资产价值的是（ ）。", "options": {"A": "建筑物", "B": "生产设备", "C": "不够固定资产标准的工器具", "D": "土地使用权"}, "answer": ["C"], "analysis": "不够固定资产标准的工器具属于流动资产；A、B属于固定资产，D属于无形资产。", "tags": ["流动资产"], "source": "安装教材精读笔记"}, {"id": "ch13-014", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "无形资产包括（ ）。", "options": {"A": "建筑安装工程投资", "B": "土地使用权、专利等", "C": "设备投资", "D": "待摊投资"}, "answer": ["B"], "analysis": "无形资产包括土地使用权、专利等；其余三项均属于固定资产构成。", "tags": ["无形资产"], "source": "安装教材精读笔记"}, {"id": "ch13-015", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "土地使用权在新增资产价值确定中应列为（ ）。", "options": {"A": "固定资产", "B": "无形资产", "C": "流动资产", "D": "递延资产"}, "answer": ["B"], "analysis": "土地使用权属于无形资产。", "tags": ["无形资产"], "source": "安装教材精读笔记"}, {"id": "ch13-016", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "专利权在新增资产价值确定中应列为（ ）。", "options": {"A": "固定资产", "B": "无形资产", "C": "流动资产", "D": "递延资产"}, "answer": ["B"], "analysis": "专利属于无形资产。", "tags": ["无形资产"], "source": "安装教材精读笔记"}, {"id": "ch13-017", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "下列项目中，不应计入固定资产价值的是（ ）。", "options": {"A": "建筑安装工程投资", "B": "设备投资", "C": "待摊投资", "D": "土地使用权"}, "answer": ["D"], "analysis": "土地使用权属于无形资产，不计入固定资产；A、B、C均为固定资产的构成部分。", "tags": ["固定资产构成", "无形资产"], "source": "安装教材精读笔记"}, {"id": "ch13-018", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "下列项目中，不应计入无形资产价值的是（ ）。", "options": {"A": "土地使用权", "B": "专利", "C": "设备投资", "D": "非专利技术"}, "answer": ["C"], "analysis": "设备投资属于固定资产，不计入无形资产；A、B、D属于无形资产范畴。", "tags": ["无形资产", "固定资产构成"], "source": "安装教材精读笔记"}, {"id": "ch13-019", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "不够固定资产标准的工器具，在新增资产中列为（ ）。", "options": {"A": "固定资产", "B": "流动资产", "C": "无形资产", "D": "递延资产"}, "answer": ["B"], "analysis": "不够固定资产标准的工具、器具属于流动资产。", "tags": ["流动资产"], "source": "安装教材精读笔记"}, {"id": "ch13-020", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "工程造价对比分析主要是将（ ）进行对比。", "options": {"A": "实际造价与批准的概算、预算", "B": "投标价与中标价", "C": "施工图预算与招标控制价", "D": "结算价与合同价"}, "answer": ["A"], "analysis": "工程造价对比分析是将实际造价与批准的概算、预算进行对比，考核概算执行情况。", "tags": ["工程造价对比分析"], "source": "WebSearch-竣工决算补充"}, {"id": "ch13-021", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "竣工决算的编制主体是（ ）。", "options": {"A": "施工单位", "B": "设计单位", "C": "建设单位", "D": "监理单位"}, "answer": ["C"], "analysis": "竣工决算是建设单位在建设项目竣工后编制的，综合反映项目建设成果和财务状况的总结性文件。", "tags": ["竣工决算概念"], "source": "WebSearch-竣工决算补充"}, {"id": "ch13-022", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "新增固定资产价值的计算，一般以（ ）为对象。", "options": {"A": "建设项目整体", "B": "独立发挥生产能力的单项工程", "C": "单位工程", "D": "分部分项工程"}, "answer": ["B"], "analysis": "新增固定资产价值的计算是以独立发挥生产能力的单项工程为对象。", "tags": ["固定资产确定"], "source": "WebSearch-竣工决算补充"}, {"id": "ch13-023", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "建设单位管理费在新增资产价值确定时，应计入（ ）。", "options": {"A": "固定资产（通过待摊投资分摊）", "B": "流动资产", "C": "无形资产", "D": "不计入任何资产"}, "answer": ["A"], "analysis": "建设单位管理费属于待摊投资，应在各单项工程中按比例分摊后计入固定资产价值。", "tags": ["固定资产构成", "待摊投资"], "source": "WebSearch-竣工决算补充"}, {"id": "ch13-024", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "下列各项待摊投资中，应分摊计入固定资产价值的是（ ）。", "options": {"A": "土地使用权出让金", "B": "专利购置费", "C": "建设单位管理费", "D": "不够标准的工器具购置费"}, "answer": ["C"], "analysis": "建设单位管理费属于待摊投资，分摊计入固定资产；A、B属无形资产，D属流动资产。", "tags": ["待摊投资", "固定资产构成"], "source": "WebSearch-竣工决算补充"}, {"id": "ch13-025", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "竣工财务决算报表是（ ）的综合反映文件。", "options": {"A": "仅实物工程量", "B": "项目资金来源与资金占用等财务状况", "C": "仅施工进度", "D": "仅工程质量"}, "answer": ["B"], "analysis": "竣工财务决算报表是综合反映竣工项目资金来源、资金占用、交付使用资产等财务状况的报表。", "tags": ["竣工财务决算报表"], "source": "WebSearch-竣工决算补充"}, {"id": "ch13-026", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "下列关于竣工决算与竣工结算区别的说法，正确的是（ ）。", "options": {"A": "二者编制主体相同，都是施工单位", "B": "竣工决算是建设单位编制，反映项目全部建设费用；竣工结算是施工单位编制，反映承包工程价款", "C": "竣工决算是施工阶段文件，竣工结算是竣工阶段文件", "D": "二者内容完全相同"}, "answer": ["B"], "analysis": "竣工结算由施工单位编制，确定承包工程价款；竣工决算由建设单位编制，综合反映项目全部建设费用和财务状况。", "tags": ["竣工决算概念"], "source": "WebSearch-竣工决算补充"}, {"id": "ch13-027", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "竣工决算内容的四项中，排在首位且为财务核心的是（ ）。", "options": {"A": "竣工工程平面示意图", "B": "工程造价对比分析", "C": "竣工财务决算报表", "D": "竣工财务决算说明书"}, "answer": ["C"], "analysis": "竣工财务决算报表是竣工决算的核心财务文件，与说明书共同构成竣工财务决算。", "tags": ["竣工财务决算报表", "核心内容"], "source": "安装教材精读笔记"}, {"id": "ch13-028", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "竣工工程平面示意图主要用于反映（ ）。", "options": {"A": "工程竣工后的实际平面布置和尺寸", "B": "设计概算构成", "C": "施工组织设计", "D": "投标报价组成"}, "answer": ["A"], "analysis": "竣工工程平面示意图反映工程竣工后的平面布置、位置、尺寸等实际情况。", "tags": ["竣工工程平面示意图"], "source": "安装教材精读笔记"}, {"id": "ch13-029", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "工程造价对比分析在竣工决算中的主要作用是（ ）。", "options": {"A": "确定施工单位利润", "B": "考核概算、预算执行情况，分析投资控制效果", "C": "编制招标文件", "D": "计算规费税金"}, "answer": ["B"], "analysis": "工程造价对比分析通过实际与概算对比，考核投资控制效果。", "tags": ["工程造价对比分析"], "source": "WebSearch-竣工决算补充"}, {"id": "ch13-030", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "下列资产中，属于流动资产而非固定资产的是（ ）。", "options": {"A": "厂房", "B": "主要生产设备", "C": "不够固定资产标准的小工具", "D": "变配电装置"}, "answer": ["C"], "analysis": "不够固定资产标准的工器具属流动资产；其余均属固定资产。", "tags": ["流动资产", "固定资产构成"], "source": "安装教材精读笔记"}, {"id": "ch13-031", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "下列资产中，属于无形资产的是（ ）。", "options": {"A": "建筑物", "B": "土地使用权", "C": "设备", "D": "待摊投资分摊额"}, "answer": ["B"], "analysis": "土地使用权属无形资产；A、C、D均属固定资产相关。", "tags": ["无形资产"], "source": "安装教材精读笔记"}, {"id": "ch13-032", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "待摊投资在新增资产价值确定中最终计入（ ）。", "options": {"A": "固定资产", "B": "流动资产", "C": "无形资产", "D": "不计资产"}, "answer": ["A"], "analysis": "待摊投资按一定原则分摊后计入固定资产价值。", "tags": ["待摊投资", "固定资产构成"], "source": "安装教材精读笔记"}, {"id": "ch13-033", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "下列关于新增资产分类的说法，正确的是（ ）。", "options": {"A": "新增资产只分为固定资产和流动资产两类", "B": "新增资产分为固定资产、流动资产、无形资产三类", "C": "土地一律计入固定资产", "D": "工器具一律计入固定资产"}, "answer": ["B"], "analysis": "新增资产按性质分为固定资产、流动资产、无形资产三类；土地（使用权）属无形资产，不够标准的工器具属流动资产。", "tags": ["新增资产分类"], "source": "安装教材精读笔记"}, {"id": "ch13-034", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "竣工财务决算说明书与竣工财务决算报表的关系，下列说法正确的是（ ）。", "options": {"A": "说明书可替代报表", "B": "报表是说明书的补充说明", "C": "说明书是对报表进行分析和补充说明的文件", "D": "二者无关系"}, "answer": ["C"], "analysis": "竣工财务决算说明书是对竣工财务决算报表进行分析和补充说明的文件。", "tags": ["竣工财务决算说明书"], "source": "WebSearch-竣工决算补充"}, {"id": "c