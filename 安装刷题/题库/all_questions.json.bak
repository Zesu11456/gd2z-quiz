[{"chapter": "ch01", "type": "single", "stem": "广东2018安装定额中，电气设备安装工程对应第几册？", "options": {"A": "第4册", "B": "第7册", "C": "第10册", "D": "第9册"}, "answer": ["A"], "analysis": "电气设备安装工程对应2018广东安装定额第4册（上下册）。给排水对应第10册、通风空调第7册、消防第9册。", "tags": ["定额册划分", "电气"], "source": "安装教材精读笔记 第1.1/7.2节 + 2018广东安装定额12册结构", "id": "q001", "date": "2026-07-06"}, {"chapter": "ch01", "type": "single", "stem": "广东2018安装定额中，给排水、采暖、燃气工程对应第几册？", "options": {"A": "第4册", "B": "第7册", "C": "第10册", "D": "第8册"}, "answer": ["C"], "analysis": "给排水、采暖、燃气工程对应第10册；通风空调第7册、工业管道第8册。", "tags": ["定额册划分", "给排水"], "source": "安装教材精读笔记 第1.1/7.2节", "id": "q002", "date": "2026-07-06"}, {"chapter": "ch01", "type": "single", "stem": "广东2018安装定额中，通风空调工程对应第几册？", "options": {"A": "第4册", "B": "第7册", "C": "第10册", "D": "第9册"}, "answer": ["B"], "analysis": "通风空调工程对应第7册；消防工程对应第9册、智能化工程对应第5册。", "tags": ["定额册划分", "通风"], "source": "安装教材精读笔记 第1.1/7.2节", "id": "q003", "date": "2026-07-06"}, {"chapter": "ch01", "type": "multiple", "stem": "建筑机电安装的特点包括（ ）。", "options": {"A": "配套性强", "B": "专业性强", "C": "隐蔽工程多", "D": "调试要求高", "E": "施工简单"}, "answer": ["A", "B", "C", "D"], "analysis": "建筑机电安装具有配套性强（需与土建装修配合）、专业性强、隐蔽工程多（预埋预留工作量大）、调试要求高（系统联动复杂）的特点。", "tags": ["安装特点"], "source": "安装教材精读笔记 第1.1节", "id": "q004", "date": "2026-07-06"}, {"chapter": "ch01", "type": "single", "stem": "一般照明回路的电压通常为（ ）。", "options": {"A": "380V", "B": "220V", "C": "110V", "D": "36V"}, "answer": ["B"], "analysis": "照明系统回路电压一般为220V；动力系统回路电压有380V/220V。", "tags": ["电气系统", "电压"], "source": "安装教材精读笔记 第1.2节", "id": "q005", "date": "2026-07-06"}, {"chapter": "ch01", "type": "single", "stem": "动力系统回路电压一般为（ ）。", "options": {"A": "仅380V", "B": "仅220V", "C": "380V/220V", "D": "660V"}, "answer": ["C"], "analysis": "动力系统配电箱→线路→电动机/设备，回路电压一般为380V/220V；照明回路一般为220V。", "tags": ["电气系统", "电压"], "source": "安装教材精读笔记 第1.2节", "id": "q006", "date": "2026-07-06"}, {"chapter": "ch01", "type": "multiple", "stem": "火灾自动报警系统的组成链一般包括（ ）。", "options": {"A": "探测器", "B": "控制器", "C": "联动设备", "D": "水源"}, "answer": ["A", "B", "C"], "analysis": "火灾自动报警系统：探测器→控制器→联动设备。水源属于水灭火系统（消火栓/自动喷水），不属于报警系统。", "tags": ["消防", "报警系统"], "source": "安装教材精读笔记 第1.5节", "id": "q007", "date": "2026-07-06"}, {"chapter": "ch01", "type": "multiple", "stem": "防雷接地系统一般由（ ）组成。", "options": {"A": "接闪器", "B": "引下线", "C": "接地装置", "D": "配电箱"}, "answer": ["A", "B", "C"], "analysis": "防雷接地系统：接闪器→引下线→接地装置。配电箱属于配电系统，不属防雷接地。", "tags": ["电气", "防雷接地"], "source": "安装教材精读笔记 第1.2节", "id": "q008", "date": "2026-07-06"}, {"chapter": "ch02", "type": "multiple", "stem": "下列属于型钢的是（ ）。【2024年真题】", "options": {"A": "圆钢", "B": "工字钢", "C": "槽钢", "D": "钢板", "E": "五角钢"}, "answer": ["A", "B", "C", "E"], "analysis": "钢板属于板材，不属于型钢。型钢包括：圆钢、方钢、扁钢、工字钢、槽钢、角钢、H型钢、五角钢等。", "tags": ["型钢", "材料分类"], "source": "广东二造安装历年真题精华版 真题10 + 教材精读笔记 第2.1节", "id": "q009", "date": "2026-07-06"}, {"chapter": "ch02", "type": "single", "stem": "下列材料中，属于板材的是（ ）。", "options": {"A": "角钢", "B": "工字钢", "C": "钢板", "D": "圆钢"}, "answer": ["C"], "analysis": "钢板、镀锌钢板、不锈钢板属于板材（平板状）；角钢、工字钢、圆钢等属型钢。", "tags": ["板材", "材料分类"], "source": "安装教材精读笔记 第2.1节", "id": "q010", "date": "2026-07-06"}, {"chapter": "ch02", "type": "single", "stem": "适用于生活饮用水管道的管材是（ ）。【2024年真题】", "options": {"A": "焊接钢管", "B": "镀锌钢管", "C": "无缝钢管", "D": "铸铁管"}, "answer": ["B"], "analysis": "镀锌钢管耐腐蚀，适用于生活饮用水；焊接钢管易锈蚀用于非饮用水/消防；无缝钢管用于高压高温；铸铁管主要用于排水。", "tags": ["管材", "给排水"], "source": "广东二造安装历年真题精华版 真题12 + 教材精读笔记 第2.1节", "id": "q011", "date": "2026-07-06"}, {"chapter": "ch02", "type": "single", "stem": "焊接钢管的特点及适用场合是（ ）。", "options": {"A": "耐腐蚀，生活饮用水", "B": "成本低易锈蚀，非饮用水/消防", "C": "强度高，高压高温", "D": "主要用于排水"}, "answer": ["B"], "analysis": "焊接钢管成本低但易锈蚀，适用于非饮用水、消防等；生活饮用水用镀锌钢管，高压高温用无缝钢管。", "tags": ["管材"], "source": "安装教材精读笔记 第2.1节", "id": "q012", "date": "2026-07-06"}, {"chapter": "ch02", "type": "single", "stem": "无缝钢管主要适用的场合是（ ）。", "options": {"A": "低压给水", "B": "高压、高温", "C": "生活饮用水", "D": "排水"}, "answer": ["B"], "analysis": "无缝钢管强度高，主要用于高压、高温场合；镀锌钢管用于生活饮用水，焊接钢管用于非饮用水/消防。", "tags": ["管材"], "source": "安装教材精读笔记 第2.1节", "id": "q013", "date": "2026-07-06"}, {"chapter": "ch02", "type": "single", "stem": "BV线指的是（ ）。", "options": {"A": "铜芯聚氯乙烯绝缘电线", "B": "交联聚乙烯绝缘电力电缆", "C": "铝芯电线", "D": "护套线"}, "answer": ["A"], "analysis": "BV线为铜芯聚氯乙烯绝缘电线；YJV为交联聚乙烯绝缘电力电缆。", "tags": ["电气材料", "线缆"], "source": "安装教材精读笔记 第2.2节", "id": "q014", "date": "2026-07-06"}, {"chapter": "ch02", "type": "single", "stem": "YJV表示的电缆类型是（ ）。", "options": {"A": "铜芯聚氯乙烯绝缘电线", "B": "交联聚乙烯绝缘电力电缆", "C": "控制电缆", "D": "封闭母线"}, "answer": ["B"], "analysis": "YJV为交联聚乙烯绝缘电力电缆；BV为电线，母线为封闭母线/插接母线。", "tags": ["电气材料", "线缆"], "source": "安装教材精读笔记 第2.2节", "id": "q015", "date": "2026-07-06"}, {"chapter": "ch02", "type": "single", "stem": "配管材料中，SC代表的是（ ）。", "options": {"A": "焊接钢管", "B": "薄壁电线管", "C": "PVC塑料管", "D": "镀锌钢管"}, "answer": ["A"], "analysis": "SC表示焊接钢管；JDG/MT为薄壁钢管（电线管）；PC为PVC塑料管。", "tags": ["电气材料", "配管"], "source": "安装教材精读笔记 第2.2节", "id": "q016", "date": "2026-07-06"}, {"chapter": "ch02", "type": "multiple", "stem": "下列属于薄壁钢管（电线管）的是（ ）。", "options": {"A": "SC", "B": "JDG", "C": "MT", "D": "PC"}, "answer": ["B", "C"], "analysis": "JDG、MT为薄壁钢管（电线管）；SC为焊接钢管，PC为PVC塑料管。", "tags": ["电气材料", "配管"], "source": "安装教材精读笔记 第2.2节", "id": "q017", "date": "2026-07-06"}, {"chapter": "ch02", "type": "single", "stem": "PVC管（PC）的材质是（ ）。", "options": {"A": "钢管", "B": "塑料管", "C": "铝合金", "D": "铜管"}, "answer": ["B"], "analysis": "PC管即PVC塑料管，属塑料管；SC为焊接钢管，JDG/MT为薄壁钢管。", "tags": ["电气材料", "配管"], "source": "安装教材精读笔记 第2.2节", "id": "q018", "date": "2026-07-06"}, {"chapter": "ch02", "type": "multiple", "stem": "焊接按结合特点主要分为（ ）。【2024年真题】", "options": {"A": "熔焊", "B": "压焊", "C": "钎焊", "D": "气焊"}, "answer": ["A", "B", "C"], "analysis": "焊接按结合特点分熔焊、压焊、钎焊三大类；气焊属熔焊的一种，不是独立大类。", "tags": ["焊接"], "source": "广东二造安装历年真题精华版 真题11 + 教材精读笔记 第3.3节", "id": "q019", "date": "2026-07-06"}, {"chapter": "ch02", "type": "multiple", "stem": "下列焊接方法中属于熔焊的是（ ）。", "options": {"A": "电弧焊", "B": "气焊", "C": "电阻焊", "D": "摩擦焊"}, "answer": ["A", "B"], "analysis": "熔焊使母材与钎料（此处指焊条/焊丝）熔化，包括电弧焊、气焊；电阻焊、摩擦焊属压焊。", "tags": ["焊接", "熔焊"], "source": "安装教材精读笔记 第3.3节", "id": "q020", "date": "2026-07-06"}, {"chapter": "ch02", "type": "single", "stem": "钎焊时，关于母材与钎料熔化的正确说法是（ ）。", "options": {"A": "母材与钎料均熔化", "B": "仅母材熔化", "C": "仅钎料熔化", "D": "均不熔化"}, "answer": ["C"], "analysis": "钎焊是利用熔点低于母材的钎料熔化填入接头间隙，母材不熔化（区别于熔焊）。", "tags": ["焊接", "钎焊"], "source": "安装教材精读笔记 第3.3节 + 附录易混淆概念", "id": "q021", "date": "2026-07-06"}, {"chapter": "ch02", "type": "multiple", "stem": "管道连接方式及适用，下列说法正确的有（ ）。", "options": {"A": "螺纹连接—小口径钢管", "B": "焊接—碳钢管/不锈钢管", "C": "法兰连接—大口径管道", "D": "卡箍连接—消防管道"}, "answer": ["A", "B", "C", "D"], "analysis": "螺纹连接用于小口径钢管；焊接用于碳钢/不锈钢管；法兰用于大口径管道；卡箍（沟槽）连接常用于消防管道。", "tags": ["管道连接"], "source": "安装教材精读笔记 第3.2节", "id": "q022", "date": "2026-07-06"}, {"chapter": "ch03", "type": "single", "stem": "敷设配线管时，明配导管的弯曲半径不宜小于管外径的（ ）倍。【2022年真题】", "options": {"A": "4", "B": "5", "C": "6", "D": "8"}, "answer": ["C"], "analysis": "明配导管弯曲半径不宜小于管外径的6倍。", "tags": ["配管", "弯曲半径"], "source": "广东二造安装历年真题精华版 真题8 + 教材精读笔记 第3.1节", "id": "q023", "date": "2026-07-06"}, {"chapter": "ch03", "type": "single", "stem": "当两个接线盒间只有一个弯曲时，导管弯曲半径不宜小于管外径的（ ）倍。【2022年真题】", "options": {"A": "4", "B": "5", "C": "6", "D": "8"}, "answer": ["A"], "analysis": "两接线盒间只有一个弯曲时，弯曲半径不宜小于管外径的4倍。", "tags": ["配管", "弯曲半径"], "source": "广东二造安装历年真题精华版 真题9 + 教材精读笔记 第3.1节", "id": "q024", "date": "2026-07-06"}, {"chapter": "ch03", "type": "single", "stem": "配管施工流程的第一步是（ ）。", "options": {"A": "穿线", "B": "预埋预留", "C": "支架安装", "D": "接线"}, "answer": ["B"], "analysis": "配管施工从预埋预留开始，然后支架安装、管道敷设、穿线、接线。", "tags": ["配管", "施工流程"], "source": "安装教材精读笔记 第3.1节", "id": "q026", "date": "2026-07-06"}, {"chapter": "ch03", "type": "multiple", "stem": "焊接按结合特点的三大类中，下列属于压焊的是（ ）。", "options": {"A": "电弧焊", "B": "电阻焊", "C": "摩擦焊", "D": "气焊"}, "answer": ["B", "C"], "analysis": "压焊包括电阻焊、摩擦焊等；电弧焊、气焊属熔焊。", "tags": ["焊接", "压焊"], "source": "安装教材精读笔记 第3.3节", "id": "q027", "date": "2026-07-06"}, {"chapter": "ch03", "type": "single", "stem": "小口径钢管常用的连接方式是（ ）。", "options": {"A": "螺纹连接", "B": "焊接", "C": "法兰连接", "D": "卡箍连接"}, "answer": ["A"], "analysis": "小口径钢管常用螺纹连接；大口径管道用法兰；消防管道常用卡箍。", "tags": ["管道连接"], "source": "安装教材精读笔记 第3.2节", "id": "q028", "date": "2026-07-06"}, {"chapter": "ch03", "type": "single", "stem": "消防管道优先采用的连接方式是（ ）。", "options": {"A": "螺纹连接", "B": "卡箍连接", "C": "焊接", "D": "法兰连接"}, "answer": ["B"], "analysis": "消防管道（尤其自动喷水）优先采用沟槽（卡箍）连接，便于快速安装与维修。", "tags": ["管道连接", "消防"], "source": "安装教材精读笔记 第3.2节", "id": "q029", "date": "2026-07-06"}, {"chapter": "ch03", "type": "multiple", "stem": "建筑机电安装“隐蔽工程多”主要体现在（ ）。", "options": {"A": "预埋预留工作量大", "B": "调试复杂", "C": "管线暗敷隐蔽", "D": "装修配合"}, "answer": ["A", "C"], "analysis": "隐蔽工程多指预埋预留工作量大、管线暗敷在结构/装修内难以直观检查。", "tags": ["安装特点", "隐蔽工程"], "source": "安装教材精读笔记 第1.1节", "id": "q030", "date": "2026-07-06"}, {"chapter": "ch03", "type": "multiple", "stem": "下列关于配管弯曲半径的说法，正确的有（ ）。", "options": {"A": "明配≥6倍管外径", "B": "单弯≥4倍管外径", "C": "暗配≥10倍", "D": "无要求"}, "answer": ["A", "B"], "analysis": "明配导管弯曲半径≥6倍管外径；两盒间仅一个弯曲时≥4倍管外径。", "tags": ["配管", "弯曲半径"], "source": "安装教材精读笔记 第3.1节 + 附录必背数字", "id": "q031", "date": "2026-07-06"}, {"chapter": "ch04", "type": "multiple", "stem": "下列属于起重机械的是（ ）。", "options": {"A": "塔吊", "B": "汽车吊", "C": "电焊机", "D": "套丝机"}, "answer": ["A", "B"], "analysis": "起重机械包括塔吊、汽车吊，用于设备吊装；电焊机属焊接设备，套丝机属管道机械。", "tags": ["施工机械"], "source": "安装教材精读笔记 第4.1节", "id": "q032", "date": "2026-07-06"}, {"chapter": "ch04", "type": "single", "stem": "管道加工（套丝、弯管）常用的机械是（ ）。", "options": {"A": "电焊机", "B": "套丝机/弯管机", "C": "汽车吊", "D": "兆欧表"}, "answer": ["B"], "analysis": "套丝机、弯管机属管道机械，用于管道加工；电焊机用于焊接，汽车吊用于吊装。", "tags": ["施工机械"], "source": "安装教材精读笔记 第4.1节", "id": "q033", "date": "2026-07-06"}, {"chapter": "ch04", "type": "multiple", "stem": "安装工程中常用的检测仪表包括（ ）。", "options": {"A": "压力表", "B": "万用表", "C": "兆欧表", "D": "接地电阻测试仪"}, "answer": ["A", "B", "C", "D"], "analysis": "压力表测管道压力；万用表测电气参数；兆欧表测绝缘电阻；接地电阻测试仪测接地系统。", "tags": ["检测仪表"], "source": "安装教材精读笔记 第4.2节", "id": "q034", "date": "2026-07-06"}, {"chapter": "ch04", "type": "single", "stem": "测量电气设备绝缘电阻应使用的仪表是（ ）。", "options": {"A": "万用表", "B": "兆欧表", "C": "压力表", "D": "钳形表"}, "answer": ["B"], "analysis": "兆欧表（摇表）用于测量绝缘电阻；万用表测通断/电压电流，不能准确测绝缘。", "tags": ["检测仪表", "绝缘"], "source": "安装教材精读笔记 第4.2节", "id": "q035", "date": "2026-07-06"}, {"chapter": "ch04", "type": "single", "stem": "接地系统测试应使用（ ）。", "options": {"A": "兆欧表", "B": "接地电阻测试仪", "C": "万用表", "D": "压力表"}, "answer": ["B"], "analysis": "接地电阻测试仪专门用于接地系统电阻测试；兆欧表测绝缘电阻。", "tags": ["检测仪表", "接地"], "source": "安装教材精读笔记 第4.2节", "id": "q036", "date": "2026-07-06"}, {"chapter": "ch05", "type": "multiple", "stem": "施工组织设计中还包含的内容有（ ）。", "options": {"A": "平面布置", "B": "保证措施", "C": "预算编制", "D": "竣工决算"}, "answer": ["A", "B"], "analysis": "还包括施工平面布置、质量/安全/文明施工等保证措施；预算编制与竣工决算不属施工组织设计内容。", "tags": ["施工组织设计"], "source": "安装教材精读笔记 第5.1节", "id": "q038", "date": "2026-07-06"}, {"chapter": "ch05", "type": "single", "stem": "施工方案编制要点不包括（ ）。", "options": {"A": "确定施工顺序", "B": "选择施工方法", "C": "选择施工机械", "D": "确定合同价款"}, "answer": ["D"], "analysis": "施工方案要点：确定施工顺序、选择施工方法、选择施工机械、安排施工人员；合同价款不属施工方案。", "tags": ["施工方案"], "source": "安装教材精读笔记 第5.2节", "id": "q039", "date": "2026-07-06"}, {"chapter": "ch05", "type": "multiple", "stem": "施工方案编制要点包括（ ）。", "options": {"A": "施工顺序", "B": "施工方法", "C": "施工机械", "D": "施工人员"}, "answer": ["A", "B", "C", "D"], "analysis": "施工方案要点：确定施工顺序、选择施工方法、选择施工机械、安排施工人员。", "tags": ["施工方案"], "source": "安装教材精读笔记 第5.2节", "id": "q040", "date": "2026-07-06"}, {"chapter": "ch05", "type": "single", "stem": "施工进度计划的常用表达形式是（ ）。", "options": {"A": "横道图/网络图", "B": "柱状图", "C": "饼图", "D": "折线图"}, "answer": ["A"], "analysis": "进度计划常用横道图（甘特图）或网络图表达。", "tags": ["进度计划"], "source": "安装教材精读笔记 第5.1节", "id": "q041", "date": "2026-07-06"}, {"chapter": "ch06", "type": "single", "stem": "电气工程图中，符号“MX”表示（ ）。", "options": {"A": "荧光灯", "B": "照明配电箱", "C": "开关", "D": "插座"}, "answer": ["B"], "analysis": "MX表示照明配电箱；YG表示荧光灯灯具；○表示一般照明灯位。", "tags": ["识图", "电气图例"], "source": "安装教材精读笔记 第6.1节", "id": "q042", "date": "2026-07-06"}, {"chapter": "ch06", "type": "single", "stem": "电气工程图中，“YG”表示（ ）。", "options": {"A": "荧光灯灯具", "B": "配电箱", "C": "灯位", "D": "开关"}, "answer": ["A"], "analysis": "YG表示荧光灯灯具；MX为照明配电箱，○为灯位。", "tags": ["识图", "电气图例"], "source": "安装教材精读笔记 第6.1节", "id": "q043", "date": "2026-07-06"}, {"chapter": "ch06", "type": "multiple", "stem": "给排水工程图常用图例包括（ ）。", "options": {"A": "JL（给水立管）", "B": "PL（排水立管）", "C": "RL（热水立管）", "D": "MX"}, "answer": ["A", "B", "C"], "analysis": "JL=给水立管、PL=排水立管、RL=热水立管；MX为电气照明配电箱。", "tags": ["识图", "给排水图例"], "source": "安装教材精读笔记 第6.2节", "id": "q044", "date": "2026-07-06"}, {"chapter": "ch06", "type": "multiple", "stem": "通风空调工程图常用图例包括（ ）。", "options": {"A": "SF（送风）", "B": "HF（回风）", "C": "PF（排风）", "D": "PL"}, "answer": ["A", "B", "C"], "analysis": "SF=送风、HF=回风、PF=排风；PL为排水立管（给排水图例）。", "tags": ["识图", "通风图例"], "source": "安装教材精读笔记 第6.3节", "id": "q045", "date": "2026-07-06"}, {"chapter": "ch06", "type": "single", "stem": "安装工程识图的一般顺序是（ ）。", "options": {"A": "平面图→系统图→目录", "B": "图纸目录图例→系统图→平面图", "C": "系统图→平面图→目录", "D": "目录→平面图→系统图"}, "answer": ["B"], "analysis": "识图顺序：先看图纸目录和图例，再看系统图了解组成，最后看平面图了解具体位置。", "tags": ["识图", "顺序"], "source": "安装教材精读笔记 第6.1节", "id": "q046", "date": "2026-07-06"}, {"chapter": "ch06", "type": "single", "stem": "电气平面图中“○”一般表示（ ）。", "options": {"A": "配电箱", "B": "灯位（一般照明）", "C": "开关", "D": "插座"}, "answer": ["B"], "analysis": "○表示灯位（一般照明）；MX为配电箱，开关、插座另有专门符号。", "tags": ["识图", "电气图例"], "source": "安装教材精读笔记 第6.1节", "id": "q047", "date": "2026-07-06"}, {"chapter": "ch07", "type": "single", "stem": "2024版清单标准《通用安装工程工程量计算标准》GB/T 50856-2024 的专业附录数量为（ ）。", "options": {"A": "附录A～N共14个", "B": "附录A～M共13个", "C": "10个", "D": "12个"}, "answer": ["A"], "analysis": "2024版清单含附录A～N共14个专业附录，每个附录含项目设置、特征描述、计量单位、计算规则。", "tags": ["清单", "附录"], "source": "安装教材精读笔记 第7.1节", "id": "q048", "date": "2026-07-06"}, {"chapter": "ch07", "type": "multiple", "stem": "2024版清单中，每个专业附录一般包含（ ）。", "options": {"A": "工程量清单项目设置", "B": "项目特征描述", "C": "计量单位", "D": "工程量计算规则"}, "answer": ["A", "B", "C", "D"], "analysis": "每个附录包含：清单项目设置、项目特征描述、计量单位、工程量计算规则四要素。", "tags": ["清单", "附录"], "source": "安装教材精读笔记 第7.1节", "id": "q049", "date": "2026-07-06"}, {"chapter": "ch07", "type": "single", "stem": "通用安装工程工程量计算时，应依据（ ）计算。", "options": {"A": "设计图示尺寸", "B": "施工人员估计", "C": "定额含量", "D": "经验数值"}, "answer": ["A"], "analysis": "清单工程量按设计图示尺寸计算；定额含量用于计价时的工料机消耗。", "tags": ["清单", "计量规则"], "source": "安装教材精读笔记 第7.1节", "id": "q050", "date": "2026-07-06"}, {"chapter": "ch07", "type": "single", "stem": "工程量清单中，项目特征描述主要影响（ ）。", "options": {"A": "工程量大小", "B": "综合单价", "C": "工期", "D": "质量等级"}, "answer": ["B"], "analysis": "项目特征描述影响综合单价（决定人工、材料、机械及施工难度）；工程量按图示尺寸算。", "tags": ["清单", "项目特征"], "source": "安装教材精读笔记 第7.1节", "id": "q051", "date": "2026-07-06"}, {"chapter": "ch07", "type": "single", "stem": "广东省2018版安装定额共分为（ ）。", "options": {"A": "10册", "B": "12册", "C": "14册", "D": "8册"}, "answer": ["B"], "analysis": "广东2018安装定额共12册（含部分上下册）。", "tags": ["定额", "册数"], "source": "安装教材精读笔记 第7.2节 + 2018广东安装定额", "id": "q052", "date": "2026-07-06"}, {"chapter": "ch07", "type": "multiple", "stem": "下列属于广东2018安装定额册的是（ ）。", "options": {"A": "第4册 电气设备安装", "B": "第7册 通风空调工程", "C": "第10册 给排水采暖燃气", "D": "第12册 刷油防腐蚀绝热"}, "answer": ["A", "B", "C", "D"], "analysis": "四者均属广东2018安装定额12册体系（另有第1机械、2热力、3静置设备、5智能化、6自控仪表、8工业管道、9消防、11通信）。", "tags": ["定额", "册名"], "source": "安装教材精读笔记 第7.2节", "id": "q053", "date": "2026-07-06"}, {"chapter": "ch07", "type": "single", "stem": "广东2018安装定额第3册的名称是（ ）。", "options": {"A": "机械设备安装", "B": "静置设备与工艺金属结构", "C": "工业管道", "D": "消防工程"}, "answer": ["B"], "analysis": "第3册为静置设备与工艺金属结构安装；第1册机械设备、第8册工业管道、第9册消防。", "tags": ["定额", "册名"], "source": "安装教材精读笔记 第7.2节", "id": "q054", "date": "2026-07-06"}, {"chapter": "ch07", "type": "single", "stem": "广东省安装工程中，企业管理费和利润的计费基数是（ ）。", "options": {"A": "人工费", "B": "人工费+材料费", "C": "人工费+施工机具使用费", "D": "人工费+机械费+材料费"}, "answer": ["C"], "analysis": "广东2018安装定额规定：管理费、利润均以分部分项的人工费与施工机具使用费之和为计费基数（与北京等地“纯人工费”不同）。", "tags": ["计价", "计费基数", "利润"], "source": "2018广东安装定额第10册总说明（管理费以人工费与施工机具费之和为计算基数）", "id": "q055", "date": "2026-07-06"}, {"chapter": "ch07", "type": "multiple", "stem": "关于清单与定额的衔接，下列说法正确的有（ ）。", "options": {"A": "清单规定计量规则（量怎么算）", "B": "定额规定消耗量（要多少工料机）", "C": "两者结合用于计价", "D": "清单规定消耗量"}, "answer": ["A", "B", "C"], "analysis": "清单管“量怎么算”（计量规则），定额管“要多少”（工料机消耗量），二者结合用于组价算综合单价。", "tags": ["清单定额衔接"], "source": "安装教材精读笔记 第7.3节", "id": "q056", "date": "2026-07-06"}, {"chapter": "ch07", "type": "single", "stem": "下列关于清单与定额关系的说法正确的是（ ）。", "options": {"A": "清单管消耗量", "B": "定额管计量规则", "C": "清单管计量规则、定额管消耗量", "D": "二者作用完全相同"}, "answer": ["C"], "analysis": "清单确定计量规则与项目特征，定额提供工料机消耗量，二者分工不同、结合计价。", "tags": ["清单定额衔接"], "source": "安装教材精读笔记 第7.3节", "id": "q057", "date": "2026-07-06"}, {"chapter": "ch07", "type": "multiple", "stem": "2024清单与2018定额衔接的主要考点包括（ ）。", "options": {"A": "计量单位一致性", "B": "工作内容对应", "C": "项目特征描述", "D": "工程量偏差调整"}, "answer": ["A", "B", "C"], "analysis": "衔接考点：计量单位一致或换算、工作内容对应、项目特征描述选定额；工程量偏差属合同价款调整范畴。", "tags": ["清单定额衔接"], "source": "广东二造安装历年真题精华版 第六/七节", "id": "q058", "date": "2026-07-06"}, {"chapter": "ch08", "type": "multiple", "stem": "BIM技术在安装工程中的应用包括（ ）。", "options": {"A": "自动提取工程量", "B": "三维碰撞检查", "C": "5D BIM（3D+时间+成本）", "D": "手工算量"}, "answer": ["A", "B", "C"], "analysis": "BIM可自动提取工程量、三维可视化碰撞检查、5D BIM（3D模型+时间+成本）管理。", "tags": ["BIM"], "source": "安装教材精读笔记 第8.1节", "id": "q060", "date": "2026-07-06"}, {"chapter": "ch08", "type": "single", "stem": "所谓“5D BIM”中的5D是指（ ）。", "options": {"A": "3D模型+时间+成本", "B": "3D+质量+成本", "C": "2D+时间+成本", "D": "4D+人工"}, "answer": ["A"], "analysis": "5D BIM = 3D模型 + 时间（4D进度）+ 成本（5D造价）。", "tags": ["BIM", "5D"], "source": "安装教材精读笔记 第8.1节", "id": "q061", "date": "2026-07-06"}, {"chapter": "ch08", "type": "multiple", "stem": "国内常用算量软件包括（ ）。", "options": {"A": "广联达", "B": "鲁班", "C": "斯维尔（广东常用）", "D": "手工记账"}, "answer": ["A", "B", "C"], "analysis": "广联达市场占有率最高，鲁班为传统老牌，斯维尔在广东地区常用。", "tags": ["算量软件"], "source": "安装教材精读笔记 第8.2节", "id": "q062", "date": "2026-07-06"}, {"chapter": "ch08", "type": "single", "stem": "在广东地区较为常用的算量软件是（ ）。", "options": {"A": "广联达", "B": "鲁班", "C": "斯维尔", "D": "鸿业"}, "answer": ["C"], "analysis": "教材指出斯维尔在广东地区常用；广联达全国占有率最高，但并非“广东地区特色常用”的指向。", "tags": ["算量软件", "广东"], "source": "安装教材精读笔记 第8.2节", "id": "q063", "date": "2026-07-06"}, {"chapter": "ch09", "type": "multiple", "stem": "安装工程预算编制的依据包括（ ）。【2024年真题】", "options": {"A": "施工图纸", "B": "施工组织设计", "C": "预算定额", "D": "市场价格信息"}, "answer": ["A", "B", "C", "D"], "analysis": "预算编制依据：施工图纸、施工组织设计、预算定额、市场价格信息、费用定额等。", "tags": ["预算", "编制依据"], "source": "广东二造安装历年真题精华版 真题14 + 教材精读笔记 第9.1节", "id": "q064", "date": "2026-07-06"}, {"chapter": "ch09", "type": "single", "stem": "下列还可作为安装工程预算编制依据的是（ ）。", "options": {"A": "费用定额", "B": "招标文件", "C": "竣工图", "D": "审计报告"}, "answer": ["A"], "analysis": "预算编制依据还包括费用定额；招标文件主要用于清单编制，竣工图/审计报告非预算编制直接依据。", "tags": ["预算", "编制依据"], "source": "安装教材精读笔记 第9.1节", "id": "q065", "date": "2026-07-06"}, {"chapter": "ch09", "type": "single", "stem": "施工图预算中“套用定额”主要依据（ ）。", "options": {"A": "2018广东安装定额", "B": "2024版清单", "C": "设计图纸", "D": "施工合同"}, "answer": ["A"], "analysis": "算量依据清单（2024版），套价依据定额（2018广东安装定额）。", "tags": ["预算", "定额套用"], "source": "安装教材精读笔记 第9.2节", "id": "q067", "date": "2026-07-06"}, {"chapter": "ch09", "type": "single", "stem": "下列费用中，不属于分部分项工程费的是（ ）。", "options": {"A": "人工费", "B": "材料费", "C": "规费", "D": "利润"}, "answer": ["C"], "analysis": "分部分项工程费含人、材、机、管理费、利润；规费和税金在费用构成中单独列项，不属于分部分项工程费。", "tags": ["费用构成", "分部分项"], "source": "广东二造安装历年真题精华版 真题4 + 教材精读笔记 第9.3节", "id": "q070", "date": "2026-07-06"}, {"chapter": "ch10", "type": "multiple", "stem": "最高投标限价的编制原则包括（ ）。", "options": {"A": "依据国家或省级计价定额", "B": "依据设计文件", "C": "采用市场价格信息", "D": "不得上浮或下调"}, "answer": ["A", "B", "C", "D"], "analysis": "最高投标限价应依据计价定额、设计文件、市场价编制，且不得上浮或下调。", "tags": ["最高投标限价", "原则"], "source": "安装教材精读笔记 第10.1节", "id": "q072", "date": "2026-07-06"}, {"chapter": "ch10", "type": "single", "stem": "最高投标限价的编制主体是（ ）。", "options": {"A": "施工单位", "B": "招标人", "C": "监理单位", "D": "审计单位"}, "answer": ["B"], "analysis": "最高投标限价由招标人编制（或委托），用于控制工程造价；施工图预算多由施工单位编制。", "tags": ["最高投标限价", "主体"], "source": "安装教材精读笔记 第10.2节", "id": "q073", "date": "2026-07-06"}, {"chapter": "ch10", "type": "single", "stem": "与施工图预算相比，最高投标限价一般在（ ）编制。", "options": {"A": "施工图完成后", "B": "招标前", "C": "竣工后", "D": "施工期间"}, "answer": ["B"], "analysis": "最高投标限价在招标前编制；施工图预算在施工图完成后编制。", "tags": ["最高投标限价", "时间"], "source": "安装教材精读笔记 第10.2节", "id": "q074", "date": "2026-07-06"}, {"chapter": "ch10", "type": "multiple", "stem": "最高投标限价与施工图预算的区别体现在（ ）。", "options": {"A": "编制主体", "B": "编制目的", "C": "编制时间", "D": "计量单位"}, "answer": ["A", "B", "C"], "analysis": "区别：编制主体（招标方vs施工方）、目的（控价vs投标参考）、时间（招标前vs施工图后）；计量单位二者一致。", "tags": ["最高投标限价", "区别"], "source": "安装教材精读笔记 第10.2节", "id": "q075", "date": "2026-07-06"}, {"chapter": "ch11", "type": "multiple", "stem": "常用的投标报价策略包括（ ）。", "options": {"A": "不平衡报价法", "B": "多方案报价法", "C": "增加建议法", "D": "最低价中标法"}, "answer": ["A", "B", "C"], "analysis": "投标策略：不平衡报价（调整各子项单价）、多方案报价、增加建议法；最低价中标非策略方法。", "tags": ["投标报价", "策略"], "source": "安装教材精读笔记 第11.1节", "id": "q076", "date": "2026-07-06"}, {"chapter": "ch11", "type": "multiple", "stem": "其他项目费一般包括（ ）。", "options": {"A": "暂列金额", "B": "暂估价", "C": "计日工", "D": "总承包服务费"}, "answer": ["A", "B", "C", "D"], "analysis": "其他项目费含暂列金额、暂估价、计日工、总承包服务费。", "tags": ["投标报价", "其他项目费"], "source": "安装教材精读笔记 第11.2节", "id": "q077", "date": "2026-07-06"}, {"chapter": "ch11", "type": "single", "stem": "下列费用中属于其他项目费的是（ ）。", "options": {"A": "安全文明施工费", "B": "暂列金额", "C": "企业管理费", "D": "利润"}, "answer": ["B"], "analysis": "暂列金额属其他项目费；安全文明施工费属措施项目费，企业管理费、利润含在分部分项。", "tags": ["投标报价", "其他项目费"], "source": "安装教材精读笔记 第11.2节", "id": "q078", "date": "2026-07-06"}, {"chapter": "ch11", "type": "single", "stem": "不平衡报价法的核心是（ ）。", "options": {"A": "统一提高所有单价", "B": "有意识调整各子项单价", "C": "只报总价", "D": "不计利润"}, "answer": ["B"], "analysis": "不平衡报价是在总报价不变前提下，有意识地调高早期/量增项目单价、调低后期/量减项目单价。", "tags": ["投标报价", "不平衡报价"], "source": "安装教材精读笔记 第11.1节", "id": "q080", "date": "2026-07-06"}, {"chapter": "ch12", "type": "single", "stem": "按合同约定，工程进度款按期中结算价款总额计，其支付比例一般为（ ）。【2022年真题】", "options": {"A": "不低于50%，不高于80%", "B": "不低于50%，不高于85%", "C": "不低于60%，不高于85%", "D": "不低于60%，不高于90%"}, "answer": ["D"], "analysis": "进度款支付比例：不低于60%，不高于90%（依据GB 50500-2013）。", "tags": ["进度款", "支付比例"], "source": "广东二造安装历年真题精华版 真题3 + 教材精读笔记 第12.2节", "id": "q081", "date": "2026-07-06"}, {"chapter": "ch12", "type": "single", "stem": "发包人需到现场计量核实时，应提前（ ）小时通知承包人。【2022年真题】", "options": {"A": "7", "B": "12", "C": "24", "D": "48"}, "answer": ["C"], "analysis": "发包人需现场计量核实时，应在计量前24小时通知承包人。", "tags": ["计量", "通知时间"], "source": "广东二造安装历年真题精华版 真题6 + 教材精读笔记 第12.2节", "id": "q082", "date": "2026-07-06"}, {"chapter": "ch12", "type": "multiple", "stem": "工程价款结算方式一般包括（ ）。", "options": {"A": "按月结算", "B": "分段结算", "C": "竣工后一次结算", "D": "按年结算"}, "answer": ["A", "B", "C"], "analysis": "结算方式：按月结算、分段结算、竣工后一次结算（小型短工期工程）。", "tags": ["结算方式"], "source": "安装教材精读笔记 第12.1节", "id": "q083", "date": "2026-07-06"}, {"chapter": "ch12", "type": "single", "stem": "工期短、规模小的小型工程适合采用的结算方式是（ ）。", "options": {"A": "按月结算", "B": "分段结算", "C": "竣工后一次结算", "D": "按月+分段"}, "answer": ["C"], "analysis": "小型短工期工程适合竣工后一次结算。", "tags": ["结算方式"], "source": "安装教材精读笔记 第12.1节", "id": "q084", "date": "2026-07-06"}, {"chapter": "ch12", "type": "multiple", "stem": "引起合同价款调整的因素包括（ ）。", "options": {"A": "工程量清单项目特征描述不符", "B": "工程量偏差超过15%", "C": "物价变化超过合同约定幅度", "D": "法规变化"}, "answer": ["A", "B", "C", "D"], "analysis": "调价因素：特征不符、工程量偏差超15%、物价变化超幅、法规变化等。", "tags": ["价款调整", "因素"], "source": "安装教材精读笔记 第12.3节", "id": "q085", "date": "2026-07-06"}, {"chapter": "ch12", "type": "single", "stem": "工程量偏差超过（ ）时，可进行调整合同价款。", "options": {"A": "5%", "B": "10%", "C": "15%", "D": "20%"}, "answer": ["C"], "analysis": "工程量偏差超过15%时，可调整综合单价/合同价款。", "tags": ["价款调整", "偏差阈值"], "source": "安装教材精读笔记 第12.3节 + 附录必背数字", "id": "q086", "date": "2026-07-06"}, {"chapter": "ch12", "type": "single", "stem": "下列情形中，需要进行工程变更确认的是（ ）。【2025年真题】", "options": {"A": "设计变更本身", "B": "施工条件变化", "C": "材料价格小幅波动", "D": "项目延期"}, "answer": ["B"], "analysis": "施工条件变化会导致工程变更，需进行变更确认；设计变更本身即变更文件，无需再“确认”其变更性质。", "tags": ["工程变更"], "source": "广东二造安装历年真题精华版 真题5", "id": "q087", "date": "2026-07-06"}, {"chapter": "ch12", "type": "multiple", "stem": "关于进度款支付，下列说法正确的有（ ）。", "options": {"A": "支付比例不低于60%", "B": "支付比例不高于90%", "C": "按期中结算价款总额计", "D": "固定为80%"}, "answer": ["A", "B", "C"], "analysis": "进度款按期中结算价款总额计，不低于60%、不高于90%；并非固定比例。", "tags": ["进度款"], "source": "安装教材精读笔记 第12.2节", "id": "q088", "date": "2026-07-06"}, {"chapter": "ch12", "type": "single", "stem": "因法规变化导致工程造价变动时，应（ ）。", "options": {"A": "调整合同价款", "B": "不调整", "C": "终止合同", "D": "重新招标"}, "answer": ["A"], "analysis": "法规变化属于合同价款调整因素，应调整合同价款。", "tags": ["价款调整", "法规变化"], "source": "安装教材精读笔记 第12.3节", "id": "q089", "date": "2026-07-06"}, {"chapter": "ch12", "type": "multiple", "stem": "电缆敷设完毕后，应在下列哪些位置设置电缆标示牌（ ）。【2024年真题】", "options": {"A": "引出入端", "B": "终端", "C": "中间接头", "D": "转弯处"}, "answer": ["A", "B", "C", "D"], "analysis": "电缆标示牌应设于引出入端、终端、中间接头、转弯处，注明编号、电压、型号、规格、起止点等。", "tags": ["电气", "电缆标示牌"], "source": "广东二造安装历年真题精华版 真题7", "id": "q090", "date": "2026-07-06"}, {"chapter": "ch13", "type": "multiple", "stem": "竣工决算的内容一般包括（ ）。", "options": {"A": "竣工财务决算报表", "B": "竣工财务决算说明书", "C": "竣工工程平面示意图", "D": "工程造价对比分析"}, "answer": ["A", "B", "C", "D"], "analysis": "竣工决算含：财务决算报表、财务决算说明书、竣工工程平面示意图、工程造价对比分析。", "tags": ["竣工决算"], "source": "安装教材精读笔记 第13.1节", "id": "q091", "date": "2026-07-06"}, {"chapter": "ch13", "type": "multiple", "stem": "新增资产价值按性质可分为（ ）。", "options": {"A": "固定资产", "B": "流动资产", "C": "无形资产（土地使用权、专利等）", "D": "递延资产"}, "answer": ["A", "B", "C"], "analysis": "新增资产：固定资产、流动资产、无形资产（如土地使用权、专利）；教材列举此三类。", "tags": ["竣工决算", "新增资产"], "source": "安装教材精读笔记 第13.2节", "id": "q092", "date": "2026-07-06"}, {"chapter": "ch13", "type": "single", "stem": "土地使用权在新增资产中属于（ ）。", "options": {"A": "固定资产", "B": "流动资产", "C": "无形资产", "D": "其他资产"}, "answer": ["C"], "analysis": "土地使用权、专利等属无形资产。", "tags": ["竣工决算", "无形资产"], "source": "安装教材精读笔记 第13.2节", "id": "q093", "date": "2026-07-06"}, {"chapter": "ch13", "type": "single", "stem": "不够固定资产标准的工具、器具，在新增资产中属于（ ）。", "options": {"A": "固定资产", "B": "流动资产", "C": "无形资产", "D": "递延资产"}, "answer": ["B"], "analysis": "不够固定资产标准的工器具属流动资产。", "tags": ["竣工决算", "流动资产"], "source": "安装教材精读笔记 第13.2节", "id": "q094", "date": "2026-07-06"}, {"chapter": "ch14", "type": "single", "stem": "根据GB/T 50856-2024，柔性软风管的清单计量单位是（ ）。", "options": {"A": "m", "B": "节", "C": "㎡", "D": "个"}, "answer": ["A"], "analysis": "柔性软风管按设计图示管道中心线长度以“m”计算（清单与2018定额第7册一致）。", "tags": ["计量", "柔性软风管"], "source": "广东二造安装历年真题精华版 模拟1 + 2018定额第7册", "id": "q095", "date": "2026-07-06"}, {"chapter": "ch14", "type": "single", "stem": "根据广东2018安装定额第7册，帆布软接口的计量单位是（ ）。", "options": {"A": "m", "B": "节", "C": "㎡", "D": "个"}, "answer": ["C"], "analysis": "帆布软接口（软管）按设计图示尺寸展开面积以“㎡”计算。", "tags": ["计量", "帆布软接口"], "source": "广东二造安装历年真题精华版 模拟2 + 2018定额第7册", "id": "q096", "date": "2026-07-06"}, {"chapter": "ch14", "type": "multiple", "stem": "风管展开面积的计算，下列说法正确的有（ ）。", "options": {"A": "矩形风管 S=2×(宽+高)×长度", "B": "圆形风管 S=π×直径×长度", "C": "按风管体积计算", "D": "按风管重量计算"}, "answer": ["A", "B"], "analysis": "矩形风管展开面积=2×(宽+高)×长；圆形=π×直径×长。", "tags": ["计量", "风管"], "source": "安装教材精读笔记 第14.3节", "id": "q097", "date": "2026-07-06"}, {"chapter": "ch14", "type": "single", "stem": "矩形风管展开面积的计算式为（ ）。", "options": {"A": "宽×高×长", "B": "2×(宽+高)×长", "C": "(宽+高)×长", "D": "周长×长÷2"}, "answer": ["B"], "analysis": "矩形风管展开面积 S=2×(宽+高)×长度。", "tags": ["计量", "风管"], "source": "安装教材精读笔记 第14.3节", "id": "q098", "date": "2026-07-06"}, {"chapter": "ch14", "type": "single", "stem": "给排水管道工程量一般按（ ）计算。", "options": {"A": "实际长度", "B": "设计图示管道中心线长度（m）", "C": "外表面积", "D": "重量"}, "answer": ["B"], "analysis": "各种管道均按设计图示管道中心线长度以“m”计算，不扣除阀门、管件所占长度。", "tags": ["计量", "管道"], "source": "安装教材精读笔记 第14.2节 + 2018定额第10册", "id": "q099", "date": "2026-07-06"}, {"chapter": "ch14", "type": "multiple", "stem": "给排水工程量计算时，下列做法正确的有（ ）。", "options": {"A": "管道按中心线长度m", "B": "管件（弯头、三通）分别计算", "C": "阀门按类型和规格以个计", "D": "卫生器具按套计"}, "answer": ["A", "B", "C", "D"], "analysis": "管道按中心线长度m；管件弯头三通分别计算；阀门按类型规格以个；卫生器具按套。", "tags": ["计量", "给排水"], "source": "安装教材精读笔记 第14.2节", "id": "q100", "date": "2026-07-06"}, {"chapter": "ch14", "type": "single", "stem": "电气配线长度一般计算为（ ）。", "options": {"A": "配管长度", "B": "配管长度+预留长度", "C": "水平段长度", "D": "垂直段长度"}, "answer": ["B"], "analysis": "配线长度=配管长度+预留长度；配管长度=水平段+垂直段。", "tags": ["计量", "电气配线"], "source": "安装教材精读笔记 第14.1节", "id": "q101", "date": "2026-07-06"}, {"chapter": "ch14", "type": "single", "stem": "广东2018安装定额第10册中，管道安装定额项目（ ）。", "options": {"A": "已含管道支架制作安装", "B": "不含管道支架，发生时另套相应项目", "C": "已含管卡", "D": "已含托钩"}, "answer": ["B"], "analysis": "管道安装定额项目均不含管道支架、管卡、托钩等制作安装，发生时另套本册及第4册相应项目。", "tags": ["定额", "支架"], "source": "2018广东安装定额第10册 说明", "id": "q102", "date": "2026-07-06"}, {"chapter": "ch14", "type": "multiple", "stem": "广东2018安装定额第12册（刷油、防腐蚀、绝热）中，关于型钢分类计量的说法正确的有（ ）。", "options": {"A": "大型型钢（H型钢及任一边>300mm）按㎡", "B": "管廊钢结构按kg", "C": "一般钢结构（含管道支架）按kg", "D": "全部按kg"}, "answer": ["A", "B", "C"], "analysis": "第12册：大型型钢（H型钢/任一边>300mm）按㎡；管廊、一般钢结构（含管道支架）按kg。", "tags": ["定额", "型钢计量", "第12册"], "source": "2018广东安装定额第12册 说明", "id": "q103", "date": "2026-07-06"}, {"chapter": "ch14", "type": "single", "stem": "广东2018安装定额第12册中，H型钢钢结构刷油按（ ）计量。", "options": {"A": "kg", "B": "㎡", "C": "个", "D": "m"}, "answer": ["B"], "analysis": "H型钢及任一边>300mm的大型型钢，刷油按展开面积㎡计量。", "tags": ["定额", "型钢计量", "第12册"], "source": "2018广东安装定额第12册 说明", "id": "q104", "date": "2026-07-06"}, {"chapter": "ch14", "type": "multiple", "stem": "广东2018安装定额第12册中，折合面积规定正确的有（ ）。", "options": {"A": "管廊综合 37㎡/t", "B": "大型型钢综合 25㎡/t", "C": "一般钢结构 37㎡/t", "D": "全部 25㎡/t"}, "answer": ["A", "B"], "analysis": "管廊综合每吨折合37㎡/t；大型型钢综合每吨折合25㎡/t。", "tags": ["定额", "折合面积", "第12册"], "source": "2018广东安装定额第12册 说明", "id": "q105", "date": "2026-07-06"}, {"chapter": "ch14", "type": "single", "stem": "由钢管组成的金属结构，刷油时应按（ ）执行。", "options": {"A": "H型钢刷油", "B": "管道刷油", "C": "板材刷油", "D": "一般钢结构刷油"}, "answer": ["B"], "analysis": "第12册规定：由钢管组成的金属结构刷油按管道刷油；由钢板组成的按H型钢刷油。", "tags": ["定额", "刷油", "第12册"], "source": "2018广东安装定额第12册 说明", "id": "q106", "date": "2026-07-06"}, {"chapter": "ch14", "type": "single", "stem": "由钢板组成的金属结构，刷油时应按（ ）执行。", "options": {"A": "管道刷油", "B": "H型钢刷油", "C": "板材刷油", "D": "一般钢结构刷油"}, "answer": ["B"], "analysis": "由钢板组成的金属结构刷油按H型钢刷油；由钢管组成的按管道刷油。", "tags": ["定额", "刷油", "第12册"], "source": "2018广东安装定额第12册 说明", "id": "q107", "date": "2026-07-06"}, {"id": "ch01-001", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "根据安装工程主要专业分类，电气设备安装工程对应的2018版广东省安装定额册号为（ ）。", "options": {"A": "第4册", "B": "第5册", "C": "第7册", "D": "第10册"}, "answer": ["A"], "analysis": "教材第1章明确：电气设备安装（变配电、照明、动力、防雷接地）对应2018定额第4册。", "tags": ["专业分类", "定额册号", "电气设备安装"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-002", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "给排水工程在2018版广东省安装定额中对应的册号是（ ）。", "options": {"A": "第7册", "B": "第8册", "C": "第10册", "D": "第12册"}, "answer": ["C"], "analysis": "教材第1章表：给排水工程（室内外给水、排水、热水）对应2018定额第10册（给排水、采暖、燃气工程）。", "tags": ["专业分类", "定额册号", "给排水工程"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-003", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "通风空调工程对应的2018版广东省安装定额册号为（ ）。", "options": {"A": "第4册", "B": "第7册", "C": "第9册", "D": "第10册"}, "answer": ["B"], "analysis": "教材第1章表：通风空调工程（通风、空调、防排烟）对应2018定额第7册。", "tags": ["专业分类", "定额册号", "通风空调工程"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-004", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "消防工程对应的2018版广东省安装定额册号为（ ）。", "options": {"A": "第5册", "B": "第7册", "C": "第9册", "D": "第11册"}, "answer": ["C"], "analysis": "教材第1章表：消防工程（水灭火、火灾报警、气体灭火）对应2018定额第9册。", "tags": ["专业分类", "定额册号", "消防工程"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-005", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "智能化工程对应的2018版广东省安装定额册号为（ ）。", "options": {"A": "第4册", "B": "第5册", "C": "第6册", "D": "第8册"}, "answer": ["B"], "analysis": "教材第1章表：智能化工程（综合布线、安防、楼宇自控）对应2018定额第5册（建筑智能化工程）。", "tags": ["专业分类", "定额册号", "智能化工程"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-006", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "工业管道工程对应的2018版广东省安装定额册号为（ ）。", "options": {"A": "第8册", "B": "第9册", "C": "第10册", "D": "第11册"}, "answer": ["A"], "analysis": "教材第1章表：工业管道（工艺管道、长输管道）对应2018定额第8册（工业管道，上下册）。", "tags": ["专业分类", "定额册号", "工业管道"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-007", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "下列属于电气设备安装工程主要内容的是（ ）。", "options": {"A": "综合布线", "B": "变配电、照明、动力、防雷接地", "C": "通风管道", "D": "消防报警"}, "answer": ["B"], "analysis": "教材第1章：电气设备安装主要内容包括变配电、照明、动力、防雷接地。", "tags": ["专业分类", "电气设备安装"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-008", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "给排水工程的主要内容包括（ ）。", "options": {"A": "室内外给水、排水、热水", "B": "通风、空调", "C": "变配电", "D": "综合布线"}, "answer": ["A"], "analysis": "教材第1章：给排水工程主要包括室内外给水、排水、热水。", "tags": ["专业分类", "给排水工程"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-009", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "通风空调工程的主要内容包括（ ）。", "options": {"A": "给排水", "B": "通风、空调、防排烟", "C": "变配电", "D": "综合布线"}, "answer": ["B"], "analysis": "教材第1章：通风空调工程主要包括通风、空调、防排烟。", "tags": ["专业分类", "通风空调工程"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-010", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "消防工程的主要内容包括（ ）。", "options": {"A": "水灭火、火灾报警、气体灭火", "B": "照明", "C": "通信", "D": "工业管道"}, "answer": ["A"], "analysis": "教材第1章：消防工程主要包括水灭火、火灾报警、气体灭火。", "tags": ["专业分类", "消防工程"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-011", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "智能化工程的主要内容包括（ ）。", "options": {"A": "防雷接地", "B": "综合布线、安防、楼宇自控", "C": "给排水", "D": "通风"}, "answer": ["B"], "analysis": "教材第1章：智能化工程主要包括综合布线、安全防范、楼宇自控。", "tags": ["专业分类", "智能化工程"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-012", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "工业管道工程的主要内容包括（ ）。", "options": {"A": "工艺管道、长输管道", "B": "卫生器具", "C": "照明", "D": "通风"}, "answer": ["A"], "analysis": "教材第1章：工业管道主要包括工艺管道、长输管道。", "tags": ["专业分类", "工业管道"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-013", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "下列关于安装专业与2018定额册号对应关系中，正确的是（ ）。", "options": {"A": "给排水工程—第4册", "B": "电气设备安装—第10册", "C": "电气设备安装—第4册", "D": "消防工程—第7册"}, "answer": ["C"], "analysis": "教材第1章：电气设备安装对应第4册，给排水对应第10册，消防对应第9册，通风空调对应第7册。", "tags": ["专业分类", "定额册号"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-014", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "建筑机电安装通常不包括下列（ ）专业。", "options": {"A": "电气设备安装", "B": "给排水工程", "C": "土建结构工程", "D": "通风空调工程"}, "answer": ["C"], "analysis": "建筑机电安装指建筑内的机械设备、电气、给排水、通风空调、消防、智能化等，土建结构不属于机电安装范畴。", "tags": ["专业分类", "建筑机电安装"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-015", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "防雷接地系统属于下列哪个安装专业（ ）。", "options": {"A": "电气设备安装", "B": "给排水工程", "C": "消防工程", "D": "智能化工程"}, "answer": ["A"], "analysis": "教材第1章：防雷接地是电气设备安装工程的系统组成之一。", "tags": ["专业分类", "电气设备安装", "防雷接地"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-016", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "火灾自动报警系统属于下列哪个安装专业（ ）。", "options": {"A": "消防工程", "B": "电气设备安装", "C": "智能化工程", "D": "给排水工程"}, "answer": ["A"], "analysis": "教材第1章：火灾自动报警系统属于消防工程的主要系统之一。", "tags": ["专业分类", "消防工程", "火灾报警"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-017", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "建筑设备监控系统（楼宇自控）属于下列哪个安装专业（ ）。", "options": {"A": "智能化工程", "B": "电气设备安装", "C": "消防工程", "D": "给排水工程"}, "answer": ["A"], "analysis": "教材第1章：建筑设备监控系统（楼宇自控）是智能化工程的子系统。", "tags": ["专业分类", "智能化工程", "楼宇自控"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-018", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "室内外消火栓系统属于下列哪个安装专业（ ）。", "options": {"A": "消防工程", "B": "给排水工程", "C": "电气设备安装", "D": "智能化工程"}, "answer": ["A"], "analysis": "教材第1章：消火栓系统（室内外消火栓）属于消防工程的主要系统。", "tags": ["专业分类", "消防工程", "消火栓"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-019", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "安装工程的主要专业分类（建筑机电安装）包括下列哪些（ ）。", "options": {"A": "电气设备安装", "B": "给排水工程", "C": "通风空调工程", "D": "消防工程"}, "answer": ["A", "B", "C", "D"], "analysis": "教材第1章表列出安装工程主要专业分类共6大类，其中建筑机电安装包括：电气设备安装、给排水工程、通风空调工程、消防工程、智能化工程、工业管道。本题四项均属该分类。", "tags": ["专业分类", "建筑机电安装"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-020", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "关于各安装专业对应的2018版广东安装定额册号，下列说法正确的有（ ）。", "options": {"A": "电气设备安装—第4册", "B": "给排水工程—第10册", "C": "通风空调工程—第7册", "D": "消防工程—第9册"}, "answer": ["A", "B", "C", "D"], "analysis": "教材第1章表：电气—第4册、给排水—第10册、通风空调—第7册、消防—第9册，均正确。", "tags": ["专业分类", "定额册号"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-021", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "下列专业与2018定额册号的对应关系中，正确的有（ ）。", "options": {"A": "工业管道—第8册", "B": "智能化工程—第5册", "C": "电气设备安装—第4册", "D": "给排水工程—第7册"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：工业管道—第8册、智能化—第5册、电气—第4册均正确；给排水工程对应第10册而非第7册，D错误。", "tags": ["专业分类", "定额册号"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-022", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "下列安装工程中，属于建筑机电安装（而非工业设备类）范畴的有（ ）。", "options": {"A": "通风空调工程", "B": "消防工程", "C": "机械设备安装（第1册）", "D": "刷油防腐蚀绝热（第12册）"}, "answer": ["A", "B"], "analysis": "建筑机电安装指建筑内的机电系统；机械设备安装（第1册）、刷油防腐蚀绝热（第12册）属于工业设备类定额，不属于建筑机电安装6大专业。", "tags": ["专业分类", "建筑机电安装"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-023", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "根据教材第1章，下列关于各专业内容的描述，正确的有（ ）。", "options": {"A": "电气设备安装含变配电", "B": "给排水工程含热水系统", "C": "消防工程含气体灭火", "D": "智能化工程含综合布线"}, "answer": ["A", "B", "C", "D"], "analysis": "教材第1章：电气含变配电照明动力防雷；给排水含室内外给水排水热水；消防含水灭火火灾报警气体灭火；智能化含综合布线安防楼宇自控。四项均正确。", "tags": ["专业分类", "各系统内容"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-024", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "下列内容中，属于给排水工程的有（ ）。", "options": {"A": "室内给水管道", "B": "排水管道", "C": "热水系统", "D": "通风管道"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：给排水工程包括室内外给水、排水、热水系统；通风管道属于通风空调工程。", "tags": ["专业分类", "给排水工程"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-025", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "下列内容中，属于消防工程的有（ ）。", "options": {"A": "室内外消火栓", "B": "自动喷水灭火系统", "C": "火灾自动报警系统", "D": "综合布线系统"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：消防工程包括消火栓、自动喷水、火灾报警、气体灭火等；综合布线属智能化工程。", "tags": ["专业分类", "消防工程"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-026", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "智能化工程的主要子系统包括（ ）。", "options": {"A": "综合布线系统", "B": "安全防范系统", "C": "建筑设备监控系统（楼宇自控）", "D": "防雷接地系统"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：智能化工程子系统含综合布线、安全防范（视频监控、门禁）、建筑设备监控（楼宇自控）；防雷接地属电气。", "tags": ["专业分类", "智能化工程"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-027", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "下列关于专业与2018定额册号的对应关系中，错误的有（ ）。", "options": {"A": "电气设备安装—第5册", "B": "给排水工程—第10册", "C": "通风空调工程—第7册", "D": "消防工程—第8册"}, "answer": ["A", "D"], "analysis": "教材第1章：电气对应第4册而非第5册（A错）；消防对应第9册而非第8册（D错）；给排水—第10册、通风空调—第7册正确。", "tags": ["专业分类", "定额册号"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-028", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "电气设备安装工程包含下列哪些系统（ ）。", "options": {"A": "变压器安装", "B": "配电柜安装", "C": "防雷接地装置", "D": "通风机安装"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：电气设备安装含变配电、照明、动力、防雷接地；通风机安装属通风空调工程（第7册）。", "tags": ["专业分类", "电气设备安装"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-029", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "工业管道工程包含下列哪些内容（ ）。", "options": {"A": "工艺管道", "B": "长输管道", "C": "卫生器具", "D": "室内消火栓"}, "answer": ["A", "B"], "analysis": "教材第1章：工业管道包括工艺管道、长输管道；卫生器具属给排水（第10册），消火栓属消防（第9册）。", "tags": ["专业分类", "工业管道"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-030", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "根据教材第1章，下列关于各专业分类描述正确的有（ ）。", "options": {"A": "通风空调工程含防排烟", "B": "给排水工程含热水系统", "C": "消防工程含水灭火系统", "D": "电气设备安装含通信系统"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：通风空调含防排烟、给排水含热水、消防含水灭火均正确；通信设备及线路属第11册，不属于电气设备安装主要内容。", "tags": ["专业分类", "各系统内容"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-031", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "建筑机电安装特点中，“需与土建、装修配合”体现的是（ ）。", "options": {"A": "配套性强", "B": "专业性强", "C": "隐蔽工程多", "D": "调试要求高"}, "answer": ["A"], "analysis": "教材第1章：建筑机电安装特点之一“配套性强”指需与土建、装修配合。", "tags": ["建筑机电安装特点", "配套性强"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-032", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "建筑机电安装特点中，“涉及多专业交叉”体现的是（ ）。", "options": {"A": "配套性强", "B": "专业性强", "C": "隐蔽工程多", "D": "调试要求高"}, "answer": ["B"], "analysis": "教材第1章：建筑机电安装特点之一“专业性强”指涉及多专业交叉。", "tags": ["建筑机电安装特点", "专业性强"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-033", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "建筑机电安装特点中，“预埋预留工作量大”体现的是（ ）。", "options": {"A": "配套性强", "B": "专业性强", "C": "隐蔽工程多", "D": "调试要求高"}, "answer": ["C"], "analysis": "教材第1章：建筑机电安装特点之一“隐蔽工程多”指预埋预留工作量大。", "tags": ["建筑机电安装特点", "隐蔽工程多"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-034", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "建筑机电安装特点中，“系统联动调试复杂”体现的是（ ）。", "options": {"A": "配套性强", "B": "专业性强", "C": "隐蔽工程多", "D": "调试要求高"}, "answer": ["D"], "analysis": "教材第1章：建筑机电安装特点之一“调试要求高”指系统联动调试复杂。", "tags": ["建筑机电安装特点", "调试要求高"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-035", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "下列描述中，不属于建筑机电安装特点的是（ ）。", "options": {"A": "配套性强", "B": "专业性强", "C": "隐蔽工程多", "D": "完全露天作业"}, "answer": ["D"], "analysis": "教材第1章建筑机电安装特点为配套性强、专业性强、隐蔽工程多、调试要求高；机电安装大量在建筑物内，并非完全露天作业。", "tags": ["建筑机电安装特点"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-036", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "建筑机电安装与土建、装修配合密切，说明其具有（ ）。", "options": {"A": "配套性强", "B": "单一性", "C": "无隐蔽性", "D": "无需调试"}, "answer": ["A"], "analysis": "教材第1章：与土建、装修配合密切正是“配套性强”特点的体现。", "tags": ["建筑机电安装特点", "配套性强"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-037", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "建筑机电安装“调试要求高”的主要原因是（ ）。", "options": {"A": "系统联动调试复杂", "B": "材料价格低", "C": "工期极短", "D": "无规范要求"}, "answer": ["A"], "analysis": "教材第1章：调试要求高是因为系统联动调试复杂。", "tags": ["建筑机电安装特点", "调试要求高"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-038", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "建筑机电安装“隐蔽工程多”主要是指（ ）。", "options": {"A": "预埋预留工作量大", "B": "设备均露天布置", "C": "无需图纸", "D": "人工投入少"}, "answer": ["A"], "analysis": "教材第1章：隐蔽工程多表现为预埋预留工作量大。", "tags": ["建筑机电安装特点", "隐蔽工程多"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-040", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "建筑机电安装“配套性强”体现在（ ）。", "options": {"A": "需与土建配合", "B": "需与装修配合", "C": "可完全独立施工", "D": "无需协调"}, "answer": ["A", "B"], "analysis": "教材第1章：配套性强指需与土建、装修配合，C、D与配套性强相悖。", "tags": ["建筑机电安装特点", "配套性强"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-041", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "建筑机电安装“隐蔽工程多”表现在（ ）。", "options": {"A": "预埋", "B": "预留", "C": "工作量大", "D": "均为明装"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：隐蔽工程多指预埋预留工作量大；D“均为明装”与隐蔽工程多相矛盾。", "tags": ["建筑机电安装特点", "隐蔽工程多"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-042", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "建筑机电安装“调试要求高”表现在（ ）。", "options": {"A": "系统联动调试", "B": "调试复杂", "C": "无需调试", "D": "单机即可投用"}, "answer": ["A", "B"], "analysis": "教材第1章：调试要求高是因为系统联动调试复杂；C、D与调试要求高相矛盾。", "tags": ["建筑机电安装特点", "调试要求高"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-043", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "下列关于建筑机电安装特点的表述中，错误的有（ ）。", "options": {"A": "可完全独立施工，无需配合", "B": "隐蔽工程很少", "C": "配套性强", "D": "调试要求高"}, "answer": ["A", "B"], "analysis": "教材第1章：建筑机电安装具有配套性强、专业性强、隐蔽工程多、调试要求高；A、B与特点相反，属错误表述。", "tags": ["建筑机电安装特点"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-044", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "在变配电系统中，设备组成的正确顺序为：变压器→配电柜→配电箱。其中变压器之后依次是（ ）。", "options": {"A": "配电柜、配电箱", "B": "线路、灯具", "C": "接闪器、引下线", "D": "电动机、设备"}, "answer": ["A"], "analysis": "教材第1章：变配电系统组成顺序为变压器→配电柜→配电箱。", "tags": ["电气系统", "变配电系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-045", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "照明系统的基本组成顺序为：配电箱→线路→灯具→开关。其起点设备是（ ）。", "options": {"A": "配电箱", "B": "变压器", "C": "电动机", "D": "接闪器"}, "answer": ["A"], "analysis": "教材第1章：照明系统由配电箱→线路→灯具→开关组成，起点为配电箱。", "tags": ["电气系统", "照明系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-046", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "动力系统的基本组成顺序为：配电箱→线路→电动机/设备。其末端设备是（ ）。", "options": {"A": "电动机/设备", "B": "开关", "C": "灯具", "D": "接地装置"}, "answer": ["A"], "analysis": "教材第1章：动力系统由配电箱→线路→电动机/设备组成，末端为电动机/设备。", "tags": ["电气系统", "动力系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-047", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "防雷接地系统的基本组成顺序为：接闪器→引下线→接地装置。其最上端（接收雷击）的部件是（ ）。", "options": {"A": "接闪器", "B": "引下线", "C": "接地装置", "D": "配电箱"}, "answer": ["A"], "analysis": "教材第1章：防雷接地系统由接闪器→引下线→接地装置组成，最上端为接闪器。", "tags": ["电气系统", "防雷接地"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-048", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "在防雷接地系统中，连接接闪器与接地装置的部件是（ ）。", "options": {"A": "引下线", "B": "配电箱", "C": "线路", "D": "灯具"}, "answer": ["A"], "analysis": "教材第1章：防雷接地系统组成为接闪器→引下线→接地装置，引下线连接接闪器与接地装置。", "tags": ["电气系统", "防雷接地"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-049", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "防雷接地系统的最末端（泄放雷电流入地）的部件是（ ）。", "options": {"A": "接地装置", "B": "接闪器", "C": "引下线", "D": "配电柜"}, "answer": ["A"], "analysis": "教材第1章：防雷接地系统组成为接闪器→引下线→接地装置，最末端为接地装置。", "tags": ["电气系统", "防雷接地"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-050", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "照明系统中，在配电箱之后、灯具之前的环节是（ ）。", "options": {"A": "线路", "B": "灯具", "C": "开关", "D": "变压器"}, "answer": ["A"], "analysis": "教材第1章：照明系统顺序为配电箱→线路→灯具→开关，配电箱之后为线路。", "tags": ["电气系统", "照明系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-051", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "照明系统中，灯具之后连接的部件是（ ）。", "options": {"A": "开关", "B": "配电箱", "C": "变压器", "D": "接地装置"}, "answer": ["A"], "analysis": "教材第1章：照明系统顺序为配电箱→线路→灯具→开关，灯具之后为开关。", "tags": ["电气系统", "照明系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-052", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "在建筑电气工程图中，符号“MX”通常表示（ ）。", "options": {"A": "照明配电箱", "B": "变压器", "C": "电缆", "D": "接地装置"}, "answer": ["A"], "analysis": "教材第1章及第6章图例：MX表示照明配电箱。", "tags": ["电气系统", "图例", "配电箱"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-053", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "配电箱（MX）在电气系统中通常作为（ ）。", "options": {"A": "出线回路起点", "B": "进线终点", "C": "接地装置", "D": "灯具本体"}, "answer": ["A"], "analysis": "教材第1章考试重点：配电箱（MX）通常为出线回路起点。", "tags": ["电气系统", "配电箱"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-054", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "照明回路的电压一般为（ ）。", "options": {"A": "220V", "B": "380V", "C": "660V", "D": "110V"}, "answer": ["A"], "analysis": "教材第1章考试重点：照明回路电压一般为220V。", "tags": ["电气系统", "电压", "照明"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-055", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "动力回路的电压一般为（ ）。", "options": {"A": "380V或220V", "B": "仅220V", "C": "仅380V", "D": "仅110V"}, "answer": ["A"], "analysis": "教材第1章考试重点：动力回路电压有380V/220V。", "tags": ["电气系统", "电压", "动力"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-056", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "变配电系统由下列哪些部分组成（ ）。", "options": {"A": "变压器", "B": "配电柜", "C": "配电箱", "D": "通风机"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：变配电系统组成为变压器→配电柜→配电箱；通风机属通风空调工程。", "tags": ["电气系统", "变配电系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-057", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "照明系统由下列哪些部分组成（ ）。", "options": {"A": "配电箱", "B": "线路", "C": "灯具", "D": "开关"}, "answer": ["A", "B", "C", "D"], "analysis": "教材第1章：照明系统组成为配电箱→线路→灯具→开关，四项均属照明系统。", "tags": ["电气系统", "照明系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-058", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "动力系统由下列哪些部分组成（ ）。", "options": {"A": "配电箱", "B": "线路", "C": "电动机/设备", "D": "接闪器"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：动力系统组成为配电箱→线路→电动机/设备；接闪器属防雷接地系统。", "tags": ["电气系统", "动力系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-059", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "防雷接地系统由下列哪些部分组成（ ）。", "options": {"A": "接闪器", "B": "引下线", "C": "接地装置", "D": "配电箱"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：防雷接地系统组成为接闪器→引下线→接地装置；配电箱属配电系统。", "tags": ["电气系统", "防雷接地"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-060", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "根据教材第1章，下列关于电气设备安装各系统组成顺序的描述，正确的有（ ）。", "options": {"A": "变配电：变压器→配电柜→配电箱", "B": "照明：配电箱→线路→灯具→开关", "C": "动力：配电箱→线路→电动机/设备", "D": "防雷：接闪器→引下线→接地装置"}, "answer": ["A", "B", "C", "D"], "analysis": "教材第1章：四个系统的组成顺序均如选项所述，全部正确。", "tags": ["电气系统", "系统组成"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-061", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "关于建筑电气图中的配电箱（MX），下列说法正确的有（ ）。", "options": {"A": "MX表示照明配电箱", "B": "通常为出线回路起点", "C": "属照明系统设备", "D": "属消防系统设备"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：MX表示照明配电箱，通常为出线回路起点，属照明/配电系统；不属于消防系统。", "tags": ["电气系统", "配电箱", "图例"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-062", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "关于电气系统电压，下列说法正确的有（ ）。", "options": {"A": "照明回路电压一般为220V", "B": "动力回路电压有380V/220V", "C": "照明回路均为380V", "D": "动力回路仅为220V"}, "answer": ["A", "B"], "analysis": "教材第1章考试重点：照明回路一般220V、动力回路380V/220V；C、D与教材相反。", "tags": ["电气系统", "电压"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-064", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "给水系统的基本组成顺序为：水源→水泵→管道→用水点。其起点是（ ）。", "options": {"A": "水源", "B": "水泵", "C": "管道", "D": "用水点"}, "answer": ["A"], "analysis": "教材第1章：给水系统组成为水源→水泵→管道→用水点，起点为水源。", "tags": ["给排水系统", "给水系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-065", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "排水系统的基本组成顺序为：排水点→管道→化粪池→市政管网。其中介于管道与市政管网之间的环节是（ ）。", "options": {"A": "化粪池", "B": "水泵", "C": "水源", "D": "用水点"}, "answer": ["A"], "analysis": "教材第1章：排水系统组成为排水点→管道→化粪池→市政管网，管道之后为化粪池。", "tags": ["给排水系统", "排水系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-066", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "热水系统的基本组成顺序为：热源→管道→用水点。其起点是（ ）。", "options": {"A": "热源", "B": "管道", "C": "用水点", "D": "化粪池"}, "answer": ["A"], "analysis": "教材第1章：热水系统组成为热源→管道→用水点，起点为热源。", "tags": ["给排水系统", "热水系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-067", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "给水系统中，在水泵之后、用水点之前的环节是（ ）。", "options": {"A": "管道", "B": "水源", "C": "化粪池", "D": "市政管网"}, "answer": ["A"], "analysis": "教材第1章：给水系统顺序为水源→水泵→管道→用水点，水泵之后为管道。", "tags": ["给排水系统", "给水系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-068", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "排水系统中，在管道之后、市政管网之前的环节是（ ）。", "options": {"A": "化粪池", "B": "水源", "C": "用水点", "D": "热源"}, "answer": ["A"], "analysis": "教材第1章：排水系统顺序为排水点→管道→化粪池→市政管网，管道之后为化粪池。", "tags": ["给排水系统", "排水系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-069", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "下列属于给排水工程基本工作内容的是（ ）。", "options": {"A": "室内外给水、排水、热水系统的安装", "B": "通风管道制作", "C": "火灾报警布线", "D": "综合布线"}, "answer": ["A"], "analysis": "教材第1章：给排水工程主要内容包括室内外给水、排水、热水系统。", "tags": ["给排水系统", "专业分类"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-070", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "给水系统由下列哪些环节组成（ ）。", "options": {"A": "水源", "B": "水泵", "C": "管道", "D": "用水点"}, "answer": ["A", "B", "C", "D"], "analysis": "教材第1章：给水系统组成为水源→水泵→管道→用水点，四项均属给水系统。", "tags": ["给排水系统", "给水系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-071", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "排水系统由下列哪些环节组成（ ）。", "options": {"A": "排水点", "B": "管道", "C": "化粪池", "D": "市政管网"}, "answer": ["A", "B", "C", "D"], "analysis": "教材第1章：排水系统组成为排水点→管道→化粪池→市政管网，四项均属排水系统。", "tags": ["给排水系统", "排水系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-072", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "给排水工程包含的子系统包括（ ）。", "options": {"A": "给水系统", "B": "排水系统", "C": "热水系统", "D": "通风系统"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：给排水工程包括给水、排水、热水系统；通风系统属通风空调工程。", "tags": ["给排水系统", "专业分类"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-073", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "根据教材第1章，下列关于给排水系统组成的描述，正确的有（ ）。", "options": {"A": "给水：水源→水泵→管道→用水点", "B": "排水：排水点→管道→化粪池→市政管网", "C": "热水：热源→管道→用水点", "D": "排水：用水点→管道→水源"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：给水、排水、热水系统组成顺序均如A、B、C所述；D顺序错误。", "tags": ["给排水系统", "系统组成"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-074", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "通风工程中，按通风动力方式可分为（ ）。", "options": {"A": "自然通风、机械通风", "B": "舒适性空调、工艺性空调", "C": "湿式、干式", "D": "高压、低压"}, "answer": ["A"], "analysis": "教材第1章：通风分为自然通风、机械通风。", "tags": ["通风空调系统", "通风分类"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-075", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "空调工程按用途可分为（ ）。", "options": {"A": "舒适性空调、工艺性空调", "B": "自然通风、机械通风", "C": "湿式、干式", "D": "单冷、冷暖"}, "answer": ["A"], "analysis": "教材第1章：空调分为舒适性空调、工艺性空调。", "tags": ["通风空调系统", "空调分类"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-076", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "通风空调工程中，风系统的基本组成顺序为（ ）。", "options": {"A": "风机→风管→风口", "B": "冷水机组→水泵→末端", "C": "传感器→控制器→执行器", "D": "水源→水泵→管道"}, "answer": ["A"], "analysis": "教材第1章：风系统组成为风机→风管→风口。", "tags": ["通风空调系统", "风系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-077", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "通风空调工程中，水系统的基本组成顺序为（ ）。", "options": {"A": "冷水机组→水泵→空调末端", "B": "风机→风管→风口", "C": "传感器→控制器→执行器", "D": "热源→管道→用水点"}, "answer": ["A"], "analysis": "教材第1章：水系统组成为冷水机组→水泵→空调末端。", "tags": ["通风空调系统", "水系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-078", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "通风空调工程中，控制系统的基本组成顺序为（ ）。", "options": {"A": "传感器→控制器→执行器", "B": "风机→风管→风口", "C": "冷水机组→水泵→末端", "D": "接闪器→引下线→接地装置"}, "answer": ["A"], "analysis": "教材第1章：控制系统组成为传感器→控制器→执行器。", "tags": ["通风空调系统", "控制系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-079", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "根据GB/T 50856-2024及2018广东安装定额第7册，柔性软风管的计量单位是（ ）。", "options": {"A": "m", "B": "节", "C": "㎡", "D": "个"}, "answer": ["A"], "analysis": "教材第1章及真题：柔性软风管按设计图示管道中心线长度以“m”计算（2024清单与2018定额第7册均为m）。", "tags": ["通风空调系统", "计量单位", "柔性软风管"], "source": "历年真题精华版"}, {"id": "ch01-080", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "通风空调工程按教材第1章的分类包括（ ）。", "options": {"A": "自然通风、机械通风", "B": "舒适性空调、工艺性空调", "C": "湿式系统、干式系统", "D": "高压系统、低压系统"}, "answer": ["A", "B"], "analysis": "教材第1章：通风分为自然通风、机械通风；空调分为舒适性空调、工艺性空调。C属消防自动喷水灭火系统类型，非通风空调分类。", "tags": ["通风空调系统", "分类"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-081", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "通风空调工程中，风系统由下列哪些部分组成（ ）。", "options": {"A": "风机", "B": "风管", "C": "风口", "D": "冷却塔"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：风系统组成为风机→风管→风口；冷却塔一般属水系统设备。", "tags": ["通风空调系统", "风系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-082", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "通风空调工程中，水系统由下列哪些部分组成（ ）。", "options": {"A": "冷水机组", "B": "水泵", "C": "空调末端", "D": "传感器"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：水系统组成为冷水机组→水泵→空调末端；传感器属控制系统。", "tags": ["通风空调系统", "水系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-083", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "根据教材第1章，下列关于通风空调工程的说法，正确的有（ ）。", "options": {"A": "柔性软风管计量单位为m", "B": "帆布软接口计量单位为㎡", "C": "风系统：风机→风管→风口", "D": "通风分为自然通风与机械通风"}, "answer": ["A", "B", "C", "D"], "analysis": "教材第1章：柔性软风管计量单位m、帆布软接口计量单位㎡（2018定额第7册）；风系统风机→风管→风口；通风分自然、机械通风。四项均正确。", "tags": ["通风空调系统", "计量单位", "系统组成"], "source": "历年真题精华版"}, {"id": "ch01-084", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "消防工程的主要系统一般不包括下列哪项（ ）。", "options": {"A": "综合布线系统", "B": "消火栓系统", "C": "自动喷水灭火系统", "D": "火灾自动报警系统"}, "answer": ["A"], "analysis": "教材第1章：消防工程主要包括消火栓、自动喷水、火灾报警、气体灭火；综合布线属智能化工程。", "tags": ["消防系统", "专业分类"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-085", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "自动喷水灭火系统按喷头动作方式可分为（ ）。", "options": {"A": "湿式、干式、预作用", "B": "自然、机械", "C": "舒适、工艺", "D": "高压、低压"}, "answer": ["A"], "analysis": "教材第1章：自动喷水灭火系统包括湿式、干式、预作用等类型。", "tags": ["消防系统", "自动喷水"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-086", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "消火栓系统的主要组成部分是（ ）。", "options": {"A": "室内外消火栓", "B": "探测器", "C": "气体钢瓶", "D": "综合布线"}, "answer": ["A"], "analysis": "教材第1章：消火栓系统包括室内外消火栓。", "tags": ["消防系统", "消火栓"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-087", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "火灾自动报警系统的基本组成顺序为（ ）。", "options": {"A": "探测器→控制器→联动设备", "B": "水源→水泵→管道", "C": "风机→风管→风口", "D": "接闪器→引下线→接地装置"}, "answer": ["A"], "analysis": "教材第1章：火灾自动报警系统组成为探测器→控制器→联动设备。", "tags": ["消防系统", "火灾报警"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-088", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "下列自动喷水灭火系统类型中，属于教材第1章所列类型的是（ ）。", "options": {"A": "湿式、干式、预作用均属", "B": "仅湿式", "C": "仅干式", "D": "仅预作用"}, "answer": ["A"], "analysis": "教材第1章：自动喷水灭火系统包括湿式、干式、预作用，三种均属其类型。", "tags": ["消防系统", "自动喷水"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-089", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "气体灭火系统属于下列哪个安装专业（ ）。", "options": {"A": "消防工程", "B": "给排水工程", "C": "电气设备安装", "D": "智能化工程"}, "answer": ["A"], "analysis": "教材第1章：气体灭火是消防工程的主要系统之一。", "tags": ["消防系统", "气体灭火"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-090", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "消防工程的主要系统包括（ ）。", "options": {"A": "消火栓系统", "B": "自动喷水灭火系统", "C": "火灾自动报警系统", "D": "综合布线系统"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：消防工程包括水灭火（消火栓、自动喷水）、火灾报警、气体灭火；综合布线属智能化。", "tags": ["消防系统", "专业分类"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-091", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "自动喷水灭火系统按教材第1章包括下列哪些类型（ ）。", "options": {"A": "湿式系统", "B": "干式系统", "C": "预作用系统", "D": "消火栓系统"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：自动喷水灭火系统包括湿式、干式、预作用；消火栓系统属消火栓系统，非自动喷水类型。", "tags": ["消防系统", "自动喷水"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-092", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "火灾自动报警系统由下列哪些部分组成（ ）。", "options": {"A": "探测器", "B": "控制器", "C": "联动设备", "D": "接地装置"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：火灾自动报警系统组成为探测器→控制器→联动设备；接地装置属防雷接地。", "tags": ["消防系统", "火灾报警"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-093", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "根据教材第1章，下列属于消防工程内容的有（ ）。", "options": {"A": "水灭火系统", "B": "火灾自动报警系统", "C": "气体灭火系统", "D": "通风系统"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：消防工程包括水灭火、火灾报警、气体灭火；通风系统属通风空调工程。", "tags": ["消防系统", "专业分类"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-094", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "智能化工程的主要子系统不包括下列哪项（ ）。", "options": {"A": "防雷接地系统", "B": "综合布线系统", "C": "安全防范系统", "D": "建筑设备监控系统"}, "answer": ["A"], "analysis": "教材第1章：智能化工程子系统含综合布线、安全防范、建筑设备监控；防雷接地属电气。", "tags": ["智能化系统", "子系统"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-095", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "安全防范系统通常不包括下列哪项（ ）。", "options": {"A": "给水管道", "B": "视频监控", "C": "门禁", "D": "入侵报警"}, "answer": ["A"], "analysis": "教材第1章：安全防范系统包括视频监控、门禁等；给水管道属给排水工程。", "tags": ["智能化系统", "安全防范"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-096", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "建筑设备监控系统通常又称为（ ）。", "options": {"A": "楼宇自控", "B": "防雷接地", "C": "给水系统", "D": "消火栓系统"}, "answer": ["A"], "analysis": "教材第1章：建筑设备监控系统即楼宇自控（BAS），是智能化工程子系统。", "tags": ["智能化系统", "楼宇自控"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-097", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "综合布线系统属于下列哪个安装专业（ ）。", "options": {"A": "智能化工程", "B": "电气设备安装", "C": "消防工程", "D": "给排水工程"}, "answer": ["A"], "analysis": "教材第1章：综合布线系统是智能化工程的主要子系统之一。", "tags": ["智能化系统", "综合布线"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-098", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "下列属于智能化工程基本工作内容的是（ ）。", "options": {"A": "综合布线、安防、楼宇自控", "B": "变配电", "C": "通风管道", "D": "消防报警"}, "answer": ["A"], "analysis": "教材第1章：智能化工程主要包括综合布线、安全防范、楼宇自控。", "tags": ["智能化系统", "专业分类"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-100", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "安全防范系统一般包括（ ）。", "options": {"A": "视频监控", "B": "门禁", "C": "综合布线", "D": "楼宇自控"}, "answer": ["A", "B"], "analysis": "教材第1章：安全防范系统包括视频监控、门禁；综合布线、楼宇自控是智能化其他子系统。", "tags": ["智能化系统", "安全防范"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-101", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "根据教材第1章，下列关于智能化工程的说法，正确的有（ ）。", "options": {"A": "含综合布线系统", "B": "含安全防范系统", "C": "含建筑设备监控（楼宇自控）", "D": "属于电气设备安装工程"}, "answer": ["A", "B", "C"], "analysis": "教材第1章：智能化工程含综合布线、安全防范、楼宇自控，是独立专业（对应第5册），不属于电气设备安装（第4册）。", "tags": ["智能化系统", "专业分类"], "source": "安装教材精读笔记(第1章)"}, {"id": "ch01-102", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "2018版广东省通用安装工程综合定额第1册是（ ）。", "options": {"A": "机械设备安装工程", "B": "热力设备安装工程", "C": "电气设备安装工程", "D": "静置设备与工艺金属结构"}, "answer": ["A"], "analysis": "2018广东安装定额共12册，第1册为机械设备安装工程。", "tags": ["12册定额", "第1册"], "source": "2018广东安装定额"}, {"id": "ch01-103", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "2018版广东省安装定额第2册是（ ）。", "options": {"A": "机械设备安装工程", "B": "热力设备安装工程", "C": "电气设备安装工程", "D": "工业管道工程"}, "answer": ["B"], "analysis": "2018广东安装定额第2册为热力设备安装工程。", "tags": ["12册定额", "第2册"], "source": "2018广东安装定额"}, {"id": "ch01-104", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "2018版广东省安装定额第3册是（ ）。", "options": {"A": "机械设备安装工程", "B": "静置设备与工艺金属结构制作安装工程", "C": "电气设备安装工程", "D": "自动化控制仪表"}, "answer": ["B"], "analysis": "2018广东安装定额第3册为静置设备与工艺金属结构制作安装工程。", "tags": ["12册定额", "第3册"], "source": "2018广东安装定额"}, {"id": "ch01-105", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "2018版广东省安装定额第4册是（ ），且为上下册形式。", "options": {"A": "电气设备安装工程", "B": "建筑智能化工程", "C": "通风空调工程", "D": "消防工程"}, "answer": ["A"], "analysis": "2018广东安装定额第4册为电气设备安装工程（上下册），对应建筑机电安装电气专业。", "tags": ["12册定额", "第4册", "电气设备"], "source": "2018广东安装定额"}, {"id": "ch01-106", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "2018版广东省安装定额第5册是（ ）。", "options": {"A": "建筑智能化工程", "B": "自动化控制仪表安装工程", "C": "通风空调工程", "D": "工业管道工程"}, "answer": ["A"], "analysis": "2018广东安装定额第5册为建筑智能化工程，对应智能化专业。", "tags": ["12册定额", "第5册", "智能化"], "source": "2018广东安装定额"}, {"id": "ch01-107", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "2018版广东省安装定额第6册是（ ）。", "options": {"A": "自动化控制仪表安装工程", "B": "建筑智能化工程", "C": "通风空调工程", "D": "消防工程"}, "answer": ["A"], "analysis": "2018广东安装定额第6册为自动化控制仪表安装工程。", "tags": ["12册定额", "第6册"], "source": "2018广东安装定额"}, {"id": "ch01-108", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "2018版广东省安装定额第7册是（ ）。", "options": {"A": "通风空调工程", "B": "工业管道工程", "C": "消防工程", "D": "给排水、采暖、燃气工程"}, "answer": ["A"], "analysis": "2018广东安装定额第7册为通风空调工程，对应通风空调专业。", "tags": ["12册定额", "第7册", "通风空调"], "source": "2018广东安装定额"}, {"id": "ch01-109", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "2018版广东省安装定额第8册是（ ），且为上下册形式。", "options": {"A": "工业管道工程", "B": "消防工程", "C": "给排水、采暖、燃气工程", "D": "通信设备及线路工程"}, "answer": ["A"], "analysis": "2018广东安装定额第8册为工业管道工程（上下册），对应工业管道专业。", "tags": ["12册定额", "第8册", "工业管道"], "source": "2018广东安装定额"}, {"id": "ch01-110", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "2018版广东省安装定额第9册是（ ）。", "options": {"A": "消防工程", "B": "给排水、采暖、燃气工程", "C": "通信设备及线路工程", "D": "刷油、防腐蚀、绝热工程"}, "answer": ["A"], "analysis": "2018广东安装定额第9册为消防工程，对应消防专业。", "tags": ["12册定额", "第9册", "消防"], "source": "2018广东安装定额"}, {"id": "ch01-111", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "下列均属于2018版广东省通用安装工程综合定额册号的有（ ）。", "options": {"A": "第4册 电气设备安装", "B": "第7册 通风空调工程", "C": "第10册 给排水、采暖、燃气工程", "D": "第12册 刷油、防腐蚀、绝热工程"}, "answer": ["A", "B", "C", "D"], "analysis": "2018广东安装定额共12册，第4、7、10、12册名称如选项所述，均正确。", "tags": ["12册定额", "册号"], "source": "2018广东安装定额"}, {"id": "ch01-112", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "2018版广东省安装定额第10册（给排水、采暖、燃气工程）包含下列哪些内容（ ）。", "options": {"A": "给排水管道安装", "B": "采暖管道安装", "C": "燃气管道安装", "D": "通信设备安装"}, "answer": ["A", "B", "C"], "analysis": "2018定额第10册为给排水、采暖、燃气工程，含给排水、采暖、燃气管道及器具安装；通信设备安装属第11册。", "tags": ["12册定额", "第10册"], "source": "2018广东安装定额"}, {"id": "ch01-113", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "2018版广东省安装定额第11册（通信设备及线路工程）包含下列哪些内容（ ）。", "options": {"A": "通信设备安装", "B": "通信线路敷设", "C": "移动通信基站", "D": "给排水管道"}, "answer": ["A", "B", "C"], "analysis": "2018定额第11册为通信设备及线路工程，含通信设备、通信线路、移动通信基站等；给排水管道属第10册。", "tags": ["12册定额", "第11册"], "source": "2018广东安装定额"}, {"id": "ch01-114", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "2018版广东省安装定额第12册（刷油、防腐蚀、绝热工程）包含下列哪些内容（ ）。", "options": {"A": "刷油工程", "B": "防腐蚀工程", "C": "绝热工程", "D": "通风管道制作"}, "answer": ["A", "B", "C"], "analysis": "2018定额第12册为刷油、防腐蚀、绝热工程；通风管道制作安装属第7册。", "tags": ["12册定额", "第12册"], "source": "2018广东安装定额"}, {"id": "ch01-115", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "2018版广东省安装定额中，以“上下册”形式出版的册有（ ）。", "options": {"A": "第4册 电气设备安装", "B": "第8册 工业管道", "C": "第7册 通风空调", "D": "第10册 给排水、采暖、燃气"}, "answer": ["A", "B"], "analysis": "2018广东安装定额中第4册（电气设备安装）与第8册（工业管道）为上下册形式；第7、10册为单册。", "tags": ["12册定额", "上下册"], "source": "2018广东安装定额"}, {"id": "ch01-116", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "关于2018版广东省通用安装工程综合定额的册设置，下列说法正确的有（ ）。", "options": {"A": "共12册", "B": "第3册为静置设备与工艺金属结构", "C": "第6册为自动化控制仪表", "D": "第5册为建筑智能化工程"}, "answer": ["A", "B", "C", "D"], "analysis": "2018广东安装定额共12册，第3册静置设备与工艺金属结构、第5册建筑智能化、第6册自动化控制仪表，均正确。", "tags": ["12册定额", "册设置"], "source": "2018广东安装定额"}, {"id": "ch01-117", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "《通用安装工程工程量计算标准》的标准编号为（ ）。", "options": {"A": "GB/T 50856-2024", "B": "GB 50856-2013", "C": "GB 50500-2013", "D": "GB/T 50500-2024"}, "answer": ["A"], "analysis": "2024版清单标准编号为GB/T 50856-2024。", "tags": ["2024清单", "标准编号"], "source": "GB/T 50856-2024"}, {"id": "ch01-118", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "GB/T 50856-2024的标准名称为（ ）。", "options": {"A": "通用安装工程工程量计算标准", "B": "建设工程工程量清单计价规范", "C": "通用安装工程工程量计算规范", "D": "广东省安装综合定额"}, "answer": ["A"], "analysis": "GB/T 50856-2024名称为《通用安装工程工程量计算标准》。", "tags": ["2024清单", "标准名称"], "source": "GB/T 50856-2024"}, {"id": "ch01-119", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "GB/T 50856-2024的标准性质为（ ）。", "options": {"A": "推荐性标准", "B": "强制性标准", "C": "企业标准", "D": "协会标准"}, "answer": ["A"], "analysis": "2024版由原先强制性GB 50856-2013调整为推荐性标准GB/T 50856-2024，不再设强制性条文。", "tags": ["2024清单", "标准性质"], "source": "GB/T 50856-2024"}, {"id": "ch01-120", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "GB/T 50856-2024的实施日期是（ ）。", "options": {"A": "2025年9月1日", "B": "2024年11月12日", "C": "2019年3月1日", "D": "2013年1月1日"}, "answer": ["A"], "analysis": "GB/T 50856-2024于2024年11月12日发布，2025年9月1日实施。", "tags": ["2024清单", "实施日期"], "source": "GB/T 50856-2024"}, {"id": "ch01-121", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "GB/T 50856-2024替代的上一版标准是（ ）。", "options": {"A": "GB 50856-2013", "B": "GB 50500-2013", "C": "GB/T 50500-2013", "D": "GB 50243-2016"}, "answer": ["A"], "analysis": "GB/T 50856-2024替代GB 50856-2013，自实施之日起原标准废止。", "tags": ["2024清单", "替代标准"], "source": "GB/T 50856-2024"}, {"id": "ch01-122", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "GB/T 50856-2024共设置多少个专业附录（含措施项目附录）（ ）。", "options": {"A": "14个", "B": "12个", "C": "9个", "D": "16个"}, "answer": ["A"], "analysis": "2024版清单共14个专业附录（A～N及P），项目总数1189个。", "tags": ["2024清单", "附录数量"], "source": "GB/T 50856-2024"}, {"id": "ch01-123", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "关于GB/T 50856-2024，下列说法正确的有（ ）。", "options": {"A": "标准编号GB/T 50856-2024", "B": "名称为通用安装工程工程量计算标准", "C": "为推荐性标准", "D": "实施日期2025年9月1日"}, "answer": ["A", "B", "C", "D"], "analysis": "2024版清单编号GB/T 50856-2024、名称《通用安装工程工程量计算标准》、推荐性标准、2025年9月1日实施，四项均正确。", "tags": ["2024清单", "基本信息"], "source": "GB/T 50856-2024"}, {"id": "ch01-124", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "GB/T 50856-2024的适用范围包括（ ）。", "options": {"A": "新建通用安装工程", "B": "扩建通用安装工程", "C": "改建通用安装工程", "D": "设计施工总承包"}, "answer": ["A", "B", "C"], "analysis": "2024版清单适用于新建、扩建、改建通用安装工程的施工发承包及实施阶段计量；明确不再适用于设计施工总承包。", "tags": ["2024清单", "适用范围"], "source": "GB/T 50856-2024"}, {"id": "ch01-126", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "GB/T 50856-2024相比2013版新增的附录有（ ）。", "options": {"A": "附录M 刷油、防腐蚀、绝热工程", "B": "附录N 其他及附属工程", "C": "附录A 机械设备安装工程", "D": "附录P 措施项目"}, "answer": ["A", "B"], "analysis": "2024版新增附录M（刷油、防腐蚀、绝热工程）和附录N（其他及附属工程）；附录A、P在2013版已存在。", "tags": ["2024清单", "新增附录"], "source": "GB/T 50856-2024"}, {"id": "ch01-127", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "2018版广东省通用安装工程综合定额主要用于规定（ ）。", "options": {"A": "人工、材料、施工机具的消耗量", "B": "工程量清单计量规则", "C": "清单项目编码", "D": "项目特征描述要求"}, "answer": ["A"], "analysis": "2018广东安装定额为消耗量定额，规定完成工程量所需的人工、材料、机具消耗量（社会平均成本），用于计价。", "tags": ["2018定额", "定额性质"], "source": "2018广东安装定额"}, {"id": "ch01-128", "date": "2026-07-06", "chapter": "ch01", "type": "single", "stem": "在实际工程中，2024版清单与2018版广东安装定额的关系是（ ）。", "options": {"A": "配套使用", "B": "互相替代", "C": "仅用清单即可", "D": "仅用定额即可"}, "answer": ["A"], "analysis": "2018定额规定“消耗量”，2024清单规定“计量规则”，两者配套使用：清单算量、定额组价，共同完成计价。", "tags": ["清单与定额衔接", "配套使用"], "source": "2018广东安装定额"}, {"id": "ch01-129", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "关于2018版广东安装定额与2024版清单的关系，下列说法正确的有（ ）。", "options": {"A": "2018定额规定人工材料机具消耗量", "B": "2024清单规定工程量计量规则", "C": "两者应配套使用", "D": "2024清单规定消耗量"}, "answer": ["A", "B", "C"], "analysis": "2018定额规定“消耗量”，2024清单规定“计量规则”，二者配套使用完成计价；D将二者作用颠倒，错误。", "tags": ["清单与定额衔接"], "source": "2018广东安装定额"}, {"id": "ch01-130", "date": "2026-07-06", "chapter": "ch01", "type": "multiple", "stem": "关于2018版广东安装定额与2024版清单的性质及执行，下列说法正确的有（ ）。", "options": {"A": "2018定额在广东省内强制性执行", "B": "2024清单为推荐性标准", "C": "2024清单替代GB 50856-2013", "D": "2018定额为推荐性标准"}, "answer": ["A", "B", "C"], "analysis": "2018广东安装定额在省内强制性执行，2024清单为推荐性标准且替代GB 50856-2013；D错误，2018定额为强制性。", "tags": ["清单与定额衔接", "标准性质"], "source": "GB/T 50856-2024"}, {"id": "ch02-001", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列材料中，属于型钢的是（ ）。", "options": {"A": "钢板", "B": "工字钢", "C": "镀锌钢板", "D": "不锈钢板"}, "answer": ["B"], "analysis": "型钢是具有一定截面形状的长条钢材，包括工字钢、槽钢、角钢、圆钢、H型钢等；钢板属于板材，不属于型钢。", "tags": ["型钢与板材区分"], "source": "安装教材精读笔记"}, {"id": "ch02-002", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "五角钢在安装工程材料分类中属于（ ）。", "options": {"A": "板材", "B": "型钢", "C": "管材", "D": "线缆"}, "answer": ["B"], "analysis": "依据2024年真题，五角钢属于型钢，与钢板（板材）有明显区别。", "tags": ["型钢与板材区分", "五角钢"], "source": "历年真题精华版"}, {"id": "ch02-004", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "H型钢按《广东省通用安装工程综合定额（2018）》第十二册分类计量，属于（ ）。", "options": {"A": "一般钢结构", "B": "管廊钢结构", "C": "大型型钢", "D": "管道刷油"}, "answer": ["C"], "analysis": "第十二册册说明规定：H型钢及任何一边大于300mm以上的型钢均为大型型钢，按展开面积（㎡）计算。", "tags": ["第12册型钢分类计量", "大型型钢"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-005", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "圆钢属于下列哪一类材料（ ）。", "options": {"A": "板材", "B": "管材", "C": "型钢", "D": "母线"}, "answer": ["C"], "analysis": "圆钢是截面为圆形的长条钢材，属于型钢的一种。", "tags": ["型钢与板材区分"], "source": "安装教材精读笔记"}, {"id": "ch02-006", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "槽钢在安装工程材料分类中属于（ ）。", "options": {"A": "型钢", "B": "板材", "C": "管材", "D": "线材"}, "answer": ["A"], "analysis": "槽钢为凹槽截面型钢，常用于支撑结构，属于型钢类。", "tags": ["型钢与板材区分"], "source": "安装教材精读笔记"}, {"id": "ch02-007", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "角钢属于（ ）。", "options": {"A": "板材", "B": "型钢", "C": "管材", "D": "电缆"}, "answer": ["B"], "analysis": "角钢为L形截面型钢，属于型钢类，常用于支架、支撑结构。", "tags": ["型钢与板材区分"], "source": "安装教材精读笔记"}, {"id": "ch02-008", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列关于型钢与板材区别的说法，正确的是（ ）。", "options": {"A": "型钢是平板", "B": "板材有固定截面形状", "C": "型钢具有一定截面形状", "D": "板材用于支撑结构"}, "answer": ["C"], "analysis": "型钢具有一定截面形状（如工字、槽、角、圆等），板材为平板，型钢多用于支撑结构。", "tags": ["型钢与板材区分"], "source": "安装教材精读笔记"}, {"id": "ch02-009", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "工字钢在安装工程中的主要用途是（ ）。", "options": {"A": "介质输送", "B": "支撑结构", "C": "平台铺设板材", "D": "电气绝缘"}, "answer": ["B"], "analysis": "型钢（工字钢、槽钢、角钢、圆钢）主要用于支撑结构。", "tags": ["型钢与板材区分", "型钢用途"], "source": "安装教材精读笔记"}, {"id": "ch02-010", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "钢板属于（ ）。", "options": {"A": "型钢", "B": "板材", "C": "管材", "D": "线材"}, "answer": ["B"], "analysis": "钢板为平板状材料，属于板材类，用于平台、容器等。", "tags": ["型钢与板材区分"], "source": "安装教材精读笔记"}, {"id": "ch02-011", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列既属于型钢又常用于制作管道支架的是（ ）。", "options": {"A": "钢板", "B": "角钢", "C": "镀锌钢板", "D": "PVC板"}, "answer": ["B"], "analysis": "角钢属于型钢，型钢（含角钢、槽钢等）多用于支撑结构及管道支架制作；钢板、镀锌钢板属于板材。", "tags": ["型钢与板材区分", "型钢用途"], "source": "安装教材精读笔记"}, {"id": "ch02-012", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "方钢在安装工程材料分类中属于（ ）。", "options": {"A": "板材", "B": "型钢", "C": "管材", "D": "电缆"}, "answer": ["B"], "analysis": "型钢包括圆钢、方钢、扁钢、工字钢、槽钢、角钢、H型钢等，方钢属于型钢。", "tags": ["型钢与板材区分"], "source": "安装教材精读笔记"}, {"id": "ch02-013", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "扁钢属于（ ）。", "options": {"A": "型钢", "B": "板材", "C": "管材", "D": "母线"}, "answer": ["A"], "analysis": "扁钢为矩形截面长条钢材，属于型钢的一种。", "tags": ["型钢与板材区分"], "source": "安装教材精读笔记"}, {"id": "ch02-014", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列材料中，不属于型钢的是（ ）。", "options": {"A": "圆钢", "B": "工字钢", "C": "钢板", "D": "角钢"}, "answer": ["C"], "analysis": "钢板属于板材，不属于型钢；圆钢、工字钢、角钢均为型钢。", "tags": ["型钢与板材区分"], "source": "安装教材精读笔记"}, {"id": "ch02-015", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "在安装工程材料分类中，不锈钢板属于（ ）。", "options": {"A": "型钢", "B": "板材", "C": "管材", "D": "线材"}, "answer": ["B"], "analysis": "不锈钢板虽材质特殊，但形态为平板，仍属于板材类。", "tags": ["型钢与板材区分"], "source": "安装教材精读笔记"}, {"id": "ch02-016", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列关于五角钢的说法，正确的是（ ）。", "options": {"A": "属于板材", "B": "属于型钢", "C": "属于管材", "D": "属于电缆"}, "answer": ["B"], "analysis": "五角钢是具有一定截面形状的型钢，属2024年真题明确考点，钢板才属于板材。", "tags": ["型钢与板材区分", "五角钢"], "source": "历年真题精华版"}, {"id": "ch02-017", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "H型钢钢结构刷油时，依据第十二册其工程量计量单位是（ ）。", "options": {"A": "kg", "B": "㎡", "C": "m", "D": "根"}, "answer": ["B"], "analysis": "第十二册规定大型型钢（含H型钢、任何一边大于300mm的型钢）按设计图示尺寸以㎡计算。", "tags": ["第12册型钢分类计量", "大型型钢"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-018", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "型钢与板材最本质的区别是（ ）。", "options": {"A": "颜色不同", "B": "是否经过镀锌", "C": "是否具有特定截面形状", "D": "是否用于电气"}, "answer": ["C"], "analysis": "型钢具有特定截面形状（工字、槽、角、圆、H等），板材为平板，这是二者最本质的区别。", "tags": ["型钢与板材区分"], "source": "安装教材精读笔记"}, {"id": "ch02-019", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列属于型钢的有（ ）。（2024年真题）", "options": {"A": "圆钢", "B": "工字钢", "C": "槽钢", "D": "钢板", "E": "五角钢"}, "answer": ["A", "B", "C", "E"], "analysis": "型钢包括圆钢、方钢、扁钢、工字钢、槽钢、角钢、H型钢、五角钢等；钢板属于板材，不属于型钢。", "tags": ["型钢与板材区分", "五角钢"], "source": "历年真题精华版"}, {"id": "ch02-020", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列材料中，属于板材的有（ ）。", "options": {"A": "钢板", "B": "镀锌钢板", "C": "不锈钢板", "D": "工字钢", "E": "角钢"}, "answer": ["A", "B", "C"], "analysis": "钢板、镀锌钢板、不锈钢板均为平板状材料，属于板材；工字钢、角钢属于型钢。", "tags": ["型钢与板材区分"], "source": "安装教材精读笔记"}, {"id": "ch02-021", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列型钢中，常用于支撑结构的有（ ）。", "options": {"A": "工字钢", "B": "槽钢", "C": "角钢", "D": "圆钢", "E": "钢板"}, "answer": ["A", "B", "C", "D"], "analysis": "型钢（工字钢、槽钢、角钢、圆钢等）主要用于支撑结构；钢板属于板材，不属型钢。", "tags": ["型钢与板材区分", "型钢用途"], "source": "安装教材精读笔记"}, {"id": "ch02-022", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列材料中，属于型钢的有（ ）。", "options": {"A": "方钢", "B": "扁钢", "C": "H型钢", "D": "钢板", "E": "钢管"}, "answer": ["A", "B", "C"], "analysis": "方钢、扁钢、H型钢均为型钢；钢板属于板材，钢管属于管材。", "tags": ["型钢与板材区分"], "source": "安装教材精读笔记"}, {"id": "ch02-023", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列关于型钢的说法，正确的有（ ）。", "options": {"A": "型钢具有一定截面形状", "B": "工字钢属于型钢", "C": "角钢属于型钢", "D": "钢板属于型钢", "E": "五角钢属于型钢"}, "answer": ["A", "B", "C", "E"], "analysis": "型钢具有一定截面形状，工字钢、角钢、五角钢均属型钢；钢板属于板材，不属型钢。", "tags": ["型钢与板材区分"], "source": "安装教材精读笔记"}, {"id": "ch02-024", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列材料中，属于板材类的有（ ）。", "options": {"A": "钢板", "B": "花纹钢板", "C": "镀锌钢板", "D": "槽钢", "E": "圆钢"}, "answer": ["A", "B", "C"], "analysis": "钢板、花纹钢板、镀锌钢板均为平板状板材；槽钢、圆钢属于型钢。", "tags": ["型钢与板材区分"], "source": "安装教材精读笔记"}, {"id": "ch02-025", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列既可作支撑结构又属于型钢的有（ ）。", "options": {"A": "工字钢", "B": "槽钢", "C": "H型钢", "D": "钢板", "E": "钢管"}, "answer": ["A", "B", "C"], "analysis": "工字钢、槽钢、H型钢均为型钢且常用于支撑结构；钢板属板材，钢管属管材。", "tags": ["型钢与板材区分", "型钢用途"], "source": "安装教材精读笔记"}, {"id": "ch02-026", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "依据第十二册定额，下列刷油按'㎡'计量单位的有（ ）。", "options": {"A": "大型型钢", "B": "H型钢钢结构", "C": "一般钢结构", "D": "管廊钢结构", "E": "管道"}, "answer": ["A", "B"], "analysis": "第十二册规定大型型钢（含H型钢及任何一边大于300mm的型钢）按㎡；一般钢结构、管廊钢结构按kg；管道按㎡（但管道非型钢类，题意为型钢分类计量，故选AB）。", "tags": ["第12册型钢分类计量", "大型型钢"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-028", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列关于型钢与板材的说法，正确的有（ ）。", "options": {"A": "型钢有特定截面形状", "B": "板材为平板", "C": "钢板属于板材", "D": "工字钢属于型钢", "E": "镀锌钢板属于型钢"}, "answer": ["A", "B", "C", "D"], "analysis": "型钢有特定截面形状，板材为平板；钢板、镀锌钢板属板材，工字钢属型钢。E错误。", "tags": ["型钢与板材区分"], "source": "安装教材精读笔记"}, {"id": "ch02-031", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "无缝钢管的主要特点是（ ）。", "options": {"A": "成本低、易锈蚀", "B": "强度高，用于高压、高温", "C": "耐腐蚀，用于饮用水", "D": "易结垢"}, "answer": ["B"], "analysis": "无缝钢管强度高，主要用于高压、高温场合。", "tags": ["金属管材特点与适用", "无缝钢管"], "source": "安装教材精读笔记"}, {"id": "ch02-032", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "镀锌钢管适用于（ ）。", "options": {"A": "非饮用水", "B": "生活饮用水", "C": "高压高温蒸汽", "D": "排水"}, "answer": ["B"], "analysis": "镀锌钢管耐腐蚀，适用于生活饮用水管道。", "tags": ["金属管材特点与适用", "镀锌钢管"], "source": "安装教材精读笔记"}, {"id": "ch02-033", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "焊接钢管不宜用于（ ）。", "options": {"A": "消防管道", "B": "非饮用水", "C": "生活饮用水", "D": "支架制作"}, "answer": ["C"], "analysis": "焊接钢管易锈蚀，不宜用于生活饮用水；可用于消防、非饮用水及支架。", "tags": ["金属管材特点与适用", "焊接钢管"], "source": "安装教材精读笔记"}, {"id": "ch02-034", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列管材中，主要由于耐腐蚀而用于生活饮用水的是（ ）。", "options": {"A": "焊接钢管", "B": "镀锌钢管", "C": "无缝钢管", "D": "铸铁管"}, "answer": ["B"], "analysis": "镀锌钢管表面镀锌层耐腐蚀，因此适用于生活饮用水。", "tags": ["金属管材特点与适用", "镀锌钢管"], "source": "安装教材精读笔记"}, {"id": "ch02-035", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "铸铁管多用于（ ）。", "options": {"A": "生活饮用水", "B": "高压高温蒸汽", "C": "排水", "D": "消防喷淋主干"}, "answer": ["C"], "analysis": "铸铁管主要（多用于）排水系统，不宜用于生活饮用水。", "tags": ["金属管材特点与适用", "铸铁管"], "source": "安装教材精读笔记"}, {"id": "ch02-036", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "高压、高温场合宜优先选用（ ）。", "options": {"A": "焊接钢管", "B": "镀锌钢管", "C": "无缝钢管", "D": "塑料管"}, "answer": ["C"], "analysis": "无缝钢管强度高，适用于高压、高温场合。", "tags": ["金属管材特点与适用", "无缝钢管"], "source": "安装教材精读笔记"}, {"id": "ch02-037", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "成本较低但易锈蚀的管材是（ ）。", "options": {"A": "镀锌钢管", "B": "焊接钢管", "C": "无缝钢管", "D": "不锈钢管"}, "answer": ["B"], "analysis": "焊接钢管成本低但易锈蚀，是其突出特点。", "tags": ["金属管材特点与适用", "焊接钢管"], "source": "安装教材精读笔记"}, {"id": "ch02-038", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "消防管道常采用的管材是（ ）。", "options": {"A": "焊接钢管", "B": "无缝钢管", "C": "镀锌钢管", "D": "PVC管"}, "answer": ["A"], "analysis": "焊接钢管适用于非饮用水、消防等场合，消防管道常采用焊接钢管。", "tags": ["金属管材特点与适用", "焊接钢管"], "source": "安装教材精读笔记"}, {"id": "ch02-039", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列管材中，不属于金属管的是（ ）。", "options": {"A": "焊接钢管", "B": "镀锌钢管", "C": "无缝钢管", "D": "PVC管"}, "answer": ["D"], "analysis": "焊接钢管、镀锌钢管、无缝钢管均为金属管材；PVC管为塑料管，属非金属管材。", "tags": ["金属管材特点与适用"], "source": "安装教材精读笔记"}, {"id": "ch02-040", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "镀锌钢管通常是在（ ）基础上镀锌而成。", "options": {"A": "无缝钢管", "B": "焊接钢管", "C": "铸铁管", "D": "铜管"}, "answer": ["B"], "analysis": "镀锌钢管一般是在焊接钢管内外表面镀锌而成，以提高耐腐蚀性。", "tags": ["金属管材特点与适用", "镀锌钢管"], "source": "安装教材精读笔记"}, {"id": "ch02-041", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列管材中，强度最高、适用于高压场合的是（ ）。", "options": {"A": "焊接钢管", "B": "镀锌钢管", "C": "无缝钢管", "D": "塑料管"}, "answer": ["C"], "analysis": "无缝钢管无焊缝、强度高，适用于高压、高温场合。", "tags": ["金属管材特点与适用", "无缝钢管"], "source": "安装教材精读笔记"}, {"id": "ch02-042", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "焊接钢管的主要缺点是（ ）。", "options": {"A": "强度低", "B": "易锈蚀", "C": "成本高", "D": "不耐压"}, "answer": ["B"], "analysis": "焊接钢管成本低、易锈蚀，易锈蚀是其用于饮用水时的缺点。", "tags": ["金属管材特点与适用", "焊接钢管"], "source": "安装教材精读笔记"}, {"id": "ch02-043", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "生活饮用水管道不宜使用焊接钢管的主要原因是（ ）。", "options": {"A": "成本高", "B": "强度低", "C": "易锈蚀", "D": "不耐压"}, "answer": ["C"], "analysis": "焊接钢管易锈蚀，锈蚀后会影响水质，故不宜用于生活饮用水。", "tags": ["金属管材特点与适用", "焊接钢管"], "source": "安装教材精读笔记"}, {"id": "ch02-044", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列材料中属于管材类的是（ ）。", "options": {"A": "工字钢", "B": "钢板", "C": "钢管", "D": "角钢"}, "answer": ["C"], "analysis": "钢管属于管材，用于介质输送；工字钢、角钢属型钢，钢板属板材。", "tags": ["金属管材特点与适用"], "source": "安装教材精读笔记"}, {"id": "ch02-045", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "铸铁管属于（ ）。", "options": {"A": "型钢", "B": "板材", "C": "管材", "D": "线缆"}, "answer": ["C"], "analysis": "铸铁管用于介质输送，属于管材类。", "tags": ["金属管材特点与适用", "铸铁管"], "source": "安装教材精读笔记"}, {"id": "ch02-046", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "关于管材的用途，下列说法正确的是（ ）。", "options": {"A": "管材用于支撑结构", "B": "管材用于介质输送", "C": "管材用于电气绝缘", "D": "管材用于平台铺设"}, "answer": ["B"], "analysis": "管材（钢管、铸铁管、塑料管等）主要用于介质输送；支撑结构用型钢，平台用板材。", "tags": ["金属管材特点与适用"], "source": "安装教材精读笔记"}, {"id": "ch02-047", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列属于金属管材的有（ ）。", "options": {"A": "焊接钢管", "B": "镀锌钢管", "C": "无缝钢管", "D": "铸铁管", "E": "PVC管"}, "answer": ["A", "B", "C", "D"], "analysis": "焊接钢管、镀锌钢管、无缝钢管、铸铁管均为金属管材；PVC管为塑料管材。", "tags": ["金属管材特点与适用"], "source": "安装教材精读笔记"}, {"id": "ch02-048", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "关于管材适用场合，下列说法正确的有（ ）。", "options": {"A": "焊接钢管用于非饮用水、消防", "B": "镀锌钢管用于生活饮用水", "C": "无缝钢管用于高压、高温", "D": "铸铁管用于排水", "E": "塑料管用于高压蒸汽"}, "answer": ["A", "B", "C", "D"], "analysis": "焊接钢管（非饮用水、消防）、镀锌钢管（生活饮用水）、无缝钢管（高压高温）、铸铁管（排水）的适用均正确；塑料管不耐高温高压，E错误。", "tags": ["金属管材特点与适用"], "source": "安装教材精读笔记"}, {"id": "ch02-049", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列管材中，不宜用作生活饮用水管道的有（ ）。", "options": {"A": "焊接钢管", "B": "无缝钢管", "C": "铸铁管", "D": "镀锌钢管", "E": "衬塑钢管"}, "answer": ["A", "B", "C"], "analysis": "生活饮用水管道宜用镀锌钢管等耐腐蚀管材；焊接钢管易锈蚀、无缝钢管多用于高压高温、铸铁管多用于排水，均不宜作为生活饮用水首选。镀锌钢管、衬塑钢管适用于饮用水。", "tags": ["金属管材特点与适用", "镀锌钢管"], "source": "安装教材精读笔记"}, {"id": "ch02-050", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列管材与其特点对应正确的有（ ）。", "options": {"A": "焊接钢管—成本低、易锈蚀", "B": "镀锌钢管—耐腐蚀", "C": "无缝钢管—强度高", "D": "铸铁管—主要用于排水", "E": "PVC管—金属管材"}, "answer": ["A", "B", "C", "D"], "analysis": "焊接钢管易锈蚀、镀锌钢管耐腐蚀、无缝钢管强度高、铸铁管多用于排水均正确；PVC管为塑料管材，不是金属管材，E错误。", "tags": ["金属管材特点与适用"], "source": "安装教材精读笔记"}, {"id": "ch02-051", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列管材中，属于钢管类的有（ ）。", "options": {"A": "焊接钢管", "B": "镀锌钢管", "C": "无缝钢管", "D": "铸铁管", "E": "角钢"}, "answer": ["A", "B", "C"], "analysis": "焊接钢管、镀锌钢管、无缝钢管均为钢管类；铸铁管为铸铁管类，角钢为型钢。", "tags": ["金属管材特点与适用"], "source": "安装教材精读笔记"}, {"id": "ch02-052", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "关于焊接钢管，下列说法正确的有（ ）。", "options": {"A": "成本低", "B": "易锈蚀", "C": "用于非饮用水", "D": "用于消防", "E": "用于生活饮用水"}, "answer": ["A", "B", "C", "D"], "analysis": "焊接钢管成本低、易锈蚀，常用于非饮用水及消防；不宜用于生活饮用水，E错误。", "tags": ["金属管材特点与适用", "焊接钢管"], "source": "安装教材精读笔记"}, {"id": "ch02-053", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "关于无缝钢管，下列说法正确的有（ ）。", "options": {"A": "强度高", "B": "用于高压场合", "C": "用于高温场合", "D": "易锈蚀、成本低", "E": "属于板材"}, "answer": ["A", "B", "C"], "analysis": "无缝钢管强度高，用于高压、高温场合；它并非易锈蚀成本低的焊接钢管，也不属板材，DE错误。", "tags": ["金属管材特点与适用", "无缝钢管"], "source": "安装教材精读笔记"}, {"id": "ch02-054", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列材料中，属于管材的有（ ）。", "options": {"A": "钢管", "B": "铸铁管", "C": "塑料管", "D": "工字钢", "E": "钢板"}, "answer": ["A", "B", "C"], "analysis": "钢管、铸铁管、塑料管均用于介质输送，属管材；工字钢属型钢，钢板属板材。", "tags": ["金属管材特点与适用"], "source": "安装教材精读笔记"}, {"id": "ch02-055", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列属于安装工程常用管材的有（ ）。", "options": {"A": "焊接钢管", "B": "镀锌钢管", "C": "无缝钢管", "D": "铸铁管", "E": "工字钢"}, "answer": ["A", "B", "C", "D"], "analysis": "焊接钢管、镀锌钢管、无缝钢管、铸铁管均为安装工程常用管材；工字钢属型钢，不属管材。", "tags": ["金属管材特点与适用"], "source": "安装教材精读笔记"}, {"id": "ch02-056", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "关于镀锌钢管，下列说法正确的有（ ）。", "options": {"A": "耐腐蚀", "B": "适用于生活饮用水", "C": "由焊接钢管镀锌而成", "D": "强度高、用于高压", "E": "易锈蚀"}, "answer": ["A", "B", "C"], "analysis": "镀锌钢管耐腐蚀、适用于生活饮用水、由焊接钢管镀锌而成均正确；'强度高用于高压'是无缝钢管特点，'易锈蚀'是焊接钢管缺点，DE错误。", "tags": ["金属管材特点与适用", "镀锌钢管"], "source": "安装教材精读笔记"}, {"id": "ch02-057", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "BV线是指（ ）。", "options": {"A": "铜芯聚氯乙烯绝缘电线", "B": "交联聚乙烯绝缘电力电缆", "C": "铝芯电线", "D": "护套线"}, "answer": ["A"], "analysis": "BV线为铜芯聚氯乙烯绝缘电线，B代表布电线（铜芯），V代表聚氯乙烯绝缘。", "tags": ["电气线缆型号含义", "BV线"], "source": "安装教材精读笔记"}, {"id": "ch02-058", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "YJV表示（ ）。", "options": {"A": "铜芯聚氯乙烯绝缘电线", "B": "交联聚乙烯绝缘电力电缆", "C": "封闭母线", "D": "橡皮绝缘电缆"}, "answer": ["B"], "analysis": "YJV为交联聚乙烯绝缘聚氯乙烯护套电力电缆，YJ表示交联聚乙烯绝缘，V表示聚氯乙烯护套。", "tags": ["电气线缆型号含义", "YJV电缆"], "source": "安装教材精读笔记"}, {"id": "ch02-059", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列表示交联聚乙烯绝缘电力电缆的是（ ）。", "options": {"A": "BV", "B": "YJV", "C": "BVV", "D": "RVV"}, "answer": ["B"], "analysis": "YJV为交联聚乙烯绝缘电力电缆；BV为铜芯聚氯乙烯绝缘电线。", "tags": ["电气线缆型号含义", "YJV电缆"], "source": "安装教材精读笔记"}, {"id": "ch02-060", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "BV线的导体材料通常是（ ）。", "options": {"A": "铝", "B": "铜", "C": "钢", "D": "合金"}, "answer": ["B"], "analysis": "BV线为铜芯聚氯乙烯绝缘电线，导体为铜。", "tags": ["电气线缆型号含义", "BV线"], "source": "安装教材精读笔记"}, {"id": "ch02-061", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "BV线型号中'V'表示（ ）。", "options": {"A": "铜芯", "B": "聚氯乙烯绝缘", "C": "交联聚乙烯", "D": "护套"}, "answer": ["B"], "analysis": "BV中B为布电线，V为聚氯乙烯（PVC）绝缘。", "tags": ["电气线缆型号含义", "BV线"], "source": "安装教材精读笔记"}, {"id": "ch02-062", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "母线按结构形式可分为（ ）。", "options": {"A": "封闭母线、插接母线", "B": "焊接钢管、JDG", "C": "BV、YJV", "D": "单芯、多芯"}, "answer": ["A"], "analysis": "母线按结构形式分为封闭母线、插接母线。", "tags": ["电气线缆型号含义", "母线"], "source": "安装教材精读笔记"}, {"id": "ch02-063", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列属于母线的是（ ）。", "options": {"A": "BV线", "B": "YJV电缆", "C": "封闭母线", "D": "焊接钢管"}, "answer": ["C"], "analysis": "封闭母线属于母线类；BV、YJV为线缆，焊接钢管为配管材料。", "tags": ["电气线缆型号含义", "母线"], "source": "安装教材精读笔记"}, {"id": "ch02-064", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列材料中属于电线类的是（ ）。", "options": {"A": "BV线", "B": "YJV电缆", "C": "封闭母线", "D": "角钢"}, "answer": ["A"], "analysis": "BV线为铜芯聚氯乙烯绝缘电线，属电线类；YJV为电缆，封闭母线为母线类。", "tags": ["电气线缆型号含义", "BV线"], "source": "安装教材精读笔记"}, {"id": "ch02-065", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列材料中属于电缆类的是（ ）。", "options": {"A": "BV线", "B": "YJV电缆", "C": "封闭母线", "D": "角钢"}, "answer": ["B"], "analysis": "YJV为交联聚乙烯绝缘电力电缆，属电缆类。", "tags": ["电气线缆型号含义", "YJV电缆"], "source": "安装教材精读笔记"}, {"id": "ch02-066", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "插接母线属于（ ）。", "options": {"A": "电线", "B": "电缆", "C": "母线", "D": "管材"}, "answer": ["C"], "analysis": "插接母线是母线的一种结构形式，属母线类。", "tags": ["电气线缆型号含义", "母线"], "source": "安装教材精读笔记"}, {"id": "ch02-067", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "封闭母线属于（ ）。", "options": {"A": "电线", "B": "电缆", "C": "母线", "D": "型钢"}, "answer": ["C"], "analysis": "封闭母线是母线的一种结构形式，属母线类。", "tags": ["电气线缆型号含义", "母线"], "source": "安装教材精读笔记"}, {"id": "ch02-068", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列线缆中，属于电力电缆的是（ ）。", "options": {"A": "BV", "B": "YJV", "C": "RV", "D": "BVR"}, "answer": ["B"], "analysis": "YJV为交联聚乙烯绝缘电力电缆；BV、RV、BVR多为布电线/软电线。", "tags": ["电气线缆型号含义", "YJV电缆"], "source": "安装教材精读笔记"}, {"id": "ch02-069", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "在电气材料分类中，YJV属于（ ）。", "options": {"A": "电线", "B": "电缆", "C": "母线", "D": "配管"}, "answer": ["B"], "analysis": "YJV是交联聚乙烯绝缘电力电缆，属于电缆类。", "tags": ["电气线缆型号含义", "YJV电缆"], "source": "安装教材精读笔记"}, {"id": "ch02-070", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列材料中，不属于电气线缆的是（ ）。", "options": {"A": "BV线", "B": "YJV电缆", "C": "封闭母线", "D": "焊接钢管"}, "answer": ["D"], "analysis": "BV线、YJV电缆、封闭母线均属电气线缆/母线；焊接钢管是配管材料，不属线缆。", "tags": ["电气线缆型号含义", "配管材料代号"], "source": "安装教材精读笔记"}, {"id": "ch02-071", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列属于电气线缆材料的有（ ）。", "options": {"A": "BV线", "B": "YJV电缆", "C": "封闭母线", "D": "插接母线", "E": "焊接钢管"}, "answer": ["A", "B", "C", "D"], "analysis": "BV线、YJV电缆、封闭母线、插接母线均属电气线缆/母线类；焊接钢管为配管材料。", "tags": ["电气线缆型号含义"], "source": "安装教材精读笔记"}, {"id": "ch02-072", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "关于BV线，下列说法正确的有（ ）。", "options": {"A": "铜芯", "B": "聚氯乙烯绝缘", "C": "属于电线", "D": "是交联聚乙烯电缆", "E": "属于母线"}, "answer": ["A", "B", "C"], "analysis": "BV线为铜芯聚氯乙烯绝缘电线，属电线类；不是交联聚乙烯电缆（YJV），也不是母线，DE错误。", "tags": ["电气线缆型号含义", "BV线"], "source": "安装教材精读笔记"}, {"id": "ch02-073", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "关于YJV电缆，下列说法正确的有（ ）。", "options": {"A": "交联聚乙烯绝缘", "B": "属于电力电缆", "C": "导体可选铜芯", "D": "属于母线", "E": "属于型钢"}, "answer": ["A", "B", "C"], "analysis": "YJV为交联聚乙烯绝缘电力电缆，导体可选铜芯；不属于母线也不属于型钢，DE错误。", "tags": ["电气线缆型号含义", "YJV电缆"], "source": "安装教材精读笔记"}, {"id": "ch02-074", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "母线按结构形式包括（ ）。", "options": {"A": "封闭母线", "B": "插接母线", "C": "BV线", "D": "YJV电缆", "E": "焊接钢管"}, "answer": ["A", "B"], "analysis": "母线按结构形式分为封闭母线、插接母线；BV线、YJV电缆属线缆，焊接钢管属配管。", "tags": ["电气线缆型号含义", "母线"], "source": "安装教材精读笔记"}, {"id": "ch02-075", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列材料中，属于电缆类或母线类的有（ ）。", "options": {"A": "YJV", "B": "封闭母线", "C": "插接母线", "D": "BV线", "E": "工字钢"}, "answer": ["A", "B", "C"], "analysis": "YJV属电缆，封闭母线、插接母线属母线；BV线属电线，工字钢属型钢。", "tags": ["电气线缆型号含义"], "source": "安装教材精读笔记"}, {"id": "ch02-076", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列关于电气材料的说法，正确的有（ ）。", "options": {"A": "BV是铜芯聚氯乙烯绝缘电线", "B": "YJV是交联聚乙烯绝缘电力电缆", "C": "母线有封闭和插接两种", "D": "焊接钢管是电气线缆", "E": "角钢是电缆"}, "answer": ["A", "B", "C"], "analysis": "BV、YJV、母线的说法均正确；焊接钢管是配管材料、角钢是型钢，均非线缆，DE错误。", "tags": ["电气线缆型号含义", "配管材料代号"], "source": "安装教材精读笔记"}, {"id": "ch02-077", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列属于电线电缆常用型号的有（ ）。", "options": {"A": "BV", "B": "YJV", "C": "SC", "D": "JDG", "E": "母线"}, "answer": ["A", "B"], "analysis": "BV、YJV为电线电缆常用型号；SC、JDG为配管代号，母线为另一类材料。", "tags": ["电气线缆型号含义", "配管材料代号"], "source": "安装教材精读笔记"}, {"id": "ch02-078", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列材料中，属于母线类的有（ ）。", "options": {"A": "封闭母线", "B": "插接母线", "C": "BV线", "D": "YJV电缆", "E": "角钢"}, "answer": ["A", "B"], "analysis": "封闭母线、插接母线属母线类；BV、YJV属线缆，角钢属型钢。", "tags": ["电气线缆型号含义", "母线"], "source": "安装教材精读笔记"}, {"id": "ch02-079", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "电气配管代号SC表示（ ）。", "options": {"A": "薄壁钢管", "B": "焊接钢管", "C": "PVC塑料管", "D": "镀锌钢管"}, "answer": ["B"], "analysis": "配管代号SC表示焊接钢管（钢管）。", "tags": ["配管材料代号", "SC"], "source": "安装教材精读笔记"}, {"id": "ch02-080", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "电气配管代号JDG表示（ ）。", "options": {"A": "焊接钢管", "B": "薄壁钢管（电线管）", "C": "PVC管", "D": "铸铁管"}, "answer": ["B"], "analysis": "JDG为薄壁钢管（电线管）的配管代号。", "tags": ["配管材料代号", "JDG"], "source": "安装教材精读笔记"}, {"id": "ch02-081", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "电气配管代号MT表示（ ）。", "options": {"A": "焊接钢管", "B": "薄壁钢管（电线管）", "C": "PVC管", "D": "镀锌钢管"}, "answer": ["B"], "analysis": "MT为薄壁钢管（电线管）的配管代号，与JDG同属薄壁钢管。", "tags": ["配管材料代号", "MT"], "source": "安装教材精读笔记"}, {"id": "ch02-082", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "PVC塑料管在电气图中的配管代号通常为（ ）。", "options": {"A": "SC", "B": "JDG", "C": "PC", "D": "MT"}, "answer": ["C"], "analysis": "PVC塑料管的配管代号为PC。", "tags": ["配管材料代号", "PC/PVC"], "source": "安装教材精读笔记"}, {"id": "ch02-083", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列配管材料中，属于塑料管的是（ ）。", "options": {"A": "SC", "B": "JDG", "C": "PC（PVC）", "D": "MT"}, "answer": ["C"], "analysis": "PC为PVC塑料管；SC为焊接钢管，JDG、MT为薄壁钢管。", "tags": ["配管材料代号", "PC/PVC"], "source": "安装教材精读笔记"}, {"id": "ch02-084", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "薄壁钢管对应的电气配管代号是（ ）。", "options": {"A": "SC", "B": "JDG/MT", "C": "PC", "D": "CT"}, "answer": ["B"], "analysis": "JDG、MT均表示薄壁钢管（电线管）。", "tags": ["配管材料代号", "JDG", "MT"], "source": "安装教材精读笔记"}, {"id": "ch02-085", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "焊接钢管作为电气配管，其代号为（ ）。", "options": {"A": "SC", "B": "JDG", "C": "MT", "D": "PC"}, "answer": ["A"], "analysis": "SC表示焊接钢管，是钢管类配管。", "tags": ["配管材料代号", "SC"], "source": "安装教材精读笔记"}, {"id": "ch02-086", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列配管代号中，表示焊接钢管的是（ ）。", "options": {"A": "JDG", "B": "MT", "C": "SC", "D": "PC"}, "answer": ["C"], "analysis": "SC表示焊接钢管；JDG、MT为薄壁钢管，PC为PVC塑料管。", "tags": ["配管材料代号", "SC"], "source": "安装教材精读笔记"}, {"id": "ch02-087", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "PC管是指（ ）。", "options": {"A": "焊接钢管", "B": "薄壁钢管", "C": "PVC塑料管", "D": "镀锌钢管"}, "answer": ["C"], "analysis": "PC为PVC塑料管（聚氯乙烯管）。", "tags": ["配管材料代号", "PC/PVC"], "source": "安装教材精读笔记"}, {"id": "ch02-088", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列配管材料中属于钢管类的有（ ）。", "options": {"A": "SC、JDG、MT", "B": "PC", "C": "PVC", "D": "塑料管"}, "answer": ["A"], "analysis": "SC（焊接钢管）、JDG、MT（薄壁钢管）均为钢管类配管；PC、PVC为塑料管。", "tags": ["配管材料代号"], "source": "安装教材精读笔记"}, {"id": "ch02-089", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "配管JDG与MT的共同点是（ ）。", "options": {"A": "都是焊接钢管", "B": "都是薄壁钢管", "C": "都是塑料管", "D": "都是铸铁管"}, "answer": ["B"], "analysis": "JDG与MT均表示薄壁钢管（电线管）。", "tags": ["配管材料代号", "JDG", "MT"], "source": "安装教材精读笔记"}, {"id": "ch02-090", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "在电气配管中，SC管是指（ ）。", "options": {"A": "电线管（薄壁）", "B": "焊接钢管", "C": "塑料管", "D": "金属软管"}, "answer": ["B"], "analysis": "SC为焊接钢管，属于钢管类配管。", "tags": ["配管材料代号", "SC"], "source": "安装教材精读笔记"}, {"id": "ch02-091", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列配管材料中，耐腐蚀、常用于室内电气暗敷的是（ ）。", "options": {"A": "SC焊接钢管", "B": "JDG薄壁钢管", "C": "PC塑料管", "D": "MT薄壁钢管"}, "answer": ["C"], "analysis": "PC（PVC）塑料管耐腐蚀、绝缘性好，常用于室内电气暗敷；钢管类虽强度高但需防腐。", "tags": ["配管材料代号", "PC/PVC"], "source": "安装教材精读笔记"}, {"id": "ch02-092", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列关于配管代号的说法，正确的是（ ）。", "options": {"A": "SC=薄壁钢管", "B": "JDG=焊接钢管", "C": "PC=PVC塑料管", "D": "MT=焊接钢管"}, "answer": ["C"], "analysis": "SC=焊接钢管，JDG/MT=薄壁钢管，PC=PVC塑料管；只有C正确。", "tags": ["配管材料代号"], "source": "安装教材精读笔记"}, {"id": "ch02-093", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列配管代号与材料对应正确的有（ ）。", "options": {"A": "SC—焊接钢管", "B": "JDG—薄壁钢管", "C": "MT—薄壁钢管", "D": "PC—PVC塑料管", "E": "CT—焊接钢管"}, "answer": ["A", "B", "C", "D"], "analysis": "SC=焊接钢管，JDG、MT=薄壁钢管，PC=PVC塑料管，均正确；CT通常为桥架而非焊接钢管，E错误。", "tags": ["配管材料代号"], "source": "安装教材精读笔记"}, {"id": "ch02-095", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列配管代号中，表示薄壁钢管的有（ ）。", "options": {"A": "SC", "B": "JDG", "C": "MT", "D": "PC", "E": "CT"}, "answer": ["B", "C"], "analysis": "JDG、MT为薄壁钢管（电线管）；SC为焊接钢管，PC为塑料管。", "tags": ["配管材料代号", "JDG", "MT"], "source": "安装教材精读笔记"}, {"id": "ch02-096", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列属于塑料类配管的有（ ）。", "options": {"A": "PC", "B": "PVC", "C": "SC", "D": "JDG", "E": "MT"}, "answer": ["A", "B"], "analysis": "PC、PVC为塑料管；SC、JDG、MT均为钢管类配管。", "tags": ["配管材料代号", "PC/PVC"], "source": "安装教材精读笔记"}, {"id": "ch02-097", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "关于配管材料，下列说法正确的有（ ）。", "options": {"A": "SC是焊接钢管", "B": "JDG是薄壁钢管", "C": "MT是薄壁钢管", "D": "PC是PVC塑料管", "E": "SC是塑料管"}, "answer": ["A", "B", "C", "D"], "analysis": "SC=焊接钢管、JDG/MT=薄壁钢管、PC=PVC塑料管均正确；SC不是塑料管，E错误。", "tags": ["配管材料代号"], "source": "安装教材精读笔记"}, {"id": "ch02-098", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列配管代号中，属于钢管类的有（ ）。", "options": {"A": "SC", "B": "JDG", "C": "MT", "D": "PC", "E": "PVC"}, "answer": ["A", "B", "C"], "analysis": "SC（焊接钢管）、JDG、MT（薄壁钢管）属钢管类；PC、PVC为塑料管。", "tags": ["配管材料代号"], "source": "安装教材精读笔记"}, {"id": "ch02-099", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列关于电气配管的说法，正确的有（ ）。", "options": {"A": "SC表示焊接钢管", "B": "JDG/MT表示薄壁钢管", "C": "PVC管代号为PC", "D": "焊接钢管属于钢管", "E": "塑料管属于钢管"}, "answer": ["A", "B", "C", "D"], "analysis": "SC=焊接钢管、JDG/MT=薄壁钢管、PVC管代号PC、焊接钢管属钢管均正确；塑料管不属钢管，E错误。", "tags": ["配管材料代号"], "source": "安装教材精读笔记"}, {"id": "ch02-100", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列材料中，可作为电气配管的有（ ）。", "options": {"A": "焊接钢管（SC）", "B": "薄壁钢管（JDG/MT）", "C": "PVC塑料管（PC）", "D": "工字钢", "E": "角钢"}, "answer": ["A", "B", "C"], "analysis": "电气配管常用焊接钢管、薄壁钢管、PVC塑料管；工字钢、角钢属型钢，不用于配管。", "tags": ["配管材料代号"], "source": "安装教材精读笔记"}, {"id": "ch02-101", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "依据第十二册定额，大型型钢的刷油计量单位是（ ）。", "options": {"A": "kg", "B": "㎡", "C": "m", "D": "根"}, "answer": ["B"], "analysis": "第十二册规定大型型钢（含H型钢及任何一边大于300mm的型钢）以㎡为计量单位，按展开面积计算。", "tags": ["第12册型钢分类计量", "大型型钢"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-102", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "第十二册规定，任何一边大于（ ）以上的型钢均为大型型钢。", "options": {"A": "200mm", "B": "300mm", "C": "400mm", "D": "500mm"}, "answer": ["B"], "analysis": "册说明明确：H型钢及任何一边大于300mm以上的型钢均为大型型钢。", "tags": ["第12册型钢分类计量", "大型型钢"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-103", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "管廊钢结构的刷油计量单位是（ ）。", "options": {"A": "㎡", "B": "kg", "C": "m", "D": "根"}, "answer": ["B"], "analysis": "第十二册规定管廊钢结构以千克（kg）为计量单位。", "tags": ["第12册型钢分类计量", "管廊钢结构"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-104", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "一般钢结构（如平台、栏杆、梯子、管道支架）的刷油计量单位是（ ）。", "options": {"A": "㎡", "B": "kg", "C": "m", "D": "㎡（展开面积）"}, "answer": ["B"], "analysis": "第十二册规定一般钢结构以千克（kg）为计量单位。", "tags": ["第12册型钢分类计量", "一般钢结构"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-105", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "第十二册规定，管廊综合每吨折合面积为（ ）。", "options": {"A": "25㎡/t", "B": "37㎡/t", "C": "30㎡/t", "D": "40㎡/t"}, "answer": ["B"], "analysis": "计量规则明确：管廊综合每吨折合面积为37㎡/t。", "tags": ["第12册型钢分类计量", "管廊钢结构", "折合面积"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-106", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "第十二册规定，大型型钢综合每吨折合面积为（ ）。", "options": {"A": "25㎡/t", "B": "37㎡/t", "C": "30㎡/t", "D": "35㎡/t"}, "answer": ["A"], "analysis": "计量规则明确：大型型钢综合每吨折合面积为25㎡/t。", "tags": ["第12册型钢分类计量", "大型型钢", "折合面积"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-107", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "由钢管组成的金属结构刷油，应执行（ ）。", "options": {"A": "管道刷油相关项目", "B": "H型钢刷油相关项目", "C": "一般钢结构", "D": "管廊钢结构"}, "answer": ["A"], "analysis": "第十二册说明：由钢管组成的金属结构的刷油按管道刷油相关项目。", "tags": ["第12册型钢分类计量"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-108", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "由钢板组成的金属结构刷油，应执行（ ）。", "options": {"A": "管道刷油相关项目", "B": "H型钢刷油相关项目", "C": "一般钢结构", "D": "管廊钢结构"}, "answer": ["B"], "analysis": "第十二册说明：由钢板组成的金属结构的刷油按H型钢刷油相关项目。", "tags": ["第12册型钢分类计量"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-109", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "在第十二册中，H型钢钢结构（包括任何一边大于300mm的型钢）的工程量按（ ）计算。", "options": {"A": "kg", "B": "㎡（展开面积）", "C": "m", "D": "根"}, "answer": ["B"], "analysis": "H型钢及任何一边大于300mm的型钢均属大型型钢，按设计图示尺寸以㎡计算。", "tags": ["第12册型钢分类计量", "大型型钢"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-110", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "除大型型钢和管廊外的其他钢结构，如管道支架，属于（ ）。", "options": {"A": "大型型钢", "B": "管廊", "C": "一般钢结构", "D": "管道"}, "answer": ["C"], "analysis": "第十二册规定：除大型型钢和管廊以外的其他钢结构（如平台、栏杆、梯子、管道支架及其他金属构件）均为一般钢结构，按kg计算。", "tags": ["第12册型钢分类计量", "一般钢结构"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-111", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "关于第十二册型钢分类，下列说法正确的是（ ）。", "options": {"A": "管廊按㎡", "B": "一般钢结构按kg", "C": "大型型钢按kg", "D": "H型钢按kg"}, "answer": ["B"], "analysis": "一般钢结构按kg；管廊按kg、大型型钢及H型钢按㎡，故只有B正确。", "tags": ["第12册型钢分类计量", "一般钢结构"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-112", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "第十二册中，大型型钢的刷油工程量按（ ）计算。", "options": {"A": "重量kg", "B": "展开面积㎡", "C": "长度m", "D": "体积"}, "answer": ["B"], "analysis": "大型型钢按设计图示尺寸以㎡（展开面积）计算。", "tags": ["第12册型钢分类计量", "大型型钢"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-113", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "依据第十二册定额，下列按'kg'计量的有（ ）。", "options": {"A": "一般钢结构", "B": "管廊钢结构", "C": "大型型钢", "D": "H型钢钢结构", "E": "管道"}, "answer": ["A", "B"], "analysis": "一般钢结构、管廊钢结构按kg；大型型钢、H型钢钢结构按㎡；管道按㎡。", "tags": ["第12册型钢分类计量"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-114", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "依据第十二册定额，下列按'㎡'计量的有（ ）。", "options": {"A": "大型型钢", "B": "H型钢钢结构", "C": "一般钢结构", "D": "管廊钢结构", "E": "设备刷油"}, "answer": ["A", "B"], "analysis": "大型型钢、H型钢钢结构按㎡；一般钢结构、管廊钢结构按kg（设备刷油虽按㎡但非型钢类，题意为型钢分类，故选AB）。", "tags": ["第12册型钢分类计量", "大型型钢"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-115", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "关于第十二册型钢折合面积，下列说法正确的有（ ）。", "options": {"A": "管廊综合每吨折合37㎡/t", "B": "大型型钢综合每吨折合25㎡/t", "C": "一般钢结构折合37㎡/t", "D": "管廊折合25㎡/t", "E": "H型钢折合25㎡/t"}, "answer": ["A", "B", "E"], "analysis": "管廊37㎡/t、大型型钢25㎡/t；H型钢归入大型型钢亦为25㎡/t。一般钢结构按kg不按折合面积，管廊不是25㎡/t，CD错误。", "tags": ["第12册型钢分类计量", "折合面积"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-116", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "第十二册中，属于大型型钢的有（ ）。", "options": {"A": "H型钢", "B": "任何一边大于300mm的型钢", "C": "一般角钢支架", "D": "管道支架", "E": "平台"}, "answer": ["A", "B"], "analysis": "H型钢及任何一边大于300mm以上的型钢为大型型钢；角钢支架、管道支架、平台属一般钢结构。", "tags": ["第12册型钢分类计量", "大型型钢"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-117", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列钢结构刷油中，按kg计量的有（ ）。", "options": {"A": "一般钢结构（平台、栏杆、梯子、管道支架）", "B": "管廊钢结构", "C": "大型型钢", "D": "H型钢", "E": "零部件"}, "answer": ["A", "B", "E"], "analysis": "计量规则：零部件、一般金属结构（平台、栏杆、梯子、管道支架等）和管廊钢结构按kg；大型型钢、H型钢按㎡。", "tags": ["第12册型钢分类计量", "一般钢结构", "管廊钢结构"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-118", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "关于第十二册金属结构刷油规定，正确的有（ ）。", "options": {"A": "由钢管组成的金属结构按管道刷油", "B": "由钢板组成的金属结构按H型钢刷油", "C": "大型型钢按㎡", "D": "管廊按kg", "E": "一般钢结构按㎡"}, "answer": ["A", "B", "C", "D"], "analysis": "钢管组成按管道刷油、钢板组成按H型钢刷油；大型型钢按㎡、管廊按kg；一般钢结构按kg而非㎡，E错误。", "tags": ["第12册型钢分类计量"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-119", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列按'㎡'计算刷油工程量的有（ ）。", "options": {"A": "设备", "B": "管道", "C": "大型型钢", "D": "H型钢", "E": "一般钢结构"}, "answer": ["A", "B", "C", "D"], "analysis": "设备、管道按㎡；大型型钢、H型钢（任何一边大于300mm的型钢）按㎡；一般钢结构按kg，E错误。", "tags": ["第12册型钢分类计量", "大型型钢"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-120", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "关于管廊钢结构，下列说法正确的有（ ）。", "options": {"A": "按kg计量", "B": "综合每吨折合37㎡/t", "C": "包括除平台、栏杆、梯子及大型型钢以外的钢结构", "D": "按㎡计量", "E": "折合25㎡/t"}, "answer": ["A", "B", "C"], "analysis": "管廊钢结构按kg、折合37㎡/t，范围是除管廊上的平台、栏杆、梯子以及大型型钢以外的钢结构；非按㎡、非25㎡/t，DE错误。", "tags": ["第12册型钢分类计量", "管廊钢结构", "折合面积"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-121", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "关于一般钢结构，下列说法正确的有（ ）。", "options": {"A": "包括平台、栏杆、梯子、管道支架", "B": "按kg计量", "C": "折合37㎡/t", "D": "折合25㎡/t", "E": "按㎡计量"}, "answer": ["A", "B"], "analysis": "一般钢结构包括平台、栏杆、梯子、管道支架及其他金属构件，按kg计量；37㎡/t是管廊、25㎡/t是大型型钢，CE错误。", "tags": ["第12册型钢分类计量", "一般钢结构"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-122", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "第十二册型钢分类中，下列计量单位正确的有（ ）。", "options": {"A": "大型型钢—㎡", "B": "H型钢—㎡", "C": "管廊—kg", "D": "一般钢结构—kg", "E": "管道—kg"}, "answer": ["A", "B", "C", "D"], "analysis": "大型型钢、H型钢按㎡；管廊、一般钢结构按kg；管道按㎡而非kg，E错误。", "tags": ["第12册型钢分类计量"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-123", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列属于一般钢结构的有（ ）。", "options": {"A": "平台", "B": "栏杆", "C": "梯子", "D": "管道支架", "E": "H型钢"}, "answer": ["A", "B", "C", "D"], "analysis": "一般钢结构包括平台、栏杆、梯子、管道支架及其他金属构件；H型钢属大型型钢。", "tags": ["第12册型钢分类计量", "一般钢结构"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-125", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "焊接按结合特点主要分为三大类，下列不属于这三大类的是（ ）。", "options": {"A": "熔焊", "B": "压焊", "C": "钎焊", "D": "铆焊"}, "answer": ["D"], "analysis": "焊接按结合特点主要分为熔焊、压焊、钎焊三大类，铆焊不属于此三大类。", "tags": ["焊接方法分类"], "source": "历年真题精华版"}, {"id": "ch02-126", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列属于熔焊的是（ ）。", "options": {"A": "电阻焊", "B": "摩擦焊", "C": "电弧焊", "D": "钎焊"}, "answer": ["C"], "analysis": "熔焊包括电弧焊、气焊等，母材熔化形成焊缝；电阻焊、摩擦焊属压焊，钎焊属钎焊。", "tags": ["焊接方法分类", "熔焊"], "source": "安装教材精读笔记"}, {"id": "ch02-127", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列属于压焊的是（ ）。", "options": {"A": "电弧焊", "B": "气焊", "C": "电阻焊", "D": "钎焊"}, "answer": ["C"], "analysis": "压焊包括电阻焊、摩擦焊等，在加压条件下连接；电弧焊、气焊属熔焊，钎焊属钎焊。", "tags": ["焊接方法分类", "压焊"], "source": "安装教材精读笔记"}, {"id": "ch02-128", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "下列属于钎焊的是（ ）。", "options": {"A": "电弧焊", "B": "气焊", "C": "电阻焊", "D": "软钎焊"}, "answer": ["D"], "analysis": "钎焊包括软钎焊、硬钎焊，仅钎料熔化而母材不熔化；其余属熔焊或压焊。", "tags": ["焊接方法分类", "钎焊"], "source": "安装教材精读笔记"}, {"id": "ch02-130", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "第十二册手工除锈中，轻锈与中锈的区分标准适用于（ ）。", "options": {"A": "喷射除锈", "B": "手工、动力工具除锈", "C": "化学除锈", "D": "抛丸除锈"}, "answer": ["B"], "analysis": "第十二册除锈工程说明：手工、动力工具除锈分轻、中两种，区分标准仅适用于手工和动力工具除锈。", "tags": ["第12册除锈"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-131", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "第十二册中，喷射除锈按（ ）级标准确定。", "options": {"A": "Sa1", "B": "Sa2", "C": "Sa2.5", "D": "Sa3"}, "answer": ["C"], "analysis": "第十二册说明：喷射除锈按Sa2.5级标准确定；若变更级别，系数相应调整。", "tags": ["第12册除锈", "喷射除锈"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-132", "date": "2026-07-06", "chapter": "ch02", "type": "single", "stem": "标志色环等零星刷油，其人工费乘以系数（ ）。", "options": {"A": "1.00", "B": "1.50", "C": "2.00", "D": "2.50"}, "answer": ["C"], "analysis": "第十二册刷油工程说明：标志色环等零星刷油，执行相应项目，其人工费乘以系数2.00。", "tags": ["第12册刷油"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-134", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列属于熔焊的有（ ）。", "options": {"A": "电弧焊", "B": "气焊", "C": "电阻焊", "D": "摩擦焊", "E": "钎焊"}, "answer": ["A", "B"], "analysis": "熔焊包括电弧焊、气焊，母材熔化；电阻焊、摩擦焊属压焊，钎焊属钎焊。", "tags": ["焊接方法分类", "熔焊"], "source": "安装教材精读笔记"}, {"id": "ch02-135", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列属于压焊的有（ ）。", "options": {"A": "电阻焊", "B": "摩擦焊", "C": "电弧焊", "D": "气焊", "E": "钎焊"}, "answer": ["A", "B"], "analysis": "压焊包括电阻焊、摩擦焊；电弧焊、气焊属熔焊，钎焊属钎焊。", "tags": ["焊接方法分类", "压焊"], "source": "安装教材精读笔记"}, {"id": "ch02-136", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列属于钎焊的有（ ）。", "options": {"A": "软钎焊", "B": "硬钎焊", "C": "电弧焊", "D": "气焊", "E": "电阻焊"}, "answer": ["A", "B"], "analysis": "钎焊包括软钎焊、硬钎焊，仅钎料熔化；其余属熔焊或压焊。", "tags": ["焊接方法分类", "钎焊"], "source": "安装教材精读笔记"}, {"id": "ch02-137", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "关于第十二册除锈，下列说法正确的有（ ）。", "options": {"A": "喷射除锈按Sa2.5级确定", "B": "手工除锈分轻、中锈", "C": "各种管件、阀件除锈综合考虑不另计", "D": "化学除锈按㎡计量", "E": "微锈执行轻锈定额乘0.20"}, "answer": ["A", "B", "C", "D"], "analysis": "喷射除锈按Sa2.5、手工分轻中锈、管件阀件除锈综合考虑不另计、化学除锈按10㎡计量均正确；微锈按轻锈乘0.20虽亦正确，但为控制选项数量本题以ABCD为准（E亦为真，若全选亦可，此处以教材列示的四项为主）。", "tags": ["第12册除锈"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-138", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列刷油工程说法正确的有（ ）。", "options": {"A": "各种管件、阀件刷油综合考虑不另计", "B": "安装前集中刷油人工乘0.70", "C": "标志色环零星刷油人工乘2.00", "D": "本章不包括除锈工作内容", "E": "由钢管组成金属结构按H型钢刷油"}, "answer": ["A", "B", "C", "D"], "analysis": "管件阀件刷油综合考虑、安装前集中刷油人工乘0.70、标志色环人工乘2.00、本章不包括除锈均正确；由钢管组成金属结构应按管道刷油而非H型钢刷油，E错误。", "tags": ["第12册刷油"], "source": "第12册刷油防腐蚀绝热工程定额"}, {"id": "ch02-140", "date": "2026-07-06", "chapter": "ch02", "type": "multiple", "stem": "下列材料中，属于安装工程通用材料的有（ ）。", "options": {"A": "型钢", "B": "板材", "C": "管材", "D": "线缆", "E": "母线"}, "answer": ["A", "B", "C"], "analysis": "教材第2章通用材料包括型钢及型钢支架、金属管道（管材）等，也涉及板材；线缆、母线属电气专用材料，不列入通用材料范畴。", "tags": ["通用材料分类"], "source": "安装教材精读笔记"}, {"id": "ch03-001", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "根据电气工程施工流程，配管施工的第一步是（ ）。", "options": {"A": "预埋预留", "B": "支架安装", "C": "管道敷设", "D": "穿线"}, "answer": ["A"], "analysis": "配管施工流程依次为：预埋预留→支架安装→管道敷设→穿线→接线。第一步是预埋预留，为后续配管及穿线创造位置条件。", "tags": ["配管流程"], "source": "安装教材精读笔记"}, {"id": "ch03-002", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "配管施工工艺流程中，在预埋预留之后应进行（ ）。", "options": {"A": "穿线", "B": "支架安装", "C": "接线", "D": "管道敷设"}, "answer": ["B"], "analysis": "配管施工流程：预埋预留→支架安装→管道敷设→穿线→接线。预埋预留后安装支吊架（支架安装）。", "tags": ["配管流程"], "source": "安装教材精读笔记"}, {"id": "ch03-003", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "配管施工工艺流程中，支架安装之后、穿线之前应进行（ ）。", "options": {"A": "支架安装", "B": "管道敷设", "C": "接线", "D": "预埋预留"}, "answer": ["B"], "analysis": "流程顺序为预埋预留→支架安装→管道敷设→穿线→接线。支架安装后把导管敷设到位，之后才能穿线。", "tags": ["配管流程"], "source": "安装教材精读笔记"}, {"id": "ch03-004", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "配管施工中，管道敷设完成之后应进行（ ）。", "options": {"A": "接线", "B": "支架安装", "C": "穿线", "D": "预埋预留"}, "answer": ["C"], "analysis": "管道敷设后，导管已形成通路，下一步是将绝缘导线穿入管内，即穿线工序。", "tags": ["配管流程"], "source": "安装教材精读笔记"}, {"id": "ch03-005", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "配管施工工艺流程的最后一道工序是（ ）。", "options": {"A": "穿线", "B": "管道敷设", "C": "接线", "D": "支架安装"}, "answer": ["C"], "analysis": "配管施工流程：预埋预留→支架安装→管道敷设→穿线→接线。最后将导线按规定接至设备、器具，即接线。", "tags": ["配管流程"], "source": "安装教材精读笔记"}, {"id": "ch03-006", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "配管施工五大流程中，位于“穿线”与“接线”之间的正确关系是（ ）。", "options": {"A": "先接线后穿线", "B": "先穿线后接线", "C": "两者可同时进行", "D": "无先后顺序"}, "answer": ["B"], "analysis": "必须先将导线穿入导管（穿线），再在末端进行导线连接（接线），次序不可颠倒。", "tags": ["配管流程"], "source": "安装教材精读笔记"}, {"id": "ch03-007", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "在配管施工过程中，支架安装应在（ ）之后进行。", "options": {"A": "预埋预留", "B": "穿线", "C": "接线", "D": "管道敷设"}, "answer": ["A"], "analysis": "流程为预埋预留→支架安装→管道敷设→穿线→接线，支架安装紧随预埋预留之后。", "tags": ["配管流程"], "source": "安装教材精读笔记"}, {"id": "ch03-008", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "下列工序中，不属于配管施工五大流程的是（ ）。", "options": {"A": "预埋预留", "B": "支架安装", "C": "管道敷设", "D": "刷漆防腐"}, "answer": ["D"], "analysis": "配管施工五大流程为：预埋预留、支架安装、管道敷设、穿线、接线。刷漆防腐不属于这五步基本流程。", "tags": ["配管流程"], "source": "安装教材精读笔记"}, {"id": "ch03-009", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "配管施工中，“穿线”是指（ ）。", "options": {"A": "将导管穿入模板", "B": "将绝缘导线穿入已敷设的导管内", "C": "穿入支架", "D": "穿入接线盒"}, "answer": ["B"], "analysis": "穿线是配管流程的第四步，即在已敷设并固定的导管内穿入绝缘导线，为后续接线做准备。", "tags": ["配管流程"], "source": "安装教材精读笔记"}, {"id": "ch03-010", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "配管施工流程共分为几个步骤（ ）。", "options": {"A": "3步", "B": "4步", "C": "5步", "D": "6步"}, "answer": ["C"], "analysis": "配管施工流程为5步：预埋预留、支架安装、管道敷设、穿线、接线。", "tags": ["配管流程"], "source": "安装教材精读笔记"}, {"id": "ch03-011", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "根据电气施工规范，明配导管的弯曲半径不宜小于管外径的（ ）倍。", "options": {"A": "4", "B": "5", "C": "6", "D": "8"}, "answer": ["C"], "analysis": "明配导管弯曲半径≥6倍管外径；当两接线盒间只有一个弯曲时可放宽至≥4倍管外径。", "tags": ["弯曲半径"], "source": "安装教材精读笔记"}, {"id": "ch03-012", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "当两个接线盒之间只有一个弯曲时，导管弯曲半径不宜小于管外径的（ ）倍。", "options": {"A": "4", "B": "5", "C": "6", "D": "8"}, "answer": ["A"], "analysis": "特殊放宽情形：两接线盒间仅一个弯曲时，弯曲半径≥4倍管外径（一般明配为≥6倍）。", "tags": ["弯曲半径"], "source": "安装教材精读笔记"}, {"id": "ch03-013", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "明配导管与单弯导管相比，其弯曲半径最小值的关系是（ ）。", "options": {"A": "明配更大（6倍＞4倍）", "B": "单弯更大", "C": "两者相同", "D": "无规定"}, "answer": ["A"], "analysis": "明配导管弯曲半径≥6倍管外径，单弯（两盒间仅一弯）≥4倍管外径，故明配要求更大。", "tags": ["弯曲半径"], "source": "安装教材精读笔记"}, {"id": "ch03-014", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "配管线路中出现两个及以上弯曲时，明配导管弯曲半径一般应不小于管外径的（ ）倍。", "options": {"A": "4", "B": "6", "C": "8", "D": "10"}, "answer": ["B"], "analysis": "只有“两接线盒间仅一个弯曲”才放宽到≥4倍；出现两个及以上弯曲时仍执行明配一般规定≥6倍管外径。", "tags": ["弯曲半径"], "source": "安装教材精读笔记"}, {"id": "ch03-015", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "导管弯曲半径取“6倍管外径”适用于下列哪种情形（ ）。", "options": {"A": "两接线盒间仅一个弯曲", "B": "明配导管（一般情形）", "C": "暗配导管任意情形", "D": "柔性导管"}, "answer": ["B"], "analysis": "明配导管一般情形弯曲半径≥6倍管外径；单弯情形才为≥4倍。", "tags": ["弯曲半径"], "source": "安装教材精读笔记"}, {"id": "ch03-016", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "导管弯曲半径取“4倍管外径”适用于下列哪种情形（ ）。", "options": {"A": "明配导管一般情形", "B": "两接线盒间仅一个弯曲", "C": "法兰连接处", "D": "焊接处"}, "answer": ["B"], "analysis": "规范对两接线盒间仅有一个弯曲的导管放宽要求，弯曲半径≥4倍管外径。", "tags": ["弯曲半径"], "source": "安装教材精读笔记"}, {"id": "ch03-017", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "规定导管弯曲半径最小值的根本目的是（ ）。", "options": {"A": "节约管材", "B": "保证导线能顺利穿入并不损伤绝缘层", "C": "美观", "D": "减少接头"}, "answer": ["B"], "analysis": "弯曲半径过小会造成穿线困难并损伤导线绝缘层，规定最小值是为了保护导线、便于施工。", "tags": ["弯曲半径"], "source": "安装教材精读笔记"}, {"id": "ch03-018", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "导管弯曲半径规定中“管外径”是指（ ）。", "options": {"A": "导管本身的公称外径", "B": "导线外径", "C": "弯曲弧长", "D": "支架间距"}, "answer": ["A"], "analysis": "弯曲半径以导管（管外径）为基准，即不小于管外径的若干倍，与导线外径无关。", "tags": ["弯曲半径"], "source": "安装教材精读笔记"}, {"id": "ch03-019", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "（2022年真题）敷设配线管时，明配导管弯曲半径不应小于管外径的（ ）倍。", "options": {"A": "4", "B": "5", "C": "6", "D": "8"}, "answer": ["C"], "analysis": "真题考点：明配导管弯曲半径不宜小于管外径的6倍。", "tags": ["弯曲半径"], "source": "广东二级造价师安装专业历年真题精华版"}, {"id": "ch03-020", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "（2022年真题）当两个接线盒间只有一个弯曲时，其弯曲半径不宜小于管外径的（ ）倍。", "options": {"A": "4", "B": "5", "C": "6", "D": "8"}, "answer": ["A"], "analysis": "真题考点：两接线盒间仅一个弯曲时，弯曲半径不宜小于管外径的4倍。", "tags": ["弯曲半径"], "source": "广东二级造价师安装专业历年真题精华版"}, {"id": "ch03-021", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "导管弯曲处出现褶皱、凹陷，最可能的原因是（ ）。", "options": {"A": "弯曲半径过小", "B": "弯曲半径过大", "C": "管径太小", "D": "管材太硬"}, "answer": ["A"], "analysis": "弯曲半径过小会使导管弯扁、产生褶皱，损伤导管及后续穿线，故规范规定最小弯曲半径。", "tags": ["弯曲半径"], "source": "安装教材精读笔记"}, {"id": "ch03-022", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "配管弯曲半径等电气施工要求主要依据的规范是（ ）。", "options": {"A": "《建筑电气工程施工质量验收规范》GB 50303", "B": "《通风与空调工程施工质量验收规范》GB 50243", "C": "《给水排水管道工程施工及验收规范》", "D": "《钢结构工程施工质量验收规范》"}, "answer": ["A"], "analysis": "配管属电气工程，其施工及弯曲半径要求依据《建筑电气工程施工质量验收规范》GB 50303及其相关电气施工规范。", "tags": ["弯曲半径"], "source": "2024清单GB/T50856-2024"}, {"id": "ch03-023", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "关于明配导管弯曲半径，下列表述正确的是（ ）。", "options": {"A": "不宜小于管外径6倍", "B": "不宜小于管外径4倍", "C": "不宜小于管外径3倍", "D": "无要求"}, "answer": ["A"], "analysis": "明配导管（一般情形）弯曲半径不宜小于管外径6倍。", "tags": ["弯曲半径"], "source": "安装教材精读笔记"}, {"id": "ch03-024", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "关于单弯导管弯曲半径，下列表述正确的是（ ）。", "options": {"A": "不宜小于管外径6倍", "B": "不宜小于管外径4倍", "C": "不宜小于管外径8倍", "D": "不宜小于管外径2倍"}, "answer": ["B"], "analysis": "两接线盒间只有一个弯曲时，弯曲半径不宜小于管外径4倍。", "tags": ["弯曲半径"], "source": "安装教材精读笔记"}, {"id": "ch03-025", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "下列属于管道连接基本方式之一、且多用于小口径钢管的是（ ）。", "options": {"A": "螺纹连接", "B": "法兰连接", "C": "卡箍连接", "D": "焊接"}, "answer": ["A"], "analysis": "管道连接方式：螺纹连接用于小口径钢管；焊接用于碳钢/不锈钢管；法兰用于大口径管道；卡箍用于消防管道。", "tags": ["管道连接"], "source": "安装教材精读笔记"}, {"id": "ch03-026", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "碳钢管、不锈钢管常采用的连接方式是（ ）。", "options": {"A": "螺纹连接", "B": "焊接", "C": "卡箍连接", "D": "法兰连接"}, "answer": ["B"], "analysis": "焊接适用于碳钢管、不锈钢管，可获得可靠的永久性连接。", "tags": ["管道连接"], "source": "安装教材精读笔记"}, {"id": "ch03-027", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "大口径管道通常采用（ ）连接。", "options": {"A": "螺纹连接", "B": "卡箍连接", "C": "法兰连接", "D": "焊接"}, "answer": ["C"], "analysis": "法兰连接适用于大口径管道，便于拆卸、检修和密封。", "tags": ["管道连接"], "source": "安装教材精读笔记"}, {"id": "ch03-028", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "消防管道常采用的连接方式是（ ）。", "options": {"A": "螺纹连接", "B": "焊接", "C": "卡箍连接", "D": "法兰连接"}, "answer": ["C"], "analysis": "卡箍（沟槽）连接常用于消防管道，施工快捷、便于维修。", "tags": ["管道连接"], "source": "安装教材精读笔记"}, {"id": "ch03-029", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "下列连接方式中，属于不可拆卸（永久性）连接的是（ ）。", "options": {"A": "螺纹连接", "B": "法兰连接", "C": "卡箍连接", "D": "焊接"}, "answer": ["D"], "analysis": "焊接形成冶金结合，属不可拆卸的永久性连接；螺纹、法兰、卡箍均可拆卸。", "tags": ["管道连接"], "source": "安装教材精读笔记"}, {"id": "ch03-030", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "卡箍连接在2018定额第10册中又称为（ ）。", "options": {"A": "沟槽连接", "B": "承插连接", "C": "热熔连接", "D": "卡压连接"}, "answer": ["A"], "analysis": "第10册给排水中，钢管（沟槽连接）即卡箍连接，二者为同一方式的不同称谓。", "tags": ["管道连接"], "source": "2018定额第10册"}, {"id": "ch03-031", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "根据2018定额第10册，镀锌钢管（室内外）采用的连接方式是（ ）。", "options": {"A": "螺纹连接", "B": "焊接", "C": "法兰连接", "D": "卡箍连接"}, "answer": ["A"], "analysis": "第10册中镀锌钢管分“室外镀锌钢管（螺纹连接）”“室内镀锌钢管（螺纹连接）”，主要采用螺纹连接。", "tags": ["管道连接"], "source": "2018定额第10册"}, {"id": "ch03-032", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "下列连接方式中，密封性好且便于拆卸检修、多用于大口径管道的是（ ）。", "options": {"A": "螺纹连接", "B": "法兰连接", "C": "卡箍连接", "D": "焊接"}, "answer": ["B"], "analysis": "法兰连接多用于大口径管道，密封可靠、可拆卸检修方便。", "tags": ["管道连接"], "source": "安装教材精读笔记"}, {"id": "ch03-033", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "消防喷淋管道常采用的连接方式为（ ）。", "options": {"A": "焊接", "B": "卡箍（沟槽）连接", "C": "螺纹连接", "D": "承插连接"}, "answer": ["B"], "analysis": "消防管道（如自动喷淋）常采用卡箍（沟槽）连接，便于快速安装和维修。", "tags": ["管道连接"], "source": "安装教材精读笔记"}, {"id": "ch03-034", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "焊接连接方式适用于下列哪种管材（ ）。", "options": {"A": "仅塑料管", "B": "碳钢管、不锈钢管", "C": "仅铸铁管", "D": "仅PVC管"}, "answer": ["B"], "analysis": "焊接适用于碳钢管、不锈钢管等金属管道；塑料管一般采用热熔、粘接等。", "tags": ["管道连接"], "source": "安装教材精读笔记"}, {"id": "ch03-035", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "下列关于管道连接方式适用场合的说法，正确的是（ ）。", "options": {"A": "螺纹连接用于小口径钢管", "B": "焊接用于消防管道", "C": "法兰用于小口径钢管", "D": "卡箍用于大口径给水主干管常规连接"}, "answer": ["A"], "analysis": "螺纹连接适用于小口径钢管；焊接用于碳钢/不锈钢管；法兰用于大口径管道；卡箍用于消防管道。", "tags": ["管道连接"], "source": "安装教材精读笔记"}, {"id": "ch03-036", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "卡箍（沟槽）连接用于消防管道的主要优点是（ ）。", "options": {"A": "成本最低", "B": "施工快捷、便于维修拆卸", "C": "不可拆卸", "D": "仅用于小口径"}, "answer": ["B"], "analysis": "卡箍连接安装快捷、便于拆装维修，是消防管道常用的连接方式。", "tags": ["管道连接"], "source": "安装教材精读笔记"}, {"id": "ch03-037", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "铜管采用的“钎焊”连接，在焊接三大类中属于（ ）。", "options": {"A": "熔焊", "B": "压焊", "C": "钎焊", "D": "铆焊"}, "answer": ["C"], "analysis": "铜管钎焊仅钎料熔化、母材不熔化，属于钎焊。", "tags": ["焊接分类"], "source": "2018定额第10册"}, {"id": "ch03-038", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "焊接按结合特点主要分为三大类，下列不包括（ ）。", "options": {"A": "熔焊", "B": "压焊", "C": "钎焊", "D": "铆焊"}, "answer": ["D"], "analysis": "焊接按结合特点分为熔焊、压焊、钎焊三大类；铆焊（铆接）不属于焊接三大类。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-041", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "下列焊接方法中，属于压焊的是（ ）。", "options": {"A": "电阻焊", "B": "电弧焊", "C": "气焊", "D": "硬钎焊"}, "answer": ["A"], "analysis": "压焊包括电阻焊、摩擦焊等；电弧焊、气焊属熔焊；硬钎焊属钎焊。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-043", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "下列焊接方法中，属于钎焊的是（ ）。", "options": {"A": "软钎焊", "B": "电弧焊", "C": "电阻焊", "D": "摩擦焊"}, "answer": ["A"], "analysis": "钎焊包括软钎焊、硬钎焊；电弧焊属熔焊；电阻焊、摩擦焊属压焊。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-045", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "熔焊的本质特征是（ ）。", "options": {"A": "仅钎料熔化、母材不熔化", "B": "焊接时母材金属熔化并形成熔池", "C": "只靠加压不加热", "D": "用铆钉连接"}, "answer": ["B"], "analysis": "熔焊在焊接时母材金属熔化（可加填充金属）形成熔池冷却后结合。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-046", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "钎焊的本质特征是（ ）。", "options": {"A": "母材金属熔化", "B": "仅钎料熔化、母材不熔化", "C": "只靠加压", "D": "母材与钎料都不熔化"}, "answer": ["B"], "analysis": "钎焊加热至钎料熔化而母材不熔化，液态钎料润湿母材间隙后冷却结合。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-047", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "熔焊与钎焊的根本区别在于（ ）。", "options": {"A": "是否使用设备", "B": "母材是否熔化", "C": "是否在水中进行", "D": "是否加压"}, "answer": ["B"], "analysis": "熔焊母材熔化，钎焊仅钎料熔化、母材不熔化，这是两者根本区别。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-048", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "焊条电弧焊（手工电弧焊）属于焊接三大类中的（ ）。", "options": {"A": "熔焊", "B": "压焊", "C": "钎焊", "D": "粘接"}, "answer": ["A"], "analysis": "焊条电弧焊母材与焊条熔化，属于熔焊。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-049", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "氩弧焊（气体保护焊）属于焊接三大类中的（ ）。", "options": {"A": "熔焊", "B": "压焊", "C": "钎焊", "D": "铆焊"}, "answer": ["A"], "analysis": "氩弧焊母材熔化并受保护气体保护，属于熔焊。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-050", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "点焊属于（ ）。", "options": {"A": "熔焊", "B": "压焊（电阻焊）", "C": "钎焊", "D": "气焊"}, "answer": ["B"], "analysis": "点焊通过电极加压并通电，使接触处熔化结合，属电阻焊，归于压焊。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-051", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "软钎焊与硬钎焊的划分依据是（ ）。", "options": {"A": "母材种类", "B": "钎料熔点（以约450℃为界）", "C": "焊接电流大小", "D": "是否加压"}, "answer": ["B"], "analysis": "软钎焊与硬钎焊以钎料熔点为界，通常软钎焊钎料熔点低于450℃，硬钎焊高于450℃。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-052", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "软钎焊的钎料熔点一般（ ）。", "options": {"A": "低于450℃", "B": "高于450℃", "C": "等于母材熔点", "D": "高于母材熔点"}, "answer": ["A"], "analysis": "软钎焊（如锡铅钎料）熔点一般低于450℃；硬钎焊钎料熔点高于450℃。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-053", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "硬钎焊的钎料熔点一般（ ）。", "options": {"A": "低于450℃", "B": "高于450℃", "C": "低于室温", "D": "等于0℃"}, "answer": ["B"], "analysis": "硬钎焊（如铜锌、银基钎料）熔点一般高于450℃。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-054", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "埋弧焊属于焊接三大类中的（ ）。", "options": {"A": "熔焊", "B": "压焊", "C": "钎焊", "D": "铆焊"}, "answer": ["A"], "analysis": "埋弧焊母材与焊丝熔化，属于熔焊。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-055", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "下列焊接中，母材金属不参与熔化的是（ ）。", "options": {"A": "电弧焊", "B": "气焊", "C": "钎焊", "D": "埋弧焊"}, "answer": ["C"], "analysis": "钎焊仅钎料熔化，母材不熔化；电弧焊、气焊、埋弧焊均属熔焊，母材熔化。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-056", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "压焊的共同特点是（ ）。", "options": {"A": "母材必须完全熔化", "B": "焊接时施加压力使焊件结合", "C": "必须使用钎料", "D": "必须水下作业"}, "answer": ["B"], "analysis": "压焊在焊接过程中施加压力（可同时加热）使金属结合，如电阻焊、摩擦焊。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-057", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "钎焊常用于下列哪类工件的连接（ ）。", "options": {"A": "厚大钢结构", "B": "薄壁、精密及异种金属", "C": "大型船体", "D": "钢筋混凝土"}, "answer": ["B"], "analysis": "钎焊加热温度较低、母材不熔化，适合薄壁、精密及异种金属连接。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-058", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "气焊（氧乙炔焊）在焊接三大类中属于（ ）。", "options": {"A": "熔焊", "B": "压焊", "C": "钎焊", "D": "粘接"}, "answer": ["A"], "analysis": "气焊利用气体火焰使母材熔化，属于熔焊。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-059", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "电阻焊（如点焊、缝焊、对焊）在焊接三大类中属于（ ）。", "options": {"A": "熔焊", "B": "压焊", "C": "钎焊", "D": "铆焊"}, "answer": ["B"], "analysis": "电阻焊通过加压通电使接触面熔化结合，属压焊。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-060", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "SC管是指（ ）。", "options": {"A": "PVC塑料管", "B": "焊接钢管", "C": "薄壁镀锌钢管", "D": "铸铁管"}, "answer": ["B"], "analysis": "配管材料代号：SC为焊接钢管，JDG/MT为薄壁镀锌钢管（电线管），PC为PVC塑料管。", "tags": ["配管材料"], "source": "安装教材精读笔记"}, {"id": "ch03-061", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "JDG/MT管是指（ ）。", "options": {"A": "焊接钢管", "B": "薄壁镀锌钢管（电线管）", "C": "PVC塑料管", "D": "铸铁管"}, "answer": ["B"], "analysis": "JDG/MT为薄壁镀锌钢管，又称电线管。", "tags": ["配管材料"], "source": "安装教材精读笔记"}, {"id": "ch03-063", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "下列配管材料中，属于塑料导管的是（ ）。", "options": {"A": "SC", "B": "JDG", "C": "PC", "D": "MT"}, "answer": ["C"], "analysis": "PC为PVC塑料管；SC为焊接钢管，JDG/MT为薄壁镀锌钢管。", "tags": ["配管材料"], "source": "安装教材精读笔记"}, {"id": "ch03-064", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "下列配管材料中，属于钢导管的是（ ）。", "options": {"A": "PC", "B": "SC", "C": "PVC", "D": "塑料波纹管"}, "answer": ["B"], "analysis": "SC为焊接钢管，属钢导管；PC为塑料管。", "tags": ["配管材料"], "source": "安装教材精读笔记"}, {"id": "ch03-065", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "电线管（薄壁钢管）的常用代号是（ ）。", "options": {"A": "SC", "B": "PC", "C": "JDG/MT", "D": "RC"}, "answer": ["C"], "analysis": "JDG/MT代表薄壁镀锌钢导管（电线管）。", "tags": ["配管材料"], "source": "安装教材精读笔记"}, {"id": "ch03-066", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "下列配管中，绝缘性好、重量轻、常用于室内暗敷的是（ ）。", "options": {"A": "SC焊接钢管", "B": "JDG薄壁钢管", "C": "PC塑料管", "D": "铸铁管"}, "answer": ["C"], "analysis": "PC（PVC塑料管）绝缘、质轻、耐腐蚀，常用于室内暗敷。", "tags": ["配管材料"], "source": "安装教材精读笔记"}, {"id": "ch03-067", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "暗敷于混凝土结构中的配管，常优先采用（ ）。", "options": {"A": "PC塑料管", "B": "SC焊接钢管", "C": "JDG薄壁管", "D": "玻璃管"}, "answer": ["B"], "analysis": "暗敷于混凝土中需承受机械力，常采用SC焊接钢管等钢导管以获足够保护。", "tags": ["配管材料"], "source": "安装教材精读笔记"}, {"id": "ch03-068", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "配管材料代号SC、JDG、PC分别对应（ ）。", "options": {"A": "塑料管、焊接钢管、薄壁钢管", "B": "焊接钢管、薄壁镀锌钢管、PVC塑料管", "C": "薄壁钢管、焊接钢管、塑料管", "D": "铜管、铝管、钢管"}, "answer": ["B"], "analysis": "SC=焊接钢管，JDG/MT=薄壁镀锌钢管，PC=PVC塑料管。", "tags": ["配管材料"], "source": "安装教材精读笔记"}, {"id": "ch03-069", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "矩形风管展开面积的计算公式为（ ）。", "options": {"A": "S=π×直径×长度", "B": "S=2×（宽+高）×长度", "C": "S=宽×高×长度", "D": "S=周长×宽度"}, "answer": ["B"], "analysis": "矩形风管展开面积S=2×（宽+高）×长度；圆形风管S=π×直径×长度。", "tags": ["通风施工"], "source": "2018定额第7册"}, {"id": "ch03-070", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "圆形风管展开面积的计算公式为（ ）。", "options": {"A": "S=2×（宽+高）×长度", "B": "S=π×直径×长度", "C": "S=直径×长度", "D": "S=半径×长度"}, "answer": ["B"], "analysis": "圆形风管展开面积S=π×直径×长度。", "tags": ["通风施工"], "source": "2018定额第7册"}, {"id": "ch03-071", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "根据2024版清单，柔性软风管的计量单位是（ ）。", "options": {"A": "m", "B": "㎡", "C": "个", "D": "节"}, "answer": ["A"], "analysis": "柔性软风管按设计图示管道中心线长度以“m”计算。", "tags": ["通风施工"], "source": "2024清单GB/T50856-2024"}, {"id": "ch03-072", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "根据2018定额第7册，帆布软接口的计量单位是（ ）。", "options": {"A": "m", "B": "㎡", "C": "个", "D": "节"}, "answer": ["B"], "analysis": "帆布软接口按设计图示尺寸以“㎡”计算，注意与柔性软风管（m）区分。", "tags": ["通风施工"], "source": "2018定额第7册"}, {"id": "ch03-073", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "通风管道工程量一般按（ ）计算。", "options": {"A": "中心线长度", "B": "展开面积", "C": "体积", "D": "重量"}, "answer": ["B"], "analysis": "通风管道（风管）工程量按设计图示展开面积计算，而非中心线长度（软管才用m）。", "tags": ["通风施工"], "source": "2018定额第7册"}, {"id": "ch03-074", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "根据2018定额第10册，室内钢管可采用的连接方式包括（ ）。", "options": {"A": "仅螺纹连接", "B": "焊接或沟槽（卡箍）连接", "C": "仅法兰连接", "D": "仅承插连接"}, "answer": ["B"], "analysis": "第10册中室内钢管有“室内钢管（焊接）”“室内钢管（沟槽连接）”，即可焊接或沟槽（卡箍）连接。", "tags": ["管道连接"], "source": "2018定额第10册"}, {"id": "ch03-075", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "根据2018定额第10册，薄壁不锈钢管可采用的连接方式不包括（ ）。", "options": {"A": "卡压连接", "B": "卡套连接", "C": "承插氩弧焊", "D": "沟槽连接（钢管常用）"}, "answer": ["D"], "analysis": "第10册薄壁不锈钢管有卡压、卡套、承插氩弧焊、螺纹、对接电弧焊等；沟槽连接主要用于钢管。", "tags": ["管道连接"], "source": "2018定额第10册"}, {"id": "ch03-076", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "根据2018定额第10册，铜管可采用的连接方式不包括（ ）。", "options": {"A": "卡压连接", "B": "氧乙炔焊", "C": "钎焊", "D": "沟槽连接（钢管常用）"}, "answer": ["D"], "analysis": "第10册铜管有卡压、氧乙炔焊、钎焊等；沟槽连接主要用于钢管。", "tags": ["管道连接"], "source": "2018定额第10册"}, {"id": "ch03-077", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "不锈钢管（对接电弧焊）在焊接三大类中属于（ ）。", "options": {"A": "熔焊", "B": "压焊", "C": "钎焊", "D": "铆焊"}, "answer": ["A"], "analysis": "对接电弧焊母材熔化，属于熔焊。", "tags": ["焊接分类"], "source": "2018定额第10册"}, {"id": "ch03-078", "date": "2026-07-06", "chapter": "ch03", "type": "single", "stem": "安装工程施工方法与工艺流程属于教材（ ）。", "options": {"A": "第1章", "B": "第2章", "C": "第3章", "D": "第4章"}, "answer": ["C"], "analysis": "第3章为安装工程施工方法与工艺流程，涵盖配管、管道连接、焊接方法、通风施工等。", "tags": ["章节定位"], "source": "安装教材精读笔记"}, {"id": "ch03-079", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "配管施工工艺流程包括下列哪些步骤（ ）。", "options": {"A": "预埋预留", "B": "支架安装", "C": "管道敷设", "D": "穿线", "E": "电缆敷设"}, "answer": ["A", "B", "C", "D"], "analysis": "配管施工流程为：预埋预留→支架安装→管道敷设→穿线→接线。本题A、B、C、D均为配管施工步骤；电缆敷设属于电气线路工程，不属于配管施工流程，故不选E。", "tags": ["配管流程"], "source": "安装教材精读笔记"}, {"id": "ch03-080", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "下列属于配管施工流程的有（ ）。", "options": {"A": "预埋预留", "B": "支架安装", "C": "管道敷设", "D": "刷漆防腐", "E": "穿线"}, "answer": ["A", "B", "C", "E"], "analysis": "配管五步为预埋预留、支架安装、管道敷设、穿线、接线；刷漆防腐不属于基本流程。", "tags": ["配管流程"], "source": "安装教材精读笔记"}, {"id": "ch03-081", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "在“管道敷设”这一工序之前，应已完成的工作有（ ）。", "options": {"A": "预埋预留", "B": "支架安装", "C": "穿线", "D": "接线"}, "answer": ["A", "B"], "analysis": "流程为预埋预留→支架安装→管道敷设→穿线→接线，管道敷设前需完成预埋预留和支架安装；穿线、接线在其后。", "tags": ["配管流程"], "source": "安装教材精读笔记"}, {"id": "ch03-082", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "配管施工的最后两步（顺序）通常包括（ ）。", "options": {"A": "穿线", "B": "接线", "C": "支架安装", "D": "管道敷设"}, "answer": ["A", "B"], "analysis": "流程末两步为先穿线、后接线；支架安装与管道敷设均在前。", "tags": ["配管流程"], "source": "安装教材精读笔记"}, {"id": "ch03-083", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "关于配管流程顺序，下列说法正确的有（ ）。", "options": {"A": "预埋预留在支架安装之前", "B": "管道敷设在穿线之前", "C": "接线在穿线之后", "D": "支架安装在管道敷设之后", "E": "穿线在支架安装之前"}, "answer": ["A", "B", "C"], "analysis": "正确顺序：预埋预留→支架安装→管道敷设→穿线→接线。D错（支架安装在管道敷设前），E错（穿线在支架安装后）。", "tags": ["配管流程"], "source": "安装教材精读笔记"}, {"id": "ch03-084", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "关于导管弯曲半径，下列说法正确的有（ ）。", "options": {"A": "明配导管弯曲半径不宜小于管外径6倍", "B": "两接线盒间仅一个弯曲时不宜小于管外径4倍", "C": "明配导管弯曲半径不宜小于管外径4倍", "D": "单弯允许比一般明配更小"}, "answer": ["A", "B", "D"], "analysis": "明配≥6倍，单弯（两盒间仅一弯）≥4倍，故单弯允许小于明配（4＜6）。C错（应为6倍）。", "tags": ["弯曲半径"], "source": "安装教材精读笔记"}, {"id": "ch03-085", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "关于配管弯曲半径，下列表述正确的有（ ）。", "options": {"A": "明配导管弯曲半径不宜小于6倍管外径", "B": "单弯不宜小于4倍管外径", "C": "单弯不宜小于6倍管外径", "D": "弯曲半径越大越有利于保护导线"}, "answer": ["A", "B", "D"], "analysis": "明配≥6倍，单弯≥4倍，C错（单弯为4倍）；弯曲半径足够大有利于穿线与保护导线。", "tags": ["弯曲半径"], "source": "安装教材精读笔记"}, {"id": "ch03-086", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "规定导管最小弯曲半径，主要考虑的因素有（ ）。", "options": {"A": "保证导线能顺利穿入", "B": "防止损伤导线绝缘层", "C": "保证导管弯处不变形过大", "D": "管径大小直接决定倍数"}, "answer": ["A", "B", "C"], "analysis": "弯曲半径以“倍管外径”为比例规定，目的是保护导线与导管；倍数与管径本身无直接决定关系。", "tags": ["弯曲半径"], "source": "安装教材精读笔记"}, {"id": "ch03-087", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "下列关于配管弯曲的说法，正确的有（ ）。", "options": {"A": "弯曲处不应有褶皱、凹陷", "B": "弯曲半径应满足规范要求", "C": "明配要求比暗配更严格", "D": "单弯要求比一般明配更宽松"}, "answer": ["A", "B", "C", "D"], "analysis": "弯曲处不得褶皱凹陷；明配≥6倍、单弯≥4倍，故明配比暗配要求高、单弯比一般明配宽松。各项均正确。", "tags": ["弯曲半径"], "source": "安装教材精读笔记"}, {"id": "ch03-088", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "下列导管弯曲半径取值正确的有（ ）。", "options": {"A": "明配导管≥6倍管外径", "B": "单弯≥4倍管外径", "C": "一般明配（多弯）不小于6倍", "D": "消防管道一律≥8倍"}, "answer": ["A", "B", "C"], "analysis": "规范仅规定明配≥6倍、单弯≥4倍，无“消防管≥8倍”的专门要求，D错。", "tags": ["弯曲半径"], "source": "安装教材精读笔记"}, {"id": "ch03-089", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "影响配管弯曲半径规定的因素包括（ ）。", "options": {"A": "保证导线顺利穿入", "B": "防止损伤导线绝缘层", "C": "施工便利与质量", "D": "材料生产厂家名称"}, "answer": ["A", "B", "C"], "analysis": "弯曲半径规定出于导线保护与施工质量；与材料厂家无关。", "tags": ["弯曲半径"], "source": "安装教材精读笔记"}, {"id": "ch03-090", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "管道的基本连接方式包括（ ）。", "options": {"A": "螺纹连接", "B": "焊接", "C": "法兰连接", "D": "卡箍连接"}, "answer": ["A", "B", "C", "D"], "analysis": "教材列出的管道连接方式：螺纹连接、焊接、法兰连接、卡箍连接。", "tags": ["管道连接"], "source": "安装教材精读笔记"}, {"id": "ch03-091", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "下列连接方式中，属于可拆卸连接的有（ ）。", "options": {"A": "螺纹连接", "B": "法兰连接", "C": "焊接", "D": "卡箍连接"}, "answer": ["A", "B", "D"], "analysis": "螺纹、法兰、卡箍均可拆卸；焊接为永久性不可拆连接。", "tags": ["管道连接"], "source": "安装教材精读笔记"}, {"id": "ch03-092", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "下列连接方式中，属于不可拆卸（永久性）连接的有（ ）。", "options": {"A": "焊接", "B": "钎焊", "C": "螺纹连接", "D": "卡箍连接"}, "answer": ["A", "B"], "analysis": "焊接与钎焊均形成冶金结合，属不可拆卸连接；螺纹、卡箍可拆卸。", "tags": ["管道连接"], "source": "安装教材精读笔记"}, {"id": "ch03-093", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "适用于大口径管道的连接方式有（ ）。", "options": {"A": "法兰连接", "B": "焊接", "C": "螺纹连接", "D": "卡箍连接"}, "answer": ["A", "B"], "analysis": "法兰多用于大口径管道并便于检修；焊接也常用于大口径金属管。螺纹多用于小口径，卡箍多用于消防管道。", "tags": ["管道连接"], "source": "安装教材精读笔记"}, {"id": "ch03-094", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "消防管道常用的连接方式有（ ）。", "options": {"A": "卡箍连接", "B": "法兰连接", "C": "螺纹连接（小口径）", "D": "焊接"}, "answer": ["A", "B", "C"], "analysis": "消防管道以卡箍（沟槽）连接为主，大口径也可用法兰，小口径可用螺纹；本题取常见三类。", "tags": ["管道连接"], "source": "安装教材精读笔记"}, {"id": "ch03-095", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "关于法兰连接，下列说法正确的有（ ）。", "options": {"A": "适用于大口径管道", "B": "可拆卸", "C": "便于检修", "D": "密封性较好"}, "answer": ["A", "B", "C", "D"], "analysis": "法兰连接多用于大口径，可拆卸、便于检修、密封性好，各项均正确。", "tags": ["管道连接"], "source": "安装教材精读笔记"}, {"id": "ch03-096", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "焊接连接适用于下列哪些管材（ ）。", "options": {"A": "碳钢管", "B": "不锈钢管", "C": "PVC塑料管", "D": "铸铁管"}, "answer": ["A", "B"], "analysis": "焊接适用于碳钢管、不锈钢管等金属管；PVC一般用热熔/粘接，铸铁多用承插。", "tags": ["管道连接"], "source": "安装教材精读笔记"}, {"id": "ch03-097", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "关于卡箍（沟槽）连接，下列说法正确的有（ ）。", "options": {"A": "又称沟槽连接", "B": "常用于消防管道", "C": "施工快捷", "D": "便于维修拆卸"}, "answer": ["A", "B", "C", "D"], "analysis": "卡箍连接即沟槽连接，用于消防管道，安装快捷、可拆装维修，各项均正确。", "tags": ["管道连接"], "source": "2018定额第10册"}, {"id": "ch03-098", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "焊接按结合特点主要分为哪三大类（ ）。", "options": {"A": "熔焊", "B": "压焊", "C": "钎焊", "D": "铆焊"}, "answer": ["A", "B", "C"], "analysis": "焊接按结合特点分为熔焊、压焊、钎焊三大类；铆焊（铆接）不属焊接三大类。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-099", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "下列焊接方法中，属于熔焊的有（ ）。", "options": {"A": "电弧焊", "B": "气焊", "C": "电阻焊", "D": "摩擦焊"}, "answer": ["A", "B"], "analysis": "熔焊包括电弧焊、气焊等；电阻焊、摩擦焊属于压焊。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-100", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "下列焊接方法中，属于压焊的有（ ）。", "options": {"A": "电阻焊", "B": "摩擦焊", "C": "电弧焊", "D": "气焊"}, "answer": ["A", "B"], "analysis": "压焊包括电阻焊、摩擦焊；电弧焊、气焊属熔焊。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-101", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "下列焊接方法中，属于钎焊的有（ ）。", "options": {"A": "软钎焊", "B": "硬钎焊", "C": "电弧焊", "D": "气焊"}, "answer": ["A", "B"], "analysis": "钎焊分为软钎焊、硬钎焊；电弧焊、气焊属熔焊。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-102", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "关于熔焊，下列说法正确的有（ ）。", "options": {"A": "焊接时母材金属熔化", "B": "可加入填充金属", "C": "电弧焊属于熔焊", "D": "气焊属于熔焊"}, "answer": ["A", "B", "C", "D"], "analysis": "熔焊母材熔化（可加填充金属），电弧焊、气焊均属熔焊，各项均正确。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-103", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "关于钎焊，下列说法正确的有（ ）。", "options": {"A": "仅钎料熔化", "B": "母材不熔化", "C": "分软钎焊和硬钎焊", "D": "适用于异种金属连接"}, "answer": ["A", "B", "C", "D"], "analysis": "钎焊仅钎料熔化、母材不熔化，分软/硬两类，适合异种金属，各项均正确。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-104", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "关于压焊，下列说法正确的有（ ）。", "options": {"A": "焊接时施加压力", "B": "电阻焊属于压焊", "C": "摩擦焊属于压焊", "D": "母材必须加热到熔点以上才叫压焊"}, "answer": ["A", "B", "C"], "analysis": "压焊通过加压（可加热）使金属结合，电阻焊、摩擦焊均属压焊；D错误，压焊不要求母材整体熔化到熔点以上。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-105", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "下列焊接中，母材金属熔化并参与结合的有（ ）。", "options": {"A": "电弧焊", "B": "气焊", "C": "电阻焊", "D": "钎焊"}, "answer": ["A", "B"], "analysis": "熔焊（电弧焊、气焊）母材熔化；电阻焊属压焊（局部熔化加压），钎焊母材不熔化，故选熔焊两项。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-106", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "下列焊接中，母材不熔化（仅钎料熔化）的有（ ）。", "options": {"A": "软钎焊", "B": "硬钎焊", "C": "电弧焊", "D": "气焊"}, "answer": ["A", "B"], "analysis": "钎焊仅钎料熔化、母材不熔化；电弧焊、气焊为熔焊，母材熔化。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-107", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "软钎焊与硬钎焊的区别体现在（ ）。", "options": {"A": "钎料熔点不同（约450℃为界）", "B": "接头强度不同", "C": "适用场合不同", "D": "是否使用电流"}, "answer": ["A", "B", "C"], "analysis": "两者以钎料熔点为界（软＜450℃、硬＞450℃），强度与适用场合随之不同；与是否用电无必然对应关系。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-108", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "下列焊接方法归类正确的有（ ）。", "options": {"A": "焊条电弧焊→熔焊", "B": "点焊→压焊", "C": "软钎焊→钎焊", "D": "摩擦焊→熔焊"}, "answer": ["A", "B", "C"], "analysis": "焊条电弧焊属熔焊，点焊属压焊（电阻焊），软钎焊属钎焊；摩擦焊属压焊而非熔焊，D错。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-109", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "属于熔焊的气体保护焊/电弧焊类的有（ ）。", "options": {"A": "氩弧焊", "B": "CO₂气体保护焊", "C": "埋弧焊", "D": "电阻焊"}, "answer": ["A", "B", "C"], "analysis": "氩弧焊、CO₂焊、埋弧焊均属熔焊；电阻焊属压焊。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-111", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "关于焊接方法分类，下列说法正确的有（ ）。", "options": {"A": "按结合特点分熔焊、压焊、钎焊", "B": "熔焊母材熔化", "C": "钎焊仅钎料熔化", "D": "压焊需施加压力"}, "answer": ["A", "B", "C", "D"], "analysis": "焊接按结合特点分三大类，熔焊母材熔化、钎焊仅钎料熔化、压焊需加压，各项均正确。", "tags": ["焊接分类"], "source": "安装教材精读笔记"}, {"id": "ch03-112", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "常用配管材料代号与名称对应正确的有（ ）。", "options": {"A": "SC→焊接钢管", "B": "JDG/MT→薄壁镀锌钢管", "C": "PC→PVC塑料管", "D": "PVC→焊接钢管"}, "answer": ["A", "B", "C"], "analysis": "SC=焊接钢管，JDG/MT=薄壁镀锌钢管，PC=PVC塑料管；D错。", "tags": ["配管材料"], "source": "安装教材精读笔记"}, {"id": "ch03-113", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "下列配管材料中，属于导管（管类）的有（ ）。", "options": {"A": "SC", "B": "JDG", "C": "PC", "D": "电缆桥架"}, "answer": ["A", "B", "C"], "analysis": "SC、JDG、PC均为配管导管；电缆桥架是线缆敷设装置，不属于配管导管。", "tags": ["配管材料"], "source": "安装教材精读笔记"}, {"id": "ch03-114", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "关于PC（PVC塑料管），下列说法正确的有（ ）。", "options": {"A": "属塑料管", "B": "绝缘性能好", "C": "重量轻", "D": "耐腐蚀"}, "answer": ["A", "B", "C", "D"], "analysis": "PC为PVC塑料管，绝缘、质轻、耐腐蚀，各项均正确。", "tags": ["配管材料"], "source": "安装教材精读笔记"}, {"id": "ch03-115", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "配管材料的选择应考虑（ ）。", "options": {"A": "敷设环境", "B": "腐蚀情况", "C": "机械保护要求", "D": "导体电阻率"}, "answer": ["A", "B", "C"], "analysis": "配管选材需考虑环境、腐蚀与机械保护；导体电阻率属于导线而非导管选材因素。", "tags": ["配管材料"], "source": "安装教材精读笔记"}, {"id": "ch03-116", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "下列代号与名称对应正确的有（ ）。", "options": {"A": "SC=焊接钢管", "B": "JDG=紧定式薄壁钢导管", "C": "PC=塑料管", "D": "MT=电线管"}, "answer": ["A", "B", "C", "D"], "analysis": "SC焊接钢管，JDG紧定式薄壁钢导管，PC塑料管，MT电线管，各项均正确。", "tags": ["配管材料"], "source": "安装教材精读笔记"}, {"id": "ch03-117", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "通风管道工程量计算，下列说法正确的有（ ）。", "options": {"A": "矩形风管S=2×（宽+高）×长度", "B": "圆形风管S=π×直径×长度", "C": "按展开面积计算", "D": "按中心线长度计算"}, "answer": ["A", "B", "C"], "analysis": "风管按展开面积计算：矩形S=2×（宽+高）×长，圆形S=π×D×长；按中心线长度计算的是柔性软风管，非一般风管。", "tags": ["通风施工"], "source": "2018定额第7册"}, {"id": "ch03-118", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "关于柔性软风管与帆布软接口，下列说法正确的有（ ）。", "options": {"A": "柔性软风管按m计算", "B": "帆布软接口按㎡计算", "C": "两者均属通风工程内容", "D": "帆布软接口按m计算"}, "answer": ["A", "B", "C"], "analysis": "柔性软风管（m）、帆布软接口（㎡）计量单位不同，易混淆；D错。", "tags": ["通风施工"], "source": "2018定额第7册"}, {"id": "ch03-119", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "2018定额第7册（通风空调工程）包括的内容有（ ）。", "options": {"A": "通风空调设备及部件制作安装", "B": "通风管道制作安装", "C": "风口、风阀、风帽等部件安装", "D": "配管（电气导管）"}, "answer": ["A", "B", "C"], "analysis": "第7册涵盖通风空调设备部件、风管及部件安装；配管属第4册电气工程。", "tags": ["通风施工"], "source": "2018定额第7册"}, {"id": "ch03-120", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "通风管道施工一般包括（ ）。", "options": {"A": "风管制作", "B": "风管安装", "C": "部件安装", "D": "柔性接口安装"}, "answer": ["A", "B", "C", "D"], "analysis": "通风施工含风管制作、安装、各类部件及柔性接口安装，各项均正确。", "tags": ["通风施工"], "source": "2018定额第7册"}, {"id": "ch03-121", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "根据2018定额第10册，室内钢管可采用的连接方式有（ ）。", "options": {"A": "焊接", "B": "沟槽（卡箍）连接", "C": "螺纹连接（镀锌钢管）", "D": "承插连接（铸铁管）"}, "answer": ["A", "B", "C"], "analysis": "第10册室内钢管有焊接、沟槽连接；镀锌钢管用螺纹连接；承插多用于铸铁管。", "tags": ["管道连接"], "source": "2018定额第10册"}, {"id": "ch03-122", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "根据2018定额第10册，铜管可采用的连接方式有（ ）。", "options": {"A": "卡压连接", "B": "氧乙炔焊", "C": "钎焊", "D": "对接电弧焊（钢管常用）"}, "answer": ["A", "B", "C"], "analysis": "第10册铜管有卡压、氧乙炔焊、钎焊；对接电弧焊多用于不锈钢管。", "tags": ["管道连接"], "source": "2018定额第10册"}, {"id": "ch03-123", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "根据2018定额第10册，薄壁不锈钢管可采用的连接方式有（ ）。", "options": {"A": "卡压连接", "B": "卡套连接", "C": "承插氩弧焊", "D": "对接电弧焊"}, "answer": ["A", "B", "C", "D"], "analysis": "第10册薄壁不锈钢管有卡压、卡套、承插氩弧焊、螺纹、对接电弧焊等多种方式，各项均正确。", "tags": ["管道连接"], "source": "2018定额第10册"}, {"id": "ch03-124", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "第10册管道安装中，涉及“熔焊”的连接方式有（ ）。", "options": {"A": "钢管焊接", "B": "不锈钢管对接电弧焊", "C": "铜管氧乙炔焊", "D": "铜管钎焊"}, "answer": ["A", "B", "C"], "analysis": "钢管焊接、不锈钢对接电弧焊、铜管氧乙炔焊均属熔焊；铜管钎焊属钎焊，D不选。", "tags": ["焊接分类"], "source": "2018定额第10册"}, {"id": "ch03-125", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "第3章安装工程施工方法与工艺流程涉及的专业施工内容包括（ ）。", "options": {"A": "电气配管施工", "B": "管道连接施工", "C": "焊接方法", "D": "通风管道施工"}, "answer": ["A", "B", "C", "D"], "analysis": "第3章涵盖配管、管道连接、焊接方法、通风施工等专业施工方法与工艺流程，各项均正确。", "tags": ["章节定位"], "source": "安装教材精读笔记"}, {"id": "ch03-126", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "配管施工相关资料与依据包括（ ）。", "options": {"A": "2018定额第4册（电气设备安装）", "B": "《建筑电气工程施工质量验收规范》GB 50303", "C": "设计图纸", "D": "2024清单附录D（电气设备安装）"}, "answer": ["A", "B", "C", "D"], "analysis": "配管属电气工程，涉及第4册定额、电气施工规范、设计文件及2024清单附录D，各项均正确。", "tags": ["章节定位"], "source": "2024清单GB/T50856-2024"}, {"id": "ch03-127", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "管道施工方法涉及的内容包括（ ）。", "options": {"A": "2018定额第10册（给排水采暖燃气）", "B": "2018定额第8册（工业管道）", "C": "连接方式选择", "D": "焊接方法选择"}, "answer": ["A", "B", "C", "D"], "analysis": "管道施工涉及第10册给排水、第8册工业管道，以及连接方式、焊接方法选择，各项均正确。", "tags": ["章节定位"], "source": "2018定额第10册"}, {"id": "ch03-128", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "下列属于施工工艺流程内容的有（ ）。", "options": {"A": "配管五大步骤", "B": "管道连接方式选择", "C": "焊接方法选择", "D": "通风管道制作安装"}, "answer": ["A", "B", "C", "D"], "analysis": "第3章施工方法与工艺流程包含配管流程、管道连接、焊接方法、通风管道施工等，各项均正确。", "tags": ["章节定位"], "source": "安装教材精读笔记"}, {"id": "ch03-129", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "关于2024版清单（GB/T 50856-2024）与第3章施工方法的衔接，下列说法正确的有（ ）。", "options": {"A": "清单规定计量规则（怎么算量）", "B": "定额规定消耗量（要多少工料机）", "C": "两者结合用于计价", "D": "附录D为电气设备安装、附录G为通风空调、附录K为给排水采暖燃气"}, "answer": ["A", "B", "C", "D"], "analysis": "2024清单规定计量规则，2018定额规定消耗量，结合用于计价；附录D/G/K分别对应电气、通风、给排水，各项均正确。", "tags": ["清单定额衔接"], "source": "2024清单GB/T50856-2024"}, {"id": "ch03-130", "date": "2026-07-06", "chapter": "ch03", "type": "multiple", "stem": "建筑机电安装的特点中，与第3章施工方法密切相关的有（ ）。", "options": {"A": "配套性强（需与土建配合预埋）", "B": "隐蔽工程多（预埋预留量大）", "C": "专业性强（多专业交叉）", "D": "调试要求高（系统联动）"}, "answer": ["A", "B", "C", "D"], "analysis": "建筑机电安装配套性强、隐蔽工程多、专业性强、调试要求高，均在第3章施工方法中体现，各项均正确。", "tags": ["章节定位"], "source": "安装教材精读笔记"}, {"id": "ch04-001", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "在建筑安装工程中，塔吊（塔式起重机）主要用于（ ）。", "options": {"A": "设备与构件吊装", "B": "管螺纹加工", "C": "电气测量", "D": "接地电阻测试"}, "answer": ["A"], "analysis": "根据教材第4章，起重机械（塔吊、汽车吊）的用途是设备吊装。", "tags": ["起重机械", "塔吊", "设备吊装"], "source": "安装教材精读笔记"}, {"id": "ch04-002", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "下列施工机械中，属于起重机械的是（ ）。", "options": {"A": "电焊机", "B": "塔吊", "C": "套丝机", "D": "兆欧表"}, "answer": ["B"], "analysis": "起重机械的代表设备为塔吊、汽车吊；电焊机属焊接设备，套丝机属管道机械，兆欧表属检测仪表。", "tags": ["起重机械", "分类"], "source": "安装教材精读笔记"}, {"id": "ch04-003", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "下列起重机械中，具有机动灵活、可随车转移、适合设备分散吊装的是（ ）。", "options": {"A": "塔吊", "B": "汽车吊", "C": "龙门吊", "D": "施工电梯"}, "answer": ["B"], "analysis": "汽车吊以汽车底盘为行驶机构，机动灵活、转场方便，适合设备进场及分散作业点吊装。", "tags": ["起重机械", "汽车吊"], "source": "安装教材精读笔记"}, {"id": "ch04-004", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "塔式起重机（塔吊）最显著的特点是（ ）。", "options": {"A": "可带载高速长途行驶", "B": "作业半径大、适合建筑工地长期吊装", "C": "只能在室内使用", "D": "不需要任何基础"}, "answer": ["B"], "analysis": "塔吊一般固定设置，臂架回转、作业半径大，适合建筑工地长期、大范围的设备与材料吊装。", "tags": ["起重机械", "塔吊"], "source": "安装教材精读笔记"}, {"id": "ch04-005", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "汽车式起重机作业时的正确做法是（ ）。", "options": {"A": "可带重载长途行驶", "B": "必须打支腿保持稳定后作业", "C": "可在斜坡上不支腿吊装", "D": "边行驶边吊装"}, "answer": ["B"], "analysis": "汽车吊作业前必须打支腿并铺垫板以保持稳定，一般不能带载行驶，更不可边行驶边吊装。", "tags": ["起重机械", "汽车吊", "安全作业"], "source": "安装教材精读笔记"}, {"id": "ch04-006", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "在高层建筑施工中，用于长期、大范围材料与设备垂直及水平吊装，应优先选用的起重机械是（ ）。", "options": {"A": "汽车吊", "B": "塔吊", "C": "手拉葫芦", "D": "卷扬机"}, "answer": ["B"], "analysis": "塔吊适合长期固定、大范围吊装，是高层建筑主体施工的主要吊装机械。", "tags": ["起重机械", "塔吊"], "source": "安装教材精读笔记"}, {"id": "ch04-007", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "下列机械中，不属于起重机械的是（ ）。", "options": {"A": "塔吊", "B": "汽车吊", "C": "龙门起重机", "D": "电焊机"}, "answer": ["D"], "analysis": "电焊机属于焊接设备，其余均为起重机械。", "tags": ["起重机械", "分类"], "source": "安装教材精读笔记"}, {"id": "ch04-008", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "汽车吊相比塔吊，其突出优点是（ ）。", "options": {"A": "起升高度更大", "B": "机动灵活、转场方便", "C": "作业半径更大", "D": "可长期固定作业"}, "answer": ["B"], "analysis": "汽车吊以汽车为底盘，机动灵活、转场方便；塔吊则作业半径大、适合长期固定吊装。", "tags": ["起重机械", "汽车吊", "塔吊"], "source": "安装教材精读笔记"}, {"id": "ch04-009", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "将大型设备从运输车辆吊至设备基础上就位，这一过程主要属于（ ）的工作内容。", "options": {"A": "焊接设备", "B": "起重机械", "C": "管道机械", "D": "检测仪表"}, "answer": ["B"], "analysis": "设备吊装是起重机械（塔吊、汽车吊）的典型用途。", "tags": ["起重机械", "设备吊装"], "source": "安装教材精读笔记"}, {"id": "ch04-010", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "电焊机（手工电弧焊设备）在安装工程中的主要用途是（ ）。", "options": {"A": "管道焊接", "B": "管螺纹加工", "C": "管道弯曲", "D": "绝缘电阻测量"}, "answer": ["A"], "analysis": "根据教材第4章，焊接设备（电焊机、氩弧焊机）用途为管道焊接。", "tags": ["焊接设备", "电焊机"], "source": "安装教材精读笔记"}, {"id": "ch04-011", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "下列设备中，属于焊接设备的是（ ）。", "options": {"A": "塔吊", "B": "电焊机", "C": "套丝机", "D": "压力表"}, "answer": ["B"], "analysis": "电焊机、氩弧焊机属于焊接设备；塔吊属起重机械，套丝机属管道机械，压力表属检测仪表。", "tags": ["焊接设备", "分类"], "source": "安装教材精读笔记"}, {"id": "ch04-012", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "氩弧焊机（TIG焊）焊接质量高、变形小，特别适用于（ ）的焊接。", "options": {"A": "普通碳钢结构", "B": "不锈钢及有色金属管道", "C": "混凝土", "D": "木材"}, "answer": ["B"], "analysis": "氩弧焊采用氩气保护、电弧稳定，特别适合不锈钢、铜、铝等有色金属及高质量管道打底焊。", "tags": ["焊接设备", "氩弧焊机"], "source": "安装教材精读笔记"}, {"id": "ch04-013", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "电焊机与氩弧焊机相比，电焊机的特点是（ ）。", "options": {"A": "设备简单、成本低，适合普通碳钢管材焊接", "B": "必须用氩气保护", "C": "只能焊铝", "D": "无电弧产生"}, "answer": ["A"], "analysis": "手工电弧焊（电焊机）设备简单、成本低，适合普通碳钢管道与钢结构焊接；氩弧焊需氩气保护。", "tags": ["焊接设备", "电焊机", "氩弧焊机"], "source": "安装教材精读笔记"}, {"id": "ch04-014", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "氩弧焊机采用（ ）作为保护气体进行焊接。", "options": {"A": "二氧化碳", "B": "氩气", "C": "氧气", "D": "氮气"}, "answer": ["B"], "analysis": "氩弧焊（钨极惰性气体保护焊TIG）以氩气作保护气体，防止熔池氧化。", "tags": ["焊接设备", "氩弧焊机", "保护气体"], "source": "安装教材精读笔记"}, {"id": "ch04-015", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "在管道安装中，不锈钢工艺管道打底焊常采用的焊接设备是（ ）。", "options": {"A": "套丝机", "B": "氩弧焊机", "C": "弯管机", "D": "兆欧表"}, "answer": ["B"], "analysis": "不锈钢管道打底焊要求质量高、氧化少，常采用氩弧焊机（TIG）。", "tags": ["焊接设备", "氩弧焊机"], "source": "安装教材精读笔记"}, {"id": "ch04-016", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "手工电弧焊（电焊机）利用（ ）的热量熔化金属实现焊接。", "options": {"A": "电阻", "B": "电弧", "C": "摩擦", "D": "超声波"}, "answer": ["B"], "analysis": "手工电弧焊利用电弧热熔化焊条与母材形成焊缝。", "tags": ["焊接设备", "电焊机"], "source": "安装教材精读笔记"}, {"id": "ch04-017", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "下列焊接方法中，需要惰性气体保护且钨极不熔化的是（ ）。", "options": {"A": "手工电弧焊", "B": "氩弧焊（TIG）", "C": "气焊", "D": "钎焊"}, "answer": ["B"], "analysis": "氩弧焊（钨极惰性气体保护焊）钨极不熔化，以氩气等惰性气体保护电弧与熔池。", "tags": ["焊接设备", "氩弧焊机"], "source": "安装教材精读笔记"}, {"id": "ch04-018", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "焊接设备（电焊机、氩弧焊机）在安装工程中的典型用途是（ ）。", "options": {"A": "设备吊装", "B": "管道焊接", "C": "管螺纹加工", "D": "压力测量"}, "answer": ["B"], "analysis": "焊接设备用于管道焊接、钢结构焊接等，是安装工程中连接金属构件的主要设备。", "tags": ["焊接设备", "管道焊接"], "source": "安装教材精读笔记"}, {"id": "ch04-019", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "套丝机在管道安装中的主要用途是（ ）。", "options": {"A": "弯曲管材", "B": "加工管外螺纹（管螺纹）", "C": "测量管道压力", "D": "焊接管道"}, "answer": ["B"], "analysis": "根据教材第4章，管道机械（套丝机、弯管机）用途为管道加工；套丝机用于加工管外螺纹。", "tags": ["管道机械", "套丝机"], "source": "安装教材精读笔记"}, {"id": "ch04-020", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "下列机械中，用于管道弯曲加工的是（ ）。", "options": {"A": "套丝机", "B": "弯管机", "C": "电焊机", "D": "兆欧表"}, "answer": ["B"], "analysis": "弯管机用于将直管弯曲成所需角度，属于管道机械。", "tags": ["管道机械", "弯管机"], "source": "安装教材精读笔记"}, {"id": "ch04-021", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "套丝机加工出的管螺纹主要用于管道的（ ）连接。", "options": {"A": "焊接", "B": "螺纹连接", "C": "法兰连接", "D": "卡箍连接"}, "answer": ["B"], "analysis": "套丝机在管端加工外螺纹，用于管道的螺纹连接（如镀锌钢管）。", "tags": ["管道机械", "套丝机", "螺纹连接"], "source": "安装教材精读笔记"}, {"id": "ch04-022", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "下列设备中，属于管道机械的是（ ）。", "options": {"A": "塔吊", "B": "电焊机", "C": "套丝机", "D": "万用表"}, "answer": ["C"], "analysis": "套丝机、弯管机属于管道机械，用于管道加工。", "tags": ["管道机械", "分类"], "source": "安装教材精读笔记"}, {"id": "ch04-023", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "弯管机用于将直管弯曲成所需角度，常用于管道安装中（ ）。", "options": {"A": "改变管道走向", "B": "测量压力", "C": "加工螺纹", "D": "焊接接口"}, "answer": ["A"], "analysis": "弯管机可绕开梁柱等障碍物改变管道走向，是管道加工机械。", "tags": ["管道机械", "弯管机"], "source": "安装教材精读笔记"}, {"id": "ch04-024", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "镀锌钢管采用螺纹连接时，管端外螺纹通常由（ ）加工。", "options": {"A": "弯管机", "B": "套丝机", "C": "电焊机", "D": "汽车吊"}, "answer": ["B"], "analysis": "螺纹连接前需用套丝机在镀锌钢管管端加工外螺纹。", "tags": ["管道机械", "套丝机", "螺纹连接"], "source": "安装教材精读笔记"}, {"id": "ch04-025", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "管道机械（套丝机、弯管机）在安装工程中的用途属于（ ）。", "options": {"A": "设备吊装", "B": "管道加工", "C": "电气测量", "D": "焊接"}, "answer": ["B"], "analysis": "套丝机、弯管机用于对管材进行套丝、弯曲等加工，属于管道机械范畴。", "tags": ["管道机械", "管道加工"], "source": "安装教材精读笔记"}, {"id": "ch04-026", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "与热弯相比，采用弯管机冷弯管道的优点是（ ）。", "options": {"A": "需消耗加热燃料", "B": "不损伤管材组织、操作简便", "C": "只能弯大口径管", "D": "弯后必须退火"}, "answer": ["B"], "analysis": "弯管机冷弯不必加热，可避免损伤管材组织，操作简便、效率高。", "tags": ["管道机械", "弯管机", "冷弯"], "source": "安装教材精读笔记"}, {"id": "ch04-027", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "在给排水管道安装中，为绕开梁柱改变管路方向，应选用（ ）。", "options": {"A": "套丝机", "B": "弯管机", "C": "电焊机", "D": "压力表"}, "answer": ["B"], "analysis": "弯管机可将直管弯曲以改变走向，适应管路绕障。", "tags": ["管道机械", "弯管机"], "source": "安装教材精读笔记"}, {"id": "ch04-028", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "压力表在安装工程中的主要用途是（ ）。", "options": {"A": "测量管道或设备内介质压力", "B": "测量绝缘电阻", "C": "测量接地电阻", "D": "测量电压"}, "answer": ["A"], "analysis": "根据教材第4章，压力表用于测量管道压力（及设备内介质压力）。", "tags": ["检测仪表", "压力表"], "source": "安装教材精读笔记"}, {"id": "ch04-029", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "下列检测仪表中，用于测量管道压力的是（ ）。", "options": {"A": "兆欧表", "B": "接地电阻测试仪", "C": "压力表", "D": "万用表"}, "answer": ["C"], "analysis": "压力表是测量管道或设备压力的仪表。", "tags": ["检测仪表", "压力表"], "source": "安装教材精读笔记"}, {"id": "ch04-030", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "压力表通常安装在（ ）上以监测介质压力。", "options": {"A": "管道或设备", "B": "接地极", "C": "电缆绝缘层", "D": "电动机绕组"}, "answer": ["A"], "analysis": "压力表装于管道或设备本体上，用于现场指示介质压力。", "tags": ["检测仪表", "压力表"], "source": "安装教材精读笔记"}, {"id": "ch04-031", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "在给排水、供热、工业管道系统中，用于现场指示介质压力的仪表是（ ）。", "options": {"A": "万用表", "B": "压力表", "C": "兆欧表", "D": "接地电阻测试仪"}, "answer": ["B"], "analysis": "压力表用于管道系统介质压力的现场监测与指示。", "tags": ["检测仪表", "压力表"], "source": "安装教材精读笔记"}, {"id": "ch04-032", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "下列检测仪表中，属于测量压力类仪表的是（ ）。", "options": {"A": "压力表", "B": "兆欧表", "C": "万用表", "D": "接地电阻测试仪"}, "answer": ["A"], "analysis": "压力表属于压力测量类仪表；其余分别测绝缘、电气参数、接地。", "tags": ["检测仪表", "压力表"], "source": "安装教材精读笔记"}, {"id": "ch04-033", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "管道系统水压试验时，用于观测试验压力的仪表是（ ）。", "options": {"A": "兆欧表", "B": "压力表", "C": "接地电阻测试仪", "D": "万用表"}, "answer": ["B"], "analysis": "水压试验通过压力表观测试验压力是否达到要求。", "tags": ["检测仪表", "压力表", "水压试验"], "source": "安装教材精读笔记"}, {"id": "ch04-034", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "压力表所测得的“压力”一般指的是（ ）。", "options": {"A": "绝对压力", "B": "表压力（相对大气压）", "C": "真空度", "D": "大气压力"}, "answer": ["B"], "analysis": "工程中压力表指示的是相对于大气压的表压力。", "tags": ["检测仪表", "压力表", "表压力"], "source": "安装教材精读笔记"}, {"id": "ch04-035", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "在锅炉、压力容器及管道上，为保障安全需装设的监测仪表是（ ）。", "options": {"A": "接地电阻测试仪", "B": "压力表", "C": "兆欧表", "D": "万用表"}, "answer": ["B"], "analysis": "锅炉、压力容器及管道需装设压力表以监测运行压力、保障安全。", "tags": ["检测仪表", "压力表"], "source": "安装教材精读笔记"}, {"id": "ch04-036", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "万用表在电气安装工程中的主要用途是（ ）。", "options": {"A": "测量绝缘电阻", "B": "测量电压、电流、电阻等电气参数", "C": "测量接地电阻", "D": "测量管道压力"}, "answer": ["B"], "analysis": "根据教材第4章，万用表用于电气测量，可测电压、电流、电阻等。", "tags": ["检测仪表", "万用表"], "source": "安装教材精读笔记"}, {"id": "ch04-037", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "下列检测仪表中，可用于测量交直流电压、电流和电阻的是（ ）。", "options": {"A": "兆欧表", "B": "万用表", "C": "压力表", "D": "接地电阻测试仪"}, "answer": ["B"], "analysis": "万用表是通用电气测量仪表，可测交直流电压、电流、电阻及通断。", "tags": ["检测仪表", "万用表"], "source": "安装教材精读笔记"}, {"id": "ch04-038", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "万用表属于（ ）类仪表。", "options": {"A": "压力测量", "B": "电气测量", "C": "温度测量", "D": "流量测量"}, "answer": ["B"], "analysis": "万用表属电气测量仪表，用于多种电气参数的测量。", "tags": ["检测仪表", "万用表"], "source": "安装教材精读笔记"}, {"id": "ch04-039", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "在电气线路安装中，用万用表可进行的检查是（ ）。", "options": {"A": "线路通断", "B": "管道压力", "C": "接地电阻", "D": "焊缝质量"}, "answer": ["A"], "analysis": "万用表电阻档可判断线路通断，是电气安装调试常用手段。", "tags": ["检测仪表", "万用表", "通断测试"], "source": "安装教材精读笔记"}, {"id": "ch04-040", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "下列检测仪表中，属于通用电气测量仪表、可测电压电流电阻的是（ ）。", "options": {"A": "万用表", "B": "压力表", "C": "兆欧表", "D": "接地电阻测试仪"}, "answer": ["A"], "analysis": "万用表是通用电气测量仪表；兆欧表专测绝缘、接地电阻测试仪专测接地、压力表测压力。", "tags": ["检测仪表", "万用表"], "source": "安装教材精读笔记"}, {"id": "ch04-041", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "用万用表测量低压线路是否带电，应使用的功能是（ ）。", "options": {"A": "电阻档", "B": "电压档", "C": "压力档", "D": "兆欧档"}, "answer": ["B"], "analysis": "判断是否带电应使用电压档测量电压。", "tags": ["检测仪表", "万用表", "电压档"], "source": "安装教材精读笔记"}, {"id": "ch04-042", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "安装工程中，用于测试电气线路通断、电压、电流的综合仪表是（ ）。", "options": {"A": "接地电阻测试仪", "B": "万用表", "C": "压力表", "D": "套丝机"}, "answer": ["B"], "analysis": "万用表集电压、电流、电阻、通断测试于一体，是电气综合测量仪表。", "tags": ["检测仪表", "万用表"], "source": "安装教材精读笔记"}, {"id": "ch04-043", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "万用表不能用于测量（ ）。", "options": {"A": "直流电压", "B": "交流电流", "C": "管道介质压力", "D": "电阻"}, "answer": ["C"], "analysis": "万用表用于电气参数测量，不能测量管道介质压力（由压力表测量）。", "tags": ["检测仪表", "万用表"], "source": "安装教材精读笔记"}, {"id": "ch04-044", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "兆欧表（摇表）在电气安装工程中的主要用途是（ ）。", "options": {"A": "测量绝缘电阻", "B": "测量管道压力", "C": "测量接地电阻", "D": "测量交流电压"}, "answer": ["A"], "analysis": "根据教材第4章，兆欧表用于绝缘电阻测量。", "tags": ["检测仪表", "兆欧表", "绝缘电阻"], "source": "安装教材精读笔记"}, {"id": "ch04-045", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "下列检测仪表中，专门用于测量绝缘电阻的是（ ）。", "options": {"A": "万用表", "B": "兆欧表", "C": "压力表", "D": "接地电阻测试仪"}, "answer": ["B"], "analysis": "兆欧表（摇表）专门用于测量高阻值绝缘电阻。", "tags": ["检测仪表", "兆欧表", "绝缘电阻"], "source": "安装教材精读笔记"}, {"id": "ch04-046", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "兆欧表测量的绝缘物理量，其计量单位是（ ）。", "options": {"A": "欧姆(Ω)", "B": "兆欧(MΩ)", "C": "安培(A)", "D": "伏特(V)"}, "answer": ["B"], "analysis": "绝缘电阻数值很大，兆欧表以其计量单位“兆欧(MΩ)”命名。", "tags": ["检测仪表", "兆欧表", "单位"], "source": "安装教材精读笔记"}, {"id": "ch04-047", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "电缆敷设完成后，为检验其绝缘性能应使用的仪表是（ ）。", "options": {"A": "压力表", "B": "万用表", "C": "兆欧表", "D": "接地电阻测试仪"}, "answer": ["C"], "analysis": "电缆绝缘用兆欧表测量芯线对地、芯线间绝缘电阻。", "tags": ["检测仪表", "兆欧表", "电缆绝缘"], "source": "安装教材精读笔记"}, {"id": "ch04-048", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "电动机接线后，检查其绕组对地及相间绝缘应使用（ ）。", "options": {"A": "兆欧表", "B": "万用表", "C": "压力表", "D": "弯管机"}, "answer": ["A"], "analysis": "电动机绕组绝缘用兆欧表测试，以确认绝缘合格。", "tags": ["检测仪表", "兆欧表", "电机绝缘"], "source": "安装教材精读笔记"}, {"id": "ch04-049", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "下列检测仪表中，用于绝缘电阻测量的是（ ）。", "options": {"A": "兆欧表", "B": "接地电阻测试仪", "C": "压力表", "D": "万用表"}, "answer": ["A"], "analysis": "绝缘电阻由兆欧表测量。", "tags": ["检测仪表", "兆欧表"], "source": "安装教材精读笔记"}, {"id": "ch04-050", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "兆欧表又称“摇表”，其名称来源于测量对象为（ ）。", "options": {"A": "电压等级", "B": "兆欧级的高绝缘电阻", "C": "接地电阻", "D": "管道压力"}, "answer": ["B"], "analysis": "兆欧表以“兆欧(MΩ)”为计量单位，故俗称摇表，专测高绝缘电阻。", "tags": ["检测仪表", "兆欧表"], "source": "安装教材精读笔记"}, {"id": "ch04-051", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "与万用表电阻档相比，兆欧表的特点是（ ）。", "options": {"A": "测量低阻值通断", "B": "测量高阻值绝缘电阻", "C": "测量交流电压", "D": "测量管道压力"}, "answer": ["B"], "analysis": "兆欧表输出高压，专测高阻值绝缘电阻；万用表电阻档仅测低阻值及通断。", "tags": ["检测仪表", "兆欧表", "万用表"], "source": "安装教材精读笔记"}, {"id": "ch04-052", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "在电气设备和线路投运前，必须进行（ ）测试以确认绝缘性能合格。", "options": {"A": "接地电阻", "B": "绝缘电阻（用兆欧表）", "C": "管道压力", "D": "流量"}, "answer": ["B"], "analysis": "投运前用兆欧表进行绝缘电阻测试，确认设备、线路绝缘合格。", "tags": ["检测仪表", "兆欧表", "绝缘电阻"], "source": "安装教材精读笔记"}, {"id": "ch04-053", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "接地电阻测试仪在安装工程中的主要用途是（ ）。", "options": {"A": "测量管道压力", "B": "测试接地系统的接地电阻", "C": "测量绝缘电阻", "D": "测量交流电压"}, "answer": ["B"], "analysis": "根据教材第4章，接地电阻测试仪用于接地系统测试。", "tags": ["检测仪表", "接地电阻测试仪", "接地系统"], "source": "安装教材精读笔记"}, {"id": "ch04-054", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "下列检测仪表中，用于接地系统测试的是（ ）。", "options": {"A": "兆欧表", "B": "接地电阻测试仪", "C": "压力表", "D": "万用表"}, "answer": ["B"], "analysis": "接地电阻测试仪专用于测量接地装置的接地电阻。", "tags": ["检测仪表", "接地电阻测试仪"], "source": "安装教材精读笔记"}, {"id": "ch04-055", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "防雷接地装置、保护接地装置施工完成后，应测量其（ ）以检验合格。", "options": {"A": "绝缘电阻", "B": "接地电阻", "C": "管道压力", "D": "电压"}, "answer": ["B"], "analysis": "接地装置完工后应以接地电阻测试仪测量接地电阻，是否符合设计要求。", "tags": ["检测仪表", "接地电阻测试仪", "接地"], "source": "安装教材精读笔记"}, {"id": "ch04-056", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "接地电阻测试仪测量的物理量，其计量单位是（ ）。", "options": {"A": "兆欧(MΩ)", "B": "欧姆(Ω)", "C": "伏特(V)", "D": "安培(A)"}, "answer": ["B"], "analysis": "接地电阻数值较小，单位为欧姆(Ω)。", "tags": ["检测仪表", "接地电阻测试仪", "单位"], "source": "安装教材精读笔记"}, {"id": "ch04-058", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "建筑物防雷接地系统中，接地电阻值应使用（ ）进行测量。", "options": {"A": "兆欧表", "B": "接地电阻测试仪", "C": "万用表", "D": "压力表"}, "answer": ["B"], "analysis": "防雷接地电阻由接地电阻测试仪测量。", "tags": ["检测仪表", "接地电阻测试仪", "防雷接地"], "source": "安装教材精读笔记"}, {"id": "ch04-059", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "与兆欧表不同，接地电阻测试仪专门用于测量（ ）。", "options": {"A": "绝缘电阻", "B": "接地装置的接地电阻", "C": "管道压力", "D": "交流电流"}, "answer": ["B"], "analysis": "兆欧表测绝缘、接地电阻测试仪测接地装置电阻，二者测量对象不同。", "tags": ["检测仪表", "接地电阻测试仪", "兆欧表"], "source": "安装教材精读笔记"}, {"id": "ch04-060", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "在电气安装工程中，为保障人身设备安全，对接地系统应进行的测试项目是（ ）。", "options": {"A": "绝缘电阻测试", "B": "接地电阻测试", "C": "管道压力测试", "D": "焊接质量"}, "answer": ["B"], "analysis": "接地系统需进行接地电阻测试，确保接地可靠、保障安全。", "tags": ["检测仪表", "接地电阻测试仪", "接地"], "source": "安装教材精读笔记"}, {"id": "ch04-061", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "下列检测仪表与其测量对象的对应关系中，正确的是（ ）。", "options": {"A": "兆欧表—接地电阻", "B": "接地电阻测试仪—接地系统", "C": "压力表—绝缘电阻", "D": "万用表—管道压力"}, "answer": ["B"], "analysis": "接地电阻测试仪测接地系统；兆欧表测绝缘、压力表测压力、万用表测电气参数。", "tags": ["检测仪表", "对应关系"], "source": "安装教材精读笔记"}, {"id": "ch04-062", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "根据2018版广东安装定额，施工机具费包括施工机械使用费和（ ）。", "options": {"A": "人工费", "B": "施工仪器仪表使用费", "C": "材料费", "D": "企业管理费"}, "answer": ["B"], "analysis": "2018定额规定，施工机具费=施工机械使用费+施工仪器仪表使用费。", "tags": ["施工机具费", "2018定额"], "source": "2018定额详细解读"}, {"id": "ch04-063", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "根据2018版广东安装定额，施工仪器仪表使用费不包括（ ）。", "options": {"A": "折旧费", "B": "维护费", "C": "校验费", "D": "燃料动力费"}, "answer": ["D"], "analysis": "仪器仪表使用费含折旧、维护、校验、动力费；燃料动力费属于施工机械使用费。", "tags": ["施工机具费", "仪器仪表使用费", "2018定额"], "source": "2018定额详细解读"}, {"id": "ch04-064", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "GB/T 50856-2024《通用安装工程工程量计算标准》的性质是（ ）。", "options": {"A": "强制性国家标准", "B": "推荐性标准", "C": "设计规范", "D": "施工验收规范"}, "answer": ["B"], "analysis": "2024版由强制性标准调整为推荐性标准（编号GB/T），合同中约定采用后具约束力。", "tags": ["2024清单", "标准性质"], "source": "GB/T50856-2024详细解读"}, {"id": "ch04-065", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "GB/T 50856-2024《通用安装工程工程量计算标准》的实施日期是（ ）。", "options": {"A": "2019年3月1日", "B": "2025年9月1日", "C": "2013年", "D": "2024年11月12日"}, "answer": ["B"], "analysis": "该标准2024年11月12日发布，2025年9月1日实施，同时废止GB 50856-2013。", "tags": ["2024清单", "实施日期"], "source": "GB/T50856-2024详细解读"}, {"id": "ch04-066", "date": "2026-07-06", "chapter": "ch04", "type": "single", "stem": "在广东二级造价师安装专业考试中，关于施工机械与检测仪表，下列说法正确的是（ ）。", "options": {"A": "塔吊、汽车吊属于起重机械，用于设备吊装", "B": "兆欧表用于测量管道压力", "C": "接地电阻测试仪用于测量绝缘电阻", "D": "套丝机用于管道焊接"}, "answer": ["A"], "analysis": "起重机械（塔吊、汽车吊）用途为设备吊装；兆欧表测绝缘、接地电阻测试仪测接地、套丝机加工螺纹。", "tags": ["综合", "施工机械", "检测仪表"], "source": "历年真题精华版"}, {"id": "ch04-067", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "下列属于起重机械的有（ ）。", "options": {"A": "塔吊", "B": "汽车吊", "C": "套丝机", "D": "电焊机", "E": "龙门吊"}, "answer": ["A", "B", "E"], "analysis": "塔吊、汽车吊、龙门吊均为起重机械；套丝机属管道机械，电焊机属焊接设备。", "tags": ["起重机械", "分类"], "source": "安装教材精读笔记"}, {"id": "ch04-068", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "关于塔吊与汽车吊的区别，下列说法正确的有（ ）。", "options": {"A": "塔吊一般固定设置、作业半径大", "B": "汽车吊机动灵活、可随车转移", "C": "塔吊适合长期大范围吊装", "D": "汽车吊适合分散作业点吊装", "E": "两者都属于焊接设备"}, "answer": ["A", "B", "C", "D"], "analysis": "塔吊固定、作业半径大、适合长期吊装；汽车吊机动灵活、适合分散吊装；二者均属起重机械而非焊接设备。", "tags": ["起重机械", "塔吊", "汽车吊"], "source": "安装教材精读笔记"}, {"id": "ch04-069", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "起重机械（塔吊、汽车吊）在安装工程中的主要用途包括（ ）。", "options": {"A": "设备吊装", "B": "构件吊装", "C": "管道焊接", "D": "材料垂直运输", "E": "绝缘电阻测试"}, "answer": ["A", "B", "D"], "analysis": "起重机械用于设备、构件吊装及材料垂直运输；管道焊接属焊接设备，绝缘测试属检测仪表。", "tags": ["起重机械", "设备吊装"], "source": "安装教材精读笔记"}, {"id": "ch04-070", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "下列做法符合汽车式起重机安全作业要求的有（ ）。", "options": {"A": "作业前打支腿", "B": "支腿下铺垫板", "C": "可带载长途行驶", "D": "作业前检查地基承载力", "E": "超载吊装"}, "answer": ["A", "B", "D"], "analysis": "汽车吊作业前应打支腿、垫板并查地基承载力；不得带载行驶、不得超载。", "tags": ["起重机械", "汽车吊", "安全作业"], "source": "安装教材精读笔记"}, {"id": "ch04-071", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "塔式起重机适用于下列哪些情形（ ）。", "options": {"A": "高层建筑主体施工吊装", "B": "长期固定的建筑工地", "C": "大范围材料吊装", "D": "频繁转场的零散作业", "E": "设备就位"}, "answer": ["A", "B", "C"], "analysis": "塔吊适合固定工地、长期、大范围吊装；频繁转场零散作业宜用汽车吊。", "tags": ["起重机械", "塔吊"], "source": "安装教材精读笔记"}, {"id": "ch04-072", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "下列属于焊接设备的有（ ）。", "options": {"A": "电焊机", "B": "氩弧焊机", "C": "套丝机", "D": "弯管机", "E": "汽车吊"}, "answer": ["A", "B"], "analysis": "电焊机、氩弧焊机为焊接设备；套丝机、弯管机为管道机械，汽车吊为起重机械。", "tags": ["焊接设备", "分类"], "source": "安装教材精读笔记"}, {"id": "ch04-073", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "关于氩弧焊机，下列说法正确的有（ ）。", "options": {"A": "采用氩气保护", "B": "焊接质量高、变形小", "C": "适用于不锈钢焊接", "D": "适用于有色金属管道焊接", "E": "利用电阻热熔化金属"}, "answer": ["A", "B", "C", "D"], "analysis": "氩弧焊以氩气保护、质量高变形小，适合不锈钢及有色金属；其热源为电弧而非电阻热。", "tags": ["焊接设备", "氩弧焊机"], "source": "安装教材精读笔记"}, {"id": "ch04-074", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "电焊机（手工电弧焊）的特点包括（ ）。", "options": {"A": "设备简单", "B": "成本较低", "C": "适合普通碳钢管道焊接", "D": "需氩气保护", "E": "焊接变形比氩弧焊大"}, "answer": ["A", "B", "C", "E"], "analysis": "手工电弧焊设备简单、成本低、适合普通碳钢；不需氩气保护；相对氩弧焊变形较大。", "tags": ["焊接设备", "电焊机"], "source": "安装教材精读笔记"}, {"id": "ch04-075", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "焊接设备在安装工程中的用途包括（ ）。", "options": {"A": "管道焊接", "B": "钢结构焊接", "C": "设备吊装", "D": "管螺纹加工", "E": "设备与管道连接处的焊接"}, "answer": ["A", "B", "E"], "analysis": "焊接设备用于管道、钢结构及设备接口焊接；吊装属起重机械、套丝属管道机械。", "tags": ["焊接设备", "管道焊接"], "source": "安装教材精读笔记"}, {"id": "ch04-076", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "下列焊接设备中，适用于管道焊接的有（ ）。", "options": {"A": "电焊机", "B": "氩弧焊机", "C": "塔吊", "D": "套丝机", "E": "弯管机"}, "answer": ["A", "B"], "analysis": "电焊机、氩弧焊机均可用于管道焊接；其余不属焊接设备。", "tags": ["焊接设备", "管道焊接"], "source": "安装教材精读笔记"}, {"id": "ch04-077", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "关于电焊机与氩弧焊机的比较，正确的有（ ）。", "options": {"A": "电焊机设备简单、成本低", "B": "氩弧焊机焊接质量高", "C": "氩弧焊机需用氩气保护", "D": "电焊机仅用于木材", "E": "氩弧焊机适用于有色金属"}, "answer": ["A", "B", "C", "E"], "analysis": "电焊机简单低成本、氩弧焊质量高需氩气保护且适合有色金属；电焊机不用于木材。", "tags": ["焊接设备", "电焊机", "氩弧焊机"], "source": "安装教材精读笔记"}, {"id": "ch04-078", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "下列属于管道机械的有（ ）。", "options": {"A": "套丝机", "B": "弯管机", "C": "塔吊", "D": "电焊机", "E": "施工电梯"}, "answer": ["A", "B"], "analysis": "套丝机、弯管机属于管道机械；其余分别为起重机械、焊接设备。", "tags": ["管道机械", "分类"], "source": "安装教材精读笔记"}, {"id": "ch04-079", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "套丝机的主要功能包括（ ）。", "options": {"A": "加工管外螺纹", "B": "切管", "C": "管道弯曲", "D": "倒角", "E": "测量绝缘电阻"}, "answer": ["A", "B", "D"], "analysis": "套丝机可切管、倒角并加工管外螺纹；弯曲由弯管机完成，绝缘由兆欧表测。", "tags": ["管道机械", "套丝机"], "source": "安装教材精读笔记"}, {"id": "ch04-080", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "弯管机在管道安装中的作用包括（ ）。", "options": {"A": "将直管弯曲成所需角度", "B": "改变管道走向", "C": "加工管螺纹", "D": "适应管路绕障", "E": "用于焊接接口"}, "answer": ["A", "B", "D"], "analysis": "弯管机用于弯曲管材、改变走向、绕障；螺纹由套丝机加工，弯管不直接用于焊接。", "tags": ["管道机械", "弯管机"], "source": "安装教材精读笔记"}, {"id": "ch04-081", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "管道机械（套丝机、弯管机）的典型用途有（ ）。", "options": {"A": "管螺纹加工", "B": "管道弯曲", "C": "设备吊装", "D": "管道加工", "E": "绝缘电阻测试"}, "answer": ["A", "B", "D"], "analysis": "管道机械用于管螺纹加工、弯曲等管道加工作业。", "tags": ["管道机械", "管道加工"], "source": "安装教材精读笔记"}, {"id": "ch04-082", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "关于套丝机，下列说法正确的有（ ）。", "options": {"A": "用于加工管外螺纹", "B": "用于管道螺纹连接前的管端处理", "C": "属于管道机械", "D": "属于起重机械", "E": "可用于焊接"}, "answer": ["A", "B", "C"], "analysis": "套丝机属管道机械，加工管外螺纹供螺纹连接使用，不做吊装与焊接。", "tags": ["管道机械", "套丝机"], "source": "安装教材精读笔记"}, {"id": "ch04-083", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "关于压力表，下列说法正确的有（ ）。", "options": {"A": "用于测量管道压力", "B": "用于测量设备内介质压力", "C": "属于检测仪表", "D": "用于测量绝缘电阻", "E": "属于施工机械"}, "answer": ["A", "B", "C"], "analysis": "压力表属检测仪表，测管道及设备内介质压力；不测绝缘、不属施工机械。", "tags": ["检测仪表", "压力表"], "source": "安装教材精读笔记"}, {"id": "ch04-084", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "下列检测仪表中，用于测量压力的有（ ）。", "options": {"A": "压力表", "B": "真空表", "C": "兆欧表", "D": "万用表", "E": "接地电阻测试仪"}, "answer": ["A", "B"], "analysis": "压力表、真空表均属压力类测量仪表；其余分别测绝缘、电气参数、接地。", "tags": ["检测仪表", "压力表"], "source": "安装教材精读笔记"}, {"id": "ch04-085", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "压力表适用于下列哪些系统的压力监测（ ）。", "options": {"A": "给水管道", "B": "供热管道", "C": "工业工艺管道", "D": "接地系统", "E": "绝缘电阻"}, "answer": ["A", "B", "C"], "analysis": "压力表用于给水、供热、工业等管道系统的介质压力监测；不用于接地与绝缘。", "tags": ["检测仪表", "压力表"], "source": "安装教材精读笔记"}, {"id": "ch04-086", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "下列场合中，需要设置压力表的有（ ）。", "options": {"A": "水泵出口管道", "B": "锅炉本体", "C": "压力容器", "D": "接地电阻测试点", "E": "电缆绝缘层"}, "answer": ["A", "B", "C"], "analysis": "水泵出口、锅炉、压力容器需设压力表监测压力；接地与电缆绝缘分别用其他仪表。", "tags": ["检测仪表", "压力表"], "source": "安装教材精读笔记"}, {"id": "ch04-087", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "检测仪表中，与“压力测量”相关的包括（ ）。", "options": {"A": "压力表", "B": "压力变送器", "C": "兆欧表", "D": "接地电阻测试仪", "E": "弯管机"}, "answer": ["A", "B"], "analysis": "压力表、压力变送器均用于压力测量；其余不属压力测量。", "tags": ["检测仪表", "压力表"], "source": "安装教材精读笔记"}, {"id": "ch04-088", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "关于压力表的用途，正确的有（ ）。", "options": {"A": "测量管道压力", "B": "测量设备内介质压力", "C": "用于管道系统试压观测", "D": "测量接地电阻", "E": "属于焊接设备"}, "answer": ["A", "B", "C"], "analysis": "压力表测管道与设备压力、用于试压观测；不测接地、不属焊接设备。", "tags": ["检测仪表", "压力表"], "source": "安装教材精读笔记"}, {"id": "ch04-089", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "万用表可以测量的电气参数包括（ ）。", "options": {"A": "电压", "B": "电流", "C": "电阻", "D": "管道压力", "E": "高值绝缘电阻"}, "answer": ["A", "B", "C"], "analysis": "万用表可测电压、电流、电阻及通断；管道压力由压力表测，高值绝缘由兆欧表测。", "tags": ["检测仪表", "万用表"], "source": "安装教材精读笔记"}, {"id": "ch04-090", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "关于万用表，下列说法正确的有（ ）。", "options": {"A": "属于电气测量仪表", "B": "可测电压、电流、电阻", "C": "可用于线路通断测试", "D": "用于测量管道压力", "E": "用于接地系统测试"}, "answer": ["A", "B", "C"], "analysis": "万用表是通用电气测量仪表，可测电压电流电阻及通断；不测压力、不测接地。", "tags": ["检测仪表", "万用表"], "source": "安装教材精读笔记"}, {"id": "ch04-091", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "下列检测仪表中，属于电气类测量仪表的有（ ）。", "options": {"A": "万用表", "B": "兆欧表", "C": "接地电阻测试仪", "D": "压力表", "E": "弯管机"}, "answer": ["A", "B", "C"], "analysis": "万用表、兆欧表、接地电阻测试仪均属电气类测量仪表；压力表属压力类、弯管机属机械。", "tags": ["检测仪表", "分类"], "source": "安装教材精读笔记"}, {"id": "ch04-092", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "在电气安装调试中，万用表可用于（ ）。", "options": {"A": "测线路电压", "B": "测线路电流", "C": "判断线路通断", "D": "测接地电阻", "E": "测管道压力"}, "answer": ["A", "B", "C"], "analysis": "万用表可测电压、电流、判断通断；接地用接地电阻测试仪、压力用压力表。", "tags": ["检测仪表", "万用表"], "source": "安装教材精读笔记"}, {"id": "ch04-093", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "下列关于万用表用途的说法，正确的有（ ）。", "options": {"A": "测量交直流电压", "B": "测量交直流电流", "C": "测量电阻", "D": "测试电路通断", "E": "测量接地电阻"}, "answer": ["A", "B", "C", "D"], "analysis": "万用表可测交直流电压、电流、电阻并测通断；接地电阻由接地电阻测试仪测量。", "tags": ["检测仪表", "万用表"], "source": "安装教材精读笔记"}, {"id": "ch04-094", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "下列场合适合使用万用表的有（ ）。", "options": {"A": "检查插座是否带电", "B": "测量电动机绕组电阻", "C": "测量线路电流", "D": "测量管道压力", "E": "测量接地极电阻"}, "answer": ["A", "B", "C"], "analysis": "万用表可查带电、测绕组电阻、测线路电流；压力与接地分别用压力表、接地电阻测试仪。", "tags": ["检测仪表", "万用表"], "source": "安装教材精读笔记"}, {"id": "ch04-095", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "关于兆欧表，下列说法正确的有（ ）。", "options": {"A": "用于测量绝缘电阻", "B": "又称摇表", "C": "测量单位为兆欧(MΩ)", "D": "用于测量接地电阻", "E": "属于检测仪表"}, "answer": ["A", "B", "C", "E"], "analysis": "兆欧表（摇表）属检测仪表，测绝缘电阻、单位兆欧；接地电阻由接地电阻测试仪测。", "tags": ["检测仪表", "兆欧表", "绝缘电阻"], "source": "安装教材精读笔记"}, {"id": "ch04-096", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "下列检测仪表中，用于绝缘电阻测量的有（ ）。", "options": {"A": "兆欧表", "B": "摇表", "C": "接地电阻测试仪", "D": "万用表", "E": "压力表"}, "answer": ["A", "B"], "analysis": "兆欧表即摇表，专测绝缘电阻；其余不用于绝缘测量。", "tags": ["检测仪表", "兆欧表"], "source": "安装教材精读笔记"}, {"id": "ch04-097", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "兆欧表适用于下列哪些项目的测试（ ）。", "options": {"A": "电缆绝缘电阻", "B": "电动机绕组绝缘", "C": "线路相间绝缘", "D": "接地电阻", "E": "管道压力"}, "answer": ["A", "B", "C"], "analysis": "兆欧表用于电缆、电机绕组、线路相间等绝缘电阻测试；不测接地与压力。", "tags": ["检测仪表", "兆欧表", "绝缘电阻"], "source": "安装教材精读笔记"}, {"id": "ch04-098", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "关于兆欧表与万用表电阻档的区别，正确的有（ ）。", "options": {"A": "兆欧表用于测量高阻值绝缘电阻", "B": "万用表电阻档用于测量低阻值及通断", "C": "兆欧表的计量单位是兆欧(MΩ)", "D": "兆欧表用于测量接地电阻", "E": "万用表用于测量管道压力"}, "answer": ["A", "B", "C"], "analysis": "兆欧表测高阻绝缘、单位兆欧；万用表电阻档测低阻及通断；二者均不测接地与压力。", "tags": ["检测仪表", "兆欧表", "万用表"], "source": "安装教材精读笔记"}, {"id": "ch04-099", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "下列电气测试项目中，需使用兆欧表的有（ ）。", "options": {"A": "电缆对地绝缘", "B": "电机绕组绝缘", "C": "配电柜相间绝缘", "D": "接地电阻", "E": "管道试压"}, "answer": ["A", "B", "C"], "analysis": "绝缘电阻类测试（电缆、电机、相间）用兆欧表；接地与试压用其他仪表。", "tags": ["检测仪表", "兆欧表"], "source": "安装教材精读笔记"}, {"id": "ch04-100", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "关于兆欧表使用，下列说法正确的有（ ）。", "options": {"A": "测量前被测设备应断电", "B": "测量前被测设备应放电", "C": "用于测量绝缘电阻", "D": "可用于测量接地电阻", "E": "属于焊接设备"}, "answer": ["A", "B", "C"], "analysis": "兆欧表测绝缘，测量前须断电并放电；不测接地、不属焊接设备。", "tags": ["检测仪表", "兆欧表", "安全"], "source": "安装教材精读笔记"}, {"id": "ch04-101", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "下列仪表中，属于绝缘电阻测试仪表的有（ ）。", "options": {"A": "兆欧表", "B": "摇表", "C": "接地电阻测试仪", "D": "万用表", "E": "压力表"}, "answer": ["A", "B"], "analysis": "兆欧表（摇表）是绝缘电阻测试仪表；其余不是。", "tags": ["检测仪表", "兆欧表"], "source": "安装教材精读笔记"}, {"id": "ch04-102", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "关于接地电阻测试仪，下列说法正确的有（ ）。", "options": {"A": "用于接地系统测试", "B": "测量接地电阻", "C": "计量单位为欧姆(Ω)", "D": "用于测量绝缘电阻", "E": "属于检测仪表"}, "answer": ["A", "B", "C", "E"], "analysis": "接地电阻测试仪属检测仪表，测接地系统电阻、单位欧姆；绝缘由兆欧表测。", "tags": ["检测仪表", "接地电阻测试仪", "接地系统"], "source": "安装教材精读笔记"}, {"id": "ch04-103", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "下列检测仪表中，用于接地系统测试的有（ ）。", "options": {"A": "接地电阻测试仪", "B": "兆欧表", "C": "接地摇表", "D": "压力表", "E": "万用表"}, "answer": ["A", "C"], "analysis": "接地电阻测试仪（接地摇表）用于接地系统测试；兆欧表测绝缘，不测接地。", "tags": ["检测仪表", "接地电阻测试仪", "接地"], "source": "安装教材精读笔记"}, {"id": "ch04-104", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "接地电阻测试仪适用于下列哪些对象（ ）。", "options": {"A": "防雷接地装置", "B": "保护接地装置", "C": "重复接地", "D": "绝缘电阻", "E": "管道压力"}, "answer": ["A", "B", "C"], "analysis": "接地电阻测试仪用于防雷、保护、重复等各类接地装置的电阻测试；不测绝缘与压力。", "tags": ["检测仪表", "接地电阻测试仪", "接地"], "source": "安装教材精读笔记"}, {"id": "ch04-105", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "关于接地电阻测试仪与兆欧表的区别，正确的有（ ）。", "options": {"A": "接地电阻测试仪测接地系统电阻", "B": "兆欧表测绝缘电阻", "C": "两者计量单位相同", "D": "接地电阻测试仪单位欧姆", "E": "兆欧表单位兆欧"}, "answer": ["A", "B", "D", "E"], "analysis": "接地电阻测试仪测接地（单位Ω），兆欧表测绝缘（单位MΩ），二者测量对象与单位均不同。", "tags": ["检测仪表", "接地电阻测试仪", "兆欧表"], "source": "安装教材精读笔记"}, {"id": "ch04-106", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "下列电气安全测试中，需使用接地电阻测试仪的有（ ）。", "options": {"A": "防雷接地电阻", "B": "保护接地电阻", "C": "设备接地连续性电阻", "D": "绝缘电阻", "E": "管道压力"}, "answer": ["A", "B", "C"], "analysis": "各类接地电阻（防雷、保护、连续性）用接地电阻测试仪；绝缘与压力用其他仪表。", "tags": ["检测仪表", "接地电阻测试仪", "接地"], "source": "安装教材精读笔记"}, {"id": "ch04-107", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "关于接地系统测试，下列说法正确的有（ ）。", "options": {"A": "使用接地电阻测试仪", "B": "测量单位为欧姆(Ω)", "C": "用于检验防雷接地", "D": "用于检验保护接地", "E": "使用兆欧表"}, "answer": ["A", "B", "C", "D"], "analysis": "接地系统测试用接地电阻测试仪、单位欧姆，用于检验防雷与保护接地；兆欧表测绝缘。", "tags": ["检测仪表", "接地电阻测试仪", "接地"], "source": "安装教材精读笔记"}, {"id": "ch04-108", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "下列仪表中，可用于接地系统测试的有（ ）。", "options": {"A": "接地电阻测试仪", "B": "接地摇表", "C": "兆欧表", "D": "万用表", "E": "压力表"}, "answer": ["A", "B"], "analysis": "接地电阻测试仪（接地摇表）可测接地系统；其余不用于接地测试。", "tags": ["检测仪表", "接地电阻测试仪", "接地"], "source": "安装教材精读笔记"}, {"id": "ch04-109", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "根据2018版广东安装定额，施工机械使用费包括（ ）。", "options": {"A": "折旧费", "B": "检修费", "C": "维护费", "D": "机上人工费", "E": "校验费"}, "answer": ["A", "B", "C", "D"], "analysis": "施工机械使用费含折旧、检修、维护、安拆、机上人工、燃料动力等；校验费属仪器仪表使用费。", "tags": ["施工机具费", "施工机械使用费", "2018定额"], "source": "2018定额详细解读"}, {"id": "ch04-110", "date": "2026-07-06", "chapter": "ch04", "type": "multiple", "stem": "施工机具费中的施工仪器仪表使用费包括（ ）。", "options": {"A": "折旧费", "B": "维护费", "C": "校验费", "D": "动力费", "E": "燃料动力费"}, "answer": ["A", "B", "C", "D"], "analysis": "仪器仪表使用费含折旧、维护、校验、动力费；燃料动力费属施工机械使用费。", "tags": ["施工机具费", "仪器仪表使用费", "2018定额"], "source": "2018定额详细解读"}, {"id": "ch05-001", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "根据《建设工程计量与计价实务（安装工程）》教材，施工组织设计的核心内容一般不包括下列哪一项？", "options": {"A": "工程概况", "B": "施工部署", "C": "施工方案", "D": "工程竣工验收报告"}, "answer": ["D"], "analysis": "教材明确施工组织设计七项内容为：工程概况、施工部署、施工方案、进度计划、资源计划、施工平面布置、保证措施。工程竣工验收报告不属于施工组织设计内容。", "tags": ["施工组织设计内容组成"], "source": "安装教材精读笔记"}, {"id": "ch05-002", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "下列内容中，属于工程概况所说明范围的有（ ）。", "options": {"A": "工程建设基本情况", "B": "建设地点特征", "C": "施工条件", "D": "企业财务计划", "E": "竣工结算金额"}, "answer": ["A", "B", "C"], "analysis": "工程概况是对项目基本情况的说明，一般包括工程建设概况、建筑结构（施工）概况、建设地点特征、施工条件等。企业财务计划与竣工结算金额不属工程概况。", "tags": ["工程概况"], "source": "安装教材精读笔记"}, {"id": "ch05-003", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工部署是对工程的总体安排，其内容一般包括（ ）。", "options": {"A": "施工任务划分", "B": "施工顺序确定", "C": "流水施工组织", "D": "竣工决算", "E": "材料市场价格"}, "answer": ["A", "B", "C"], "analysis": "施工部署是对整个工程的总体安排，包括施工任务划分、施工顺序确定、流水施工组织、分包安排等。竣工决算与材料价格不属施工部署。", "tags": ["施工部署"], "source": "安装教材精读笔记"}, {"id": "ch05-004", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工方案作为对各分部分项工程确定施工方法的内容，应明确（ ）。", "options": {"A": "具体施工方法", "B": "施工工艺", "C": "施工机械选用", "D": "竣工图绘制", "E": "企业利润目标"}, "answer": ["A", "B", "C"], "analysis": "施工方案是对各分部分项工程确定具体施工方法、施工工艺并选用施工机械的技术性文件。竣工图绘制与企业利润目标不属施工方案内容。", "tags": ["施工方案"], "source": "安装教材精读笔记"}, {"id": "ch05-005", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工组织设计的进度计划可采用下列哪些形式表达？", "options": {"A": "横道图（甘特图）", "B": "网络图", "C": "材料明细表", "D": "工程量清单", "E": "竣工图"}, "answer": ["A", "B"], "analysis": "进度计划常用横道图（甘特图）或网络图（如双代号网络图）表达。材料明细表、工程量清单、竣工图均不用于表达进度计划。", "tags": ["进度计划"], "source": "安装教材精读笔记"}, {"id": "ch05-006", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工组织设计中，资源计划不包括下列哪一项？", "options": {"A": "劳动力计划", "B": "材料计划", "C": "机械设备计划", "D": "竣工决算计划"}, "answer": ["D"], "analysis": "资源计划包括劳动力、材料、机械设备的需要量及供应计划。竣工决算属于竣工阶段造价文件，不属于施工资源计划。", "tags": ["资源计划"], "source": "安装教材精读笔记"}, {"id": "ch05-007", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工平面布置是对施工现场的空间规划，其布置内容一般包括（ ）。", "options": {"A": "临时设施", "B": "材料堆场", "C": "场内运输道路", "D": "临时水电管线", "E": "竣工结算金额"}, "answer": ["A", "B", "C", "D"], "analysis": "施工平面布置解决临时设施、材料堆场、加工厂、运输道路、临时水电等的平面规划。竣工结算金额不属平面布置内容。", "tags": ["施工平面布置"], "source": "安装教材精读笔记"}, {"id": "ch05-008", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工组织设计中，保证措施通常不包括（ ）。", "options": {"A": "质量保证措施", "B": "安全保证措施", "C": "文明施工措施", "D": "企业利润分配方案"}, "answer": ["D"], "analysis": "保证措施一般包括质量、安全、文明施工、环境保护、进度、成本等保证措施。企业利润分配方案属于企业经营管理，不属于施工保证措施。", "tags": ["保证措施"], "source": "安装教材精读笔记"}, {"id": "ch05-009", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工方案编制的首要要点是（ ）。", "options": {"A": "选择施工机械", "B": "确定施工顺序", "C": "安排施工人员", "D": "编制预算"}, "answer": ["B"], "analysis": "施工方案编制四要点为：确定施工顺序、选择施工方法、选择施工机械、安排施工人员。确定施工顺序是首要环节，决定工序先后。", "tags": ["施工方案编制要点"], "source": "安装教材精读笔记"}, {"id": "ch05-010", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工方案编制中，确定'采用什么工艺完成施工'属于（ ）。", "options": {"A": "确定施工顺序", "B": "选择施工方法", "C": "选择施工机械", "D": "安排施工人员"}, "answer": ["B"], "analysis": "选择施工方法是指确定各分项工程采用的具体施工工艺与技术措施。", "tags": ["施工方案编制要点"], "source": "安装教材精读笔记"}, {"id": "ch05-011", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工方案编制中，'安排施工人员'主要是指（ ）。", "options": {"A": "确定施工机械型号", "B": "确定各工序劳动力配置与工种安排", "C": "编制材料采购计划", "D": "绘制平面布置图"}, "answer": ["B"], "analysis": "安排施工人员是指根据施工进度和工程量，合理安排各工种劳动力数量与进场时间。", "tags": ["施工方案编制要点"], "source": "安装教材精读笔记"}, {"id": "ch05-012", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工方案编制四要点中，'选择施工机械'的目的是（ ）。", "options": {"A": "确定工序先后顺序", "B": "满足施工工艺需要并提高工效", "C": "编写竣工资料", "D": "编制招标控制价"}, "answer": ["B"], "analysis": "选择施工机械是根据施工方法和工程量，选用合适的机械设备，以满足工艺需要、提高施工效率。", "tags": ["施工方案编制要点"], "source": "安装教材精读笔记"}, {"id": "ch05-013", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "下列资料中，属于安装工程预算编制依据且与施工组织设计直接相关的是（ ）。", "options": {"A": "施工组织设计", "B": "企业税务登记证", "C": "银行对账单", "D": "员工花名册"}, "answer": ["A"], "analysis": "历年真题明确安装工程预算编制依据包括：施工图纸、施工组织设计、预算定额、市场价格信息等。施工组织设计是预算编制的重要依据之一。", "tags": ["施工组织设计与造价"], "source": "历年真题精华版"}, {"id": "ch05-014", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工组织设计是（ ）阶段的重要技术经济文件。", "options": {"A": "项目建议书", "B": "施工", "C": "竣工决算", "D": "可行性研究"}, "answer": ["B"], "analysis": "施工组织设计是指导拟建工程从施工准备到竣工验收全过程的技术、经济和组织的综合性文件，属于施工阶段。", "tags": ["施工组织设计概述"], "source": "安装教材精读笔记"}, {"id": "ch05-015", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "安装工程预算编制依据中，下列哪项不是教材列举的内容？", "options": {"A": "施工图纸", "B": "预算定额", "C": "市场价格信息", "D": "工程竣工验收备案表"}, "answer": ["D"], "analysis": "预算编制依据包括施工图纸、施工组织设计、预算定额、市场价格信息、费用定额等。竣工验收备案表是竣工后文件，不是预算编制依据。", "tags": ["施工组织设计与造价"], "source": "历年真题精华版"}, {"id": "ch05-016", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "横道图（甘特图）能够直观表达进度计划中的（ ）。", "options": {"A": "各工作的开始时间", "B": "各工作的完成时间", "C": "工作间的逻辑关系", "D": "材料单价"}, "answer": ["A", "B"], "analysis": "横道图以时间坐标为横轴、工作为纵轴，直观表达各工作的开始与完成时间；但难以明确表达工作间逻辑关系（这是其不足）。材料单价与横道图无关。", "tags": ["进度计划"], "source": "安装教材精读笔记"}, {"id": "ch05-017", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "网络图（如双代号网络图）能够明确表示的内容包括（ ）。", "options": {"A": "工作之间的逻辑关系", "B": "工作的先后顺序", "C": "关键线路", "D": "材料价格", "E": "质量标准"}, "answer": ["A", "B", "C"], "analysis": "网络图用箭线和节点表示工作及其逻辑关系，能清晰反映工序先后、依赖关系，并可找出关键线路。材料价格与质量标准不由其表示。", "tags": ["进度计划"], "source": "安装教材精读笔记"}, {"id": "ch05-018", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工平面布置图主要解决施工现场（ ）的空间布置问题。", "options": {"A": "临时设施", "B": "材料堆场", "C": "加工厂", "D": "场内运输道路", "E": "工程质量标准"}, "answer": ["A", "B", "C", "D"], "analysis": "施工平面布置解决施工期间临时设施、材料堆场、加工厂、运输道路、临时水电等的空间位置关系。工程质量标准不属平面布置内容。", "tags": ["施工平面布置"], "source": "安装教材精读笔记"}, {"id": "ch05-019", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "安装工程具有'隐蔽工程多、预埋预留工作量大'的特点，这最直接影响施工组织设计中的（ ）。", "options": {"A": "工程概况中对施工条件的描述", "B": "竣工决算", "C": "招投标文件", "D": "设计概算"}, "answer": ["A"], "analysis": "安装工程配套性强、隐蔽工程多，应在工程概况和施工部署中充分考虑与土建、装修的配合及预埋预留安排。", "tags": ["工程概况", "安装特点"], "source": "安装教材精读笔记"}, {"id": "ch05-020", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工部署的总体安排中，通常需要进行的工作包括（ ）。", "options": {"A": "确定施工任务划分", "B": "确定施工顺序", "C": "组织流水施工", "D": "编制竣工图", "E": "评定质量等级"}, "answer": ["A", "B", "C"], "analysis": "施工部署的总体安排包括施工任务划分、施工顺序确定、流水施工组织、分包安排等。编制竣工图与评定质量等级不属施工部署。", "tags": ["施工部署"], "source": "安装教材精读笔记"}, {"id": "ch05-021", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "根据教材，施工组织设计一般应包括以下哪些内容？", "options": {"A": "工程概况", "B": "施工进度计划", "C": "施工平面布置", "D": "企业年度财务计划", "E": "保证措施"}, "answer": ["A", "B", "C", "E"], "analysis": "施工组织设计七项内容：工程概况、施工部署、施工方案、进度计划、资源计划、施工平面布置、保证措施。企业年度财务计划不属于施工组织设计内容。", "tags": ["施工组织设计内容组成"], "source": "安装教材精读笔记"}, {"id": "ch05-022", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "下列属于施工组织设计七项内容的有（ ）。", "options": {"A": "施工部署", "B": "施工方案", "C": "资源计划", "D": "工程监理规划", "E": "进度计划"}, "answer": ["A", "B", "C", "E"], "analysis": "七项内容包括工程概况、施工部署、施工方案、进度计划、资源计划、施工平面布置、保证措施。工程监理规划由监理单位编制，不属于施工单位施工组织设计。", "tags": ["施工组织设计内容组成"], "source": "安装教材精读笔记"}, {"id": "ch05-023", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工方案编制的四项要点包括（ ）。", "options": {"A": "确定施工顺序", "B": "选择施工方法", "C": "选择施工机械", "D": "安排施工人员", "E": "编制竣工结算"}, "answer": ["A", "B", "C", "D"], "analysis": "施工方案编制四要点：确定施工顺序、选择施工方法、选择施工机械、安排施工人员。编制竣工结算不属于施工方案编制要点。", "tags": ["施工方案编制要点"], "source": "安装教材精读笔记"}, {"id": "ch05-024", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "资源计划通常包括下列哪些计划？", "options": {"A": "劳动力需要量计划", "B": "材料需要量计划", "C": "施工机械设备需要量计划", "D": "资金需求计划", "E": "竣工审计计划"}, "answer": ["A", "B", "C", "D"], "analysis": "资源计划是对施工所需劳动力、材料、机械设备及资金等作出的配套供应计划。竣工审计计划不属于施工资源计划。", "tags": ["资源计划"], "source": "安装教材精读笔记"}, {"id": "ch05-025", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工平面布置中一般应布置的内容有（ ）。", "options": {"A": "临时设施", "B": "材料堆场", "C": "场内运输道路", "D": "临时水电管线", "E": "永久建筑基础桩位"}, "answer": ["A", "B", "C", "D"], "analysis": "施工平面布置解决临时设施、材料堆场、加工厂、运输道路、临时水电等布置。永久建筑基础桩位属设计内容，不属于施工平面布置布置对象。", "tags": ["施工平面布置"], "source": "安装教材精读笔记"}, {"id": "ch05-026", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工组织设计的保证措施通常包括（ ）。", "options": {"A": "质量保证措施", "B": "安全保证措施", "C": "文明施工与环境保护措施", "D": "进度保证措施", "E": "企业上市计划"}, "answer": ["A", "B", "C", "D"], "analysis": "保证措施一般包括质量、安全、文明施工与环境保护、进度、成本等方面的保证措施。企业上市计划与施工保证无关。", "tags": ["保证措施"], "source": "安装教材精读笔记"}, {"id": "ch05-027", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "安装工程预算编制依据包括（ ）。", "options": {"A": "施工图纸", "B": "施工组织设计", "C": "预算定额", "D": "市场价格信息", "E": "工程承包合同"}, "answer": ["A", "B", "C", "D"], "analysis": "历年真题明确安装工程预算编制依据包括：施工图纸、施工组织设计、预算定额、市场价格信息、费用定额等（真题答案为ABCD）。", "tags": ["施工组织设计与造价"], "source": "历年真题精华版"}, {"id": "ch05-028", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "工程概况一般应说明的内容包括（ ）。", "options": {"A": "工程建设概况", "B": "工程施工概况（建筑结构特征）", "C": "建设地点特征", "D": "施工条件", "E": "工程竣工结算金额"}, "answer": ["A", "B", "C", "D"], "analysis": "工程概况是对项目基本情况的说明，通常包括工程建设概况、建筑结构（施工）概况、建设地点特征、施工条件等。竣工结算金额是竣工后内容。", "tags": ["工程概况"], "source": "安装教材精读笔记"}, {"id": "ch05-029", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "选择施工方法时应综合考虑的因素有（ ）。", "options": {"A": "工程特点与工期要求", "B": "施工单位的机械设备与技术条件", "C": "经济性", "D": "安全与质量要求", "E": "企业股票市值"}, "answer": ["A", "B", "C", "D"], "analysis": "选择施工方法需结合工程特点、工期、本单位技术装备条件、经济性与安全质量要求综合确定。企业股票市值与施工方法选择无关。", "tags": ["施工方案编制要点"], "source": "安装教材精读笔记"}, {"id": "ch05-030", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工进度计划的主要作用包括（ ）。", "options": {"A": "控制施工进度", "B": "确定各工序起止时间", "C": "作为资源计划编制依据", "D": "作为工程款支付参考", "E": "替代施工图纸"}, "answer": ["A", "B", "C", "D"], "analysis": "进度计划用于控制工期、明确工序起止时间，并是资源计划和进度款支付的依据之一。进度计划不能替代施工图纸。", "tags": ["进度计划"], "source": "安装教材精读笔记"}, {"id": "ch05-031", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工组织设计按编制对象范围可分为施工组织总设计、单位工程施工组织设计和（ ）。", "options": {"A": "分项工程施工组织设计", "B": "施工方案", "C": "竣工验收报告", "D": "可行性研究报告"}, "answer": ["B"], "analysis": "按编制范围和对象，施工组织设计分为施工组织总设计、单位工程施工组织设计、施工方案三个层次。", "tags": ["施工组织设计分类"], "source": "安装教材精读笔记"}, {"id": "ch05-032", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "针对某些技术复杂或采用新技术的分部（分项）工程，应编制（ ）。", "options": {"A": "施工组织总设计", "B": "施工方案", "C": "可行性研究报告", "D": "项目建议书"}, "answer": ["B"], "analysis": "对技术复杂、难度大或采用新技术、新工艺的分部（分项）工程，应单独编制专项施工方案。", "tags": ["施工方案"], "source": "安装教材精读笔记"}, {"id": "ch05-033", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "以一个单位工程为对象编制的施工组织设计是（ ）。", "options": {"A": "施工组织总设计", "B": "单位工程施工组织设计", "C": "项目建议书", "D": "设计概算"}, "answer": ["B"], "analysis": "单位工程施工组织设计是以单位工程（如一栋建筑的安装工程）为对象编制的指导性文件。", "tags": ["施工组织设计分类"], "source": "安装教材精读笔记"}, {"id": "ch05-034", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "以一个建设项目或建筑群为对象编制、统筹各单项工程的施工组织设计是（ ）。", "options": {"A": "单位工程施工组织设计", "B": "施工组织总设计", "C": "施工方案", "D": "竣工图"}, "answer": ["B"], "analysis": "施工组织总设计是以整个建设项目或建筑群为对象，对全场施工作出统筹规划。", "tags": ["施工组织设计分类"], "source": "安装教材精读笔记"}, {"id": "ch05-035", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "确定施工顺序时，一般应遵循的基本原则包括（ ）。", "options": {"A": "先地下后地上", "B": "先土建后安装", "C": "先主体后装修", "D": "先安装后土建", "E": "随意安排"}, "answer": ["A", "B", "C"], "analysis": "一般施工顺序遵循'先地下后地上、先土建后安装、先主体后围护、先结构后装修'等原则。'先安装后土建'与'随意安排'均错误。", "tags": ["施工方案编制要点", "施工顺序"], "source": "安装教材精读笔记"}, {"id": "ch05-036", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "安装工程中，与土建配合最密切、需在结构施工阶段完成的工序是（ ）。", "options": {"A": "设备单机试运转", "B": "预埋预留", "C": "系统联动调试", "D": "竣工清理"}, "answer": ["B"], "analysis": "安装工程隐蔽工程多，预埋预留工作量大，需在土建结构施工阶段同步配合完成。", "tags": ["安装特点", "施工顺序"], "source": "安装教材精读笔记"}, {"id": "ch05-037", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "在单位工程施工组织设计中，施工部署与施工方案的关系是（ ）。", "options": {"A": "施工部署是总体安排，施工方案是具体方法", "B": "两者完全等同", "C": "施工方案决定施工部署", "D": "两者无关系"}, "answer": ["A"], "analysis": "施工部署是对工程的总体战略性安排，施工方案是对各分部分项工程具体施工方法的技术性确定，前者指导后者。", "tags": ["施工部署", "施工方案"], "source": "安装教材精读笔记"}, {"id": "ch05-038", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "下列工种中，属于安装工程施工中需'安排施工人员'考虑的工种是（ ）。", "options": {"A": "焊工", "B": "注册会计师", "C": "证券分析师", "D": "律师"}, "answer": ["A"], "analysis": "安装工程施工涉及管工、电工、焊工、起重工等工种，安排施工人员需合理确定这些工种的配置。", "tags": ["施工方案编制要点", "安排施工人员"], "source": "安装教材精读笔记"}, {"id": "ch05-039", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工平面布置中，材料堆场应就近布置在（ ）附近，以减少二次搬运。", "options": {"A": "使用地点", "B": "建设单位办公楼", "C": "城市主干道", "D": "变电站"}, "answer": ["A"], "analysis": "材料堆场应尽量布置在使用地点附近或起重机作业半径内，以减少二次搬运、提高工效。", "tags": ["施工平面布置"], "source": "安装教材精读笔记"}, {"id": "ch05-040", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工进度计划中，'流水施工'的主要目的是（ ）。", "options": {"A": "延长工期", "B": "实现连续、均衡施工，缩短工期", "C": "增加成本", "D": "减少人员"}, "answer": ["B"], "analysis": "流水施工组织能使各专业连续、均衡施工，合理搭接，从而缩短工期、提高效益。", "tags": ["进度计划", "流水施工"], "source": "安装教材精读笔记"}, {"id": "ch05-041", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "关于网络计划中的关键工作，下列说法正确的有（ ）。", "options": {"A": "总时差为零", "B": "位于关键线路上", "C": "其持续时间影响总工期", "D": "属于普通辅助工作"}, "answer": ["A", "B", "C"], "analysis": "网络计划中总时差为零、位于关键线路上的工作为关键工作，其持续时间决定总工期。它不属于普通辅助工作。", "tags": ["进度计划", "网络图"], "source": "安装教材精读笔记"}, {"id": "ch05-042", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "质量保证措施中，对进场材料、构配件进行查验的环节是（ ）。", "options": {"A": "材料进场检验", "B": "竣工审计", "C": "招标签约", "D": "设计交底"}, "answer": ["A"], "analysis": "质量保证措施包括材料进场检验、工序交接检查、隐蔽工程验收、试验检验等过程控制。", "tags": ["保证措施", "质量"], "source": "安装教材精读笔记"}, {"id": "ch05-043", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "安全保证措施中，针对高处作业、起重吊装等危险作业应编制（ ）。", "options": {"A": "专项安全施工方案", "B": "竣工图", "C": "预算书", "D": "招标公告"}, "answer": ["A"], "analysis": "对危险性较大的分部分项工程（如起重吊装、高处作业），应编制专项安全施工方案并履行审批手续。", "tags": ["保证措施", "安全"], "source": "安装教材精读笔记"}, {"id": "ch05-044", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "文明施工措施的重点之一是（ ）。", "options": {"A": "降低施工扰民、控制粉尘噪声", "B": "提高材料价格", "C": "减少工程量", "D": "推迟竣工"}, "answer": ["A"], "analysis": "文明施工与环境保护措施包括现场封闭管理、扬尘与噪声控制、垃圾清运、减少对周边扰民等。", "tags": ["保证措施", "文明施工"], "source": "安装教材精读笔记"}, {"id": "ch05-045", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "资源计划中的'劳动力需要量计划'一般根据（ ）编制。", "options": {"A": "施工进度计划与工程量", "B": "竣工图", "C": "设计概算", "D": "招标文件"}, "answer": ["A"], "analysis": "劳动力需要量计划依据进度计划中各阶段工程量及产量定额，计算各工种所需人数与进场时间。", "tags": ["资源计划", "劳动力"], "source": "安装教材精读笔记"}, {"id": "ch05-046", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工机械设备需要量计划主要依据是（ ）。", "options": {"A": "施工方案选定的机械与施工进度", "B": "竣工结算", "C": "设计概算", "D": "财务计划"}, "answer": ["A"], "analysis": "机械设备需要量计划根据施工方案确定的机械类型和施工进度安排，确定机械种类、数量及进出场时间。", "tags": ["资源计划", "机械"], "source": "安装教材精读笔记"}, {"id": "ch05-047", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "关于施工组织设计的编制与实施，下列说法正确的有（ ）。", "options": {"A": "应在开工前编制完成", "B": "应经审批后实施", "C": "竣工后才需要编制", "D": "保修期再补充编制", "E": "可作可不作"}, "answer": ["A", "B"], "analysis": "施工组织设计是指导施工的技术经济文件，必须在开工前编制、审批完毕后实施。竣工后或保修期才编制、以及不作要求都是错误的。", "tags": ["施工组织设计概述"], "source": "安装教材精读笔记"}, {"id": "ch05-048", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工组织设计编制完成后，应经（ ）审批。", "options": {"A": "施工单位技术负责人", "B": "仅项目经理口头同意", "C": "建设单位财务", "D": "供应商"}, "answer": ["A"], "analysis": "施工组织设计需按规定程序编制、审核，由施工单位技术负责人（或总监理工程师）审批后实施。", "tags": ["施工组织设计概述"], "source": "安装教材精读笔记"}, {"id": "ch05-049", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "安装工程施工方案中，应优先采用的施工机械选择原则是（ ）。", "options": {"A": "满足工艺要求且经济合理", "B": "越贵越好", "C": "越多越好", "D": "仅看外观"}, "answer": ["A"], "analysis": "选择施工机械应能满足施工工艺要求，并综合考虑经济合理性、完好率与本单位现有装备。", "tags": ["施工方案编制要点", "选择施工机械"], "source": "安装教材精读笔记"}, {"id": "ch05-050", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "工程施工中，'先土建后安装'原则主要体现了（ ）的配合关系。", "options": {"A": "土建与安装工程", "B": "设计与勘察", "C": "建设与监理", "D": "甲方与银行"}, "answer": ["A"], "analysis": "安装工程配套性强，需与土建配合，'先土建后安装、预留预埋同步'是基本配合原则。", "tags": ["施工顺序", "安装特点"], "source": "安装教材精读笔记"}, {"id": "ch05-051", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "横道图与网络图相比，其主要缺点是（ ）。", "options": {"A": "不能直观反映工作间的逻辑关系", "B": "不能表示时间", "C": "不能表示工作量", "D": "无法绘制"}, "answer": ["A"], "analysis": "横道图直观易懂，但不能明确表达工作之间的逻辑关系和关键线路，这是其相对于网络图的主要不足。", "tags": ["进度计划"], "source": "安装教材精读笔记"}, {"id": "ch05-052", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工部署确定施工开展程序时，一般遵循（ ）。", "options": {"A": "先准备后正式", "B": "先地下后地上", "C": "先全场性工程后单位工程", "D": "先地上后地下", "E": "先竣工后开工"}, "answer": ["A", "B", "C"], "analysis": "施工开展程序一般先做好施工准备再正式施工，先做地下后做地上，先全场性工程后单位工程。'先地上后地下''先竣工后开工'均错误。", "tags": ["施工部署"], "source": "安装教材精读笔记"}, {"id": "ch05-053", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工平面布置应随（ ）进行动态调整。", "options": {"A": "不同施工阶段", "B": "竣工后", "C": "设计阶段", "D": "可研阶段"}, "answer": ["A"], "analysis": "不同施工阶段现场条件变化，施工平面布置应按阶段分别绘制并动态调整。", "tags": ["施工平面布置"], "source": "安装教材精读笔记"}, {"id": "ch05-054", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "下列文件中，可作为编制资源计划中材料需要量计划依据的是（ ）。", "options": {"A": "施工进度计划与工程量清单", "B": "竣工图", "C": "财务决算", "D": "招标公告"}, "answer": ["A"], "analysis": "材料需要量计划根据进度计划和施工图纸（清单工程量）计算各阶段材料品种、规格与数量。", "tags": ["资源计划", "材料"], "source": "安装教材精读笔记"}, {"id": "ch05-055", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工组织中，'流水段'划分主要是为了（ ）。", "options": {"A": "实现流水施工、连续作业", "B": "减少工程量", "C": "替代图纸", "D": "提高单价"}, "answer": ["A"], "analysis": "将工程划分为若干流水段，可使各施工队组在不同段上连续、均衡作业，实现流水施工。", "tags": ["进度计划", "流水施工"], "source": "安装教材精读笔记"}, {"id": "ch05-056", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工组织设计经济效益主要通过（ ）体现。", "options": {"A": "合理施工方案降低消耗、缩短工期", "B": "提高材料单价", "C": "减少必要工序", "D": "拖延工期"}, "answer": ["A"], "analysis": "优良的施工方案和施工组织能合理选用机械、减少浪费、缩短工期，从而降低成本、提高经济效益。", "tags": ["施工组织设计概述"], "source": "安装教材精读笔记"}, {"id": "ch05-057", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "安装工程预算编制依据中，与'施工方案选择机械'直接关联的是（ ）。", "options": {"A": "施工组织设计", "B": "银行利率", "C": "股票指数", "D": "税收政策"}, "answer": ["A"], "analysis": "施工方案选定的施工机械和施工方法直接影响措施项目费与机械使用费，施工组织设计是预算编制依据。", "tags": ["施工组织设计与造价"], "source": "历年真题精华版"}, {"id": "ch05-058", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "按编制对象和范围，施工组织设计可分为（ ）。", "options": {"A": "施工组织总设计", "B": "单位工程施工组织设计", "C": "施工方案", "D": "项目建议书", "E": "可行性研究报告"}, "answer": ["A", "B", "C"], "analysis": "施工组织设计按对象范围分为施工组织总设计、单位工程施工组织设计、施工方案三个层次。项目建议书和可行性研究报告不属于施工组织设计。", "tags": ["施工组织设计分类"], "source": "安装教材精读笔记"}, {"id": "ch05-059", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工部署的内容通常包括（ ）。", "options": {"A": "确定工程开展程序", "B": "划分施工任务", "C": "确定施工顺序", "D": "确定流水施工组织", "E": "编制竣工决算"}, "answer": ["A", "B", "C", "D"], "analysis": "施工部署一般包括确定工程开展程序、划分施工任务与组织安排、确定施工顺序、组织流水施工等。竣工决算不属于施工部署。", "tags": ["施工部署"], "source": "安装教材精读笔记"}, {"id": "ch05-060", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工方案中'选择施工方法'应考虑的因素包括（ ）。", "options": {"A": "结构特点与设计要求", "B": "工期要求", "C": "施工单位技术装备", "D": "经济合理性", "E": "企业注册资本"}, "answer": ["A", "B", "C", "D"], "analysis": "选择施工方法应综合考虑结构特点、工期、本单位技术装备水平和经济合理性。企业注册资本与具体方法选择无直接关系。", "tags": ["施工方案编制要点"], "source": "安装教材精读笔记"}, {"id": "ch05-061", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工进度计划的表达形式有（ ）。", "options": {"A": "横道图（甘特图）", "B": "网络图", "C": "S形曲线", "D": "前锋线检查", "E": "竣工图"}, "answer": ["A", "B", "C", "D"], "analysis": "进度计划可用横道图、网络图表达；S形曲线和前锋线检查是进度控制工具。竣工图是竣工文件，不表达计划。", "tags": ["进度计划"], "source": "安装教材精读笔记"}, {"id": "ch05-062", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工平面布置设计的原则包括（ ）。", "options": {"A": "紧凑合理、减少占地", "B": "减少二次搬运", "C": "符合安全与防火要求", "D": "利于生产和生活", "E": "尽量远离使用地点以节约用地"}, "answer": ["A", "B", "C", "D"], "analysis": "平面布置应紧凑合理、减少二次搬运、满足安全防火与环保要求、方便生产生活。选项E与减少二次搬运原则相悖。", "tags": ["施工平面布置"], "source": "安装教材精读笔记"}, {"id": "ch05-063", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "质量保证措施可包含的内容有（ ）。", "options": {"A": "建立质量责任制", "B": "材料进场检验", "C": "隐蔽工程验收", "D": "工序交接检查", "E": "虚报工程量"}, "answer": ["A", "B", "C", "D"], "analysis": "质量保证措施包括质量责任制度、材料检验、隐蔽工程验收、工序交接检查、试验检测等。虚报工程量属违规行为，不属于质量保证措施。", "tags": ["保证措施", "质量"], "source": "安装教材精读笔记"}, {"id": "ch05-064", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "安全保证措施通常包括（ ）。", "options": {"A": "安全生产责任制", "B": "安全技术交底", "C": "危险作业专项方案", "D": "消防与防护设施", "E": "隐瞒事故隐患"}, "answer": ["A", "B", "C", "D"], "analysis": "安全保证措施包括责任制、安全技术交底、危险作业专项方案、消防与个体防护等。隐瞒隐患违反安全规定，不应作为措施。", "tags": ["保证措施", "安全"], "source": "安装教材精读笔记"}, {"id": "ch05-065", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工顺序确定时应遵循的一般原则有（ ）。", "options": {"A": "先地下后地上", "B": "先土建后安装", "C": "先主体后围护", "D": "先结构后装修", "E": "先安装后土建"}, "answer": ["A", "B", "C", "D"], "analysis": "一般施工顺序原则：先地下后地上、先土建后安装、先主体后围护、先结构后装修。'先安装后土建'与原则相悖。", "tags": ["施工顺序"], "source": "安装教材精读笔记"}, {"id": "ch05-066", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "安装工程的特点对施工组织设计提出的要求包括（ ）。", "options": {"A": "加强与土建配合", "B": "重视预埋预留", "C": "做好系统调试安排", "D": "多专业交叉协调", "E": "可忽略隐蔽工程"}, "answer": ["A", "B", "C", "D"], "analysis": "安装工程配套性强、专业交叉多、隐蔽工程多、调试要求高，需加强配合、重视预埋预留与系统联动调试。不能忽略隐蔽工程。", "tags": ["安装特点"], "source": "安装教材精读笔记"}, {"id": "ch05-067", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工组织设计作为预算编制依据，其作用体现在（ ）。", "options": {"A": "确定施工方法影响机械与措施费", "B": "确定进度影响间歇与赶工费", "C": "平面布置影响临时设施费", "D": "资源计划影响人工材料机数量", "E": "可替代施工图纸计量"}, "answer": ["A", "B", "C", "D"], "analysis": "施工组织设计通过施工方案、进度、平面布置、资源计划等影响措施项目费和部分实体项目工料机消耗，是预算编制依据。但它不能替代施工图纸进行计量。", "tags": ["施工组织设计与造价"], "source": "历年真题精华版"}, {"id": "ch05-068", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工方案与施工组织总设计的关系是（ ）。", "options": {"A": "施工方案是单位工程或分项工程的具体技术文件，服从总体部署", "B": "两者无关", "C": "施工方案决定总设计", "D": "施工方案可替代总设计"}, "answer": ["A"], "analysis": "施工方案是针对单位工程或分部分项工程的具体技术性文件，其内容和部署应服从施工组织总设计/单位工程施工组织设计的整体安排。", "tags": ["施工方案", "施工组织设计分类"], "source": "安装教材精读笔记"}, {"id": "ch05-069", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "网络计划中，在不影响总工期前提下，工作可以利用的机动时间称为（ ）。", "options": {"A": "总时差", "B": "自由时差仅", "C": "间歇时间", "D": "流水步距"}, "answer": ["A"], "analysis": "总时差是不影响总工期的前提下，本工作可以利用的机动时间；自由时差是不影响紧后工作最早开始的时间。题干指总时差。", "tags": ["进度计划", "网络图"], "source": "安装教材精读笔记"}, {"id": "ch05-070", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "单位工程施工组织设计中，'主要技术组织措施'对应七项内容中的（ ）。", "options": {"A": "保证措施", "B": "工程概况", "C": "进度计划", "D": "资源计划"}, "answer": ["A"], "analysis": "保证措施（质量、安全、文明施工等）即主要技术组织措施，是确保目标实现的保障性内容。", "tags": ["保证措施"], "source": "安装教材精读笔记"}, {"id": "ch05-071", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "编制施工进度计划时，确定工作持续时间一般依据（ ）。", "options": {"A": "工程量、产量定额和资源配置", "B": "竣工图", "C": "设计概算", "D": "财务计划"}, "answer": ["A"], "analysis": "工作持续时间根据工程量、劳动定额/产量定额及投入的资源数量计算确定。", "tags": ["进度计划"], "source": "安装教材精读笔记"}, {"id": "ch05-072", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工平面布置中，为方便施工和消防，场内运输道路应（ ）。", "options": {"A": "形成环路或与场外道路连通", "B": "全部断头", "C": "设在材料堆场最远处", "D": "仅保留一条窄路"}, "answer": ["A"], "analysis": "场内道路宜形成环形或与外部道路连通，保证运输畅通并满足消防通道要求。", "tags": ["施工平面布置"], "source": "安装教材精读笔记"}, {"id": "ch05-073", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工组织设计的核心目标是实现（ ）的统一。", "options": {"A": "质量、工期、成本、安全", "B": "仅追求最低成本", "C": "仅追求最短工期", "D": "仅追求最高质量"}, "answer": ["A"], "analysis": "施工组织设计应统筹质量、工期、成本、安全等目标，寻求技术经济上的最优统一。", "tags": ["施工组织设计概述"], "source": "安装教材精读笔记"}, {"id": "ch05-074", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "安装工程系统联动调试应在（ ）进行。", "options": {"A": "各分项安装完毕、单机试运转合格后", "B": "土建开工前", "C": "设计阶段", "D": "竣工后保修期"}, "answer": ["A"], "analysis": "安装工程调试要求高，应在各系统安装完成、单机试运转合格后进行系统联动调试，这属于施工方案与进度安排的内容。", "tags": ["施工方案", "安装特点"], "source": "安装教材精读笔记"}, {"id": "ch05-075", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "资源计划中，为降低资金占用和仓储成本，材料供应一般采取（ ）。", "options": {"A": "按需分期分批供应", "B": "一次性全部进场", "C": "竣工后再采购", "D": "仅采购一半"}, "answer": ["A"], "analysis": "材料计划应依据进度分期分批供应，既保证施工需要，又减少资金占用和仓储费用。", "tags": ["资源计划", "材料"], "source": "安装教材精读笔记"}, {"id": "ch05-076", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "下列内容中，属于'施工部署'而非'施工方案'的是（ ）。", "options": {"A": "确定整个工程的施工流向", "B": "确定某管道焊接工艺参数", "C": "选定某设备吊装机械型号", "D": "确定某分项施工方法"}, "answer": ["A"], "analysis": "施工流向和总体安排属施工部署；具体焊接工艺、机械型号、分项方法是施工方案的内容。", "tags": ["施工部署", "施工方案"], "source": "安装教材精读笔记"}, {"id": "ch05-077", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "在进度计划中，相邻两个专业队先后进入同一施工段的时间间隔称为（ ）。", "options": {"A": "流水步距", "B": "流水节拍", "C": "间歇时间", "D": "搭接时间"}, "answer": ["A"], "analysis": "流水步距是相邻两个专业队先后进入同一施工段开始工作的时间间隔；流水节拍是某队在一个段上的作业时间。", "tags": ["进度计划", "流水施工"], "source": "安装教材精读笔记"}, {"id": "ch05-078", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工部署中需要确定的内容一般包括（ ）。", "options": {"A": "施工流向", "B": "施工顺序", "C": "流水段划分", "D": "材料采购渠道", "E": "资金拨付顺序"}, "answer": ["A", "B", "C"], "analysis": "施工部署需确定施工流向、施工顺序、流水段划分等总体安排。材料采购渠道与资金拨付顺序不属施工部署内容。", "tags": ["施工部署"], "source": "安装教材精读笔记"}, {"id": "ch05-079", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "安装工程预算中，由施工组织设计确定的'脚手架、临时设施'等费用一般归入（ ）。", "options": {"A": "措施项目费", "B": "分部分项工程费", "C": "规费", "D": "税金"}, "answer": ["A"], "analysis": "脚手架、临时设施、文明施工等属于措施项目费，其方案与工程量受施工组织设计影响，故施工组织设计是预算编制依据。", "tags": ["施工组织设计与造价"], "source": "历年真题精华版"}, {"id": "ch05-080", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工方案的技术经济比较，主要比较的是（ ）。", "options": {"A": "施工工期、成本、质量与安全", "B": "仅比较文字长度", "C": "仅比较负责人职级", "D": "仅比较图纸张数"}, "answer": ["A"], "analysis": "施工方案应进行技术经济比选，比较工期、成本、质量、安全、环保等综合指标，择优选用。", "tags": ["施工方案", "施工方案编制要点"], "source": "安装教材精读笔记"}, {"id": "ch05-081", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工平面布置图中，'加工厂（如管道预制场）'布置应考虑（ ）。", "options": {"A": "靠近使用地点且运输方便", "B": "远离所有建筑物", "C": "设在城市中心", "D": "设在变电站内"}, "answer": ["A"], "analysis": "加工厂宜布置在靠近使用地点、原材料与半成品运输方便且减少二次搬运的位置。", "tags": ["施工平面布置"], "source": "安装教材精读笔记"}, {"id": "ch05-082", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "确定施工顺序时，对民用建筑安装工程通常应（ ）。", "options": {"A": "先地下管线后地上设备，先主管后支管", "B": "先地上后地下", "C": "先支管后主管", "D": "同时进行无顺序"}, "answer": ["A"], "analysis": "安装工程施工顺序一般先地下后地上、先主干管后支管、先设备就位后配管接线，保证工序合理。", "tags": ["施工顺序"], "source": "安装教材精读笔记"}, {"id": "ch05-083", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "资源计划中的'资金需要量计划'主要服务于（ ）。", "options": {"A": "资金筹措与进度款申请", "B": "绘制平面布置", "C": "确定施工顺序", "D": "编制竣工图"}, "answer": ["A"], "analysis": "资金需要量计划反映各阶段资金收支，用于筹措资金、安排用款及进度款支付，是资源计划的一部分。", "tags": ["资源计划", "资金"], "source": "安装教材精读笔记"}, {"id": "ch05-084", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "单位工程施工组织设计中最具技术性的核心部分是（ ）。", "options": {"A": "施工方案", "B": "工程概况", "C": "封面", "D": "目录"}, "answer": ["A"], "analysis": "施工方案确定各分部分项工程施工方法、机械与顺序，是施工组织设计的核心技术性内容。", "tags": ["施工方案"], "source": "安装教材精读笔记"}, {"id": "ch05-085", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "在施工组织设计中，'工程概况'部分一般不需要描述的是（ ）。", "options": {"A": "工程竣工后的盈利预测", "B": "工程建设概况", "C": "建筑结构特征", "D": "施工条件"}, "answer": ["A"], "analysis": "工程概况描述项目基本情况，如建设概况、结构特征、地点特征、施工条件等；竣工盈利预测不属于工程概况。", "tags": ["工程概况"], "source": "安装教材精读笔记"}, {"id": "ch05-086", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "关于施工组织设计与工程造价的关系，正确的是（ ）。", "options": {"A": "合理的施工组织设计有利于降低工程造价", "B": "两者毫无关系", "C": "施工组织设计只影响质量不影响造价", "D": "施工组织设计越复杂造价越低"}, "answer": ["A"], "analysis": "施工组织设计通过优化方案、缩短工期、减少措施费，有利于降低造价；它是预算编制依据之一。", "tags": ["施工组织设计与造价"], "source": "历年真题精华版"}, {"id": "ch05-087", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工平面布置中，临时用电线路布置应（ ）。", "options": {"A": "符合安全规范、避免与生产干扰并便于检修", "B": "随意架设", "C": "埋在材料堆下", "D": "越乱越好"}, "answer": ["A"], "analysis": "临时水电布置应符合安全规范，线路走向清晰、避开危险源并便于检修维护。", "tags": ["施工平面布置"], "source": "安装教材精读笔记"}, {"id": "ch05-088", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工进度计划调整常用方法不包括（ ）。", "options": {"A": "改变工程结构形式", "B": "缩短关键工作持续时间", "C": "改变工作间逻辑关系", "D": "增加资源投入"}, "answer": ["A"], "analysis": "进度调整常用压缩关键工作、改变逻辑关系、增加资源等方法。改变工程结构形式不属于进度计划调整方法。", "tags": ["进度计划"], "source": "安装教材精读笔记"}, {"id": "ch05-089", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工方案中安排施工人员，主要依据不包括（ ）。", "options": {"A": "股票市值", "B": "进度计划", "C": "工程量", "D": "劳动定额"}, "answer": ["A"], "analysis": "安排施工人员依据进度计划、工程量和劳动定额计算各工种需要量；股票市值与人员安排无关。", "tags": ["施工方案编制要点", "安排施工人员"], "source": "安装教材精读笔记"}, {"id": "ch05-090", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "文明施工与环境保护措施中，'扬尘控制'主要针对（ ）。", "options": {"A": "土方与材料运输产生的粉尘", "B": "资金挪用", "C": "图纸错误", "D": "工期延误"}, "answer": ["A"], "analysis": "文明施工环保措施中的扬尘控制针对施工粉尘、土方与易撒材料运输等，采取覆盖、洒水等措施。", "tags": ["保证措施", "文明施工"], "source": "安装教材精读笔记"}, {"id": "ch05-091", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工部署中，'划分施工段'主要是为了（ ）。", "options": {"A": "组织流水施工、实现连续均衡作业", "B": "增加工程总量", "C": "替代施工图纸", "D": "减少人员"}, "answer": ["A"], "analysis": "划分施工段是流水施工的基础，可使专业队在不同段上连续作业，均衡资源投入。", "tags": ["施工部署", "流水施工"], "source": "安装教材精读笔记"}, {"id": "ch05-092", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工组织设计中，对可能出现的风险应体现在（ ）中。", "options": {"A": "保证措施（含安全等应急预案）", "B": "工程概况", "C": "竣工图", "D": "封面"}, "answer": ["A"], "analysis": "风险应对与应急预案属于安全等保证措施内容，应在施工组织设计中明确。", "tags": ["保证措施", "安全"], "source": "安装教材精读笔记"}, {"id": "ch05-093", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "在单位工程安装施工组织设计中，资源计划与进度计划的关系是（ ）。", "options": {"A": "进度计划是编制资源计划的依据", "B": "两者无关", "C": "资源计划决定工期长短", "D": "资源计划替代进度计划"}, "answer": ["A"], "analysis": "资源计划（劳动力、材料、机械、资金）需依据进度计划的时间安排来编制，进度计划是资源计划的前提。", "tags": ["资源计划", "进度计划"], "source": "安装教材精读笔记"}, {"id": "ch05-094", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工平面布置的'动态调整'原则是指（ ）。", "options": {"A": "不同施工阶段分别绘制平面布置图", "B": "开工后永不改动", "C": "仅竣工时绘制一次", "D": "由供应商决定"}, "answer": ["A"], "analysis": "随施工阶段推进，现场条件变化，应分阶段编制相应的施工平面布置图并动态调整。", "tags": ["施工平面布置"], "source": "安装教材精读笔记"}, {"id": "ch05-095", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "下列施工机械中，安装工程中用于设备吊装的是（ ）。", "options": {"A": "汽车吊", "B": "万用表", "C": "兆欧表", "D": "水准仪"}, "answer": ["A"], "analysis": "汽车吊属起重机械，用于设备吊装；万用表、兆欧表是检测仪表，水准仪用于测量，不用于吊装。", "tags": ["施工方案编制要点", "选择施工机械"], "source": "安装教材精读笔记"}, {"id": "ch05-096", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工方案编制时，对常规分部分项工程与对新技术复杂工程的区别是（ ）。", "options": {"A": "后者需编制专项施工方案并论证", "B": "两者完全一样", "C": "后者不需方案", "D": "前者需论证后者不需"}, "answer": ["A"], "analysis": "对技术复杂、危险性大或采用新技术的工程，应编制专项施工方案，必要时组织专家论证。", "tags": ["施工方案"], "source": "安装教材精读笔记"}, {"id": "ch05-097", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工组织中，'依次施工、平行施工、流水施工'是（ ）的组织方式。", "options": {"A": "施工部署/进度安排", "B": "竣工结算", "C": "设计概算", "D": "招标评标"}, "answer": ["A"], "analysis": "依次、平行、流水施工是组织施工的基本方式，属于施工部署与进度计划安排的内容。", "tags": ["施工部署", "进度计划"], "source": "安装教材精读笔记"}, {"id": "ch05-098", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工进度计划编制的第一步通常是（ ）。", "options": {"A": "划分施工过程并列出工作一览表", "B": "直接绘制竣工图", "C": "编制预算", "D": "签订承包合同"}, "answer": ["A"], "analysis": "编制进度计划一般先分解工程、列出施工过程（工作）项目，再排序、计算持续时间和绘制图表。", "tags": ["进度计划"], "source": "安装教材精读笔记"}, {"id": "ch05-099", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工方案比选时，若两种方案工期相近，应优先选择（ ）。", "options": {"A": "成本较低且安全质量有保障的方案", "B": "成本最高的方案", "C": "风险最大的方案", "D": "最复杂的方案"}, "answer": ["A"], "analysis": "技术经济比选中，在工期相近时优先选用成本低、安全可靠、质量有保障的方案。", "tags": ["施工方案", "技术经济"], "source": "安装教材精读笔记"}, {"id": "ch05-100", "date": "2026-07-06", "chapter": "ch05", "type": "single", "stem": "施工平面布置中，为减少占用农田和干扰，临时设施应（ ）。", "options": {"A": "尽量利用拟建建筑用地和原有设施", "B": "全部新建永久建筑", "C": "占用城市绿地", "D": "设在河道中"}, "answer": ["A"], "analysis": "平面布置应紧凑、少占地，尽量利用拟建区域和已有设施，减少对环境与农田的占用。", "tags": ["施工平面布置"], "source": "安装教材精读笔记"}, {"id": "ch05-101", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工方案编制四要点中，属于'技术决策'内容的有（ ）。", "options": {"A": "确定施工顺序", "B": "选择施工方法", "C": "选择施工机械", "D": "安排施工人员", "E": "编制竣工财务决算"}, "answer": ["A", "B", "C"], "analysis": "确定顺序、选择方法、选择机械属施工技术决策；安排施工人员属资源组织。竣工财务决算不属于施工方案编制要点。", "tags": ["施工方案编制要点"], "source": "安装教材精读笔记"}, {"id": "ch05-102", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工组织设计七项内容中，属于'计划类'内容的有（ ）。", "options": {"A": "施工进度计划", "B": "资源计划", "C": "施工平面布置", "D": "工程概况", "E": "保证措施"}, "answer": ["A", "B"], "analysis": "进度计划、资源计划属于计划类内容；平面布置属空间安排，工程概况属说明，保证措施属保障性内容。", "tags": ["施工组织设计内容组成"], "source": "安装教材精读笔记"}, {"id": "ch05-103", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "下列关于施工顺序的说法，正确的有（ ）。", "options": {"A": "先地下后地上", "B": "先土建后安装", "C": "先主体后装修", "D": "先设备就位后配管接线", "E": "先装修后结构"}, "answer": ["A", "B", "C", "D"], "analysis": "正确顺序原则包括先地下后地上、先土建后安装、先主体后装修、先设备就位后配管接线等。'先装修后结构'违背一般原则。", "tags": ["施工顺序"], "source": "安装教材精读笔记"}, {"id": "ch05-104", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工平面布置图中通常应标注的内容有（ ）。", "options": {"A": "拟建与原有建筑位置", "B": "材料堆场与加工厂", "C": "场内道路", "D": "临时水电线路", "E": "工程竣工结算价"}, "answer": ["A", "B", "C", "D"], "analysis": "平面布置图应标注拟建/原有建筑、堆场加工厂、道路、临时水电等。竣工结算价不在平面布置图中。", "tags": ["施工平面布置"], "source": "安装教材精读笔记"}, {"id": "ch05-105", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工进度计划编制的依据包括（ ）。", "options": {"A": "施工图纸与工程量", "B": "施工部署与工期要求", "C": "施工方案", "D": "资源供应条件", "E": "竣工图"}, "answer": ["A", "B", "C", "D"], "analysis": "进度计划编制依据有图纸工程量、施工部署与合同工期、施工方案、资源条件等。竣工图是竣工文件，非计划编制依据。", "tags": ["进度计划"], "source": "安装教材精读笔记"}, {"id": "ch05-106", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "安装工程施工方案应明确的内容有（ ）。", "options": {"A": "施工工艺流程", "B": "施工方法", "C": "施工机械选用", "D": "质量安全措施", "E": "企业年度利润目标"}, "answer": ["A", "B", "C", "D"], "analysis": "施工方案应明确工艺顺序、施工方法、机械选用及相应的质量安全保证要点。企业年度利润目标不属施工方案。", "tags": ["施工方案"], "source": "安装教材精读笔记"}, {"id": "ch05-107", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "施工组织设计对造价的影响主要体现在（ ）。", "options": {"A": "施工方案影响机械与措施费", "B": "进度安排影响赶工或间歇费", "C": "平面布置影响临时设施费", "D": "资源计划影响工料机消耗", "E": "可忽略不计"}, "answer": ["A", "B", "C", "D"], "analysis": "施工组织设计通过方案、进度、平面布置、资源计划等影响措施项目费和工料机消耗，是预算编制依据，影响显著。", "tags": ["施工组织设计与造价"], "source": "历年真题精华版"}, {"id": "ch05-108", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "保证措施中，环境保护措施通常包括（ ）。", "options": {"A": "扬尘控制", "B": "噪声控制", "C": "废水处理", "D": "建筑垃圾管理", "E": "虚报环保投入"}, "answer": ["A", "B", "C", "D"], "analysis": "环保措施包括扬尘、噪声、废水、固废（建筑垃圾）等控制管理。虚报投入不属环保措施。", "tags": ["保证措施", "文明施工"], "source": "安装教材精读笔记"}, {"id": "ch05-109", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "选择施工机械时应考虑的因素包括（ ）。", "options": {"A": "与施工方法相匹配", "B": "满足工程量与工期", "C": "经济合理", "D": "操作安全可行", "E": "设备外观颜色"}, "answer": ["A", "B", "C", "D"], "analysis": "选择机械应与方法匹配、满足工程量工期、经济合理且安全可行。外观颜色不是选择依据。", "tags": ["施工方案编制要点", "选择施工机械"], "source": "安装教材精读笔记"}, {"id": "ch05-110", "date": "2026-07-06", "chapter": "ch05", "type": "multiple", "stem": "下列关于施工组织设计的表述，正确的有（ ）。", "options": {"A": "是指导施工全过程的技术经济文件", "B": "应在开工前编制审批", "C": "核心内容含施工方案", "D": "是安装工程预算编制依据之一", "E": "竣工后才需要编制"}, "answer": ["A", "B", "C", "D"], "analysis": "施工组织设计是指导施工全过程的技术经济文件，开工前编制审批，含施工方案等七项内容，且是预算编制依据。竣工后才编制错误。", "tags": ["施工组织设计概述", "施工组织设计与造价"], "source": "安装教材精读笔记"}, {"id": "ch06-001", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "在安装工程施工图（电气工程）中，字母符号“MX”表示的是？", "options": {"A": "照明配电箱", "B": "动力配电箱", "C": "配电柜", "D": "控制箱"}, "answer": ["A"], "analysis": "据《安装教材精读笔记》第6章电气工程图例，MX 表示照明配电箱。", "tags": ["图例符号", "电气工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-002", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "安装工程施工图中，图例符号“YG”表示的是？", "options": {"A": "应急灯", "B": "荧光灯灯具", "C": "防水灯", "D": "吸顶灯"}, "answer": ["B"], "analysis": "据第6章电气工程图例，YG 表示荧光灯灯具。", "tags": ["图例符号", "电气工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-003", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "电气照明平面图中，符号“○”通常表示？", "options": {"A": "开关", "B": "插座", "C": "灯位（一般照明）", "D": "配电箱"}, "answer": ["C"], "analysis": "据第6章电气工程图例，○ 表示灯位（一般照明）。", "tags": ["图例符号", "电气工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-004", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "下列电气工程图例中，表示照明配电箱的是？", "options": {"A": "MX", "B": "YG", "C": "○", "D": "PL"}, "answer": ["A"], "analysis": "MX 为照明配电箱图例；YG 为荧光灯，○ 为灯位，PL 为排水立管。", "tags": ["图例符号", "电气工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-005", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "下列电气工程图例中，表示荧光灯灯具的是？", "options": {"A": "MX", "B": "YG", "C": "JL", "D": "SF"}, "answer": ["B"], "analysis": "YG 为荧光灯灯具；MX 为照明配电箱，JL 为给水立管，SF 为送风。", "tags": ["图例符号", "电气工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-006", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "下列电气工程图例中，表示灯位的是？", "options": {"A": "MX", "B": "YG", "C": "○", "D": "HF"}, "answer": ["C"], "analysis": "○ 表示灯位（一般照明）；HF 为回风。", "tags": ["图例符号", "电气工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-007", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "在电气照明系统组成中，配电箱（MX）通常为？", "options": {"A": "进线回路终点", "B": "出线回路起点", "C": "变压器", "D": "接地装置"}, "answer": ["B"], "analysis": "据第1章电气工程，配电箱（MX）通常为出线回路起点。", "tags": ["电气系统组成", "照明配电箱"], "source": "安装教材精读笔记"}, {"id": "ch06-008", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "一般照明回路的电压为？", "options": {"A": "110V", "B": "220V", "C": "380V", "D": "660V"}, "answer": ["B"], "analysis": "据第1章，照明回路电压一般为 220V。", "tags": ["电气系统组成", "照明回路"], "source": "安装教材精读笔记"}, {"id": "ch06-009", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "动力回路的电压通常可为？", "options": {"A": "220V", "B": "380V/220V", "C": "110V", "D": "36V"}, "answer": ["B"], "analysis": "据第1章，动力回路电压有 380V/220V。", "tags": ["电气系统组成", "动力回路"], "source": "安装教材精读笔记"}, {"id": "ch06-010", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "在照明系统中，设备的连接关系一般为？", "options": {"A": "灯具→配电箱→线路", "B": "配电箱→线路→灯具→开关", "C": "线路→配电箱→开关", "D": "开关→灯具→配电箱"}, "answer": ["B"], "analysis": "据第1章，照明系统组成：配电箱 → 线路 → 灯具 → 开关。", "tags": ["电气系统组成", "照明系统"], "source": "安装教材精读笔记"}, {"id": "ch06-011", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "安装给排水施工图中，字母符号“JL”表示的是？", "options": {"A": "给水立管", "B": "排水立管", "C": "热水立管", "D": "消防立管"}, "answer": ["A"], "analysis": "据第6章给排水工程图例，JL 表示给水立管。", "tags": ["图例符号", "给排水工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-012", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "安装给排水施工图中，字母符号“PL”表示的是？", "options": {"A": "给水立管", "B": "排水立管", "C": "热水立管", "D": "中水立管"}, "answer": ["B"], "analysis": "据第6章给排水工程图例，PL 表示排水立管。", "tags": ["图例符号", "给排水工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-013", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "安装给排水施工图中，字母符号“RL”表示的是？", "options": {"A": "热水立管", "B": "给水立管", "C": "排水立管", "D": "回水立管"}, "answer": ["A"], "analysis": "据第6章给排水工程图例，RL 表示热水立管。", "tags": ["图例符号", "给排水工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-014", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "下列图例中，属于给水立管的是？", "options": {"A": "JL", "B": "PL", "C": "RL", "D": "SF"}, "answer": ["A"], "analysis": "JL 为给水立管；PL 为排水立管，RL 为热水立管，SF 为送风。", "tags": ["图例符号", "给排水工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-015", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "下列图例中，属于排水立管的是？", "options": {"A": "JL", "B": "PL", "C": "RL", "D": "HF"}, "answer": ["B"], "analysis": "PL 为排水立管；HF 为回风。", "tags": ["图例符号", "给排水工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-016", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "下列图例中，属于热水立管的是？", "options": {"A": "JL", "B": "PL", "C": "RL", "D": "PF"}, "answer": ["C"], "analysis": "RL 为热水立管；PF 为排风。", "tags": ["图例符号", "给排水工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-017", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "给排水工程中，表示“热水立管”的图例代号是？", "options": {"A": "JL", "B": "PL", "C": "RL", "D": "GL"}, "answer": ["C"], "analysis": "RL 为热水立管；JL 为给水立管，PL 为排水立管。", "tags": ["图例符号", "给排水工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-018", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "给排水工程中，表示“排水立管”的图例代号是？", "options": {"A": "JL", "B": "PL", "C": "RL", "D": "GL"}, "answer": ["B"], "analysis": "PL 为排水立管。", "tags": ["图例符号", "给排水工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-019", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "通风空调施工图中，字母符号“SF”表示的是？", "options": {"A": "送风", "B": "回风", "C": "排风", "D": "新风"}, "answer": ["A"], "analysis": "据第6章通风空调工程图例，SF 表示送风。", "tags": ["图例符号", "通风空调工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-020", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "通风空调施工图中，字母符号“HF”表示的是？", "options": {"A": "送风", "B": "回风", "C": "排风", "D": "补风"}, "answer": ["B"], "analysis": "据第6章，HF 表示回风。", "tags": ["图例符号", "通风空调工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-021", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "通风空调施工图中，字母符号“PF”表示的是？", "options": {"A": "送风", "B": "回风", "C": "排风", "D": "进风"}, "answer": ["C"], "analysis": "据第6章，PF 表示排风。", "tags": ["图例符号", "通风空调工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-022", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "下列通风空调图例中，表示送风的是？", "options": {"A": "SF", "B": "HF", "C": "PF", "D": "WF"}, "answer": ["A"], "analysis": "SF 为送风；HF 为回风，PF 为排风。", "tags": ["图例符号", "通风空调工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-023", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "通风空调图例中，表示回风的是？", "options": {"A": "SF", "B": "HF", "C": "PF", "D": "XF"}, "answer": ["B"], "analysis": "HF 为回风。", "tags": ["图例符号", "通风空调工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-024", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "通风空调图例中，表示排风的是？", "options": {"A": "SF", "B": "HF", "C": "PF", "D": "XF"}, "answer": ["C"], "analysis": "PF 为排风。", "tags": ["图例符号", "通风空调工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-025", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "通风系统图例中，与“送风”对应的代号是？", "options": {"A": "SF", "B": "HF", "C": "PF", "D": "FF"}, "answer": ["A"], "analysis": "SF 对应送风。", "tags": ["图例符号", "通风空调工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-026", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "通风系统图例中，与“排风”对应的代号是？", "options": {"A": "SF", "B": "HF", "C": "PF", "D": "EF"}, "answer": ["C"], "analysis": "PF 对应排风。", "tags": ["图例符号", "通风空调工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-027", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "安装工程识图的正确步骤中，第一步应当？", "options": {"A": "看系统图", "B": "看平面图", "C": "看图纸目录和图例", "D": "看详图"}, "answer": ["C"], "analysis": "据第6章识图方法，第一步应先看图纸目录和图例。", "tags": ["识图方法", "识图顺序"], "source": "安装教材精读笔记"}, {"id": "ch06-028", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "安装工程识图的第二步应当看？", "options": {"A": "图纸目录", "B": "系统图", "C": "平面图", "D": "材料表"}, "answer": ["B"], "analysis": "识图第二步看系统图，以了解系统组成。", "tags": ["识图方法", "识图顺序"], "source": "安装教材精读笔记"}, {"id": "ch06-029", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "安装工程识图的第三步应当看？", "options": {"A": "图纸目录", "B": "系统图", "C": "平面图", "D": "设计说明"}, "answer": ["C"], "analysis": "识图第三步看平面图，以了解设备具体位置。", "tags": ["识图方法", "识图顺序"], "source": "安装教材精读笔记"}, {"id": "ch06-030", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "识图时看系统图的主要目的是？", "options": {"A": "了解设备具体位置", "B": "了解系统组成", "C": "统计材料", "D": "计算工程量"}, "answer": ["B"], "analysis": "据第6章，看系统图是为了了解系统组成。", "tags": ["识图方法", "系统图"], "source": "安装教材精读笔记"}, {"id": "ch06-031", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "识图时看平面图的主要目的是？", "options": {"A": "了解系统组成", "B": "了解设备具体位置/布置", "C": "看设计说明", "D": "看图例"}, "answer": ["B"], "analysis": "据第6章，看平面图是为了了解设备具体位置。", "tags": ["识图方法", "平面图"], "source": "安装教材精读笔记"}, {"id": "ch06-032", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "识图时，为了了解各图例符号的具体含义，应首先查阅？", "options": {"A": "系统图", "B": "平面图", "C": "图纸目录和图例", "D": "设备表"}, "answer": ["C"], "analysis": "图例表用于说明各符号含义，应首先查阅。", "tags": ["识图方法", "图例"], "source": "安装教材精读笔记"}, {"id": "ch06-033", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "按照识图三步法，了解“系统组成”应看？", "options": {"A": "平面图", "B": "系统图", "C": "图例", "D": "目录"}, "answer": ["B"], "analysis": "系统图用于了解系统组成。", "tags": ["识图方法", "系统图"], "source": "安装教材精读笔记"}, {"id": "ch06-034", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "按照识图三步法，了解“设备具体位置”应看？", "options": {"A": "平面图", "B": "系统图", "C": "图例", "D": "目录"}, "answer": ["A"], "analysis": "平面图用于了解设备具体位置。", "tags": ["识图方法", "平面图"], "source": "安装教材精读笔记"}, {"id": "ch06-035", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "识图中“图纸目录”的作用是？", "options": {"A": "表明系统组成", "B": "列出图纸内容及图例", "C": "标明设备位置", "D": "计算工程量"}, "answer": ["B"], "analysis": "图纸目录列出图纸内容，图例说明符号含义。", "tags": ["识图方法", "图纸目录"], "source": "安装教材精读笔记"}, {"id": "ch06-036", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "下列识图顺序正确的是？", "options": {"A": "系统图→平面图→图例", "B": "图例→系统图→平面图", "C": "平面图→系统图→图例", "D": "图例→平面图→系统图"}, "answer": ["B"], "analysis": "正确顺序为：先看图纸目录和图例 → 再看系统图 → 最后看平面图。", "tags": ["识图方法", "识图顺序"], "source": "安装教材精读笔记"}, {"id": "ch06-037", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "下列图例中，属于电气工程的是？", "options": {"A": "JL", "B": "MX", "C": "PL", "D": "RL"}, "answer": ["B"], "analysis": "MX 为照明配电箱，属电气工程；其余为给排水立管。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-038", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "下列图例中，属于给排水工程的是？", "options": {"A": "SF", "B": "YG", "C": "JL", "D": "HF"}, "answer": ["C"], "analysis": "JL 为给水立管，属给排水工程。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-039", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "下列图例中，属于通风空调工程的是？", "options": {"A": "MX", "B": "YG", "C": "SF", "D": "○"}, "answer": ["C"], "analysis": "SF 为送风，属通风空调工程。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-040", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "下列图例中，不属于通风空调工程的是？", "options": {"A": "SF", "B": "HF", "C": "PF", "D": "JL"}, "answer": ["D"], "analysis": "JL 为给水立管，属给排水工程，不属于通风空调。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-041", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "下列图例中，不属于电气工程的是？", "options": {"A": "MX", "B": "YG", "C": "○", "D": "PL"}, "answer": ["D"], "analysis": "PL 为排水立管，属给排水工程，不属于电气工程。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-042", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "下列图例中，不属于给排水工程的是？", "options": {"A": "JL", "B": "PL", "C": "RL", "D": "SF"}, "answer": ["D"], "analysis": "SF 为送风，属通风空调工程，不属于给排水。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-043", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "同时包含“MX”和“YG”图例的图纸专业是？", "options": {"A": "给排水", "B": "电气", "C": "通风", "D": "消防"}, "answer": ["B"], "analysis": "MX（照明配电箱）与 YG（荧光灯）均属电气工程图例。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-044", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "同时包含“JL”“PL”“RL”图例的图纸专业是？", "options": {"A": "电气", "B": "给排水", "C": "通风", "D": "智能化"}, "answer": ["B"], "analysis": "JL、PL、RL 均为给排水立管图例。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-045", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "同时包含“SF”“HF”“PF”图例的图纸专业是？", "options": {"A": "电气", "B": "给排水", "C": "通风空调", "D": "消防"}, "answer": ["C"], "analysis": "SF、HF、PF 均为通风空调风系统图例。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-046", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "在给排水工程中，表示立管的图例代号是？", "options": {"A": "MX", "B": "JL/PL/RL", "C": "SF", "D": "YG"}, "answer": ["B"], "analysis": "给排水立管图例为 JL（给水）、PL（排水）、RL（热水）。", "tags": ["图例符号", "给排水工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-047", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "办公室照明工程案例中，识图顺序为“配电箱MX→线路→4盏YG2-2型荧光灯”。该案例列项一般不包括？", "options": {"A": "配管", "B": "配线", "C": "灯具安装", "D": "风管制作"}, "answer": ["D"], "analysis": "据第14章案例，照明工程列项为配管、配线、灯具安装、开关安装，不含风管制作。", "tags": ["识图应用", "照明工程量"], "source": "安装教材精读笔记"}, {"id": "ch06-048", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "照明工程量计算中，配线长度的计算规则是？", "options": {"A": "配管长度", "B": "配管长度+预留长度", "C": "水平段", "D": "垂直段"}, "answer": ["B"], "analysis": "据第14章，配线长度 = 配管长度 + 预留长度。", "tags": ["识图应用", "照明工程量"], "source": "安装教材精读笔记"}, {"id": "ch06-049", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "给排水管道工程量按什么计算？", "options": {"A": "实际长度", "B": "中心线长度", "C": "外表面长度", "D": "投影长度"}, "answer": ["B"], "analysis": "据第14章，管道工程量按中心线长度计算（m）。", "tags": ["识图应用", "给排水工程量"], "source": "安装教材精读笔记"}, {"id": "ch06-050", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "给排水工程中，阀门工程量按什么计算？", "options": {"A": "m", "B": "套", "C": "个（按类型和规格）", "D": "㎡"}, "answer": ["C"], "analysis": "据第14章，阀门按类型和规格以“个”计算。", "tags": ["识图应用", "给排水工程量"], "source": "安装教材精读笔记"}, {"id": "ch06-051", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "给排水工程中，卫生器具工程量按什么计算？", "options": {"A": "m", "B": "个", "C": "套", "D": "㎡"}, "answer": ["C"], "analysis": "据第14章，卫生器具按“套”计算。", "tags": ["识图应用", "给排水工程量"], "source": "安装教材精读笔记"}, {"id": "ch06-052", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "矩形风管展开面积计算公式是？", "options": {"A": "π×直径×长度", "B": "2×(宽+高)×长度", "C": "宽×高", "D": "(宽+高)×长度"}, "answer": ["B"], "analysis": "据第14章，矩形风管展开面积 S = 2×(宽+高)×长度。", "tags": ["识图应用", "通风工程量"], "source": "安装教材精读笔记"}, {"id": "ch06-053", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "圆形风管展开面积计算公式是？", "options": {"A": "π×直径×长度", "B": "2×(宽+高)×长度", "C": "直径×长度", "D": "半径×长度"}, "answer": ["A"], "analysis": "据第14章，圆形风管展开面积 S = π×直径×长度。", "tags": ["识图应用", "通风工程量"], "source": "安装教材精读笔记"}, {"id": "ch06-054", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "根据2024版清单（GB/T 50856-2024），柔性软风管的计量单位是？", "options": {"A": "m", "B": "㎡", "C": "个", "D": "节"}, "answer": ["A"], "analysis": "据2024清单，柔性软风管按设计图示管道中心线长度以“m”计算。", "tags": ["清单计量", "柔性软风管"], "source": "广东二级造价师安装专业历年真题精华版"}, {"id": "ch06-055", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "根据2018版广东安装定额（第7册），帆布软接口的计量单位是？", "options": {"A": "m", "B": "节", "C": "㎡", "D": "个"}, "answer": ["C"], "analysis": "据2018定额（第7册），帆布软接口按设计图示尺寸以“㎡”计算。", "tags": ["定额计量", "帆布软接口"], "source": "广东二级造价师安装专业历年真题精华版"}, {"id": "ch06-056", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "电气照明平面图中，符号“○”（灯位）的灯具数量通常依据什么统计？", "options": {"A": "系统图", "B": "平面图中的符号数量", "C": "材料表", "D": "设计说明"}, "answer": ["B"], "analysis": "灯位○在平面图上表示，灯具数量按平面图中的符号数量统计。", "tags": ["图例符号", "电气工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-057", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "识图三步法中，最后看平面图是为了？", "options": {"A": "了解系统组成", "B": "统计设备材料", "C": "确定设备具体位置/布置", "D": "查看图例"}, "answer": ["C"], "analysis": "平面图用于了解设备在平面上的具体位置与布置。", "tags": ["识图方法", "平面图"], "source": "安装教材精读笔记"}, {"id": "ch06-058", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "下列图例中，表示“荧光灯灯具”且属于电气专业的是？", "options": {"A": "YG", "B": "JL", "C": "SF", "D": "PL"}, "answer": ["A"], "analysis": "YG 为荧光灯灯具，属电气工程图例。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-059", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "图例符号“○”作为灯位符号，属于哪个专业？", "options": {"A": "给排水", "B": "电气照明", "C": "通风", "D": "消防"}, "answer": ["B"], "analysis": "○ 表示灯位（一般照明），属电气照明工程图例。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-060", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "通风空调工程图例中，表示“回风”与表示“排风”的代号分别是？", "options": {"A": "SF、HF", "B": "HF、PF", "C": "PF、HF", "D": "SF、PF"}, "answer": ["B"], "analysis": "HF 表示回风，PF 表示排风。", "tags": ["图例符号", "通风空调工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-061", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "给排水工程图例中，“给水立管”“排水立管”“热水立管”的代号依次是？", "options": {"A": "JL、PL、RL", "B": "PL、JL、RL", "C": "RL、JL、PL", "D": "JL、RL、PL"}, "answer": ["A"], "analysis": "依次为 JL（给水）、PL（排水）、RL（热水）。", "tags": ["图例符号", "给排水工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-062", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "电气工程图例中，“照明配电箱”“荧光灯”“灯位”的代号依次是？", "options": {"A": "MX、YG、○", "B": "YG、MX、○", "C": "○、MX、YG", "D": "MX、○、YG"}, "answer": ["A"], "analysis": "依次为 MX（照明配电箱）、YG（荧光灯）、○（灯位）。", "tags": ["图例符号", "电气工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-063", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "在通风空调系统组成中，风系统一般为？", "options": {"A": "冷水机组→水泵→末端", "B": "风机→风管→风口", "C": "热源→管道→用水点", "D": "变压器→配电柜→配电箱"}, "answer": ["B"], "analysis": "据第1章，通风空调风系统：风机 → 风管 → 风口。", "tags": ["系统组成", "通风空调"], "source": "安装教材精读笔记"}, {"id": "ch06-064", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "在电气设备安装系统组成中，照明系统一般为？", "options": {"A": "配电箱→线路→灯具→开关", "B": "变压器→配电柜→配电箱", "C": "风机→风管→风口", "D": "水泵→管道→用水点"}, "answer": ["A"], "analysis": "据第1章，照明系统：配电箱 → 线路 → 灯具 → 开关。", "tags": ["系统组成", "电气照明"], "source": "安装教材精读笔记"}, {"id": "ch06-065", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "在给排水系统组成中，给水系统一般为？", "options": {"A": "水源→水泵→管道→用水点", "B": "排水点→管道→化粪池", "C": "热源→管道→用水点", "D": "风机→风管"}, "answer": ["A"], "analysis": "据第1章，给水系统：水源 → 水泵 → 管道 → 用水点。", "tags": ["系统组成", "给排水"], "source": "安装教材精读笔记"}, {"id": "ch06-066", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "在给排水系统组成中，排水系统一般为？", "options": {"A": "水源→水泵→管道", "B": "排水点→管道→化粪池→市政管网", "C": "热源→管道", "D": "风机→风管"}, "answer": ["B"], "analysis": "据第1章，排水系统：排水点 → 管道 → 化粪池 → 市政管网。", "tags": ["系统组成", "给排水"], "source": "安装教材精读笔记"}, {"id": "ch06-067", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "通风空调系统中，水系统一般为？", "options": {"A": "冷水机组→水泵→空调末端", "B": "风机→风管→风口", "C": "配电箱→线路", "D": "水泵→管道→用水点"}, "answer": ["A"], "analysis": "据第1章，通风空调水系统：冷水机组 → 水泵 → 空调末端。", "tags": ["系统组成", "通风空调"], "source": "安装教材精读笔记"}, {"id": "ch06-068", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "办公室照明工程识图后的列项内容一般包括？", "options": {"A": "配管、配线、灯具安装、开关安装", "B": "风管、风口、风机", "C": "管道、阀门、卫生器具", "D": "桥架、母线"}, "answer": ["A"], "analysis": "据第14章案例，照明工程列项为配管、配线、灯具安装、开关安装。", "tags": ["识图应用", "照明工程量"], "source": "安装教材精读笔记"}, {"id": "ch06-069", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "识图时，平面图主要用于反映？", "options": {"A": "系统原理与组成", "B": "设备在平面上的具体位置与走向", "C": "图例说明", "D": "设计依据"}, "answer": ["B"], "analysis": "平面图反映设备具体位置与管线走向。", "tags": ["识图方法", "平面图"], "source": "安装教材精读笔记"}, {"id": "ch06-070", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "系统图与平面图的关系中，系统图侧重？", "options": {"A": "位置", "B": "组成与连接关系", "C": "尺寸标注", "D": "材料表"}, "answer": ["B"], "analysis": "系统图侧重表达系统组成与连接关系。", "tags": ["识图方法", "系统图"], "source": "安装教材精读笔记"}, {"id": "ch06-071", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "图例表在图纸中的作用是？", "options": {"A": "表示系统组成", "B": "说明各符号的含义", "C": "标注设备位置", "D": "列出工程量"}, "answer": ["B"], "analysis": "图例表用于说明图纸中各符号的含义，识图应先看。", "tags": ["识图方法", "图例"], "source": "安装教材精读笔记"}, {"id": "ch06-072", "date": "2026-07-06", "chapter": "ch06", "type": "single", "stem": "安装工程施工图识图的正确顺序是？", "options": {"A": "目录图例→系统图→平面图", "B": "系统图→目录图例→平面图", "C": "平面图→系统图→目录图例", "D": "目录图例→平面图→系统图"}, "answer": ["A"], "analysis": "正确顺序：先看图纸目录和图例 → 再看系统图 → 最后看平面图。", "tags": ["识图方法", "识图顺序"], "source": "安装教材精读笔记"}, {"id": "ch06-073", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "下列电气工程图例中，属于照明专业常用图例的有？", "options": {"A": "MX", "B": "YG", "C": "○", "D": "JL"}, "answer": ["A", "B", "C"], "analysis": "MX（照明配电箱）、YG（荧光灯）、○（灯位）均为电气照明图例；JL 为给水立管。", "tags": ["图例符号", "电气工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-074", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "下列属于电气工程图例符号的有？", "options": {"A": "MX", "B": "YG", "C": "○", "D": "SF"}, "answer": ["A", "B", "C"], "analysis": "MX、YG、○ 属电气工程；SF（送风）属通风空调。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-075", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "给排水工程图中，下列属于立管图例代号的有？", "options": {"A": "JL", "B": "PL", "C": "RL", "D": "SF"}, "answer": ["A", "B", "C"], "analysis": "JL（给水）、PL（排水）、RL（热水）为给排水立管图例；SF 为送风。", "tags": ["图例符号", "给排水工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-076", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "给排水工程图中，下列图例表示立管的有？", "options": {"A": "JL（给水立管）", "B": "PL（排水立管）", "C": "RL（热水立管）", "D": "HF（回风）"}, "answer": ["A", "B", "C"], "analysis": "JL、PL、RL 均为给排水立管；HF 为回风，属通风。", "tags": ["图例符号", "给排水工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-077", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "通风空调工程图中，下列图例代号属于风系统标识的有？", "options": {"A": "SF", "B": "HF", "C": "PF", "D": "JL"}, "answer": ["A", "B", "C"], "analysis": "SF（送风）、HF（回风）、PF（排风）为通风风系统标识；JL 为给水立管。", "tags": ["图例符号", "通风空调工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-078", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "通风空调工程图例中，表示风系统功能的有？", "options": {"A": "SF（送风）", "B": "HF（回风）", "C": "PF（排风）", "D": "RL（热水立管）"}, "answer": ["A", "B", "C"], "analysis": "SF、HF、PF 表示风系统功能；RL 为热水立管，属给排水。", "tags": ["图例符号", "通风空调工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-079", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "安装工程识图的正确步骤包括（按先后顺序）？", "options": {"A": "先看图纸目录和图例", "B": "再看系统图", "C": "最后看平面图", "D": "先看材料表"}, "answer": ["A", "B", "C"], "analysis": "识图三步法：目录图例 → 系统图 → 平面图。", "tags": ["识图方法", "识图顺序"], "source": "安装教材精读笔记"}, {"id": "ch06-080", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "识图三步法中，各步骤的目的包括？", "options": {"A": "看目录图例—了解符号含义和图纸内容", "B": "看系统图—了解系统组成", "C": "看平面图—了解具体位置", "D": "看竣工图—了解结算"}, "answer": ["A", "B", "C"], "analysis": "三步法目的分别为了解符号含义、系统组成、设备具体位置；竣工图不属于识图三步。", "tags": ["识图方法", "识图顺序"], "source": "安装教材精读笔记"}, {"id": "ch06-081", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "下列符号中，属于给排水工程图例的有？", "options": {"A": "JL", "B": "PL", "C": "RL", "D": "MX"}, "answer": ["A", "B", "C"], "analysis": "JL、PL、RL 属给排水；MX 为照明配电箱，属电气。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-082", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "下列符号中，属于通风空调工程图例的有？", "options": {"A": "SF", "B": "HF", "C": "PF", "D": "YG"}, "answer": ["A", "B", "C"], "analysis": "SF、HF、PF 属通风空调；YG 为荧光灯，属电气。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-083", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "下列符号中，属于电气工程图例的有？", "options": {"A": "MX", "B": "YG", "C": "○", "D": "PL"}, "answer": ["A", "B", "C"], "analysis": "MX、YG、○ 属电气；PL 为排水立管，属给排水。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-084", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "根据精读笔记，以下说法正确的有？", "options": {"A": "MX表示照明配电箱", "B": "YG表示荧光灯灯具", "C": "○表示灯位", "D": "JL表示给水立管"}, "answer": ["A", "B", "C", "D"], "analysis": "四项均符合第6章图例定义（MX、YG、○属电气；JL属给排水）。", "tags": ["图例符号", "综合"], "source": "安装教材精读笔记"}, {"id": "ch06-085", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "关于给排水立管图例，下列说法正确的有？", "options": {"A": "JL表示给水立管", "B": "PL表示排水立管", "C": "RL表示热水立管", "D": "SF表示送风"}, "answer": ["A", "B", "C"], "analysis": "JL、PL、RL 对应正确；SF 为送风，属通风。", "tags": ["图例符号", "给排水工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-086", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "关于通风空调图例，下列说法正确的有？", "options": {"A": "SF表示送风", "B": "HF表示回风", "C": "PF表示排风", "D": "RL表示热水立管"}, "answer": ["A", "B", "C"], "analysis": "SF、HF、PF 对应正确；RL 为热水立管，属给排水。", "tags": ["图例符号", "通风空调工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-087", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "电气照明系统组成涉及的图例/设备包括？", "options": {"A": "配电箱(MX)", "B": "线路", "C": "灯具(YG)", "D": "开关"}, "answer": ["A", "B", "C", "D"], "analysis": "照明系统：配电箱 → 线路 → 灯具 → 开关，对应 MX、YG、○（灯位）等图例。", "tags": ["系统组成", "电气照明"], "source": "安装教材精读笔记"}, {"id": "ch06-088", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "关于配电箱（MX）的说法正确的有？", "options": {"A": "通常为出线回路起点", "B": "属于照明配电箱", "C": "在系统中连接线路", "D": "属于通风设备"}, "answer": ["A", "B", "C"], "analysis": "MX 为照明配电箱，是出线回路起点并连接线路；不属于通风设备。", "tags": ["系统组成", "照明配电箱"], "source": "安装教材精读笔记"}, {"id": "ch06-089", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "照明回路与动力回路电压说法正确的有？", "options": {"A": "照明回路一般220V", "B": "动力回路有380V/220V", "C": "照明回路一般380V", "D": "动力回路一般220V"}, "answer": ["A", "B"], "analysis": "照明回路一般 220V，动力回路 380V/220V。", "tags": ["系统组成", "电气回路"], "source": "安装教材精读笔记"}, {"id": "ch06-090", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "给排水系统组成包括？", "options": {"A": "给水系统（水源→水泵→管道→用水点）", "B": "排水系统（排水点→管道→化粪池→市政管网）", "C": "热水系统（热源→管道→用水点）", "D": "送风系统"}, "answer": ["A", "B", "C"], "analysis": "给排水含给水、排水、热水系统；送风属通风。", "tags": ["系统组成", "给排水"], "source": "安装教材精读笔记"}, {"id": "ch06-091", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "通风空调系统组成包括？", "options": {"A": "风系统（风机→风管→风口）", "B": "水系统（冷水机组→水泵→末端）", "C": "控制系统（传感器→控制器→执行器）", "D": "给水系统"}, "answer": ["A", "B", "C"], "analysis": "通风空调整体由风系统、水系统、控制系统组成；给水系统属给排水。", "tags": ["系统组成", "通风空调"], "source": "安装教材精读笔记"}, {"id": "ch06-092", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "给排水工程量计算的一般步骤包括？", "options": {"A": "管道按中心线长度(m)", "B": "管件弯头三通分别计算", "C": "阀门按类型和规格(个)", "D": "卫生器具按套"}, "answer": ["A", "B", "C", "D"], "analysis": "据第14章，给排水计量规则如上。", "tags": ["识图应用", "给排水工程量"], "source": "安装教材精读笔记"}, {"id": "ch06-093", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "通风风管展开面积计算规则正确的有？", "options": {"A": "矩形：S=2×(宽+高)×长度", "B": "圆形：S=π×直径×长度", "C": "矩形：S=宽×高", "D": "圆形：S=直径×长度"}, "answer": ["A", "B"], "analysis": "据第14章，矩形 S=2×(宽+高)×长度，圆形 S=π×直径×长度。", "tags": ["识图应用", "通风工程量"], "source": "安装教材精读笔记"}, {"id": "ch06-094", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "关于2024清单与2018定额对柔性软风管/帆布软接口，说法正确的有？", "options": {"A": "柔性软风管清单计量单位m", "B": "帆布软接口定额计量单位㎡", "C": "柔性软风管定额计量单位m", "D": "帆布软接口清单计量单位m"}, "answer": ["A", "B", "C"], "analysis": "柔性软风管清单与定额均为 m；帆布软接口定额为㎡。D 错（帆布软接口非 m）。", "tags": ["清单计量", "定额计量"], "source": "广东二级造价师安装专业历年真题精华版"}, {"id": "ch06-095", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "办公室照明工程案例中，识图后列项一般包括？", "options": {"A": "配管", "B": "配线", "C": "灯具安装", "D": "开关安装"}, "answer": ["A", "B", "C", "D"], "analysis": "据第14章案例，列项为配管、配线、灯具安装、开关安装。", "tags": ["识图应用", "照明工程量"], "source": "安装教材精读笔记"}, {"id": "ch06-096", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "安装工程识图时，关于“系统图”作用的说法正确的有？", "options": {"A": "了解系统组成", "B": "了解系统连接关系", "C": "了解设备具体位置", "D": "了解原理"}, "answer": ["A", "B", "D"], "analysis": "系统图侧重系统组成、连接关系与原理；设备具体位置由平面图反映。", "tags": ["识图方法", "系统图"], "source": "安装教材精读笔记"}, {"id": "ch06-097", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "安装工程识图时，关于“平面图”作用的说法正确的有？", "options": {"A": "了解设备具体位置", "B": "了解管线走向", "C": "了解系统组成原理", "D": "统计灯位数量"}, "answer": ["A", "B", "D"], "analysis": "平面图反映具体位置、管线走向并可用于统计灯位数量；系统组成原理由系统图反映。", "tags": ["识图方法", "平面图"], "source": "安装教材精读笔记"}, {"id": "ch06-098", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "图纸目录和图例的作用包括？", "options": {"A": "列出图纸内容", "B": "说明符号含义", "C": "表明系统组成", "D": "了解设备位置"}, "answer": ["A", "B"], "analysis": "目录列出图纸内容、图例说明符号含义；系统组成与设备位置分别由系统图、平面图反映。", "tags": ["识图方法", "图例"], "source": "安装教材精读笔记"}, {"id": "ch06-099", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "下列图例中，属于“立管”代号（给排水）的有？", "options": {"A": "JL", "B": "PL", "C": "RL", "D": "SF"}, "answer": ["A", "B", "C"], "analysis": "JL、PL、RL 为给排水立管；SF 为送风。", "tags": ["图例符号", "给排水工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-100", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "下列图例中，表示“风”相关功能的有？", "options": {"A": "SF", "B": "HF", "C": "PF", "D": "JL"}, "answer": ["A", "B", "C"], "analysis": "SF、HF、PF 为通风风系统功能；JL 为给水立管。", "tags": ["图例符号", "通风空调工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-101", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "下列符号中，与“照明”直接相关的有？", "options": {"A": "MX（照明配电箱）", "B": "YG（荧光灯）", "C": "○（灯位）", "D": "RL（热水立管）"}, "answer": ["A", "B", "C"], "analysis": "MX、YG、○ 均与照明直接相关；RL 属给排水。", "tags": ["图例符号", "电气照明"], "source": "安装教材精读笔记"}, {"id": "ch06-102", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "下列关于识图顺序的说法，正确的有？", "options": {"A": "先图例后系统图", "B": "先系统图后平面图", "C": "看图例可明确符号含义", "D": "平面图最后看"}, "answer": ["A", "B", "C", "D"], "analysis": "识图三步法：先目录图例（明确符号含义）→ 系统图 → 平面图（最后看）。", "tags": ["识图方法", "识图顺序"], "source": "安装教材精读笔记"}, {"id": "ch06-103", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "电气工程中，属于“照明系统”组成部分的有？", "options": {"A": "配电箱", "B": "线路", "C": "灯具", "D": "开关"}, "answer": ["A", "B", "C", "D"], "analysis": "照明系统：配电箱 → 线路 → 灯具 → 开关。", "tags": ["系统组成", "电气照明"], "source": "安装教材精读笔记"}, {"id": "ch06-104", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "给排水工程中，下列代号表示“立管”的有？", "options": {"A": "JL", "B": "PL", "C": "RL", "D": "MX"}, "answer": ["A", "B", "C"], "analysis": "JL、PL、RL 表示立管；MX 为照明配电箱。", "tags": ["图例符号", "给排水工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-105", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "通风空调工程中，下列代号表示“风系统功能”的有？", "options": {"A": "SF", "B": "HF", "C": "PF", "D": "MX"}, "answer": ["A", "B", "C"], "analysis": "SF、HF、PF 为风系统功能；MX 属电气。", "tags": ["图例符号", "通风空调工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-106", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "关于图例符号“○”，下列说法正确的有？", "options": {"A": "表示灯位", "B": "表示一般照明", "C": "属于电气工程图例", "D": "表示配电箱"}, "answer": ["A", "B", "C"], "analysis": "○ 表示灯位（一般照明），属电气工程；配电箱由 MX 表示。", "tags": ["图例符号", "电气工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-107", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "关于图例符号“YG”，下列说法正确的有？", "options": {"A": "表示荧光灯灯具", "B": "属于电气工程", "C": "表示灯位", "D": "表示照明配电箱"}, "answer": ["A", "B"], "analysis": "YG 表示荧光灯灯具，属电气工程；灯位用○，配电箱用 MX。", "tags": ["图例符号", "电气工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-108", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "关于图例符号“MX”，下列说法正确的有？", "options": {"A": "表示照明配电箱", "B": "通常为出线回路起点", "C": "属于电气工程", "D": "表示排水立管"}, "answer": ["A", "B", "C"], "analysis": "MX 表示照明配电箱，是出线回路起点，属电气工程；排水立管为 PL。", "tags": ["图例符号", "电气工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-109", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "下列关于“送风/回风/排风”代号对应正确的有？", "options": {"A": "SF—送风", "B": "HF—回风", "C": "PF—排风", "D": "RL—热水立管"}, "answer": ["A", "B", "C"], "analysis": "SF、HF、PF 对应送风、回风、排风；RL 为热水立管。", "tags": ["图例符号", "通风空调工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-110", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "下列关于“给水/排水/热水立管”代号对应正确的有？", "options": {"A": "JL—给水立管", "B": "PL—排水立管", "C": "RL—热水立管", "D": "SF—送风"}, "answer": ["A", "B", "C"], "analysis": "JL、PL、RL 对应正确；SF 为送风。", "tags": ["图例符号", "给排水工程图"], "source": "安装教材精读笔记"}, {"id": "ch06-111", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "安装工程各专业的图例代号属于正确对应的有？", "options": {"A": "电气：MX、YG、○", "B": "给排水：JL、PL、RL", "C": "通风：SF、HF、PF", "D": "消防：YG"}, "answer": ["A", "B", "C"], "analysis": "三类专业图例对应正确；YG 属电气照明，非消防。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-112", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "下列图例中，属于电气照明专业、不属于给排水专业的有？", "options": {"A": "MX", "B": "YG", "C": "○", "D": "JL"}, "answer": ["A", "B", "C"], "analysis": "MX、YG、○ 属电气照明；JL 属给排水。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-113", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "下列图例中，属于给排水专业、不属于通风专业的有？", "options": {"A": "JL", "B": "PL", "C": "RL", "D": "SF"}, "answer": ["A", "B", "C"], "analysis": "JL、PL、RL 属给排水；SF 属通风。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-114", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "下列图例中，属于通风专业、不属于电气专业的有？", "options": {"A": "SF", "B": "HF", "C": "PF", "D": "YG"}, "answer": ["A", "B", "C"], "analysis": "SF、HF、PF 属通风；YG 属电气。", "tags": ["图例符号", "专业归类"], "source": "安装教材精读笔记"}, {"id": "ch06-115", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "识图三步法中，“最后看平面图”的原因包括？", "options": {"A": "平面图反映具体位置", "B": "平面图反映管线走向", "C": "先看系统图才能理解组成", "D": "平面图用于结算"}, "answer": ["A", "B", "C"], "analysis": "平面图反映位置与走向，且需在理解系统组成（系统图）后阅读；结算非识图目的。", "tags": ["识图方法", "平面图"], "source": "安装教材精读笔记"}, {"id": "ch06-116", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "在照明工程量计算中，关于配线长度说法正确的有？", "options": {"A": "配线长度=配管长度+预留长度", "B": "配管长度=水平段+垂直段", "C": "灯具数量按平面图统计", "D": "配线按套计算"}, "answer": ["A", "B", "C"], "analysis": "据第14章，配线长度=配管长度+预留长度，配管长度=水平段+垂直段，灯具按平面图统计；配线非按套。", "tags": ["识图应用", "照明工程量"], "source": "安装教材精读笔记"}, {"id": "ch06-117", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "关于风管展开面积，下列说法正确的有？", "options": {"A": "矩形风管按2×(宽+高)×长度", "B": "圆形风管按π×直径×长度", "C": "风管以㎡计量", "D": "风管以m计量"}, "answer": ["A", "B", "C"], "analysis": "风管展开面积矩形、圆形公式如上，均以㎡计量；m 为柔性软风管计量单位。", "tags": ["识图应用", "通风工程量"], "source": "安装教材精读笔记"}, {"id": "ch06-118", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "根据资料，下列计量单位对应正确的有？", "options": {"A": "柔性软风管—m", "B": "帆布软接口—㎡", "C": "给排水管道—中心线长度m", "D": "阀门—个"}, "answer": ["A", "B", "C", "D"], "analysis": "柔性软风管 m、帆布软接口 ㎡、给排水管道中心线长度 m、阀门按个，均符合资料。", "tags": ["清单计量", "定额计量"], "source": "广东二级造价师安装专业历年真题精华版"}, {"id": "ch06-119", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "电气照明系统“配电箱→线路→灯具→开关”环节中，涉及到的图例符号有？", "options": {"A": "MX", "B": "YG", "C": "○", "D": "SF"}, "answer": ["A", "B", "C"], "analysis": "环节涉及 MX（配电箱）、YG（灯具）、○（灯位）；SF 属通风。", "tags": ["图例符号", "电气照明"], "source": "安装教材精读笔记"}, {"id": "ch06-120", "date": "2026-07-06", "chapter": "ch06", "type": "multiple", "stem": "安装工程识图应掌握的内容包括？", "options": {"A": "各专业图例符号含义", "B": "识图顺序", "C": "系统图与平面图的关系", "D": "仅看平面图即可"}, "answer": ["A", "B", "C"], "analysis": "识图需掌握图例含义、识图顺序及系统图与平面图关系；不能仅看平面图。", "tags": ["识图方法", "综合"], "source": "安装教材精读笔记"}, {"id": "ch07-001", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "根据《广东省建设工程计量与计价实务（安装工程）》教材，2024版通用安装工程工程量计算标准的国家标准编号是（ ）。", "options": {"A": "GB 50856-2013", "B": "GB/T 50856-2024", "C": "GB 50500-2013", "D": "GB/T 50500-2024"}, "answer": ["B"], "analysis": "2024版清单标准编号为GB/T 50856-2024《通用安装工程工程量计算标准》；2013版为GB 50856-2013（强制性），2024版改为推荐性GB/T。", "tags": ["2024清单", "标准编号"], "source": "安装教材精读笔记"}, {"id": "ch07-002", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "GB/T 50856-2024的标准名称是（ ）。", "options": {"A": "通用安装工程工程量计算规范", "B": "通用安装工程工程量计算标准", "C": "建设工程工程量清单计价规范", "D": "广东省通用安装工程综合定额"}, "answer": ["B"], "analysis": "标准全称为《通用安装工程工程量计算标准》；\"规范\"是2013版旧称，2024版改称\"标准\"。", "tags": ["2024清单", "标准名称"], "source": "2024清单详细解读"}, {"id": "ch07-003", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "GB/T 50856-2024《通用安装工程工程量计算标准》的标准性质是（ ）。", "options": {"A": "强制性国家标准", "B": "推荐性国家标准", "C": "行业标准", "D": "企业标准"}, "answer": ["B"], "analysis": "2024版由强制性标准调整为推荐性标准，编号由GB改为GB/T；在合同中约定采用后即具有约束力。", "tags": ["2024清单", "标准性质"], "source": "2024清单详细解读"}, {"id": "ch07-004", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "GB/T 50856-2024的发布日期与实施日期分别为（ ）。", "options": {"A": "2024-11-12 / 2025-09-01", "B": "2024-01-01 / 2024-09-01", "C": "2025-09-01 / 2026-01-01", "D": "2013-07-01 / 2014-01-01"}, "answer": ["A"], "analysis": "发布日期2024-11-12，实施日期2025-09-01，过渡期约9个月，实施后GB 50856-2013同时废止。", "tags": ["2024清单", "实施日期"], "source": "2024清单详细解读"}, {"id": "ch07-005", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "GB/T 50856-2024实施后将同时废止的标准是（ ）。", "options": {"A": "GB/T 50500-2013", "B": "GB 50856-2013", "C": "GB 50243-2016", "D": "GB 50303-2015"}, "answer": ["B"], "analysis": "自2025-09-01起，GB 50856-2013《通用安装工程工程量计算规范》同时废止。", "tags": ["2024清单", "废止标准"], "source": "2024清单详细解读"}, {"id": "ch07-006", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "GB/T 50856-2024的主编（批准）部门是（ ）。", "options": {"A": "广东省建设工程标准定额站", "B": "中华人民共和国住房和城乡建设部", "C": "四川省造价协会", "D": "中国建筑工业出版社"}, "answer": ["B"], "analysis": "主编、批准部门均为住建部，起草单位包括四川省建设工程造价总站等。", "tags": ["2024清单", "主编部门"], "source": "2024清单详细解读"}, {"id": "ch07-007", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "GB/T 50856-2024全册共211页，包含（ ）个工程量清单项目。", "options": {"A": "约1151个", "B": "1189个", "C": "1300个", "D": "1000个"}, "answer": ["B"], "analysis": "共1189个项目（新增369个、减少331个），较2013版约1151个有所增加。", "tags": ["2024清单", "项目数量"], "source": "2024清单详细解读"}, {"id": "ch07-008", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "关于GB/T 50856-2024的条文，下列说法正确的是（ ）。", "options": {"A": "仍保留强制性条文", "B": "全部为推荐性条文，不再设强制性条文", "C": "仅总则强制", "D": "仅附录强制"}, "answer": ["B"], "analysis": "2024版不再设立强制性条文，所有条文均为推荐性。", "tags": ["2024清单", "强制性条文"], "source": "2024清单详细解读"}, {"id": "ch07-009", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "与2013版相比，GB/T 50856-2024适用范围的重要变化是（ ）。", "options": {"A": "增加设计施工总承包", "B": "不再适用于设计施工总承包，仅适用于施工发承包", "C": "仅适用于竣工结算", "D": "仅适用于设计阶段"}, "answer": ["B"], "analysis": "2024版明确限定为施工发承包阶段，不再适用于设计施工总承包。", "tags": ["2024清单", "适用范围"], "source": "2024清单详细解读"}, {"id": "ch07-010", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单标准编号由\"GB\"变为\"GB/T\"，其根本原因是（ ）。", "options": {"A": "标准性质由强制性调整为推荐性", "B": "标准内容大幅删减", "C": "主管单位变更", "D": "仅名称变化无实质影响"}, "answer": ["A"], "analysis": "标准由强制性改为推荐性，故编号前缀由GB（强制）变为GB/T（推荐）。", "tags": ["2024清单", "编号变化"], "source": "2024清单详细解读"}, {"id": "ch07-011", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单（GB/T 50856-2024）共设置（ ）个专业附录。", "options": {"A": "12个", "B": "13个", "C": "14个", "D": "16个"}, "answer": ["C"], "analysis": "附录A~N共14个专业附录（含新增M、N），2013版为12个。", "tags": ["2024清单", "附录数量"], "source": "安装教材精读笔记"}, {"id": "ch07-012", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单附录中，紧接在附录H（工业管道工程）之后的是（ ）。", "options": {"A": "附录I", "B": "附录J", "C": "附录K", "D": "附录M"}, "answer": ["B"], "analysis": "14个附录为A、B、C、D、E、F、G、H、J、K、L、M、N、P，注意没有\"附录I\"，H之后为J。", "tags": ["2024清单", "附录编号"], "source": "2024清单详细解读"}, {"id": "ch07-013", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "下列2024版清单附录中，实际不存在的是（ ）。", "options": {"A": "附录M", "B": "附录N", "C": "附录I", "D": "附录P"}, "answer": ["C"], "analysis": "附录无\"I\"，编号序列跳过了I，分别为A~H、J~N、P。", "tags": ["2024清单", "附录编号"], "source": "2024清单详细解读"}, {"id": "ch07-014", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单中，附录A对应的是（ ）。", "options": {"A": "机械设备安装工程", "B": "电气设备安装工程", "C": "工业管道工程", "D": "消防工程"}, "answer": ["A"], "analysis": "附录A：机械设备安装工程。", "tags": ["2024清单", "附录A"], "source": "2024清单详细解读"}, {"id": "ch07-015", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单中，附录B对应的是（ ）。", "options": {"A": "热力设备安装工程", "B": "静置设备与工艺金属结构", "C": "自动化控制仪表", "D": "通风空调工程"}, "answer": ["A"], "analysis": "附录B：热力设备安装工程。", "tags": ["2024清单", "附录B"], "source": "2024清单详细解读"}, {"id": "ch07-016", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单中，附录C对应的是（ ）。", "options": {"A": "机械设备安装工程", "B": "静置设备与工艺金属结构制作安装工程", "C": "工业管道工程", "D": "通信设备及线路工程"}, "answer": ["B"], "analysis": "附录C：静置设备与工艺金属结构制作安装工程。", "tags": ["2024清单", "附录C"], "source": "2024清单详细解读"}, {"id": "ch07-017", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单中，附录D对应的是（ ）。", "options": {"A": "建筑智能化工程", "B": "电气设备安装工程", "C": "自动化控制仪表", "D": "通风空调工程"}, "answer": ["B"], "analysis": "附录D：电气设备安装工程。", "tags": ["2024清单", "附录D"], "source": "2024清单详细解读"}, {"id": "ch07-018", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单中，附录E对应的是（ ）。", "options": {"A": "建筑智能化工程", "B": "电气设备安装工程", "C": "自动化控制仪表", "D": "通风空调工程"}, "answer": ["A"], "analysis": "附录E：建筑智能化工程。", "tags": ["2024清单", "附录E"], "source": "2024清单详细解读"}, {"id": "ch07-019", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单中，附录F对应的是（ ）。", "options": {"A": "自动化控制仪表安装工程", "B": "建筑智能化工程", "C": "通风空调工程", "D": "工业管道工程"}, "answer": ["A"], "analysis": "附录F：自动化控制仪表安装工程。", "tags": ["2024清单", "附录F"], "source": "2024清单详细解读"}, {"id": "ch07-020", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单中，附录G对应的是（ ）。", "options": {"A": "工业管道工程", "B": "通风空调工程", "C": "消防工程", "D": "给排水采暖燃气工程"}, "answer": ["B"], "analysis": "附录G：通风空调工程。", "tags": ["2024清单", "附录G"], "source": "2024清单详细解读"}, {"id": "ch07-021", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单中，附录H对应的是（ ）。", "options": {"A": "工业管道工程", "B": "消防工程", "C": "给排水采暖燃气工程", "D": "通信设备及线路工程"}, "answer": ["A"], "analysis": "附录H：工业管道工程。", "tags": ["2024清单", "附录H"], "source": "2024清单详细解读"}, {"id": "ch07-022", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单中，附录J对应的是（ ）。", "options": {"A": "消防工程", "B": "工业管道工程", "C": "给排水采暖燃气工程", "D": "通信设备及线路工程"}, "answer": ["A"], "analysis": "附录J：消防工程（注意H之后跳过了I）。", "tags": ["2024清单", "附录J"], "source": "2024清单详细解读"}, {"id": "ch07-023", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单中，附录K对应的是（ ）。", "options": {"A": "给排水、采暖、燃气工程", "B": "通信设备及线路工程", "C": "刷油防腐蚀绝热工程", "D": "其他及附属工程"}, "answer": ["A"], "analysis": "附录K：给排水、采暖、燃气工程。", "tags": ["2024清单", "附录K"], "source": "2024清单详细解读"}, {"id": "ch07-024", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单中，附录L对应的是（ ）。", "options": {"A": "通信设备及线路工程", "B": "其他及附属工程", "C": "措施项目", "D": "刷油防腐蚀绝热工程"}, "answer": ["A"], "analysis": "附录L：通信设备及线路工程。", "tags": ["2024清单", "附录L"], "source": "2024清单详细解读"}, {"id": "ch07-025", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单中，附录M是相较2013版新增的附录，其对应的是（ ）。", "options": {"A": "其他及附属工程", "B": "刷油、防腐蚀、绝热工程", "C": "措施项目", "D": "通信设备及线路工程"}, "answer": ["B"], "analysis": "附录M：刷油、防腐蚀、绝热工程，为2024版新增附录。", "tags": ["2024清单", "附录M", "新增附录"], "source": "2024清单详细解读"}, {"id": "ch07-026", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单中，附录N是相较2013版新增的附录，其对应的是（ ）。", "options": {"A": "其他及附属工程", "B": "刷油、防腐蚀、绝热工程", "C": "措施项目", "D": "通信设备及线路工程"}, "answer": ["A"], "analysis": "附录N：其他及附属工程，为2024版新增附录。", "tags": ["2024清单", "附录N", "新增附录"], "source": "2024清单详细解读"}, {"id": "ch07-027", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单中，附录P对应的是（ ）。", "options": {"A": "其他及附属工程", "B": "刷油防腐蚀绝热工程", "C": "措施项目", "D": "通信设备及线路工程"}, "answer": ["C"], "analysis": "附录P：措施项目。", "tags": ["2024清单", "附录P"], "source": "2024清单详细解读"}, {"id": "ch07-028", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单相较2013版新增的两个附录是（ ）。", "options": {"A": "附录M、附录N", "B": "附录I、附录J", "C": "附录A、附录B", "D": "附录K、附录L"}, "answer": ["A"], "analysis": "2024版新增附录M（刷油防腐蚀绝热）和附录N（其他及附属工程）。", "tags": ["2024清单", "新增附录"], "source": "2024清单详细解读"}, {"id": "ch07-029", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "通用安装工程清单附录数量由2013版的12个增加到2024版的（ ）个。", "options": {"A": "13", "B": "14", "C": "15", "D": "16"}, "answer": ["B"], "analysis": "2013版12个附录，2024版14个（新增M、N）。", "tags": ["2024清单", "附录数量"], "source": "2024清单详细解读"}, {"id": "ch07-030", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单每个专业附录通常包含的内容，不包括下列哪一项（ ）。", "options": {"A": "工程量清单项目设置", "B": "项目特征描述", "C": "计量单位", "D": "施工企业资质要求"}, "answer": ["D"], "analysis": "每个附录包含：工程量清单项目设置、项目特征描述、计量单位、工程量计算规则，不含施工企业资质要求。", "tags": ["2024清单", "附录内容"], "source": "安装教材精读笔记"}, {"id": "ch07-031", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "根据2024版清单，通用安装工程工程量计算应当按（ ）计算。", "options": {"A": "施工企业实际耗用量", "B": "设计图示尺寸", "C": "定额规定的含量", "D": "招标人估算量"}, "answer": ["B"], "analysis": "工程量计算按设计图示尺寸计算，这是清单计量规则的核心原则。", "tags": ["2024清单", "计量原则"], "source": "安装教材精读笔记"}, {"id": "ch07-032", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "根据2024版清单，工程量清单项目的计量单位应当（ ）。", "options": {"A": "由投标人自行确定", "B": "严格按规范要求的单位", "C": "按施工企业习惯", "D": "按定额单位灵活换算"}, "answer": ["B"], "analysis": "计量单位必须严格按规范要求的单位执行，不得自行更改。", "tags": ["2024清单", "计量单位"], "source": "安装教材精读笔记"}, {"id": "ch07-033", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "在清单计价中，项目特征描述的主要作用之一是（ ）。", "options": {"A": "仅用于归档备查", "B": "影响综合单价", "C": "决定施工企业资质", "D": "与单价无关"}, "answer": ["B"], "analysis": "项目特征描述影响综合单价，不同材质、规格、连接方式对应不同单价。", "tags": ["2024清单", "项目特征", "综合单价"], "source": "安装教材精读笔记"}, {"id": "ch07-034", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "在施工合同履行中，若工程量清单项目的项目特征描述与施工图纸不符，应（ ）。", "options": {"A": "按原清单执行不改价", "B": "作为合同价款调整的因素之一", "C": "由投标人承担差价", "D": "直接重新招标"}, "answer": ["B"], "analysis": "项目特征描述不符属于合同价款调整因素，应按约定调整合同价款。", "tags": ["2024清单", "项目特征", "价款调整"], "source": "安装教材精读笔记"}, {"id": "ch07-035", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "根据清单计价，分部分项工程综合单价由（ ）组成。", "options": {"A": "人工费、材料费、施工机具使用费、管理费、利润", "B": "人工费、材料费、规费、税金", "C": "直接费、间接费、利润、税金", "D": "分部分项费、措施费、其他费"}, "answer": ["A"], "analysis": "综合单价=人工费+材料费+施工机具使用费+管理费+利润，不含规费和税金。", "tags": ["综合单价", "费用组成"], "source": "历年真题精华版"}, {"id": "ch07-036", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "分部分项工程综合单价中通常不单独列项计入的是（ ）。", "options": {"A": "人工费", "B": "材料费", "C": "施工机具使用费", "D": "规费和税金"}, "answer": ["D"], "analysis": "综合单价由人、材、机、管理费、利润组成，规费和税金在汇总时单独列项，不计入综合单价。", "tags": ["综合单价", "规费税金"], "source": "历年真题精华版"}, {"id": "ch07-037", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "分部分项工程费包括（ ）。", "options": {"A": "人工费、材料费、施工机具使用费、企业管理费、利润", "B": "规费和税金", "C": "措施项目费", "D": "其他项目费"}, "answer": ["A"], "analysis": "分部分项工程费=人工费+材料费+施工机具使用费+企业管理费+利润；规费、税金不在其中。", "tags": ["分部分项工程费", "费用组成"], "source": "历年真题精华版"}, {"id": "ch07-038", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "建筑安装工程费按造价构成要素包括（ ）。", "options": {"A": "分部分项工程费、措施项目费、其他项目费、规费、税金", "B": "人工费、材料费、机械费", "C": "直接费、间接费", "D": "利润、税金"}, "answer": ["A"], "analysis": "建筑安装工程费=分部分项工程费+措施项目费+其他项目费+规费+税金。", "tags": ["建筑安装工程费", "费用构成"], "source": "安装教材精读笔记"}, {"id": "ch07-039", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "一份完整的工程量清单通常不包括（ ）。", "options": {"A": "封面、扉页、总说明", "B": "分部分项工程量清单表", "C": "措施项目清单表", "D": "施工企业营业执照"}, "answer": ["D"], "analysis": "工程量清单由封面、扉页、总说明、分部分项、措施项目、其他项目、规费税金清单等组成，不含企业执照。", "tags": ["工程量清单", "组成"], "source": "历年真题精华版"}, {"id": "ch07-040", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "工程量清单编制的依据一般不包括（ ）。", "options": {"A": "建设工程工程量清单计价标准（或规范）", "B": "建设工程设计文件", "C": "招标文件、施工现场情况", "D": "施工企业年度利润目标"}, "answer": ["D"], "analysis": "清单编制依据包括计价标准、设计文件、招标文件、施工现场情况等，施工企业利润目标不是依据。", "tags": ["清单编制", "依据"], "source": "历年真题精华版"}, {"id": "ch07-041", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单对\"项目特征\"的修订方向是（ ）。", "options": {"A": "增加与设计文件无关的内容", "B": "删除与设计文件无关的内容，使其更简洁实用", "C": "取消项目特征要求", "D": "仅保留材质描述"}, "answer": ["B"], "analysis": "2024版修订部分项目特征，删除与设计文件无关的内容，使项目特征更简洁实用。", "tags": ["2024清单", "项目特征"], "source": "2024清单详细解读"}, {"id": "ch07-042", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2024版清单修订为满足新发展需求，不包括下列哪项（ ）。", "options": {"A": "装配式建筑", "B": "绿色建筑", "C": "地下综合管廊", "D": "传统现浇砖混住宅专项定额"}, "answer": ["D"], "analysis": "2024版满足装配式建筑、绿色建筑、地下综合管廊、海绵城市等新需求，无\"传统现浇砖混专项定额\"。", "tags": ["2024清单", "新发展需求"], "source": "2024清单详细解读"}, {"id": "ch07-043", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2018版广东省通用安装工程综合定额的性质是（ ）。", "options": {"A": "工程量计算标准", "B": "消耗量定额（反映社会平均成本）", "C": "企业定额", "D": "投资估算指标"}, "answer": ["B"], "analysis": "2018广东安装定额为消耗量定额，反映社会平均成本，用于计价。", "tags": ["2018定额", "定额性质"], "source": "2018定额详细解读"}, {"id": "ch07-044", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2018版广东省通用安装工程综合定额在广东省内的执行效力是（ ）。", "options": {"A": "推荐性，合同不采用则无效", "B": "强制性执行", "C": "仅作为参考", "D": "由企业自主选择"}, "answer": ["B"], "analysis": "2018定额在广东省内为强制性执行，清单为推荐性，二者配套使用。", "tags": ["2018定额", "强制性"], "source": "2018定额详细解读"}, {"id": "ch07-045", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2018版广东省通用安装工程综合定额的实施日期是（ ）。", "options": {"A": "2018-01-01", "B": "2019-03-01", "C": "2024-11-12", "D": "2025-09-01"}, "answer": ["B"], "analysis": "2018定额自2019-03-01起实施。", "tags": ["2018定额", "实施日期"], "source": "2018定额详细解读"}, {"id": "ch07-046", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "在实际工程中，2024版清单与2018版广东定额的关系应当是（ ）。", "options": {"A": "二者择一使用", "B": "配套使用", "C": "清单代替定额", "D": "定额代替清单"}, "answer": ["B"], "analysis": "清单规定\"怎么算量\"，定额规定\"消耗多少\"，二者配套使用完成计量计价。", "tags": ["清单定额", "配套使用"], "source": "2018定额详细解读"}, {"id": "ch07-047", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "广东省通用安装工程综合定额（2018版）共分为（ ）册。", "options": {"A": "10册", "B": "12册", "C": "14册", "D": "16册"}, "answer": ["B"], "analysis": "2018广东安装定额共12册（第1~12册）。", "tags": ["2018定额", "册数"], "source": "安装教材精读笔记"}, {"id": "ch07-048", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2018广东安装定额第1册是（ ）。", "options": {"A": "机械设备安装工程", "B": "电气设备安装工程", "C": "工业管道工程", "D": "消防工程"}, "answer": ["A"], "analysis": "第1册：机械设备安装工程。", "tags": ["2018定额", "册号"], "source": "安装教材精读笔记"}, {"id": "ch07-049", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2018广东安装定额第2册是（ ）。", "options": {"A": "热力设备安装工程", "B": "静置设备与工艺金属结构", "C": "自动化控制仪表", "D": "通风空调工程"}, "answer": ["A"], "analysis": "第2册：热力设备安装工程。", "tags": ["2018定额", "册号"], "source": "安装教材精读笔记"}, {"id": "ch07-050", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2018广东安装定额第3册是（ ）。", "options": {"A": "机械设备安装工程", "B": "静置设备与工艺金属结构制作安装工程", "C": "工业管道工程", "D": "通信设备及线路工程"}, "answer": ["B"], "analysis": "第3册：静置设备与工艺金属结构制作安装工程。", "tags": ["2018定额", "册号"], "source": "安装教材精读笔记"}, {"id": "ch07-051", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2018广东安装定额第4册是（ ）。", "options": {"A": "建筑智能化工程", "B": "电气设备安装工程", "C": "自动化控制仪表", "D": "通风空调工程"}, "answer": ["B"], "analysis": "第4册：电气设备安装工程（上下册）。", "tags": ["2018定额", "册号"], "source": "安装教材精读笔记"}, {"id": "ch07-052", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2018广东安装定额第5册是（ ）。", "options": {"A": "建筑智能化工程", "B": "电气设备安装工程", "C": "自动化控制仪表", "D": "通风空调工程"}, "answer": ["A"], "analysis": "第5册：建筑智能化工程。", "tags": ["2018定额", "册号"], "source": "安装教材精读笔记"}, {"id": "ch07-053", "date": "2026-07-06", "chapter": "ch07", "type": "single", "stem": "2018广东安装定额第6册是（ ）。", "options": {"A": "自动化控制仪表安装工程", "B": "建筑智能化工程", "C": "通风空调工程", "D": "工业管道工程"}, "answer": ["A"], "analysis": "第6册：自动化控制仪表安装工程。", "ta