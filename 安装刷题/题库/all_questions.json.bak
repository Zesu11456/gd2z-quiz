], "analysis": "土地使用权属无形资产，不属流动资产；A、B、D属于流动资产范畴。", "tags": ["流动资产", "无形资产"], "source": "安装教材精读笔记"}, {"id": "ch13-043", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "新增固定资产价值包括建筑安装工程投资、设备投资和（ ）。", "options": {"A": "流动资产", "B": "待摊投资", "C": "无形资产", "D": "递延资产"}, "answer": ["B"], "analysis": "固定资产价值=建筑安装工程投资+设备投资+待摊投资。", "tags": ["固定资产构成"], "source": "安装教材精读笔记"}, {"id": "ch13-044", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "竣工财务决算报表属于竣工决算的（ ）。", "options": {"A": "核心财务内容", "B": "无关内容", "C": "仅示意图", "D": "仅对比分析"}, "answer": ["A"], "analysis": "竣工财务决算报表与说明书构成竣工财务决算，是竣工决算的核心内容。", "tags": ["竣工财务决算报表", "核心内容"], "source": "安装教材精读笔记"}, {"id": "ch13-045", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "待摊投资的分摊原则是（ ）。", "options": {"A": "全部计入某一个单项工程", "B": "在各单项工程之间按比例分摊", "C": "全部计入无形资产", "D": "全部计入流动资产"}, "answer": ["B"], "analysis": "属于整个建设项目或两个以上单项工程的待摊投资，应在各单项工程中按比例分摊后计入固定资产。", "tags": ["待摊投资"], "source": "WebSearch-竣工决算补充"}, {"id": "ch13-046", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "竣工财务决算说明书主要反映的是（ ）。", "options": {"A": "竣工工程建设成果和经验", "B": "仅材料价格", "C": "仅劳务用工", "D": "仅机械台班"}, "answer": ["A"], "analysis": "竣工财务决算说明书主要反映竣工工程建设成果和经验。", "tags": ["竣工财务决算说明书"], "source": "WebSearch-竣工决算补充"}, {"id": "ch13-047", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "建设单位管理费在分摊时常按（ ）比例分摊。", "options": {"A": "仅建筑工程", "B": "建筑工程、安装工程、需安装设备价值", "C": "仅设备", "D": "仅土地"}, "answer": ["B"], "analysis": "建设单位管理费一般按建筑工程、安装工程、需安装设备价值等比例分摊计入固定资产。", "tags": ["待摊投资"], "source": "WebSearch-竣工决算补充"}, {"id": "ch13-048", "date": "2026-07-06", "chapter": "ch13", "type": "single", "stem": "下列项目中，属于竣工决算内容但不属于竣工财务决算核心的是（ ）。", "options": {"A": "竣工财务决算报表", "B": "竣工财务决算说明书", "C": "工程造价对比分析", "D": "以上均属核心"}, "answer": ["C"], "analysis": "竣工财务决算（报表+说明书）是核心内容，工程造价对比分析属于配套内容之一。", "tags": ["竣工决算内容", "核心内容"], "source": "安装教材精读笔记"}, {"id": "ch13-049", "date": "2026-07-06", "chapter": "ch13", "type": "sing